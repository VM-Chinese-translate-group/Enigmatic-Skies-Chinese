{
	chapter.083FB2FC095A6686.title: "Flourishing Island"
	chapter.0A799F91D9A1C8A1.title: "Blazing Island"
	chapter.0C0D9C8007301C03.title: "Malum"
	chapter.0EFE9E753A92388D.title: "Building"
	chapter.0FF1E0FF9CAD1914.title: "Energy"
	chapter.13C15ACA23526F9E.title: "Replication"
	chapter.17B9F323B083C6C2.title: "It Takes a Village"
	chapter.21245A37A9042E2C.title: "Equipment"
	chapter.300207E2557764E1.title: "Flashing Island"
	chapter.402AE6264B81A84B.title: "Logistics"
	chapter.40C97D6332BD825B.title: "Cascading Island"
	chapter.47870879D8E3742D.title: "To the Skies!"
	chapter.4C53D082D6306BF8.title: "Just Dire Things"
	chapter.5957A1DE2E537AC3.title: "PneumaticCraft"
	chapter.5C2F675CD8139E11.title: "Ars Nouveau"
	chapter.67558DB55ADC2157.title: "The Beginning"
	chapter.70FCD34EEFA2F001.title: "Nature's Aura"
	chapter.72447ED7D54B4AF7.title: "Vexing Island"
	chapter.777EE0C4949DFE12.title: "Applied Energistics"
	chapter.7F17CDF8564DCC49.title: "Genetics: Resequenced"
	chapter.7F9A789B53FAB216.title: "Getting Acclimated"
	chapter_group.1C7CD605A8DD7732.title: "&bDiscovery"
	chapter_group.440488E780593120.title: "&bLearning"
	chapter_group.46AB9129BBE517B6.title: "&bEnigmatic Skies"
	file.0000000000000001.title: "&n&6Enigmatic Skies&r"
	quest.00066BB06F509677.quest_desc: ["Item Cards for LaserIO allow Laser Nodes to transport Items."]
	quest.008F3C0FB9F4B451.quest_desc: ["[ \"\", { \"text\": \"Fire Essence\", \"color\":\"gray\"}, \" grants access to the fiery volcano on the \", { \"text\": \"Blazing Island\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"78626EE046E48EF3\" } }, \".\" ]"]
	quest.008F3C0FB9F4B451.title: "Blazing Island"
	quest.00946DF0B2C88A9F.quest_desc: [
		"Metals and plastics can serve as wonderful analogs to bone for structure, but motors and servos lack a certain flexibility. "
		""
		"Why re-invent what nature has already nearly perfected? Re-animated flesh can be enhanced to be stronger and more durable than ever.   "
	]
	quest.00DE313EE5B9954D.quest_desc: ["A simple tape measure to help count distances. Handy for any dedicated builder to keep around."]
	quest.01266355AAB13C39.quest_desc: [
		"Chisel offers a plethora of block variants to spice up your building. Grab a Chisel and some blocks and get to work!"
		""
		"&a🛈 Tip: Search &3@chisel&r &ain EMI to "
		"&a    discover more."
	]
	quest.015857940250CE8D.quest_desc: [
		"&7Fluid Modules&r for &7Modular Routers&r allows them to transfer fluid bi-directionally. They can also be used to place fluid in the world. "
		""
		"The &7Router&r needs some kind of storage tank in its buffer to work. A bucket is sufficient but a larger fluid tank from any other mod is ideal."
	]
	quest.016B7CA4A7FC58A1.quest_desc: ["With &7Brass&r, most of Create should now be accessible to you, greatly enhancing your options for automation."]
	quest.0227D9EC391788D6.quest_desc: [
		"Tired of looking at exposed cables everywhere?"
		""
		"&7Facades&r may be crafted from most solid blocks and act as a nice cover for cables and cable subparts, making your AE system look like an integrated part of your base."
	]
	quest.0227D9EC391788D6.title: "Cable Facades"
	quest.0230942DF53BB9E5.quest_desc: ["The following are blocks that can be used to charge energy based items and equipment."]
	quest.0230942DF53BB9E5.title: "Energy Chargers"
	quest.03405336161EF1B5.quest_desc: [
		"On most OriTech machines, you’ll notice a blue square with two vertical slits like an electrical outlet. These act as connection points for the various &7Machine Addons&r that may be attached to these machines. "
		""
		"Adding a &7Machine Extender&r at these positions will allow you to attach more addons, however this also requires increasingly higher quality &7Machine Cores&r. Adding better &7Cores&r will increase how many &7Extenders&r an addon is allowed to chain through and still count. "
		""
		"For example, at Machine Quality 4, an addon can have up to 4 &7Extenders&r between it and the machine. "
	]
	quest.03405336161EF1B5.title: "Machine Addons"
	quest.03D475AF2266ECB6.quest_desc: [
		"Villagers represent a critical source of materials, so be sure to check in with them and make use of their expertise!"
		""
		"Start by making a &7Smithing Table&r to get a &7Tool Smith Villager&r. They will sell you various workstations used by other Villagers, allowing you to easily expand your trading operations!"
		""
		"Villagers need a steady diet of good foods to do their best work, so make sure you're growing a variety of foods for them!"
		""
		"They must also be kept warm! If your Hearth goes out they'll die just as surely as you will."
		""
		"              &6&nUseful Keybinds&r"
		""
		"  Press &6U&r while hovering over a "
		"  &7Villager Spawn Egg&r to see all of "
		"  their workstations."
		""
		""
		"&a🛈 Tip: Purple Seats can be crafted "
		"&a    from Magebloom!"
	]
	quest.03D475AF2266ECB6.title: "Villagers"
	quest.0458B6BC887C9725.quest_desc: [
		"Summon a &7Wolf&r at the Altar of Birthing and gather some &7Organic Matter&r from it."
		""
		"&6⚠ Note: The Spawn Egg is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.0458B6BC887C9725.title: "Wolf"
	quest.04AE4EA4C7CFB080.quest_desc: [
		"The &7Turbo Jetpack&r functions much like an Elytra with the Space bar used to control it."
		""
		"It burns the same types of fuel as your &7Boilers&r do."
		""
		"[\"• Toggle Flight (\",{\"color\":\"gold\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Toggle Flight\"}]},\"keybind\":\"key.modern_industrialization.toggle_flight\"},\")\"]"
		""
		"• Hold Space while on the ground to be "
		"  propelled straight up"
		""
		"• Tap Space to begin gliding"
		""
		"• While gliding, hold Space to provide a "
		"  speed boost in the direction you’re "
		"  looking"
		""
		"&c⚠ Warning: Not for Indoor Use."
	]
	quest.04CE3E8B1DF8B441.quest_desc: ["The following are various forms of fluid transfer options available in Enigmatica 10."]
	quest.04CE3E8B1DF8B441.title: "Fluids"
	quest.04D144DC0EAE8BE3.quest_desc: [
		"Buy a &7Brewing Stand&r to gain access to the &7Cleric Villager's&r trades. "
		""
		"In particular, you'll need a &7Ritual Brazier&r soon, so be certain to pick one up."
		""
		"&a🛈 Tip: Potions inserted into a Hearth "
		"&a    will apply their effects to entities "
		"&a    in the area!"
	]
	quest.04D144DC0EAE8BE3.title: "Cleric"
	quest.0537E3C9A2164A7D.quest_desc: [
		"Oritech’s &7Fluid Pipes&r may not have many fancy features, but they’ll get the job done. "
		""
		"These come in three varieties, though the differences are mainly cosmetic. &7Framed Pipes&r have a nice supporting structure around them, while &7Duct Pipes&r are a full block for passing through a wall without gaps. &7Duct Pipes&r only connect to other pipes, however."
		""
		"Right-Click the pipe connecting to a machine or tank to set it to Extract mode."
	]
	quest.053C43E68E7ADB2B.quest_desc: [
		"With the &7Slice'N'Splice&r, we can rebuild and splice together the genetic material from different creatures to create the monsters we need. "
		""
		"&6⚠ Note: Enderio machines require  "
		"&6    a Capacitor to function."
	]
	quest.054093E1130E24C1.quest_desc: [
		"An &7Automatic Feeder&r is a simple feeding station for nearby animals. "
		""
		"Keep it filled with the items your animals need to breed, and they’ll take care of the rest. "
		""
		"            &6&nA Note on Automation&r"
		""
		"The &7Automatic Feeder&r can be used to count the animals in the area. "
		""
		"Place a &7Comparator&r against it to get a rough estimate, where each level of redstone means two animals. "
		""
		"At a signal of 15, it can no longer breed, meaning it's time to start culling."
	]
	quest.0545305EBB98A0BA.quest_desc: [
		"The &7Advanced Swapper&r must be bound to another &7Advanced Swapper&r, in the same way as binding &7Simple Swappers&r. "
		""
		"This version requires energy to run but can operate in a larger area, making it more useful for farms. "
		""
		"&a🛈 Tip: Use the Render Area button to "
		"&a    easily configure the working area."
	]
	quest.0554264AE11578D2.quest_desc: [
		"The &7Pressure Chamber&r is a multiblock crafting interface that uses compressed air to operate. Items are passed in and extracted from the &7Interfaces&r while Air is provided through the &7Valve&r. "
		""
		"The interfaces will be slow at first, but some &7Speed Upgrades&r will really help out."
		"&n                                                             &r "
		""
		"Start by building a 3x3x3 structure; it'll be easier to get up to pressure."
		""
		"&7Pressure Chamber Glass&r is optional, but recommended to see what's happening inside."
		""
		"&a🛈 Tip: The PNC guidebook covers the multiblock"
		"&a    requirements in detail."
	]
	quest.0554264AE11578D2.title: "Pressure Chamber"
	quest.05F232C12FA99F92.quest_desc: [
		"Capable of withstanding greater temperatures, the &7Electric Kiln&r will allow you to make &7Steel&r as well as other useful materials. "
		""
		"&n                                                                          &r"
		""
		"Every Modern Industrialization multiblock requires input and output hatches commensurate with the recipes it handles. "
		""
		"In this case, the &7Electric Kiln&r requires both fluid and item hatches."
		""
		"&a🛈 Tip: Place the controller block, then hold a Wrench "
		"&a    to see the structure. Similarly, hold a Hatch to see "
		"&a    valid locations for them."
	]
	quest.062BB5F675CF9F45.quest_desc: [
		"Welcome to Just Dire Things!"
		""
		"This mod hosts a number of small utility blocks to make life simpler, doing such tasks as interacting with entities, farming crops, and more."
		""
		"This chapter will help get you familiar with the crafting mechanics it uses, as well as introduce some of the more notable blocks."
		""
		"[\"Additionally, the author has a number of helpful \",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.youtube.com/playlist?list=PLvGYM7MCieIomj0tKtO9T5DUhvaYFjSxA\"},\"color\":\"blue\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"video guides\",\"underlined\":true},\" on YouTube. Check them out if you need a little extra help.\"]"
	]
	quest.062BB5F675CF9F45.title: "Just Dire Things"
	quest.064BF1AA27A01A3A.quest_desc: [
		"BetterBlockZ is a decorative mod with a wide variety of sci-fi inspired elements to use in your builds!"
		""
		"Each block has multiple variants that can be easily selected through keybinds, and multiple wands exist to quickly modify blocks already placed in the world."
		""
		"&a🛈 Tip: Search &3@blockz&r &ain EMI to "
		"&a    discover more."
	]
	quest.064BF1AA27A01A3A.title: "BetterBlockZ"
	quest.064F6355185A51D4.quest_desc: [
		"These adorable gold-loving critters can be a huge help in keeping your home tidy. "
		""
		"If bound to a chest, they’ll quickly gather all items from the ground and insert them into that chest. "
		""
		"They’ll also transfer from one chest to another and can farm Sourceberries without getting pricked by their thorns!"
		""
		"&a🛈 Tip: Starbuncles can be filtered with "
		"&a    Allow/Deny Scrolls!"
	]
	quest.07189DA532A429AE.quest_desc: [
		"The &7Whirl&r glyph can make some exceptionally useful spells, but getting the glyphs to make it yourself may take some time. "
		""
		"For now, you can craft some specially prepared &7Caster Tomes&r with pre-set spells to make use of it!"
		""
		"&a🛈 Tip: Caster Tomes can be used to "
		"&a    set Spell Turrets!"
	]
	quest.07189DA532A429AE.title: "Whirligigs"
	quest.0745FDF3F22807CA.quest_desc: ["[ \"\", { \"text\": \"Air Essence\", \"color\":\"gray\"}, \" access to the dizzying heights of the \", { \"text\": \"Flashing Island\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"768869D763EC54EB\" } }, \".\" ]"]
	quest.0745FDF3F22807CA.title: "Flashing Island"
	quest.074827E52A09685F.quest_desc: [
		"&7Water&r, precious and rare, will be hard to come by in this place. "
		""
		"For now, you'll be able to condense a very small amount from the clouds around you by inserting them in the &7Accumulator&r. "
		""
		"There are pipes in the floor under the &7Accumulator&r that drain &7Water&r directly into your &7Boiler&r. "
		""
		"Excess &7Water&r will overflow into the &7Fluid Drawer&r in the basement where it can be easily retrieved; just Left-Click the front with an empty &7Bucket&r."
		""
		"Remember to keep an eye on your &7Hearth&r! A bucket of water will only last about 12 minutes. "
		""
		"&6⚠ Note: Water Sources are &nnot&r &6infinite! "
	]
	quest.074827E52A09685F.title: "Water"
	quest.07684F58521A4D34.quest_desc: [
		"Playing with friends? "
		""
		"You can share your Glyph knowledge with one another using an &7Annotated Codex&r. "
		""
		"Right-Click to record your progress and your friend can Right-Click to learn everything you know."
	]
	quest.07EC0853BE4C6391.quest_desc: [
		"Animate a &7Slime&r and defeat it to obtain &7Earthen Spirits&r."
		""
		"&6⚠ Note: The Ritual Item is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.07EC0853BE4C6391.title: "Earthen Spirit"
	quest.08D496EFE575AD1E.quest_desc: [
		"With any luck, you’ll have received a Genetically Modified Cell with the trait you’re after. If not, better luck next time."
		""
		"If you did, take that GM Cell back to the DNA Extractor and proceed from there as you would with any Cell. By the end of the process, you’ll have a blood sample with your fancy new upgraded trait."
	]
	quest.0916404C0979D753.quest_desc: [
		"&7Steel Upgrades&r may be right clicked onto any &7Andesite Alloy Tier Machine&r to upgrade it directly to the &7Steel Tier&r version. "
		""
		"The target machine will retain all filters and inventory, making it a painless way to upgrade your machines."
	]
	quest.0963C14E9AF5A836.quest_desc: ["The &7Wired Charger&r will charge any FE using device placed inside of it."]
	quest.09B6773CDA5A7565.quest_desc: [
		"The Enchanting Apparatus will likely be the next device you’ll wish to set up as it’s used for many more advanced crafts, upgrading equipment, and applying enchantments!"
		""
		"This device is a free form multiblock. The Enchanting Apparatus must sit atop the Arcane Core, but the Pedestals may go anywhere within 3 blocks of the Core."
		""
		"The items in the Pedestals will be consumed by these recipes. "
	]
	quest.09C3C5173499DF7C.quest_desc: [
		"To craft essences, you’ll need to place some pedestals adjacent to the &7Imbuement Chamber&r with key items installed in each pedestal. "
		""
		"These key items are &nnot consumed&r and are only there to set the recipe. "
		""
		"Valid placement is a 3x3x3 area centered on the &7Imbuement Chamber&r."
		""
		"&a🛈 Tip: Source is optional!"
	]
	quest.09C3C5173499DF7C.title: "Essences"
	quest.0A8B7FD4A52663D3.quest_desc: [
		"&6Enigmatic Skies&r is an automation focused Expert pack designed to challenge you in new and exciting ways. "
		""
		"The &7Enigmatic Skies&r questline is your primary source of guidance through major progression goals. "
		""
		"            &n&6A Note on Information Sources&r"
		""
		"As an Expert pack, a great deal of the default progression and recipes for each mod has changed. This means that guidebooks for the various mods included in this pack may give you incorrect information. They are still an invaluable source for how blocks and items work, but don’t assume that recipes or progression requirements found in the books are accurate. "
		""
		"For recipes, your best source of information is EMI. When looking at an item’s recipe, be sure to check every tab as there may be more than one way to obtain something.  "
		""
		"Extra tooltips and information panes have also been added to many items to help explain how to use them or to highlight important information that's either custom to the pack or otherwise undocumented. "
		""
		"Likewise, these quests will also attempt to give you extra tips and tricks to help you navigate the pack. Especially where custom mechanics are concerned. "
	]
	quest.0AEC5C2683575F1C.quest_desc: [
		"Trade for a &7Runewood Sapling&r at the Weeping Well. "
		""
		"You’ll need this primarily for its wood, though the sap can be quite useful as well. "
	]
	quest.0B04BC5F88746182.quest_desc: ["The following are full-blown storage systems that hold many types of items and present them in a single easy-to-browse and searchable interface. "]
	quest.0B04BC5F88746182.title: "Storage"
	quest.0B05FA716D7335D2.quest_desc: ["The &7Simple Dropper&r is an excellent tool to help automate recipes that involve in world transformations."]
	quest.0B17FF64DFA4BA90.quest_desc: ["Looking for an easier way to get around? Consider crafting an Elytra to glide between islands in style!"]
	quest.0BB08CCD3FEDEB54.quest_desc: [
		"Moving materials long distances can be a troublesome task, but with an &7Entangled Block&r you can treat over there as if it were over here."
		""
		"Sneak Right-Click an inventory with the &7Binder&r to select it, then Right-Click the &7Entangled Block&r with the wand to bind the two. "
		""
		"Once bound, you'll be able to pipe in and out of the &7Entangled Block&r as if it were the bound inventory. Perfect for accessing fluids or items from far away!"
	]
	quest.0BB6D2595F99ADB4.quest_desc: [
		"Now that we can animate blocks and start collecting more varied Spirits, it’s time to delve into genetic manipulation."
		""
		"Craft a &7Scraper&r and Right-Click mobs to gather their &7Organic Matter&r. "
		""
		"&a🛈 Tip: The Delicate Touch enchantment "
		"&a    makes Scrapers deal no damage!"
	]
	quest.0BF882C463675433.quest_desc: [
		"Now that we have some DNA, we need to know what it can do. "
		""
		"Every mob will give Basic Genes, but others have a chance to give more specialized Genes; these are what we’re ultimately after."
		""
		"For example, had you started this process with a Sheep, you’d have a chance of getting the Eat Grass Gene, which could be used to give yourself the ability to Right-Click Grass to eat it."
		""
		"&a🛈 Tip: Check the Recipes for any given "
		"&a    Helix in EMI to see what mobs it "
		"&a    comes from!"
	]
	quest.0C0A7017CEF34F6C.quest_desc: [
		"You’d think just dumping this stuff on the ground would get it plenty cold. "
		""
		"Unfortunately, we’ll need a slightly more controlled environment to ensure the quality of the &7Plastic&r."
	]
	quest.0C32904CD01E4743.quest_desc: [
		"Animate a Zephyr and harvest it for parts."
		""
		"&6⚠ Note: The Ritual Item is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.0C8FAB4B801907B1.quest_desc: [
		"The &7Tesla Handheld Receiver&r interfaces with your Tesla Coils to receive energy wirelessly. "
		""
		"They'll charge both FE and EU consuming devices in your inventory, making them a very versatile tool for keeping your equipment charged. "
	]
	quest.0CCE0467AF123EAB.quest_desc: [
		"Just Dire Things introduces a number of tools with special capabilities, from aoe breaking to teleportation of items to a linked inventory. "
		""
		"Higher tiers also run on FE instead of using durability!"
		""
		"&a🛈 Tip: Sneak Right-Click these tools to"
		"&a    open their options menu."
	]
	quest.0D32F25CCBC9B192.quest_desc: [
		"Simple power cables for transferring Modern Industrialization’s EU power. "
		""
		"They can power blocks that use FE, but can only accept power from Modern Industrialization generators."
	]
	quest.0D65061DFD04B301.quest_desc: [
		"&7Item Modules&r for &7Modular Routers&r allow them to send to or pull from an inventory. "
		""
		"The first tier, MK1, can only send in a straight line, while MK2 can interact with any linked inventory in range. MK3 Senders are special in that they have no range limits and work across dimensions."
		""
		"&7Distributor Modules&r can pull from or send to a maximum of up to eight inventories per module, making them perfect for distributed crafts or collecting from many machines."
	]
	quest.0D65061DFD04B301.title: "Item Modules"
	quest.0D7B7B9CF7362FD8.quest_desc: [
		"Have a trait you don’t want anymore? You can remove them by crafting an Anti-Plasmid. "
		""
		"Attune it to the trait you wish to remove by crafting it together with a Plasmid of that type. Then inject it into a blood sample, just as you would with a regular Plasmid."
	]
	quest.0DA6F0172E06CCB1.quest_desc: [
		"Building on its tool upgrade system, Just Dire Things also introduces a number of abilities for its armor tiers. "
		""
		"Like tools, these are applied to armor via a Smithing Table. Many of these are active abilities, however, rather than always being active."
		"Some of these abilities, such as Run Speed, will grow in power depending on the armor tier. "
		"&n                                                  &r"
		""
		"To configure Armor abilities and bind them to keybinds for use, you’ll need to be holding a Just Dire Things tool while also wearing the armor. "
		""
		"Sneak Right-Click the tool to open its menu, then click the armor piece shown in the armor slots menu. "
		""
		"The following pages will cover what each ability does. "
		""
		"&a🛈 Tip: To see which abilities a piece"
		"&a    has, hold Shift while hovering over"
		"&a    it in EMI. "
		"{@pagebreak}"
		"&7&nHelmet Abilities"
		""
		" • &aNight Vision&r: Provides Night Vision "
		"   continually."
		" • &aWater Breathing&r: Provides Water"
		"   Breathing continually."
		" • &aDebuff Remover&r: Removes debuffs "
		"   on activation."
		"{@pagebreak}"
		"&7&nChestplate Abilities"
		""
		" • &aInvulnerability&r: Grants total "
		"   invulnerability for a short time "
		"   on activation."
		" • &aExtinguish&r: Automatically "
		"   extinguishes you when you're "
		"   burning. "
		" • &aElytra&r: Grants Elytra flight."
		" • &aDeath Protection&r: Prevents death "
		"   once per cooldown period."
		" • &aFlight&r: Grants Creative Flight."
		" • &aLava Immunity&r: Complete fire immunity."
		"{@pagebreak}"
		"&7&nLegging Abilities"
		""
		" • &aRun Speed&r: Adjustable run speed "
		"   bonus."
		" • &aWalk Speed&r: Adjustable walk speed "
		"   bonus."
		" • &aSwim Speed&r: Adjustable swim speed "
		"   bonus."
		" • &aDecoy&r: Summons a decoy to distract"
		"   mobs."
		" • &aPhase&r: Allows you to pass through "
		"   blocks. Does not impart the ability to "
		"   see in blocks. Falling will phase you "
		"   through the ground."
		"{@pagebreak}"
		"&7&nBoot Abilities"
		""
		" • &aStep Assist&r: Step over full blocks."
		" • &aJump Boost&r: Adjustable jump height"
		"   bonus."
		" • &aNegate Fall Damage&r: Soft landings."
		" • &aGround Stomp&r: Knocks back nearby "
		"   mobs on activation."
		" • &aEarthquake&r: Applies slowness to "
		"   nearby mobs on activation."
	]
	quest.0DA6F0172E06CCB1.title: "Just Dire Armor"
	quest.0DD1FC129B316381.quest_desc: [
		"These Redstone devices can be exceptionally useful for automating some of the processes in this chapter."
		""
		"Get creative and have a look around at other devices that might be useful, such as those from the &7Redstone Pen&r mod or even simple vanilla blocks like the &7Observer&r. "
	]
	quest.0DE5D9ADB947B171.quest_desc: [
		"Animate a &7Wilden Chimera&r and defeat it to obtain a &7Wilden Tribute&r."
		""
		"&7Chimera Meat&r may be obtained by killing the creature with a &7Knife&r or by trading extra &7Wilden Tributes&r to a &7Butcher&r. "
		""
		"&6⚠ Note: The Ritual Item is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.0E1258E2B2C7FFD5.quest_desc: [
		"&7Modular Routers&r can be upgraded with an &7Energy Distributor Module&r, allowing them to deliver power wirelessly to eight different blocks per module."
		""
		"To use them, the &7Router&r must also have an &7Energy Upgrade&r installed, which determines the type of energy the &7Router&r will send. This is fully compatible with both FE and EU."
	]
	quest.0E1F3FCCA1A9E405.quest_desc: [
		"These simple Platforms consist of little more than grass and clouds. "
		""
		"They can be used to help you expand your base if you wish!"
	]
	quest.0F63D034A018A4FC.quest_desc: ["Placing a &7Sewer&r beneath your animals will allow you to collect &7Sewage&r which can be used to obtain more &7Water&r and eventually converted into &7Oil&r!"]
	quest.105CABB7D9705359.quest_desc: [
		"&7Farmers&r have some very helpful tools to help you speed up your crop farms. Be sure to check out their wares!"
		""
		"They'll also help you get started with Source production with a &7Mycelial Sourcelink&r which will convert food items directly to Source."
	]
	quest.105CABB7D9705359.title: "Farmer"
	quest.11B62E499806390F.quest_desc: [
		"A &7Tablet of Harvest&r can be a great early way to start automating crop farming."
		""
		"Not only does it harvest the standard crops you’d grow on farmland, but it will also easily harvest pods grown on trees, such as &7Cocoa&r, &7Mendosteen&r, or any of the other Pods from Ars Nouveau."
		""
		"It will require a small amount of Source from a nearby &7Source Jar&r for each crop harvested and will deposit everything into an adjacent inventory. "
		""
		"&a🛈 Tip: The particles denote the Ritual's "
		"&a    working area."
	]
	quest.11EDFB60C787114D.quest_desc: [
		"&7Goo&r is used to transmute materials placed next to it, converting them into far more valuable substances. "
		""
		"Placing blocks against any face of the &7Goo&r will begin this transformation. Try placing some &7Iron Blocks&r to begin crafting &7Ferricore&r"
		""
		"When the blocks are fully engulfed by the &7Goo&r, they’ll be replaced by a crystal that can be broken to obtain the transmuted materials."
		""
		"&6⚠ Note: Goo is hungry and needs to be "
		"&6    fed to work! "
		""
		"&6    Right-Click with items to activate it."
		"&6    To find what items work, search "
		"&3    #goo_revive_tier_1&r&6 in EMI!"
	]
	quest.123BB918DF6E3936.quest_desc: [
		"Looking for a more traditional set of pipes? These pipes from Oritech should get the job done. "
		""
		"Simply place them down and Right-Click any pipes that connect to an inventory to toggle between Extract and Insert mode."
		""
		"The &7Item Pipes&r have one small quirk, however; they only extract from the first slot of the connected inventory by default."
		""
		"To allow them to extract from any slot, you just need to slap a &7Rune of Swiftness&r on the connection."
	]
	quest.1275C61F2390D761.quest_desc: [
		"The &7ME Replication Connector&r allows you to interface your Replication network with your AE2 network. With it in place, AE2 will be able to request anything from your Replication network for auto-crafting."
		""
		"Note that AE2 must be taught how to create each Matter Type. This can be done by placing Pattern Providers against Disintegrators and setting up patterns for each matter type. "
		""
		"It works best if you create one pattern per matter type."
	]
	quest.128449F277949E31.quest_desc: [
		"Placing a &7Repair Pylon&r near an active &7Spirit Crucible&r will allow you to keep an installed &7Impetus&r repaired and working at it’s best. "
		""
		"The &7Repair Pylon&r will need appropriate materials, of course, which are detailed in EMI. It can equally be used to repair many items you might otherwise repair on an Anvil. "
		""
		"For such items, you’ll want to place them in an Item Stand or Item Pedestal nearby."
	]
	quest.12E0E45FC08A5912.quest_desc: ["&7Wireless Player Chargers&r will keep your FE consuming equipment charged while you're in their admittedly small area of effect. "]
	quest.12E7105B33AC043E.quest_desc: ["[ \"\", { \"text\": \"Abjuration Essence\", \"color\":\"gray\"}, \" grants access to the blighted lands of the \", { \"text\": \"Vexing Island\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"13F15094F3AF4A73\" } }, \".\" ]"]
	quest.12E7105B33AC043E.title: "Vexing Island"
	quest.130A2701B96A941D.quest_desc: [
		"This place is mostly safe from monsters, however there are worse things than a few zombies or skeletons poking around."
		""
		"The &7Hearth&r in the gazebo will keep you warm within the bounds of the building once it is activated."
		""
		"Insert the provided &7Tiny Charcoal&r in the &7Chest&r on the left and Right-Click the &7Crystallized Water&r into the &7Accumulator&r on the right."
		""
		"If you wish to check in on it, locate the &7Trap Door&r in front and descend into the basement. "
		""
		"It will take a minute for the &7Hearth&r to warm up, and it will not heat the basement, but you can check on the &7Decrepit Boiler&r while you're down there to ensure it is operating."
		""
		"&a🛈 Tip: Some quests have multiple pages! "
		"&a    Look for a page indicator in the corner! ⤵"
		"{@pagebreak}"
		"A &7Hearth&r provides thermal regulation in a &7covered area&r (i.e. a roof or ceiling) within a &720 block spherical radius&r to a maximum of &712000 blocks total volume&r."
		""
		"The area will not spread through solid blocks, but can pass through ropes, fences, bars, and other partial blocks."
		""
		"The center of the protected area may be moved up to 96 blocks from the &7Hearth&r by attaching &7Smokestacks&r to the top. "
		""
		"Each &7Hearth&r will only produce one protected area at a time, branching &7Smokestacks&r will not allow it to affect multiple areas."
		""
		"&6⚠ Note:  Pressing F3 will allow you to better "
		"&6    visualize the protected area."
		"{@pagebreak}"
		"                   &6&nFueling the Hearth"
		"&n                                                              &r"
		""
		"    &cHeating&r                               &9Cooling&r"
		"     &7Steam                                  &7Ice"
		"&n                                                              &r"
		""
		"The &7Hearth&r has two sides marked for &cHeating&r (left and back) and two for &9Cooling&r (right and bottom).                                           "
		"Appropriate &7Fuel&r and a &7Redstone&r signal must be provided on these faces. "
		""
		"For example, pipe &7Steam&r into the left and power the back with &7Redstone&r to start heating the area."
		""
		"&a🛈 Tip: There are extra pipes hidden in the walls! "
		"&a    Feel free to re-configure it to your liking!"
	]
	quest.130A2701B96A941D.title: "Welcome to the Skies!"
	quest.136AD444BD07EFCF.quest_desc: [
		"The &7Plant Gatherer&r and &7Plant Sower&r are two machines that go hand in hand. "
		""
		"By default, when the Plant &7Gatherer harvests&r a crop, it breaks it, leaving an empty plot. Therefore, the &7Sower&r is used in tandem to re-plant those plots and keep the whole system running. "
		""
		"You’ll want to place the &7Gatherer&r on the edge of your field, while the &7Sower&r will go in the center just underground. "
		""
		"Be sure to check the Show Working area button in their GUI to get an idea of where they’ll be operating."
		""
		"With a &7+4 Range Addon&r, these machines will be able to work on the area of a standard 9x9 farm plot."
		""
		"&a🛈 Tip: Giving the Gatherer Ether Gas "
		"&a    will allow it to harvest without "
		"&a    breaking the crops. "
	]
	quest.136AD444BD07EFCF.title: "Crop Farming"
	quest.136EC4060E233E16.quest_desc: [
		"Construction Sticks help with mass placement of blocks, such as for building out walls and floors. "
		""
		"They offer a variety of options out of the box, but can be upgraded with new features by applying a Template in a Smithing Table.  "
	]
	quest.136FD7D7C0EECAE3.quest_desc: [
		"The first step to making our own &7Oil&r is, of course, lots of organic material. "
		""
		"You should have plenty of raw materials for this from your various animal farms and dorodangos. "
	]
	quest.13F15094F3AF4A73.quest_desc: [
		"                 &6&nBiome: Mushroom Fields&r&r"
		""
		"The following Placement Conversions are in effect in this biome. Remember to use these to your advantage by using Conjure Terrain to summon these blocks."
		""
		"  • &7Dirt&r                 &2⟶&r      &7Blighted Earth&r"
		"  • &7Grass Block&r      &2⟶&r      &7Blighted Earth&r"
		"  • &7Cobblestone&r      &2⟶&r      &7Tainted Rock&r"
		"  • &7Stone&r              &2⟶&r      &7Smooth Tainted Rock&r"
		"  • &7Sand&r               &2⟶&r      &7Cold Aercloud&r"
		"  • &7Sandstone&r        &2⟶&r      &7Quicksoil&r"
		"  • &7C. Deepslate&r      &2⟶&r      &7Twisted Rock&r"
		"  • &7Deepslate&r         &2⟶&r      &7Smooth Twisted Rock&r"
		""
		"                     &6&nExample Spells&r"
		""
		"&7Conjure Blighted Earth&r"
		"    &5Touch&r > &aConjure Terrain&r"
		""
		"&7Conjure Tainted Rock&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r"
		""
		"&7Conjure Smooth Tainted Rock&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aSmelt&r"
		""
		"&7Conjure Cold Aercloud&r"
		"    &5Touch&r > &aConjure Terrain&r > &aCrush&r"
		""
		"&7Conjure Quicksoil&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aCrush&r"
		""
		"&7Conjure Twisted Rock&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify x2&r"
		""
		"&7Conjure Smooth Twisted Rock&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify x2&r > &aSmelt&r"
	]
	quest.140BFF0572840B6E.quest_desc: ["A two in one charger, this device will not only fill the energy buffer on FE based equipment, but can also fill the fluid buffer at the same time, making it very useful for working with a &7Jetpack&r."]
	quest.144E3D7884732298.quest_desc: [
		"&7Drones&r are powerful programmable devices that can be made to do just about anything you’d wish. "
		""
		"They can wield weapons to attack mobs, wield tools to break blocks, place blocks, collect items, work with fluids, craft items, the works. "
		""
		"Getting them to do anything, however, will require some amount of programming. The &7Programmer&r allows you to build programs using a simple &7Visual Programming Language&r using interlocking puzzle pieces. "
		""
		"They have a variety of information available to them to drive conditional logic as well, such as the owner’s position and which direction they’re looking, Redstone levels at a block position, fluid and inventory levels, the age of mobs, and more. "
		""
		"Play around with them and see what you can come up with. They can easily be used to manage livestock, kill mobs, perform complicated farming tasks like tree farming, or even operate complex crafting mechanics like rituals."
		""
		"&a🛈 Tip: Be sure to check the guid book for more "
		"&a    details on programming drones."
	]
	quest.144E3D7884732298.title: "Programmable Drones"
	quest.1476B02AA2977ACB.quest_desc: [
		"The funny thing about being so high in the air is just how much lightning one can attract with a proper setup. "
		""
		"The &7Electrostatic Compressor&r will attract random lightning strikes, converting the energy into compressed air up to &720 bar&r."
		""
		"It works well enough in clear skies, but when a storm rolls through it will really get going."
		""
		"Up this far, it is &overy efficient&r."
		"&n                                                              &r"
		""
		"[\"An example of the structure required for this compressor can be found on \",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://blockprints.io/schematic/f0d838f5-6460-4f3d-aaf0-ab6590df20e5\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"BlockPrints.io\",\"underlined\":true},\". Press (\",{\"color\":\"gold\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"translate\":\"key.blockprints.open_menu\"}]},\"keybind\":\"key.blockprints.open_menu\"},\") to open the menu!\"]"
		""
		"&a🛈 Tip: Search &3#electrostatic&r &ain EMI to discover "
		"&a    valid blocks for an Electrostatic Grid."
	]
	quest.1476B02AA2977ACB.quest_subtitle: "Shocking Efficiency"
	quest.149BC66585EA0C34.quest_desc: [
		"Each Bookwyrm attached to the &7Primary Lectern&r allows you to link eight inventories. That goes quick if you’re binding directly to chests and the like. "
		""
		"Instead, bind to a &7Repository Catalog&r and place &7Repositories&r adjacent to it. "
		"&n                                                  &r"
		""
		"&7Repository Catalogs&r will help you maximize the number of inventories connected to the system since they act as a Storage Controller. "
		""
		"Any adjacent and connected &7Repositories&r are automatically joined to the &7Catalog&r, so anything inserted into it will be intelligently sorted into the adjoined &7Repositories&r. "
		""
		"It is recommended that you use &7Repository Catalogs&r and &7Repositories&r, but any inventory will do."
	]
	quest.154F980273016EAF.quest_desc: [
		"With but a spark, the &7Vapours&r ignite into the &7Luminiferous Aether&r. "
		""
		"&a🛈 Tip: Place the controller block, then hold a Wrench "
		"&a    to see the structure. Similarly, hold a Hatch to see "
		"&a    valid locations for them."
	]
	quest.157A20804F9E8F83.quest_desc: [
		"With all this in world crafting, an &7Item Collector&r will no doubt come in handy."
		""
		"This &7Item Collector&r places its items into the inventory it is attached to and can be filtered in a variety of ways. "
		""
		"&a🛈 Tip: Use the Render Area button to "
		"&a    easily configure the working area."
	]
	quest.159F7020B1DE875D.quest_desc: [
		"Want to bring your new friends with you? "
		""
		"By bringing them close to a &7Ritual of Binding&r, you’ll obtain a &7Bound Script&r which may be learned by Right-Clicking it in the air. "
		""
		"Once learned, a new entry will appear in your &7Spell Book&r under the &7Familiars&r tab. From there, you’ll be able to instantly summon one familiar at a time to grant you benefits. "
		""
		"These benefits range from increased spell damage and higher looting rates, to buffed speed and ranged item collection. "
		""
		"Check the &7Worn Notebook&r to see what each &7Bound Script&r has to offer you!"
	]
	quest.15FAB1720AD470A0.quest_desc: [
		"Every Modern Industrialization multiblock will require input and output hatches commensurate with the recipes it handles. "
		""
		"In this case, the &7Steam Kiln&r requires both Item and Fluid Hatches. Multiple hatches may be placed in order to accomodate different inputs. "
		""
		"To power this device, at least one Fluid Input is required for &7Steam&r, which can be piped out of your &7Decrepit Boiler&r."
		""
		"Other blocks required for any structure can also be found by looking at uses for the controller block (ie. &7Steam Kiln&r block) in &7EMI&r. Note that some of the blocks listed will be replaced by Hatches."
		""
		"&a🛈 Tip: Place the controller block, then hold the Wrench "
		"&a    to see the structure. Similarly, hold a Hatch to see "
		"&a    valid locations for them."
	]
	quest.161CA05D18639AD4.quest_desc: [
		"This workstation allows the &7Wixie&r to craft &7Farmer's Delight Cutting&r recipes. "
		""
		"It will only produce the primary output of the craft, however. For example, &7Rice&r will &nnot&r produce &7Straw&r when processed this way. "
		""
		"                   &6&nFormation&r"
		""
		"Right-Click a &7Cutting Board&r with a &7Wixie Charm&r."
		""
		"&6⚠ Note: For multi-step crafts, each "
		"&6    step must be specified separately."
	]
	quest.161CA05D18639AD4.title: "Wixie Cutting"
	quest.16BFB19411FE195F.quest_desc: [
		"LaserIO is a catch all logistics mod capable of many things. "
		""
		"Check out the guidebook for more information on how to use it to your advantage!"
	]
	quest.16BFB19411FE195F.title: "LaserIO"
	quest.16C7D5478BF3D449.quest_desc: [
		"The &7Learning&r chapters are designed to help you discover useful aspects of major content mods. "
		""
		"They also provide tips on how to use different features of those mods."
		""
		"These chapters cover a lot of ground, but they don’t cover everything. So, be sure to explore the manuals for those mods that have them."
	]
	quest.16C7D5478BF3D449.title: "Learning Mods"
	quest.17198F7EC5DC1A4F.quest_desc: ["The smell leaves something to be desired, but these bio-mechanical &7Robot Arms&r are incredibly precise and capable of adapting to changing conditions mid-task."]
	quest.17553CF42EDC67A6.quest_desc: [
		"Channeling more powerful magics requires a more specialized focus. "
		""
		"Upgrade your &7Spell Book&r with the materials you’ve discovered on this island and discover a whole new world of possibilities. "
		""
		"&a🛈 Tip: Spells and are retained when "
		"&a    upgrading your Spell Book!"
	]
	quest.17553CF42EDC67A6.title: "Tier 2 Spells"
	quest.18A17E8080792318.quest_desc: [
		"Need a little more room to work? Summoning another island is always an option. "
		""
		"Alternatively, Right-Click a &7Tainted Rock&r with an &7Abjuration Essence&r to convert a &n21x11x21&r area to this biome!"
	]
	quest.18A17E8080792318.title: "Biome Conversion"
	quest.18D575594C6F74A7.quest_desc: [
		"Made from &7Sand&r, &7Silty Dorodangos&r may be processed down into new materials!"
		""
		"                    &n&6Materials&r"
		""
		"  • &7Prismarine Shards&r"
		"  • &7Prismarine Crystals&r"
		"  • &7Nautilus Shells&r"
	]
	quest.19F8B29D38CA31B8.quest_desc: [
		"The &7Flashing Archwoods&r on this island will already have a few &7Flashpine&r grown on them. "
		""
		"Gather a few and consider setting up a farm when you can; they grow when placed on a &7Flashing Archwood Log&r and can be sped up by applying &7Bone Meal&r or other grow effects. "
		""
		"&a🛈 Tip: Harvest Rituals can be an easy "
		"&a    way to farm these fruit!"
	]
	quest.1A2B5BCA37161B1A.quest_desc: [
		"This workstation allows the &7Wixie&r to craft &7Enchanting Apparatus&r recipes. "
		""
		"This can be particularly helpful for repeat crafts as the &7Wixie&r will process ingredients more quickly than the standard &7Enchanting Apparatus&r."
		""
		"                   &6&nFormation&r"
		""
		"Right-Click a &7Enchanting Apparatus&r with a &7Wixie Charm&r."
		""
		"&6⚠ Note: For multi-step crafts, each "
		"&6    step must be specified separately."
	]
	quest.1A2B5BCA37161B1A.title: "Wixie Enchanting"
	quest.1A9CC0DF3D43189C.quest_desc: [
		"Each of these islands convert their respective areas to their own biome type when summoned, enabling new block conversions and opening up new resources. "
		""
		"To reset an area to the Void biome type, however, simply Right-Click &7Holystone&r with a &7Conjuration Essence&r to convert a &n21x11x21&r area to this biome!"
	]
	quest.1A9CC0DF3D43189C.title: "Biome Conversion"
	quest.1AB4455F15DF1F84.quest_desc: [
		"The &7Natural Altar&r is the primary Aura consuming device you'll be using."
		""
		"Think of Aura like Oxygen and Carbon Dioxide. When you breathe, you inhale Oxygen and exhale Carbon Dioxide. Do that enough without renewing the Oxygen and you will die."
		""
		"Aura is your Oxygen. "
		""
		"There are &7Aura Generators&r to replenish it, but it is a finite resource that requires upkeep. Use too much and terrible things will start to happen."
		""
		"Luckily, the &7Natural Altar&r will simply stop working if Aura gets too low. Other devices, however, can drain it away completely. "
		""
		"The &7Book of Natural Aura&r goes into more details on this mysterious force."
		"&n                                                              &r"
		""
		"This device requires a multiblock structure to function. "
		""
		"Refer to the &7Book of Natural Aura&r for a preview of block placement."
	]
	quest.1ABB07894781F511.quest_desc: [
		"By setting up some &7Powder of Fertility&r near your animals, you can keep them happy and breeding at the cost of Aura instead of food. "
		"&n                                                  &r"
		""
		"Powders apply in groups and their range is directly related to the number of powders you were holding when placing them."
		""
		"For example, hold six powders and place them on the ground. All six will be placed as a single entity and their effect will cover a six-block radius. "
		""
		"Right-Click the floating powder with your &7Mystical Magnifier&r to visualize the area."
		""
		"&a🛈 Tip: Powders may be removed by "
		"&a    punching them."
	]
	quest.1ABB07894781F511.title: "Ain't Nothing But Mammals"
	quest.1ACB8880980AF206.quest_desc: [
		"There’s much to do and you’re going to need help. With everyone else gone, you'll have to make your own friends."
		""
		"For ages, homunculi have been crafted in the same way; clay formed into the shape of a person and a note bearing instructions inserted into their head. "
		""
		"Then, just a touch of magic to animate it with a semblance of life."
		"&n                                                  &r"
		""
		"Craft some &7Source Ink&r and &7Blank Parchment&r, you'll need these to make a &7Statue&r. "
		""
		"&7Quick Soil&r will make a form of glass suitable for making &7Bottles&r. "
	]
	quest.1ACB8880980AF206.title: "Wit by Writ"
	quest.1AE63FE6C7EF59AB.quest_desc: ["A &7Simple Clicker&r or &7Activator Module&r attacking mobs with a &7Soul Shattering Weapon&r can be an excellent way to automate &7Spirit&r collection. "]
	quest.1AE63FE6C7EF59AB.title: "Clickity Clackity"
	quest.1B0718B6BDA972F0.quest_desc: ["The final tier of Boiler fuel, &7Eclipse Ember Fuel&r represents the most efficient way to power your machines."]
	quest.1B276AC6C7D95526.quest_desc: [
		"&7Plasma Turbines&r may be used to harvest the raw creational power from the &7Luminiferous Aether&r. "
		""
		"One of these will likely replace all other &7Turbines&r you've been using up until now, but you'll need quite a few to get the most out of your &7Fusion Reactor&r."
		""
		"&a🛈 Tip: Place the controller block, then hold a Wrench "
		"&a    to see the structure. Similarly, hold a Hatch to see "
		"&a    valid locations for them."
	]
	quest.1BAEB780F38B1C56.quest_desc: [
		"Connect an Access Point to your network, then place a Wireless Terminal inside it to link them and gain wireless access to the entire network."
		""
		"Greater range will cost more power!"
	]
	quest.1BDCA4CF5ED739BA.quest_desc: ["Upgrading your Goo will give you access to newer recipes and faster in-world processing."]
	quest.1C21EC957B97C70A.quest_desc: [
		"An &7Advanced Clicker&r can be an exceptionally useful device for working with mobs since it can both Attack and Right-Click them with weapons and tools. "
		""
		"Unlike a &7Simple Clicker&r, the &7Advanced Clicker&r acts in a large area. "
	]
	quest.1C4DB05778703E9B.quest_desc: [
		"&7Wardens&r were built for protection. That was the original purpose, at least."
		""
		"Somewhere along the way, they decided the best way to protect was to consume the souls of those they watched over. No more harm can come, after all, if there’s no body to be harmed."
		""
		"By harvesting the souls from these creatures, we can use them to make many of our machines operate quicker. "
		"&n                                                              &r"
		""
		"Many machines have built-in ways to speed themselves up; addons, upgrades, and the like. Sometimes, that's simply not enough, however. And in other cases, there's simply no built-in way to speed up the device."
		""
		"This system can be a great way to speed up things like the &7Cooking Pot&r and the &7Natural Altar&r, among others."
	]
	quest.1C83B47F599B117A.quest_desc: [
		"So far, we’ve dabbled with magics of the Soul. To delve deeper, we will need to stare into the void itself."
		"&n                                                  "
		""
		"Locate a Weeping Well and throw your Encyclopedia Arcana into it to obtain the necessary knowledge. "
		""
		"Once you've transformed your Encyclopedia, you'll find a new chapter listed within: &dThe Chronicles of the Void&r"
	]
	quest.1C9565D5C51B74CC.quest_desc: [
		"With a &7Cell Analyzer&r and &7DNA Extractor&r, you're ready to begin breaking down the &7Organic Matter&r you've been collecting to obtain the &7DNA&r within. "
		""
		"These samples will be spliced and introduced into a host to obtain something entirely new."
		""
		"[ \"These machines can also be used to grant entities permanent buffs. Refer to the \", { \"text\": \"Genetics: Resequenced\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"7F17CDF8564DCC49\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]} }, \" Chapter for more information.\" ]"
	]
	quest.1C9565D5C51B74CC.title: "Genetics"
	quest.1CBC50FA40BFB54A.quest_desc: [
		"The &7Large Steam Turbine&r operates on standard &7Steam&r, just as your previous power infrastructure. The &7Heat Exchanger&r is more than capable of keeping up with it. "
		""
		"It can also accept &7High Pressure Steam&r, but for reasons mentioned previously, this is &nnot recommended&r. "
		""
		"                         &n&6A Note on Ratios&r"
		""
		"Each &7Turbine&r can handle up to 16k EU/t of Steam for a final ratio of &7Two Boilers&r to &7One Heat Exchanger&r to &7One Large Turbine&r. "
		""
		"However, for the &7Turbine&r to reach this capacity it will require an &7EV Tier Energy Hatch&r and cabling. It may use lower tier Hatches, but be aware that these will limit throughput."
		""
		"&a🛈 Tip: Place the controller block, then hold a Wrench "
		"&a    to see the structure. Similarly, hold a Hatch to see "
		"&a    valid locations for them."
	]
	quest.1CEDA28FD4CB759E.quest_desc: [
		"&7Transfer Labels&r slip between blocks to enable block-to-block transfer without a pipe. "
		""
		"Sneak + Right-Click to install one on the side of a block. Once installed, the label may be configured by Right-Clicking either with another label or with a &7Label Accessor&r. "
		""
		"While in the Configuration screen, you may add more labels to control the quantity and speed of transfer, as well as set filters."
		""
		"The label may be removed by Left-Clicking it with another label or with a &7Label Accessor&r."
	]
	quest.1CF0D1E63C34AE6E.quest_desc: [
		"&7Spirit Catalyzers&r help speed up the &7Spirit Crucible&r. Simply place them nearby and fill them with your choice of furnace fuel."
		""
		"Speeding up the &7Crucible&r in this way will cause the &7Impetus&r to take damage faster as well, but the trade-off is well worth the risk."
	]
	quest.1CF4103BFBCE0E29.quest_desc: [
		"With an &7Imbuement Chamber&r, you can begin accessing new islands, each with its own unique block transformations and resources. "
		""
		"Use your &7Source Gems&r to create the &7Essences&r you'll need for each island. "
		""
		"These areas are not self-contained, however; the deeper you go into each Island’s quests, the more you’ll need resources from the other Islands. "
		""
		"Summon them all as soon as you're able. "
		""
		"[ \"A good place to start will be the \", { \"text\": \"Flourishing Island\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"6490781066FAE8CF\" } }, \", so get the materials together for \", { \"text\": \"Essence of Earth\" , \"color\":\"gray\"}, \".\" ]"
		""
		"To use the &7Imbuement Chamber&r, you’ll need to place some &7Arcane Pedestals&r or &7Platforms&r directly adjacent to it. The item shown in the middle of the recipe goes in the &7Imbuement Chamber&r, while the rest must be placed in the &7Pedestals.&r "
		""
		"&6⚠ Note: The Pedestal items are &nnot&r &6consumed. "
		""
		"&a🛈 Tip: Source is optional but will speed up the craft!"
	]
	quest.1D2F5CE5D285BAEA.quest_desc: [
		"&7Whirlisprigs&r once roamed the lands, tending to the natural world. It’s been an age since they’ve been seen, but perhaps that can be rectified?"
		""
		"Ancient texts alluded to them being related in nature to the &7Allay&r, a creature we can call forth with a little effort…"
		"&n                                                  &r"
		""
		"Craft a &7Magic Lamp&r and release its inhabitant at an &7Altar of Birthing&r. Then gather some &7Organic Matter&r from it."
		""
		"&6⚠ Note: The Spawn Egg is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.1D2F5CE5D285BAEA.quest_subtitle: "Rub me the right way"
	quest.1D2F5CE5D285BAEA.title: "Genie in a Bottle"
	quest.1D5616DFA428D46F.quest_desc: [
		"Building Gadgets offer a number of FE powered tools to assist with building ranging from block placement, block replacement, copy/paste, and even straight deletion of large areas."
		""
		"If you’re looking to build a massive base, Building Gadgets likely has a tool to help. "
		""
		"&a🛈 Tip: Search &3@buildinggadgets&r &ain EMI"
		"&a    to discover more."
	]
	quest.1D5616DFA428D46F.title: "Building Gadgets"
	quest.1D5E773A3A547A2C.quest_desc: [
		"If you’re into Cottagecore or just want some knicknacks to fill your shelves with, Handcrafted is the place to start. It’s loaded with comfy chairs and interior decorations."
		""
		"&a🛈 Tip: Search &3@handcrafted&r &ain EMI to "
		"&a    discover more."
	]
	quest.1D5E773A3A547A2C.title: "Handcrafted"
	quest.1D783196F551142F.quest_desc: [
		"Better food, better work. "
		""
		"Keep your Villages stocked up with the very finest cooking you can manage, and they’ll be able to create wonders. "
		""
		"                 &6&nA Note on Automation&r&r"
		""
		"The &7Cooking Pot&r is a sided machine, much like a &7Furnace&r. This means that specific items must be inserted on specific sides when using any form of logistics."
		""
		" • Food Ingredients must be inserted from "
		"   the top face."
		""
		" • Serving containers, such as &7Bottles&r and"
		"   &7Bowls&r, must be inserted on a side face."
		""
		" • The Result of the craft can only be "
		"   extracted from the bottom."
		""
		" • Any remainders, such as Bottles used in "
		"   the inputs, will be thrown on the floor. "
		""
		"The order of the input items does not matter, and duplicate items can be stacked in the same slot."
		""
		"Due to these requirements, it can prove difficult to automate the &7Cooking Pot&r early on since few things can extract from the bottom while the &7Heat Source&r is under the &7Pot&r. "
		""
		"&7Starbuncles&r can be very useful for extracting from the bottom, however. "
	]
	quest.1D7DF143EDEAE1EC.quest_desc: [
		"A clever device for growing more mushrooms without any hassle. "
		""
		"Simply provide power, water, and some mushrooms to get started and it’ll do the rest."
	]
	quest.1D9182A079919158.quest_desc: [
		"Need a little more room to work? Summoning another island is always an option. "
		""
		"Alternatively, Right-Click &7Sculk&r with &7Air Essence&r to convert a &n21x11x21&r area to this biome!"
	]
	quest.1D9182A079919158.title: "Biome Conversion"
	quest.1DA29F3B45DEFB4B.quest_desc: [
		"Magic can be a lonely profession. Everyone always asks, “What can you do?”, but never “How are you doing?”."
		""
		"And while it’s useful to have spells being cast for you by a Turret, they’re cold… lifeless. "
		""
		"But what if you could make your own friends? Cute, lovable, huggable friends that would spark joy just by being around? "
	]
	quest.1DA29F3B45DEFB4B.title: "Magical Friends"
	quest.1DB63D0AAD1F0E11.quest_desc: [
		"Made from &7Smooth Basalt&r, &7Volcanic Dorodangos&r may be processed down into new materials!"
		""
		"                   &n&6Materials&r"
		""
		"  • &7Blazing Quartz&r"
		"  • &7Crystallized Lava&r"
		"  • &7Cinder Flour&r"
	]
	quest.1E0B03155C2CAEE7.quest_desc: [
		"Spirit Focusing is an alchemical art whereby a catalyst item, or &7Impetus&r, is infused with &7Spirits&r to generate new materials. "
		"&n                                                  "
		""
		"For a start, craft an &7Alchemical Impetus&r and slot it into the &7Crucible&r. Depending on the &7Spirits&r inserted alongside the Impetus, you will begin to generate new materials."
		""
		"The &7Impetus&r will be damaged in the process and will eventually fracture, however there are ways to repair them to keep this process going indefinitely."
	]
	quest.1E0B03155C2CAEE7.title: "Spirit Focusing"
	quest.1E514F5A18364625.quest_desc: [
		"Finally, craft yourself a &7Whirlisprig Charm&r. These items may be Right-Clicked on any flower to make a home for your new friend."
		""
		"The &7Whirlisprig&r will manage the plants in a large area, gently harvesting small quantities of everything in its home area and depositing them in an inventory &nadjacent&r to its &7Blossom&r."
		""
		"Source is required and will be taken from a nearby &7Source Jar&r."
	]
	quest.1FDA97FE562A2C4D.quest_desc: [
		"Addons can be installed in most Industrial Foregoing machines to speed them up and make them run more efficiently. "
		""
		"Don’t miss out!"
	]
	quest.1FDA97FE562A2C4D.title: "Addons"
	quest.20454EB2C6E93573.quest_desc: [
		"The &7Player Accessor &rallows any form of logistics to interact with your inventory as if it were a chest. "
		""
		"This could be used to automatically stock building materials for a large project, among other things. "
	]
	quest.2150EE8D0B1474CE.quest_desc: [
		"The Logistics section covers items from mods that help automate moving things around."
		""
		"Be it items, fluids, or power, the mods shown here will help move it."
	]
	quest.2150EE8D0B1474CE.title: "Logistics"
	quest.21B7BDFCF5144431.quest_desc: [
		"The very mists of creation, this primordial substance existed before anything. "
		""
		"Before even the concept of “thing”. "
		""
		"Raw creation is at your fingertips."
	]
	quest.21C1CAA38D040AC8.quest_desc: [
		"Functional Storage is an expandable storage solution capable of holding all of your items and liquids. "
		""
		"Each drawer can hold from one to four item types, but will hold a truly astronomical amount of them. "
		""
		"Drawers may also be linked up to a Drawer Controller, allowing you to link all of the drawers into a single network. So, item pipes and other logistics can pipe into or out of the Controller and have access to every attached drawer."
		""
		"It’s not possible to manually access the Storage Controller, so you’ll likely want to pair this with something else that allows you access the items. An Ad Hoc AE2 network, Pretty Pipes, or an Ars nouveau Storage Lectern are all excellent options."
	]
	quest.21C1CAA38D040AC8.title: "Functional Drawers"
	quest.21FA8A625A79BE61.quest_desc: [
		"Simple fluid pipes for getting fluid from one place to another. "
		""
		"Each one will only transfer a single fluid type at a time."
	]
	quest.22344008D43D4710.quest_desc: [
		"Villagers are the soul source of many critical ingredients and their hunger knows no bounds. You’re going to need some help keeping them fed!"
		""
		"The &7Wixie&r represents a very simple means of automating various kitchen appliances, among other things. "
		""
		"                            &6&nCare and Use&r&r"
		""
		"In order to get your &7Wixie&r working, you'll need to set up their area appropriately. "
		""
		"First, place their workstation. For general crafting, this will be a &7Cauldron&r. Right-Click the workstation with the &7Wixie Charm&r to summon them."
		""
		"Next, you'll need to tell them what to craft. This is done by placing &7Arcane Pedestals&r directly adjacent to the workstation and then placing the desired output in the pedestal. "
		""
		"A single Wixie can support multiple crafts by using multiple &7Pedestals&r. Powering a &7Pedestal&r with Redstone will disable that one craft from their list, thus allowing you to stop crafting when you reach a desired amount."
		""
		"Naturally, they'll also need ingredients. Place one or more inventories nearby and use your &7Dominion Wand&r to bind them to the workstation; while holding the &7Wand&r, Sneak Right-Click the inventory then Right-Click the workstation. "
		""
		"Lastly, and most importantly, Wixies need Source. Place a &7Source Jar&r nearby, fill the inventory with ingredients, and enjoy. "
	]
	quest.22344008D43D4710.title: "Chef's Aid"
	quest.223BE2F1F8A5C87C.quest_desc: [
		"The &7Replication Terminal&r is used to request crafts from patterns stored on &7Memory Chips&r. "
		""
		"It also gives you an overview of the total amount of each &7Matter&r stored on the network and allows you to manage any ongoing requests. "
	]
	quest.22ABFC3024E54FEA.quest_desc: [
		"The Mercurial Item transport system is a simple logistics network for moving, well, items."
		""
		"The &7Inserters&r and &7Extractors&r can be placed against machines or other inventories and then linked up with &7Mercurial Copper Wire&r. "
		""
		"&7Mercurial Connection Nodes&r allow multiple wires to come together to form a broader network, as well as to extend the reach of individual wires."
	]
	quest.22ABFC3024E54FEA.title: "Mercurial Item Nodes"
	quest.235D7EF41916E480.quest_desc: ["The following are various forms of power transfer options available in Enigmatica 10."]
	quest.235D7EF41916E480.title: "Power"
	quest.23DDFBC0DB19F6A4.quest_desc: [
		"When placed beneath any Aura using blocks, the Aura Imbalance Ward will prevent the device from consuming Aura into dangerous territory. "
		""
		"Consider placing one beneath most Aura Using Devices as soon as possible. Some of them can consume Aura at a startling rate!"
	]
	quest.23ED7167CB856D26.quest_desc: [
		"Magic doesn’t come out of thin air, of course. What madness!"
		""
		"Buy a &7Codex&r from your friendly neighborhood &7Librarian&r and dissolve it in &7Sal Ammoniac&r to obtain &7Liquefied Source&r. "
		""
		"From there, you’ll be able to infuse &7Ambrosium&r with it to create &7Source Gems&r."
	]
	quest.24095EE1A419152D.quest_desc: [
		"A small multiblock consisting of the &7Controller&r and up to four &7Outputs&r stacked atop it, the &7Refinery&r is central to processing &7Crude Oil&r. "
		""
		"The Refinery uses Heat instead of Air. You can use passive heat sources such as &7Magma Blocks&r or &7Lava&r, however you may wish to use a &7Vortex Tube&r to heat it instead. "
		""
		"&a🛈 Tip: Look at Uses for Heat Pipes in"
		"&a    EMI for a list of heat sources."
	]
	quest.2498E93D32A45AB0.quest_desc: ["Energy Cards for LaserIO allow Laser Nodes to transport FE based energy."]
	quest.25570E19FFABD951.quest_desc: [
		"The &7Arcane Catalyst&r and &7Stabilized Enchanter&r will allow you to over enchant your tools, weapons, and armor to truly absurd levels of power. "
		""
		"As &7Spirit&r requirements increase, it may be a good idea to push your Spirit Plunder enchants to ever greater heights."
	]
	quest.25B419FE32D9752B.quest_desc: [
		"Make a &7Mercury Distiller&r and place it atop a &7Pyromantic Brazier&r. "
		""
		"Items, such as &7Sky Stone Dust&r, may be Right-Clicked into the &7Distiller&r while fuel may be Right-Clicked into the &7Brazier&r to begin processing."
	]
	quest.25B779319401405B.quest_desc: [
		"Welcome to Malum, a magic mod designed around the manipulation of spirits to invoke powerful rituals."
		""
		"This quest section covers the basics of using the mod. For more in-depth explanations, please refer to the Encyclopedia Arcana."
	]
	quest.25B779319401405B.title: "Malum"
	quest.26188F1C7EBA08B6.quest_desc: [
		"Open a rift and summon forth &7Psychic Squid&r to obtain &7Eldritch Spirits&r."
		""
		"&6⚠ Note: The Ritual Item is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.26188F1C7EBA08B6.title: "Eldritch Spirit"
	quest.264783EF292A494B.quest_desc: [
		"The &7Simple Clicker&r can automate a number of interactions, such as shearing sheep or killing mobs that pass in front of it. "
		""
		"It does need a tool, so be sure to provide it shears for said sheep farm or a nice looting sword for killing mobs. "
	]
	quest.267FEB0BB5D9B4D9.quest_desc: [
		"The &7Assembly Table&r is a multiblock machine capable of more advanced crafting. "
		""
		"Each piece has requirements for valid placement; refer to the PNC:R manual for the exact rules."
		""
		"A simple layout can be setup in a 2x3 space, however:"
		"&a    IO Unit   Controller     IO Unit"
		"&a    Drill      Platform        Laser"
		""
		"&6⚠ Note: The Drill \\& Laser program "
		"&6    allows the Assembly Table to craft "
		"&6    recipes that use either a drill or "
		"&6    laser, or both."
	]
	quest.267FEB0BB5D9B4D9.title: "Assembly Table"
	quest.26D35A0B06B5EA35.quest_desc: [
		"The woman’s walking stick began to burn to cinder as the Four Winds rushed her back to the earth’s embrace. "
		""
		"She thrust the flame, precious and frail, into a special earthen vessel. There, it was nurtured and grew strong."
		""
		"As the woman approached the earth once more, the heat of the vessel grew and spread, flowing across the earth. "
		""
		"Forever after, the cold of Winter would give way to the gentle touch of Spring in an endless dance of seasons.  "
	]
	quest.2722D0A13CF02C73.quest_desc: ["A &7Source Condenser&r can be a handy way to convert &7Source&r into &7Liquefied Source&r!"]
	quest.274C351C4A8F794F.quest_desc: ["Positively buzzing with arcane energy. "]
	quest.2850FCAFEEF5004C.quest_desc: [
		"Some traits, such as &7Efficiency&r, may be leveled up through a process known as Mutation."
		""
		"The results of this process are not guaranteed but there are ways to improve your chances."
		""
		"To begin, craft some &7Potions of Mutation&r, then get some &7Cells&r from a mob that can provide the basic trait. In this case, Silverfish."
		""
		"Brew the Cell samples with the potion of Mutation to obtain a Potion of Mutation with that mob set as the entity."
	]
	quest.288F7A968693F3E5.quest_desc: [
		"When supplied the appropriate fluid and a &7Firework Rocket&r to deliver it high into the atmosphere, this &7Obelisk&r will control the weather, keeping things as temperate or tempestuous as you wish."
		""
		"  • &6Liquid Sunshine&r Clears the weather, bringing "
		"    back sunny skies."
		""
		"  • &6Cloud Seed&r Calls forth clouds and rainy or "
		"    snowy weather."
		""
		"  • &6Cloud Seed Concentrated&r Calls forth a mighty "
		"    storm with lightning and thunder."
	]
	quest.289A1CE4C4092687.quest_desc: [
		"&7Interfaces&r are essentially a combined Import/Export Bus."
		""
		"For example, one might be used to stock coal for a power generator, while a nearby automated wheat farm might send all of its wheat back through the same interface. "
		""
		"Their combined nature means getting more done with a single channel."
		""
		"&a🛈 Tip: Cable Subparts cannot be "
		"&a    placed on Dense Cables."
	]
	quest.289DEC367A80D718.quest_desc: [
		"These &7Advanced&r devices operate much like their &7Simple&r counterparts, but with some added features at the cost of energy."
		""
		"First, they operate in a much larger area which may be configured to your needs."
		""
		"They also have their own robust filtering systems built in, so they can do more on their own without needing &7Sensors&r to control them."
		""
		"&a🛈 Tip: Use the Render Area button to "
		"&a    easily configure the working area."
	]
	quest.289DEC367A80D718.title: "Advanced Placers and Collectors"
	quest.28ACDB98DC2B9D41.quest_desc: [
		"Our fuel can burn plenty hot, but with the extreme cold here it's still not enough to warm certain machines to suitable temperatures. "
		""
		"We'll need some form of insulation to retain as much precious warmth as possible."
		""
		"                           &6&nExample Spells&r"
		""
		"&7Conjure Aerogel&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &6Amplify&r"
		""
		"&6⚠ Note: Apply Amplify to a Break spell to harvest Aerogel."
	]
	quest.28E44D5D6A6C1D6E.quest_desc: [
		"An alchemical device used in the production of world-shaping materials of magical importance. "
		""
		"With a &7VAT&r you can produce fluids which can shift the weather to your advantage. "
		""
		"Of course, you’ll find other uses for these fluids as well, such as the production of a particularly durable form of steel: &7Dark Steel&r."
		""
		"&6⚠ Note: Enderio machines require  "
		"&6    a Capacitor to function."
	]
	quest.28F4519591D71F80.quest_desc: [
		"&7Item Laser Relays&r pair with an &7Item Interface&r to create a larger storage network from a bunch of small inventories. "
		""
		"Place the L&7aser Relays&r against a series of chests and another against an &7Item Interface&r. Link them all together with a &7Laser Wrench&r and now any items that are pushed into the &7Interface&r will be stored in the chests. "
		""
		"Similarly, items can be pulled out of the system from the &7Interface&r, meaning this can be paired nicely with AE2 or an Ars Nouveau Storage Lectern."
	]
	quest.294B023DD4F19FE3.quest_desc: [
		"Your &7Goat Fur Suit&r should keep you warm enough while stepping out into the cold. But it won’t offer much else. "
		""
		"If you’d like to wear other armor pieces, you can insulate them at a &7Sewing Table&r."
		""
		"Insulation can always be removed by placing &7Shears&r in the bottom slot. This does not damage the insulation or the armor."
		"                           &6&nInsulation Types&r"
		""
		"    • &9Cold&r - Effective against &9Cold&r  "
		"    • &6Heat&r - Effective against &cHeat&r "
		"    • &dNeutral&r - Effective against &cHeat&r &oand&r &9Cold&r "
		"        It is 50% as effective as dedicated insulation"
		"    • &aAdaptive&r - Effective against either &cHeat&r &oor&r &9Cold&r "
		"        It is 75% as effective as dedicated insulation"
		"        and takes time to adapt to change "
		""
		"&a🛈 Tip: Search \"Insulate\" in EMI to find suitable items."
	]
	quest.2961B707783AC925.quest_desc: [
		"Once you're settled in with energy production, you should be quite comfortable upgrading your &7Goo&r to this tier."
		""
		"&a🛈 Tip: Higher tier Goos can do all of the lower tier’s recipes."
		""
		"&6⚠ Note: Goo is hungry and needs to be "
		"&6    fed to work! "
		""
		"&6    Right-Click with items to activate it."
		"&6    To find what items work, search "
		"&3    #goo_revive_tier_3&r&6 in EMI!"
	]
	quest.2A7455D9EE649BA4.quest_desc: [
		"Totemic Magic allows the intrepid sorcerer to create effects in an area and can produce some rather unique effects. "
		""
		"For example, the Rite of Sapping allows Dripstone to work more quickly, while the Rite of the Seas enhances one’s fishing abilities while standing in the area."
		"&n                                                             "
		""
		"Setting up a totem is a straightforward endeavor. Simply place a Runewood Totem Base and then place a number of Runewood logs atop it in a column. The number of logs required will depend on the specific ritual."
		""
		"Encoding the glyphs requires you to Right-Click the logs with the appropriate Spirit. "
		""
		"For the Rite of Sapping we would need four logs. Right-Click each log from top to bottom with &9Aqueous&r, &9Aqueous&r, &dArcane&r, and &5Eldritch&r. "
		""
		"Finally, Right-Click the base to activate the ritual."
		""
		"These rituals, once activated, require no maintenance nor upkeep. "
		""
		"Check the Encyclopedia Arcana for an in depth description of each rite and a list of the glyphs required to encode it. "
		""
		"Setting up Wicked Rites can be an excellent way to help farm more Spirits."
		""
		"&a🛈 Tip: A Totemic Staff will display a totem's "
		"&a    working area when held."
	]
	quest.2A7455D9EE649BA4.title: "Totemic Magic"
	quest.2AA352D00D86DCC3.quest_desc: [
		"With an &7Aerial Interface&r, you gain remote access to your own inventory. "
		""
		"This can be used to charge pneumatic equipment, auto stock or extract items, and even auto feed you or manage your XP. The sky's the limit!"
	]
	quest.2B0DDF8003305DB6.quest_desc: [
		"&7Transfer Labels&r slip between blocks to enable block-to-block transfer without a pipe. "
		""
		"Sneak + Right-Click to install one on the side of a block. Once installed, the label may be configured by Right-Clicking either with another label or with a &7Label Accessor&r. "
		""
		"While in the Configuration screen, you may add more labels to control the quantity and speed of transfer, as well as set filters."
		""
		"The label may be removed by Left-Clicking it with another label or with a &7Label Accessor&r."
	]
	quest.2B759D4770C13739.quest_desc: [
		"There’s a certain charm to hand-made objects, but for some things it’s best to relegate the task to a machine that can do the task more efficiently. "
		""
		"Like those &7Motors&r you’ve been manhandling. Do better."
	]
	quest.2BB91161DB6B6AF5.quest_desc: [
		"What, you thought you’d have to blow up a bunch of &7Iron&r to make yourself some &7Compressed Iron&r? "
		""
		"Just squish it really hard!"
	]
	quest.2C07E148B9B60809.quest_desc: [
		"The &7Thermopneumatic Processing Plant&r, or &7TPP&r, uses a combination of heat and pressure to process materials. "
		""
		"When placed side-by-side, they will share pressure, so keep this in mind if you need different requirements for different recipes. "
		""
		"Similarly, they’ll share heat in any direction, making it simple to heat an entire line of them for multiple recipes. "
	]
	quest.2C1538BE243F0CB4.quest_desc: [
		"So you’ve found a trait you’d like to have for yourself? You’ll need to infuse it into a Plasmid. "
		""
		"It only takes one Helix to set the type of a Plasmid. From there you can either use more of the same type to fill it up, or Basic Genes. Either is valid, though it will take more Basic Genes to fill it."
		""
		"&a🛈 Tip: Use Basic Genes to craft Empty "
		"&a    Plasmids rather than wasting useful "
		"&a    Genes on them."
	]
	quest.2C3B39CD6A7E044C.quest_desc: [
		"Andesite Alloy tier machines all run on &7Steam&r, which will need to be piped directly into the machine to power it. "
		""
		"Your &7Decrepit Boiler&r should produce enough for now, but you’ll soon be able to build a better boiler to generate the &7Steam&r you need to power more machines. "
	]
	quest.2C3B39CD6A7E044C.quest_subtitle: "Techonalogia!"
	quest.2CA1A8A7B84FAD71.quest_desc: [
		"Modular Routers is a catch all logistics mod capable of many things. "
		""
		"Check out the guidebook for more information on how to use it to your advantage!"
	]
	quest.2D55E211F5B4F0BF.quest_desc: ["A simple equipment charger that will top off any FE based equipment placed inside."]
	quest.2D755021F6490B86.quest_desc: [
		"Obtain your first &7Sourceberry&r by enchanting a &7Cloud Berry&r. "
		""
		"Be sure to plant the &7Sourceberry&r to grow more. The spells at your disposal should help tremendously with this task."
		""
		"&6⚠ Note: Use a Cutting Board to grind "
		"&6    Flour for Dough!"
	]
	quest.2F1EA0B091C700E1.quest_desc: [
		"The &7Fisherman Villager&r has some unusual fish to offer you, like the enigmatic &7Brown Shrooma&r. "
		""
		"You can convert these into &7Brown Mushrooms&r, perfect for making &7Dumplings&r!"
	]
	quest.2F1EA0B091C700E1.title: "Fisherman"
	quest.2F9C801DFAC1C0D9.quest_desc: [
		"Librarians will sell you everything you need to set up your own &7Storage Lectern&r to organize all of your goods. "
		""
		"The Codices they sell are also the &n&7only&r&r way to access new glyphs. "
		""
		"Each Codex will teach you a &n&7single random glyph&r&r that that isn't already known by you."
		""
		"&a🛈 Tip: Learning Glyphs increases your "
		"&a    mana, allowing you to cast more!"
	]
	quest.2F9C801DFAC1C0D9.title: "Storage Lectern"
	quest.2FEEB23C631857C3.quest_desc: [
		"Up this far, there’s no lack of space. However, it may be helpful to keep certain processes contained. "
		""
		"A &7Planarium&r may seem small, but it’s considerably bigger on the inside. As such, they can make an excellent place to put various farms and automations. "
		""
		"Sneak-Right click with an empty hand to enter. To leave, break the outer wall with any tool and you’ll be teleported back outside. "
		""
		"&a🛈 Tip: Right-clicking a Conjuration "
		"&a    Essence on a Diamond Block will "
		"&a    convert the local biome back to "
		"&a    the Planarium's Jar biome."
	]
	quest.304838EDEC32DE97.quest_desc: [
		"Thank you for playing &n&6Enigmatic Skies&r! We hope you enjoyed your time here!"
		""
		"                    &6&nFurther Reading&r"
		""
		"Inspiration comes from many sources and while there are some portions of this pack that draw on European traditions, it would be fair to say that the pack wouldn’t exist were it not for inspiration drawn from the myths and sacred stories of the native peoples of North America. "
		""
		"If you’re interested in learning more, please explore the following links:"
		""
		"&6&nNations&r"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://anishinabek.ca/\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Anishinaabe Nation\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.cherokee.org/\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Cherokee Nation\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.lenape-nation.org/\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Lenape Nation\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://ojibwe.net/stories/\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Ojibwe Nation\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.wendake.ca/\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Wendat Nation\",\"underlined\":true}]"
		""
		"&6&nStories&r"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://thecanadianencyclopedia.ca/en/article/turtle-island\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Turtle Island\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.indigenouspeople.net/spider.htm\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Grandmother Spider Steals the Fire\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.americanfolklore.net/rainbow-crow/\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Rainbow Crow\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.ganondagan.org/legend-of-the-three-sisters\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"The Three Sisters\",\"underlined\":true}]"
	]
	quest.305A56BDCBE2D2AE.quest_desc: [
		"The &7Settling Tank&r can filter &7Wastewater&r through &7Sand&r and &7Gravel&r to purify it, making it suitable for normal use. "
		""
		"As such, it can be a great way to supplement your &7Water&r production from the waste produced by your animals."
	]
	quest.307FEC610F0B542F.quest_desc: [
		"The Replicator itself essentially has two modes of operation. "
		""
		"In either mode, it will automatically drawn required materials from Tanks attached to the network."
		""
		""
		"&7&nInfinite Mode&r"
		""
		"To use this mode, simply place an item in the Infinite Mode slot. The Replicator will attempt to continually clone this item using material from the network. "
		""
		"This is generally best for things you’ll need a steady supply of. "
		""
		""
		"&7&nOn-Demand Mode&r"
		""
		"Any Replicator on the network that isn’t in Infinite Mode is available for On-Demand requests. Such requests are made at a Terminal and will automatically be balanced across available Replicators. "
		""
		"Making such a request will also require storing patterns on a Memory Chip."
		""
		"&6⚠ Note: Items with extra data, such as "
		"&6    batteries or inventories, will be"
		"&6    cloned empty."
	]
	quest.30FE41CF0C7F1270.quest_desc: [
		"Need a fuel boost? "
		""
		"&7Primal Coal&r burns 16 times longer than a log and can be produced quite easily in the &7Calcination Oven&r."
	]
	quest.3104ECE58D5CC796.quest_desc: [
		"The &7Pyromantic Brazier&r can be quite wasteful when used to power Theurgy devices, since it simply keeps burning as long as fuel remains. "
		""
		"Consider using a &7Mercury Catalyst&r instead. This device accepts &7Mercury Shards&r and converts them to Flux, storing it much like a battery. "
		""
		"A &7Caloric Flux Emitter&r may then be linked to a device and placed on a nearby &7Mercury Catalyst&r, allowing it to remotely send Flux to the linked device. "
		""
		"This will only consume Flux when the linked device is running, allowing it to operate much more efficiently. "
	]
	quest.31903F40C2037EBD.quest_desc: [
		"With a &7Trading Depot&r, you may begin to automate trades with &7Villagers&r. "
		""
		"Place the &7Depot&r such that the red dot on the back is facing the &7Villager’s Workstation&r. Then put some trade goods on the &7Depot&r.  "
		""
		"Items may be Right-Clicked on or off, but we want automation, right? So, use a hopper or some pipes to move items on and off the &7Depot&r. "
		""
		"The &7Depot&r only functions during normal Villager Working hours. So be sure you're stocking up on the things they want overnight to maximize the trading you can get done in the day."
		""
		"&a🛈 Tip: A filter may be set on the front "
		"&a    to control what is purchased. "
	]
	quest.319FD618D4608068.quest_desc: [
		"The &7Blazing Archwoods&r on this island will already have a few &7Bombegranate&r grown on them. "
		""
		"Gather a few and consider setting up a farm when you can; they grow when placed on a &7Blazing Archwood Log&r and can be sped up by applying &7Bone Meal&r or other grow effects. "
		""
		"&a🛈 Tip: Harvest Rituals can be an easy "
		"&a    way to farm these fruit!"
	]
	quest.31CAA3BC20CCDF25.quest_desc: [
		"Need a little more room to work? Summoning another island is always an option. "
		""
		"Alternatively, Right-Click a &7Blackstone&r with a &7Fire Essence&r to convert a &n21x11x21&r area to this biome!"
	]
	quest.31CAA3BC20CCDF25.title: "Biome Conversion"
	quest.31FAEA42AC32BD3E.quest_desc: ["This charger boasts an enormous buffer that can be used to rapidly charge items. "]
	quest.32305BE195F77F2F.quest_desc: [
		"Before heading out, you’ll need to start producing some Source as well; each of the following rituals will need a full &7Source Jar&r to activate."
		""
		"Purchase a &7Mycelial Sourcelink&r from &7Farmer Villager&r and use it to turn excess food directly into delectable Source. "
		""
		"&a🛈 Tip: Place your food into an  "
		"&a    adjacent Arcane Pedestal!"
	]
	quest.323D480E3C37579E.quest_desc: [
		"The &7Cascading Archwoods&r on this island will already have a few &7Frostaya&r grown on them. "
		""
		"Gather a few and consider setting up a farm when you can; they grow when placed on a &7Cascading Archwood Log&r and can be sped up by applying &7Bone Meal&r or other grow effects. "
		""
		"&a🛈 Tip: Harvest Rituals can be an easy "
		"&a    way to farm these fruit!"
	]
	quest.3263757C9A240C70.quest_desc: [
		"Chipped offers a multitude of block variants to fit your every decorative need. The Workbenches themselves are equally lovely and can spruce up your interiors quite easily."
		""
		"If you’d like to work on the go, the mod also offers a variety of handheld tools that work exactly like a placed Workstation."
		""
		"Workstation variants are aesthetic only. They can all make any Chipped block, so pick your favorite!"
		""
		"&a🛈 Tip: Search &3@chipped&r &ain EMI to "
		"&a    discover more."
	]
	quest.3263757C9A240C70.title: "Chipped"
	quest.3282293AB6B43287.quest_desc: [
		"Slow but steady, this &7Compressor&r will get you started making &7Compressed Iron&r and &7Diamonds&r. "
		""
		"It's also a simple way to make plates going forward."
		""
		"&a🛈 Tip: Remember to lock the slots to "
		"&a    control what recipe is processed!"
	]
	quest.33679351A7B6D8E6.quest_desc: [
		"Being able to place and pick up blocks automatically will help with getting some early tasks automated. "
		""
		"Here on the Flourishing Island, &7Tuff&r may be summoned with the same spell you've previously used to obtain &7Icestone&r. It can be turned into some basic devices that will be useful for automation."
		""
		"                           &6&nExample Spells&r"
		""
		"&7Conjure Tuff&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r"
	]
	quest.3456EED039818662.quest_desc: [
		"The &7Quantum Bridge&r is a multiblock used for expanding your network cross-dimensionally. It consists of a ring of eight &7Quantum Rings&r and a &7Quantum Link Chamber&r set in the center."
		""
		"In most cases, you’ll need one at both ends with a linked pair of &7Entangled Singularities&r in each. However, there exists the very handy &7Quantum Bridge Card&r which may be installed in your &7Wireless Terminal&r, allowing it to link up to a &7Quantum Bridge&r as well. "
		""
		"This means infinite cross-dimensional access to your home network at the tips of your fingers!"
		""
		"&a🛈 Tip: Name your Entangled "
		"&a    Singularities to help you remember "
		"&a    which ones go where."
	]
	quest.3456EED039818662.title: "Quantum Bridge"
	quest.34F48A8F71A7C937.quest_desc: [
		"&7Ender Crates&r represent an upgrade over Ender Chests. Not only can they be accessed by automation and logistics, but they can also be separated into multiple channels based on their name."
		""
		"To set a channel, place the &7Crate&r in an &7Anvil&r with an &7Eye of Ender&r, then set a name. The name becomes the channel and any other &7Crate&r with the same name will share the same inventory."
		""
		"Additionally, an &7Ender Ocular&r may be used to remotely access the &7Ender Crate&r. Rename it the same way as the &7Crate&r to set the channel. "
	]
	quest.34FB10F0A2504973.quest_desc: [
		"Buy a &7Loom&r to gain access to a &7Shepherd Villager&r. "
		""
		"You won’t be able to afford much yet but be sure to buy yourself a &7Tablet of Conjure Island: Lush Garden&r."
	]
	quest.34FB10F0A2504973.title: "Shepherd"
	quest.359562022532BAE1.quest_desc: [
		"Spirit Infusion is used to enhance items and materials, granting them greater potency. "
		"&n                                                  &r"
		""
		"When viewing Spirit Altar recipes in EMI, the central item and the Spirits shown to the left should be insterted onto the Altar itself. "
		""
		"Any items shown on the right must be instered into a nearby Item Pedestal or Item Stand. "
		""
		"Items may be piped into the these blocks, or otherwise Right-Clicked into place when crafting by hand."
		""
		"&6⚠ Note: Item Stands and Pedestals "
		"&6    must be within four blocks of "
		"&6    the Altar."
	]
	quest.359A7C9127500D6C.quest_desc: ["A simple &7Furnace&r, despite the cold, should protect that precious heat well enough to get started."]
	quest.35A8CEA408114638.quest_desc: [
		"As mentioned, Aura is a finite resource that must be maintained. "
		""
		"Fortunately, there are multiple generators available for doing so. "
		""
		"Each has its advantages and disadvantages and each uses unique inputs to operate. Typically speaking, the easier it is to obtain the inputs, the less Aura they’ll generate. "
		""
		"For some high output options, take a look at the &2Shooting Mark&r, &2Firecracker Gaze&r, or &2Lingering Absorber&r. "
		""
		"If you just need a little Aura for a small contraption, you might be fine with an &2Herbivorous Absorber&r or &2Swamp Homi&r."
		""
		"All of these are detailed in the &7Book of Natural Aura&r, so be sure to refer to their entries for specific information on setting them up.  "
	]
	quest.35FD905A4A4EB1F5.quest_desc: [
		"Pretty Pipes: Fluids is an addon to Pretty Pipes which allows the network to carry fluids in addition to items. The same network will effectively carry both, allowing everything to flow through a single block space. "
		""
		"&7Fluid Pipes&r are therefore only required at the end points where the pipes connect to a fluid tank. "
		""
		"Like Pretty Pipes, this addon includes &7Extraction&r and &7Retrieval Modules&r for getting fluids into and out of tanks. It also features a suite of filters and works with the Pretty Pipes priority system. "
	]
	quest.363AB8EC195285BE.quest_desc: ["&7Sludge Refiners&r sort all the gunk fed into them to create more useful materials, such as &7Soul Sand&r, &7Clay&r, and &7Rich Soil&r. "]
	quest.369D0F2CC8D028D2.quest_desc: [
		"The &7Spirit Crucible&r may be further augmented by placing up to four &7Augments&r on it and one &7Core Augment&r. Each nearby &7Catalyzer&r may be similarly augmented with a single &7Augment&r of your choosing."
		""
		"The same augment may be used more than once, however it may be best to mix and match them to achieve the desired results. "
		""
		"Holding a &7Tuning Fork&r in your hand will display the total effect of all installed augments. "
		""
		"Right-Clicking the &7Crucible&r with the &7Tuning Fork&r will also allow you to select one modifier that will receive an even greater boost."
	]
	quest.36A18D327A03810B.quest_desc: [
		"The &7Weeping Well&r has been generous with you, you have only one last thing to give it; yourself."
		""
		"Trust it. Jump in. "
		"&n                                                  &r"
		""
		"By jumping into the Well, you will receive an &7Umbral Spirit&r. "
		""
		"If you've lost yours, or simply need more, you can recreate it with some effort in the &7Particle Accelerator&r. "
	]
	quest.36A482587B5E89F7.quest_desc: [
		"Infused with brilliant light, these blocks are favored by &7Alakarkinos&r for their beauty. They’ll produce even more &7Dorodangos&r from each block! "
		""
		"Well worth the extra energy costs, to be sure. "
	]
	quest.36A482587B5E89F7.quest_subtitle: "Dorodango Unchained"
	quest.36BCEB3B27822AD1.quest_desc: [
		"These curious gems seem barely capable of holding their own form. "
		""
		"When paired with certain other items, they'll immediately assume the new form and stabilize. "
		""
		"Most device upgrades can be duplicated in this way."
	]
	quest.3753A3EB1909F923.quest_desc: [
		"Made from &7Salt&r, &7Briny Dorodangos&r may be processed down into new materials!"
		""
		"                   &n&6Materials&r"
		""
		"  • &7Lapis Lazuli&r"
		"  • &7Certus Quartz Crystals&r"
		"  • &7Neptunium Nuggets&r"
	]
	quest.37AA9E6270DB015A.quest_desc: [
		"This is a multiblock structure comprised of a central &7Empowerer&r and four &7Display Stands&r. "
		""
		"Each &7Display Stand&r must be placed three blocks away from the &7Empowerer&r in each of the cardinal directions. "
		""
		"When crafting, the central item in the recipe goes on the &7Empowerer&r while the other four items are placed in any order on the surrounding &7Display Stands&r. "
		""
		"Energy must be provided to each of the four &7Display Stands&r. "
	]
	quest.37C965C1FA40221E.quest_desc: [
		"&7Spell Turrets&r can be an incredibly powerful automation tool for casting prepared spells. "
		""
		"There are some limitations, of course, since the &7Spell Turret&r cannot use every spell form; primarily Touch and Projectile. Still, being able to trigger a spell cast on a &7Redstone&r signal is invaluable."
		""
		"The &7Turret&r may be programmed by simply Right-Clicking it with your &7Spell Book&r, a &7Caster Tome&r, or a &7Spell Parchment&r. "
		""
		"They may uses glyphs such as &7Item Pickup&r and &7Place Block&r provided they have an inventory adjacent to send to or pull from. "
		""
		"They also need a &7Source Jar&r somewhere nearby to power them."
		""
		"Try setting your &5Brawndo&r spell on a &7Turret&r and shooting a &7Cloud Berry Bush&r."
	]
	quest.37DF459B5B6E6221.quest_desc: [
		"&7Logistics Frames&r allow you to transfer items and fluids over a Tube network. "
		""
		"Due to their highly customizable nature, these can be a great way to link up machines to run passively and keep stock of key items."
		""
		"For example, you might have multiple different tanks of fluids and a bunch of chests with items attached to a network using &7Storage Frames&r. Then at each machine, have &7Requester Frames&r pulling the exact items and fluids that machine needs for a given craft. "
		""
		"The results of the craft can similarly be returned to storage by way of an &7Active Provider Frame&r, or simply left in the machine and requested by the next machine. "
	]
	quest.37ED5A328F30DD34.quest_desc: [
		"Creating monsters is no small feat and we’re going to need some very specific materials to pull it off. "
		""
		"We’ll start with something easy, slimes. We can lean on the latent magic in certain foods to get the process going, though it's still going to need an extra nudge."
		""
		"Gather some &7Spirits of Birthing&r by manually breeding animals in a high Aura environment. "
		""
		"Once you've animated your slimes, be sure to slay them with a &7Scythe&r or other &7Soul Shattering Weapon&r to properly harvest their &7Spirits&r."
		""
		"&6⚠ Note: It is sufficient to harm the mob with "
		"&6    a &oSoul Shattering Weapon&r &6or &oGlyph of Soul&r "
		"&6    &oShatter&r&6; the killing blow can come from "
		"&6    another weapon."
		""
		"&a🛈 Tip: Apply Spirit Plunder to your weapon to "
		"&a    obtain more Spirits!"
	]
	quest.3895E1D9DE518B3F.quest_desc: [
		"Casting all these spells will take its toll on your mana bar, especially if you’re trying to use a &7Spell Book&r as your primary mining tool"
		""
		"To help replenish your mana faster, consider crafting a &7Jar of Voiding&r. These handy devices will eat items you pick up and convert them directly into mana. "
		""
		"To set an item it is allowed to eat, place that item in your offhand and Right-Click with the &7Jar&r. "
		""
		"Consider adding things like &7Cobble&r and other &7Stones&r to it."
		""
		"&a🛈 Tip: The Jar can be toggled at any "
		"&a    time by Sneak + Right-Clicking with it. "
	]
	quest.38E929DADF66C1F3.quest_desc: [
		"Made from &7Mud&r, &7Boggy Dorodangos&r may be processed down into new materials!"
		""
		"                   &n&6Materials&r"
		""
		"  • &7Black Quartz&r"
		"  • &7Fish Bones&r"
		"  • &7Rotten Flesh&r"
	]
	quest.3954AC8D791145CE.quest_desc: ["Wandering Trader keeps ding-dong-ditching your house? Let this say hello instead!"]
	quest.39716C901B98BAF2.quest_desc: [
		"This workstation allows the &7Wixie&r to craft &7Stonecutter&r recipes. "
		""
		"                   &6&nFormation&r"
		""
		"Right-Click a &7Stonecutter&r with a &7Wixie Charm&r."
		""
		"&6⚠ Note: For multi-step crafts, each "
		"&6    step must be specified separately."
	]
	quest.39716C901B98BAF2.title: "Wixie Stonecutting"
	quest.398AE848C969FCEF.quest_desc: [
		"An enigmatic material that looks solid enough but feels as light as air. "
		""
		"Procuring it will involve condensing enormous quantities of air at high pressure into &7Liquid Air&r. "
		""
		"Generating Compressed Air in sufficient volumes with only a &7Thermal Compressor&r will likely prove daunting. Consider something with a bit more power, such as the &7Electrostatic Compressor&r. "
	]
	quest.39BCDF29A792B723.quest_desc: [
		"An Aura Cache acts as a personal battery for recharging Aura Using tools and armor. "
		""
		"This includes anything enchanted with Nature’s Mend and all armor and tools from Nature’s Aura. To repair this equipment, simply Sneak while holding the tool or wearing the armor. "
		""
		"The Cache can be filled in a Natural Altar, or if Aura is exceptionally high in an area, will fill passively while worn. "
	]
	quest.39E9D5470F347400.quest_desc: [
		"Raw Gold, Copper, and Iron can contain some very useful secondary minerals, obtainable with just a little bit of extra processing. "
		""
		"Craft an &7Alluvial Trommel&r and process your Crushed Ores to obtain &7Wastewater&r. "
		""
		"This may then be recycled into fresh &7Water&r and a variety of other blocks. "
		""
		"&a🛈 Tip: Remember to lock the slots to "
		"&a    control what recipe is processed!"
	]
	quest.3A078285904792A2.quest_desc: [
		"Simple item pipes for moving things around. "
		""
		"They can be filtered and accept Motors as upgrades to speed them up."
	]
	quest.3A0F43654CE474DA.quest_desc: [
		"Tree-hugging woodland spirits, &7Whirlisprigs&r will gladly join your menagerie if you show them some love and plant a tree nearby. "
		""
		"In exchange, the &7Whirlisprig&r will help you grow and farm plants. "
		"&n                                                  &r"
		""
		"Right-Click any flower with her charm to create their home. Placing more plants and a greater variety of plants in their home will make them happier and more productive. "
	]
	quest.3A7AD25302240A1B.quest_desc: [
		"Ad-Hoc Networks are the simplest form of network in Applied Energistic; they consist of a length of &7Fluix Cable&r and some connected devices such as &7Storage Buses&r and &7Terminals&r."
		""
		"The system will need some power too, which can be provided passively by a &7Crystal Resonance Generator&r, or more actively with an &7Energy Acceptor&r."
		"&n                                                            "
		""
		"Set up a simple Ad-Hoc Network using the items you’ve gathered and the rewards from this quest. "
		""
		"1. Place a &7Storage Bus&r against each &7Barrel&r and "
		"   connect them all with &7Fluix Cables&r. "
		""
		"2. Place the &7Crafting Terminal&r anywhere on the "
		"   &7Fluix Cables&r."
		""
		"3. Finally, attach your preferred source of "
		"   power. "
		""
		"If done correctly, you should now have access to the contents of all six &7Barrels&r and be able to craft using their contents at the &7Terminal&r."
		""
		"&6⚠ Note: An Ad-Hoc Network can have up to eight"
		"&6    connections in total."
	]
	quest.3A7AD25302240A1B.title: "Ad-Hoc Networks"
	quest.3B609B8A4DE93B53.quest_desc: [
		"Build a &7Melon&r farm and set your Alakarkinos to work making &7Melon Balls&r!"
		""
		"These will net you far more water than the clouds you've been using."
	]
	quest.3B77FB0A8CFAAB97.quest_desc: [
		"Potentially quite dangerous, &7Enderic Lasers&r will destroy most any blocks in their path. Some, however, are instead empowered by it."
		""
		"Use a &7Target Designator&r to aim an Enderic Laser at an &7Atomic Forge&r to deliver the power it needs to operate."
		"&n                                                 &r"
		""
		"To target a block, Sneak + Right-Click it with the &7Target Designator&r, then Sneak + Right-Click the &7Laser&r. "
	]
	quest.3BBFA042D4C4EA4E.quest_desc: [
		"&7Processing Arrays&r allow you to turn any single block Modern Industrialization machine into a batch processing multi-block powerhouse. "
		""
		"Simply build the structure, then insert one or more of the single block machines in the GUI. The exact number of machines you can insert will depend on the size of the &7Processing Array&r from 8 to 64. "
		""
		"Finally, to process recipes, ensure you have the appropriate hatches installed in the &7Array&r and supply the materials."
	]
	quest.3BCD9E36D48B205A.quest_desc: [
		"Piece together an &7LV Steam Turbine&r to begin producing electric power. "
		""
		"Be sure to grab some &7LV Cables&r from your Villagers too!"
		""
		"&a🛈 Tip: EU converts directly to FE!"
	]
	quest.3BF1CB7CDDA99856.quest_desc: [
		"Working with spirits is a messy business, both physically and mentally. "
		""
		"You’ll need proper materials to have any hope of mastering this magic, and that all starts with Soulstone. "
		""
		"We’ll learn ways to further refine this later. "
	]
	quest.3BF458796782EB49.quest_desc: [
		"The &7Cybernetics Station&r allows you to research and install various bio-mechanical enhancements into your body to provide you with permanent buffs and new abilities. "
		""
		"These abilities vary from the more mundane, such as Step Assist, to the fantastic such as built in Armor, Invisibility, and even Flight. "
		""
		"Unlike other Oritech machines, this one will not function without an appropriate upgrade installed. "
		""
		"There are three in total which can be installed on the sides and back of the &7Augmentation Center&r. "
		""
		"To get started, you’ll need to craft and install the &7Cybernetic Research Station&r. Later upgrades will require higher-tier &7Research Stations&r."
		" "
	]
	quest.3C4305830D6978C5.quest_desc: [
		"Looking for an upgrade to your mining?"
		""
		"A Pneumatic Jackhammer is an all-in-one mining tool with the ability to mine out large areas with ease. "
		""
		"It can even hot-swap enchantments by inserting either a Fortune or Silk Touch book in the inventory."
		""
		"&a🛈 Tip: An Air Canister Array acts as "
		"&a    a portable air battery, keeping "
		"&a    your tools running longer!"
	]
	quest.3C50D5FE5FA787A9.quest_desc: ["For when you just need a big fracking gun to tell the monster hordes who’s boss. "]
	quest.3C905ECF6E0A543E.quest_desc: [
		"Burning with the heat of the hells themselves, Blaze Ember may be processed into a potent fuel to ramp up your power production."
		""
		"The Fuel is also vital to the production of Steel, which will open numerous doors for you."
	]
	quest.3CA4472228D0F866.quest_desc: [
		"By adding an &7ME Controller&r to a network, we gain access to far more channels; 32 per side, in fact. "
		""
		"It doesn’t stop there, either. Multiple &7ME Controllers&r can be built together to form a larger multiblock structure with each exposed face giving you 32 more channels to work with. "
		""
		"Building such a multiblock must follow these rules:"
		""
		"  1. All controller blocks on a "
		"     network must be connected"
		""
		"  2. The total size cannot exceed "
		"     7x7x7"
		""
		"  3. A controller can have two "
		"     adjacent blocks in at most 1 axis"
		""
		"The &7AE Guide&r goes into greater technical details for those interested and includes helpful images!"
		""
		"&a🛈 Tip: Use an ME Network Analyzer to "
		"&a    debug channels on your network!"
	]
	quest.3CA4472228D0F866.title: "ME Networks"
	quest.3CBA1384BD3D28ED.quest_desc: [
		"This workstation allows the &7Wixie&r to craft &7Furnace&r recipes. "
		""
		"                   &6&nFormation&r"
		""
		"Right-Click a &7Furnace&r with a &7Wixie Charm&r."
		""
		"&6⚠ Note: For multi-step crafts, each "
		"&6    step must be specified separately."
	]
	quest.3CBA1384BD3D28ED.title: "Wixie Smelting"
	quest.3CC1C6949E17A1B9.quest_desc: [
		"Simple and reliable, the &7Liquid Compressor&r is suitable for running basic PneumaticCraft machines up to &75 bar&r. "
		"&n                                                  &r"
		""
		"Machines and Tubes will burst if over pressurized! Avoid this by disabling the Compressor when it’s nearly full. "
		""
		"[\"Refer to the \",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://wiki.enigmatica.net/enigmatica6/gameplay/how-to.../pneumaticcraft-safe-compressor-usage#compressing-air-and-basic-control\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Safe Compressor Usage\",\"underlined\":true},\" article on our wiki for more information.\"]"
	]
	quest.3CC1C6949E17A1B9.quest_subtitle: "Basic Pressure"
	quest.3D1D6D17B2900DF0.quest_desc: [
		"Animate a &7Magma Slime&r and defeat it to obtain &7Infernal Spirits&r."
		""
		"&6⚠ Note: The Ritual Item is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.3D1D6D17B2900DF0.title: "Infernal Spirit"
	quest.3D59639F51E89CF9.quest_desc: [
		"The &7Advanced Clicker&r gets an area upgrade over its Simple counterpart, allowing it to interact with things in a larger area. "
		""
		"&a🛈 Tip: Use the Render Area button to "
		"&a    easily configure the working area."
	]
	quest.3D6441ECF951BAD4.quest_desc: [
		"This incredibly cold fluid holds some mystical capabilities that may be used to augment certain Industrial Foregoing machines."
		""
		"  • Auto-harvesting in &7Hydroponic Beds&r"
		"  • Gentle-harvesting in the &7Plant Gatherer&r"
		""
		"It's also a vital component for more advanced machinery!"
	]
	quest.3D76C219EB7EEC03.quest_desc: [
		"A simple device for placing blocks in an area. It will pull blocks from an inventory above it and place them atop the specified block. "
		""
		"Specify a block to place on by putting it in an &7Item Frame&r attached to the &7Builder&r. "
	]
	quest.3D7B773741D78864.quest_desc: [
		"Harvesting edible meat from &7Wilden&r is a task that requires both skill and focus; one slip and the meat may be fouled by the cursed magic flowing through them."
		""
		"Such a delicate process can only be completed with a &7Knife&r. "
		""
		"By placing the &7Knife&r in an &7Arcane Pedestal&r next to a &7Drygmy Henge&r, they will be able to harvest the &7Meat&r for you."
	]
	quest.3D7B773741D78864.title: "Wilden Meat"
	quest.3DD21FD2F10FE43D.quest_desc: [
		"Primarily used to make &7Rubber Sheets&r, &7Latex&r is also used in its raw form for a variety of recipes. "
		""
		"You’ll want to spend some time figuring out a way to automate production. "
	]
	quest.3DE69E7B1359D76D.quest_desc: [
		"This metal resonates with the endless possibilities of the void. "
		""
		"It feels lightweight but resists sudden changes in momentum as if it were incredibly dense or being dragged through a thick fluid…"
	]
	quest.3E7A4470BD04F2A1.quest_desc: [
		"The &7Simple Sensor&r is an all purpose block and entity sensor that emits a signal according to its settings. "
		""
		"Drag an item or block from EMI to the filter slot in the middle. Right-Click blocks in the filter to configure states such as waterlogged."
		""
		"For filtering entities, use that creature’s Spawn Egg and for fluids, use a bucket of that fluid."
	]
	quest.3EA53BBEBC32F813.quest_desc: [
		"Welcome to Genetics: Resequenced!"
		""
		"This mod is all about gaining special powers, for yourself and other mobs. "
		""
		"Ever wanted to shear meat off a pig? Milk a chicken? Eat grass like a sheep? How about feed yourself directly through the power of photosynthesis?"
		""
		"Well now you can!"
		""
		"These quests will walk you through the basics of using the mod. From there it’ll be up to you to put it to use, for good or ill."
		""
		"[\"Be sure to check out their online \",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://github.com/aaronhowser1/Genetics-Resequenced/wiki\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Wiki\",\"underlined\":true},\" which is an excellent source of supplemental information.\"]"
	]
	quest.3EA53BBEBC32F813.title: "Genetics: Resequenced"
	quest.3EA705A9C893F04A.quest_desc: [
		"Modern Industrialization’s &7Boilers&r and &7Turbines&r are the basis for most electricity that you’ll be producing, be it FE or EU. "
		""
		"EU converts to FE at a one-to-one ratio and Modern Industrialization’s &7Cables&r will do that conversion for you themselves, meaning you can run them straight to any FE consuming machine to power it."
		""
		"                       &n&6A Note on Power Tiers&r&r"
		""
		"Modern Industrialization’s power tiers have two primary limitations that are worth keeping in mind."
		""
		"First, they limit the amount of power they can transfer across a given network of cables. It can therefore be useful to combine lower tier networks into a higher tier trunk line by using &7Transformers&r. For example, a cluster of eight &7LV Turbines&r will max out the transfer rate of an LV cable network. But that could be converted up to MV, allowing up to four of those clusters to power an MV cable network."
		""
		"Second, the cable tier affects the tier of EU machine they can connect to; an &7Energetic Cable (HV)&r simply won’t connect to a machine that isn’t HV tier and existing connections are dropped should the machine's tier change. Therefore, if you’re running a higher tier trunk line, you will need to use a &7Transformer&r to bring the tier down for the machine. This isn’t a concern for FE machines and they can be connected to any tier of EU cable."
		""
		"                           &n&6A Note on FE&r&r"
		""
		"So, how do you know what uses FE? A lot of mods, really. They just like to rename it to something different. In this pack, only Modern Industrialization and its addons use EU. Anything else that uses some form of electricity is using FE under the hood."
	]
	quest.3ED6754FC6B0A36D.quest_desc: [
		"The tools added by Just Dire Things have a variety of interesting properties which can be attached to them; simply craft the tool and the upgrade together in a &7Smithing Table&r."
		""
		"Once installed, each can be enabled, disabled, or otherwise configured by Sneak Right-Clicking while holding the tool. "
		""
		"Most of these work automatically when enabled. However others, like Lawnmower, are activated on Right-Click."
		""
		"The following pages will cover what each ability does. "
		""
		"&a🛈 Tip: To see which abilities a tool has,"
		"&a    hold Shift while hovering over it"
		"&a    in EMI. "
		"{@pagebreak}"
		"&7&nWeapon Abilities"
		""
		"Available on Swords and Paxels."
		""
		" • &aAuto Smoker&r: Cooks drops."
		" • &aCauterize Wounds&r: Self-Heal at the "
		"   cost of durability/energy."
		" • &aMob X-Ray&r: Highlights nearby mobs."
		""
		"&7&nMiscellaneous Abilities"
		""
		"Available on several tool types."
		""
		" • &aDrops Teleporter&r: Teleports drops "
		"   to a bound inventory."
		" • &aLava Repair&r: Repairs when dropped "
		"   in Lava, converting the Lava to "
		"   Obsidian."
		" • &aHammer&r: AoE mining starting at 3x3. "
		"   Increase with tier."
		" • &aAuto Smelter&r: Smelts mined blocks."
		" • &aInstant Break&r: Yep."
		"{@pagebreak}"
		"&7&nPickaxe Abilities"
		""
		"Available on both Pickaxes and Paxels."
		""
		" • &aOre Miner&r: Mines all connected ore."
		""
		"&7&nShovel Abilities"
		""
		"Available on both Shovels and Paxels."
		""
		" • &aLawnmower&r: Instantly breaks nearby"
		"   grass and flowers."
		""
		"&7&nAxe Abilities"
		""
		"Available on both Axes and Paxels."
		""
		" • &aTree Feller&r: Breaks logs in an area."
		" • &aLeaf Breaker&r: Instantly breaks "
		"   leaves in an area."
		"{@pagebreak}"
		"&7&nHoe Abilities"
		""
		"Hoes behave a little differently from other tools in that their special ability is to create new farmland types."
		""
		"These farmlands all have the following abilities: "
		""
		" • Immune to trampling."
		" • Boost crop growth."
		" • Auto-harvest and replant. "
		""
		"For Hoes with the Drops Teleporter ability, auto-harvest drops will go to whatever inventory the Hoe was bound to at the time of tilling. "
	]
	quest.3ED6754FC6B0A36D.title: "Just Dire Tools"
	quest.3F021EBB71F4BC70.quest_desc: [
		"&7Smart Cables&r are identical to their covered counterparts, with one small addition: they display the number of channels passing through them directly on their surface."
		""
		"These are an excellent way to help you keep track of the number of channels in use, as you can visually trace back where they’re coming from. "
	]
	quest.3F20E7D7E1C07311.quest_desc: [
		"Give this little guy a pail, a shovel, and a little snack and it’ll happily get to work for you. "
		"&n                                                  &r"
		""
		"Right-Click the &7Alakarkinos Charm&r to place it in-world, then use a &7Wand of Dominion&r to link it to any nearby inventory. "
		""
		"Alakarkinos will consume Source from nearby &7Source Jars&r to convert different blocks into &7Dorodangos&r. "
		""
		"The resulting &7Dorodangos&r may then be processed down into other key items, like &7Water&r, &7Lava&r, &7Black Quartz&r, and more!"
	]
	quest.3F20E7D7E1C07311.title: "They See Me Ballin'"
	quest.3FF6566453299DC1.quest_desc: [
		"Applied Energistics is the ultimate storage and logistics solution. Not only does it store items and fluids, but it acts as a controller for external machines by way of its auto crafting system. "
		""
		"[\"Read more about this system in the dedicated \",{\"clickEvent\":{ \"action\": \"change_page\", \"value\": \"7D82585D50D7207A\" },\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\": \"Applied Energistics\",\"underlined\":true},\" chapter. \"]"
	]
	quest.3FF8D40CD4CB33BB.quest_desc: [
		"Looking for a simple unbreakable tool? These will have you covered. "
		""
		"They need power but can accept enchantments, making them a great alternative to normal tools. "
	]
	quest.3FF8D40CD4CB33BB.title: "Power Tools"
	quest.410225ED927857D4.quest_desc: [
		"These three machines can be put together to farm passive mobs automatically. "
		""
		"First, the &7Animal Feeder&r will keep your animals fed, happy, and making babies. This will stop working automatically when there are too many animals in the working area. "
		""
		"The &7Animal Rancher&r can be used in the same area to gather Wool from Sheep and Milk from Cows. "
		""
		"The &7Animal Baby Separator&r can then be used to send the babies to a holding area while they grow up. This block also has a reverse mode to separate the grown animals out from the baby holding area and into their final destination."
		""
		"&a🛈 Tip: Install matching Range Addons "
		"&a    in each to cover the appropriate "
		"&a    area."
	]
	quest.410225ED927857D4.title: "Animal Farming"
	quest.414458433C4734C6.quest_desc: [
		"When the woman returned to the Earth, she looked around to see that life was flourishing in the new cycle. The animals, once her teachers and companions, had multiplied and spread across the land. "
		""
		"The world was blooming, but the woman felt alone again. She had learned much but now had no one with whom to share her knowledge. "
		""
		"With her hands she dug into the damp earth, molding the clay there into her likeness. With the heat of her fire, she hardened the clay. With the breath in her lungs, she breathed life into the clay. "
		""
		"With the words in her heart, she taught the new people of the animals and the land. Taught them to hunt and to tend, to plant and to harvest. She taught them to nurture the fires, to create."
	]
	quest.41614A924E5556EE.quest_desc: [
		"Welcome to Ars Nouveau!"
		""
		"This exciting mod will fulfil your every magical fantasy, from casting spells to brewing potions. "
		""
		"Summon magical creatures and craft magical gadgets to automagically perform nearly any task around your home!"
		""
		"Ars Nouveau also has a number of add-on mods which bring many new mechanics and features. "
		""
		"These quests can't cover everything, but the guidebook should help with anything not covered here."
		""
		"&a🛈 Tip: Sourceberries can be planted "
		"&a    on grass!"
	]
	quest.41614A924E5556EE.title: "Ars Nouveau"
	quest.427846D4FFE678C5.quest_desc: [
		"Ancient stories tell of warriors who would consume these &7Shards&r before battle to enhance their vitality and ensure their safe return."
		""
		"Perhaps it will also be accepted as a suitable sacrifice for the steps to come."
		""
		"&a🛈 Tip: Eating Life Shards will increase "
		"&a    your max health by one Heart each!"
	]
	quest.42A899B5E25F6124.quest_desc: [
		"Channeling the most powerful magics requires a highly specialized focus. "
		""
		"Upgrade your &7Spell Book&r with the materials you’ve discovered here and on other islands to unlock your true spell casting capabilities."
		""
		"&a🛈 Tip: Spells and are retained when "
		"&a    upgrading your Spell Book!"
	]
	quest.42A899B5E25F6124.title: "Tier 3 Spells"
	quest.42F2191B5C08849B.quest_desc: [
		"Summon a &7Bat&r at the Altar of Birthing and gather some &7Organic Matter&r from it."
		""
		"&6⚠ Note: The Spawn Egg is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
		""
		"&a🛈 Tip: Consider making an enclosure to "
		"&a    contain your bats!"
	]
	quest.42F2191B5C08849B.title: "Bat"
	quest.43580B4D15FCEF00.quest_desc: [
		"A bit of slicing and splicing will get us what we need. Prepare the required items for the ritual and create your very own &7Whirlisprig&r. "
		""
		"To earn a &7Token&r of its trust, grow any sapling nearby."
		""
		"&6⚠ Note: The Ritual Item is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.4421EB35235888DF.quest_desc: ["Welcome to Nature's Aura! "]
	quest.4421EB35235888DF.title: "Nature's Aura"
	quest.4457D6BB7AE28073.quest_desc: [
		"The mod doesn’t offer any form of power conduit, but it does offer the next best thing: wireless energy."
		""
		"The &7Energy Transmitter&r can be used to power every block in a small area. "
		""
		"Use the Render Area button to help align the work area to cover your machines."
	]
	quest.44BD4C393C59F1CB.quest_desc: [
		"The &7Discovery&r questline's purpose is to show what's available in the pack."
		""
		"These chapters are a great place to start if you're new to modded Minecraft or if you're in the need for inspiration."
	]
	quest.44BD4C393C59F1CB.title: "Discovering Enigmatica"
	quest.453240979BB90EBD.quest_desc: [
		"The Mercurial Logistics system is a simple network for moving Items and Fluids."
		""
		"The &7Inserters&r and &7Extractors&r can be placed against machines or other inventories and then linked up with &7Mercurial Wire&r. "
		""
		"&7Mercurial Connection Nodes&r allow multiple wires to come together to form a broader network, as well as to extend the reach of individual wires."
		""
		"Things will only get more complicated from here, so be sure to spend some time automating what you can."
		""
		"&a🛈 Tip: Try to keep your wires isolated to loaded chunks. "
	]
	quest.453240979BB90EBD.title: "Mercurial Networks"
	quest.4537806144939A6B.quest_desc: [
		"An animate block of Amethyst, these golems will automatically create, grow, and harvest &7Budding Amethyst&r blocks. "
		""
		"Bind them to an inventory to set the area they’ll work in. Nearby blocks will be converted into budding blocks. As they grow buds, they’ll break them and collect the drops, storing them in their bound inventory."
	]
	quest.454EB146FC67E3D5.quest_desc: [
		"Who knew accelerating objects to near relativistic speeds and smashing them together could be so lucrative?"
		""
		"The &7Particle Accelerator&r consists of a large free form multiblock structure. The &7Accelerator&r itself is used to inject items into the beam and the &7Guide Rings&r are used to guide the beam along the desired path. "
		""
		"Typically, this path should be a loop to gain the momentum needed for various crafts. "
		""
		"Speeding up the particle will require one or more &7Linear Motors&r. As the input item crosses a powered &7Motor&r, it will consume &640 * Current Speed FE&r to accelerate by &61J&r. So while a low speed collision of &6100J&r will only require about &6200k FE&r total, high speed crafts may consume millions or billions of FE."
		""
		"Starting off, you'll probably only have a few &7Linear Motors&r, so it is best to keep the ring small to reduce the time it takes for the particle to get back around to the &7Motor&r again. "
		""
		"&7Guide Rings&r may be controlled by &cRedstone&r to send a particle out into a larger loop that can handle higher speeds as the particle gains momentum."
		"&n                                                                          &r"
		""
		"[\"There are a lot of moving parts here, so be sure to check out the \",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://moddedmc.wiki/hu/project/oritech/latest/docs/particle_accelerator\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Particle Accelerator\",\"underlined\":true},\" on the Oritech Wiki, which does an excellent job of describing how this system works. \"]"
		""
		"To give an idea of scope, however, consider a recipe that requires a collision of &61000J&r. Reaching these speeds while keeping your particle contained will require a minimum distance of 11 blocks between turns."
		""
		"See the next page for a full list of speeds by &cRedstone Signal Strength&r as measured by the &7Sensor&r."
		""
		"{@pagebreak}"
		"            &6&nSignal Strength&r            &6&nParticle Speed&r "
		"                      1                             0"
		"                      2                            10"
		"                      3                            50"
		"                      4                            75"
		"                      5                           100"
		"                      6                           150"
		"                      7                           250"
		"                      8                           500"
		"                      9                           750"
		"                     10                          1000"
		"                     11                          2500"
		"                     12                          5000"
		"                     13                          7500"
		"                     14                         10000"
		"                     15                         15000"
	]
	quest.45B1C10885F542A7.quest_desc: [
		"Item Storage Cells handle any type of item. You’ll likely want quite a few of these to handle everything you have. "
		""
		"Start small, you can always upgrade to large cells later!"
	]
	quest.45E411460C53A082.quest_desc: [
		"Materials may be greatly enhanced by infusing them with one or more &7Spirit&r types and this &7Altar&r is the key to performing such operations. "
		""
		"Working with the &7Spirit Altar&r is relatively straightforward. At its simplest, you’ll need the &7Altar&r itself and some &7Item Pedestals&r to hold any extra items shown in the recipe. "
		""
		"On the &7Altar&r, you’ll insert the primary ingredient, shown in the middle of the recipe, and the &7Spirits&r shown on the left. Any items shown on the right will be placed on &7Item Pedestals&r. The craft begins immediately upon placing the items for a valid craft."
		""
		"Crafting may seem rather slow, however it can be greatly sped up by placing up to four &7Runewood Obelisks&r nearby. The passive animals you've been keeping should provide the necessary &7Spirits&r."
		""
		"                       &n&6A Note on Automation&r"
		""
		"Items may be inserted by hand or by any form of item logistics. Some form of pipe with a filter is recommended, though not required."
		""
		"Early on, you may find it convenient to set up an &7Altar&r to passively craft a single item in batches, however later on you'll be able to easily integrate this device with Applied Energistics patterns so you can request crafts on-demand."
		""
		"[\"Since it requires multiple input slots, you'll undoubtedly wish to use a \",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://guide.appliedenergistics.org/1.21.1/ae2-mechanics/subnetworks#root\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Subnet\",\"underlined\":true},\" to route items appropriately.\"]"
	]
	quest.45F3C4F0EDA160C5.quest_desc: [
		"You’ve got nothing but your wits and a few trinkets to work with; these books will help you get started. "
		""
		"• &6Cloud Burst&r will summon a fluffy cloud."
		""
		"• &6Brawndo&r will quickly grow plants."
		""
		"• &6Holdfast&r places a single block in midair which "
		"    will disappear after a few moments."
		"&n                                                              &r"
		""
		"Lost your books? Ran out of Saplings? "
		""
		"This quest is repeatable to get you going again!"
	]
	quest.4613FE560EAC7695.quest_desc: [
		"Combine the &7Purified Blood&r with a filled &7Plasmid&r in the &7Plasmid Injector&r to set the trait in the blood sample. "
		""
		"You can inject multiple traits into the same sample if you like. "
		""
		"Once you’re happy with your enhanced blood sample, it’s time to inject it into a creature. "
		""
		"[\"Many traits may be given to mobs, but not all. Refer to the \",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://github.com/aaronhowser1/Genetics-Resequenced/wiki/3.-Gene-List\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Wiki\",\"underlined\":true},\" if in doubt.\"]"
		""
		"&6⚠ Note: Some traits have prerequisites "
		"&6    that, if not met, will cause the "
		"&6    injection to fail. Refer to EMI."
		""
		"&a🛈 Tip: Traits applied to breedable "
		"&a    animals are transferred to their "
		"&a    offspring!"
	]
	quest.465D195EA5630857.quest_desc: [
		"With a Storage Lectern from Ars Nouveau, you can easily link together multiple inventories to have a central storage and crafting interface. "
		""
		"Be sure to check out the Worn Notebook for more information on this system!"
	]
	quest.46DDBE0A9170F54A.quest_desc: [
		"Forging &7Steel&r in &7Blaze Ember&r has certain… advantages over traditional practices. "
		""
		"Not only is it strong and durable, but it is uniquely porous when it comes to &7Spirits&r; as if it has a thirst for souls that can never be quenched. "
	]
	quest.46F17885C957FD5C.quest_desc: [
		"Potions of &7Fire Resistance&r and &7Ice Resistance&r won’t affect your body temperature, but they will prevent any negative effects associated with being too &9cold&r or &chot&r, making them ideal for prolonged jaunts outside of the area of your &7Hearth&r."
		""
		"By feeding them into a &7Potion Diffuser&r, you can even share the effects with your friends and &oother creatures&r in the area."
		""
		"&a🛈 Tip: Diffusers can be bound to "
		"&a    Jars that are &overy far away&r&a."
	]
	quest.472936F50BC28EBF.quest_desc: [
		"Sophisticated Storage offers a wide range of inventories to suit your needs, all of which may be connected through a Storage Controller for centralized access to everything in the network. "
		""
		"The Storage Tool is used to select the Controller and then bind different inventories to it. This allows wireless connections within a limited range. "
		""
		"It’s not possible to manually access the Storage Controller, so you’ll likely want to pair this with something else that allows you access the items. An Ad Hoc AE2 network, Pretty Pipes, or an Ars nouveau Storage Lectern are all excellent options."
	]
	quest.472936F50BC28EBF.title: "Sophisticated Storage"
	quest.47A2DB9344C8CE26.quest_desc: [
		"With a &7Zephyr Impetus&r secured, you’ll be able to mass produce some important materials; &7Weather Crystals&r and &7Wind Charges&r. "
		""
		"[ \"Refer to the Spirit Focusing quest in the \", { \"text\": \"Malum\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"0C0D9C8007301C03\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]} }, \" Chapter for information on using the Impetus.\" ]"
		""
		"&a🛈 Tip: Mending Diffusers are an easy"
		"&a    way to keep your Impetus from"
		"&a    breaking."
	]
	quest.47AFEF3DCB2990FB.quest_desc: [
		"Operating the &7Large Steam Boiler&r will need some liquid fuel. "
		""
		"All available fuels are listed in EMI, just search the uses for the &7Boiler&r. "
		""
		"To get started, however, you’ll need to start producing &7Refined Canola Oil&r. "
		""
		"&6⚠ Note: Multiblock Boilers &nonly&r &6accept "
		"&6    liquid fuel."
	]
	quest.47AFEF3DCB2990FB.title: "Refined Canola Oil"
	quest.47CB92C2ECBB7FF4.quest_desc: [
		"Bones are among the simplest things to re-animate. They hold in them a memory of life and an urge to move; they simply lack the impetus to do so. "
		""
		"For now, we’ll put them to work controlling some of our more basic machinery. "
	]
	quest.47FF0CFF9CC92DBE.quest_desc: [
		"A powered &7Refinery&r that handles the more complicated aspects of the process for you by regulating heat and pressure automatically!"
		""
		"For recipes with multiple fluid outputs, be sure to stack &7Refinery Chamber Modules&r atop the Refinery to get the extra outputs."
	]
	quest.48B6E6CDBFFD77A7.quest_desc: [
		"Runes may be imbued with powerful effects that become active when worn. Equipping them, however, requires an appropriate receptacle. "
		"&n                                                  "
		""
		"Begin by crafting a Runic Brooch. Once equipped, it will allow you to equip two Runes of your choice. "
		""
		"Runes themselves are crafted on the Runic Workbench. This is done easily enough by clicking the central recipe item onto the Workbench, followed by the required Spirits."
	]
	quest.48B6E6CDBFFD77A7.title: "Runeworking"
	quest.48C487AF892A80B2.quest_desc: [
		"Once you’re able to upgrade your Goo to &7VoidShimmer Goo&r, you’ll want to start refining your fuel into &7Voidflame Fuel&r."
		""
		"This will stretch your input materials, thus increasing efficiency and allowing your slower machines to keep up with demands. "
	]
	quest.4914692B607F8BE0.quest_desc: [
		"The Ender Source Jar is ideal for cross dimensional Source Transport. "
		""
		"So, if you’ve set up a crazy mob spawner in The End, maybe consider using this and a Vitalic Sourcelink to bring back all that delicious Source."
	]
	quest.49968116FCB311B0.quest_desc: [
		"A precious gem known for its hardness, &7Ruby&r has long been used as a bearing in precision machinery. "
		""
		"It also makes an excellent focus for certain magical pursuits. "
	]
	quest.49E18B07D6E4A5EB.quest_desc: [
		"With the latent energies in &7Ambrosium&r, we can create a &7Fermentation Vat&r to magically transmute certain materials. "
		""
		"We just need a suitable material to line the vat with to control the reaction."
		""
		"                           &6&nExample Spells&r"
		""
		"&7Conjure Quicksoil&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aCrush&r"
		""
		"&7Conjure Aether Dirt&r"
		"    &5Touch&r > &aConjure Terrain&r"
		""
		"&n                                                                          &r"
		""
		"The &7Fermentation Vat&r is operated by Right-Clicking the inputs into the machine. Once everything is in, Sneak Right-Click it again to ‘close’ it. It will only operate while closed."
		""
		"The Vat will open again automatically once it can no longer do any work. Be that because it finished, ran out of room for outputs, or ran out of inputs. "
		""
		"                       &n&6A Note on Automation&r&r"
		""
		"Fluids and Items may be inserted by any form of logistics such as pipes or hoppers, but only while the device is open. Similarly, items may only be extracted while it is open."
		""
		"The device may be closed by applying a Redstone signal to any side other than the front, which can be identified by the red dot at the bottom. "
		""
		"Regardless of the signal, the device will still open automatically if it has no room for outputs."
		""
		"The front will output a signal when the device has finished a recipe, allowing finer control for small batches."
	]
	quest.49F48B91801BE4FE.quest_desc: [
		"&7Transfer Labels&r are a great way to move items between adjacent inventories, meaning a &7Chest&r next to a &7Furnace&r can now push without the need of a hopper or other pipes. "
		""
		"The direction of flow depends on the machine the &7Labels&r is placed against. "
		""
		"For example, an &7Insert Label&r placed on the side of a &7Furnace&r will pull items from an adjacent &7Chest&r into the &7Furnace&r. Alternatively, an &7Extract Label&r on the &7Chest&r would cause it to push items from the &7Chest&r into the &7Furnace&r."
		""
		"Use a &7Label Accessor&r to Right-Click your labels, even when hidden by a machine, to configure them. Sneak + Left Click will remove the &7Label&r"
		""
		"They allow quite sophisticated filtering and can even be sped up by simply inserting more &7Labels&r in the GUI."
	]
	quest.49F48B91801BE4FE.title: "Transfer Labels"
	quest.4A3B9586D14D5037.quest_desc: [
		"Need a little more room to work? Summoning another island is always an option. "
		""
		"Alternatively, Right-Click &7Clay&r with a &7Water Essence&r to convert a &n21x11x21&r area to this biome!"
	]
	quest.4A3B9586D14D5037.title: "Biome Conversion"
	quest.4ACD723FC7EB7CD6.quest_desc: ["It's hard to keep a fire lit in this place; most open flames will go out immediately or simply not catch in the first place. "]
	quest.4ACD723FC7EB7CD6.title: "Fire"
	quest.4B2DF8F028C3CFA0.quest_desc: [
		"Animate a &7Guardian&r and gather some &7Organic Matter&r from it."
		""
		"&6⚠ Note: The Ritual Item is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.4C46DBD26BE50BCD.quest_desc: [
		"&7Aura Field Creators&r are powerful block breakers that work in pairs, breaking every block between them. "
		""
		"They can be augmented with a tool by placing the tool in an &7Item Frame&r on one of the Creators, thus allowing it to use &7Silk Touch&r, &7Fortune&r, or any other special breaking property of the installed tool. "
	]
	quest.4C91792ACCC53A2B.quest_desc: ["By applying high heat in a low-oxygen environment, we can convert &7Pelagite&r into &7Kerogen&r. "]
	quest.4CB21D6351486281.quest_desc: [
		"Catalysts may be installed on a &7Natural Altar&r to modify the recipes it can process."
		""
		"Place them on the &7short stone pillars&r of the structure to use them."
		""
		"&6⚠ Note: An Altar with a Catalyst can "
		"&6    still process basic recipes if they "
		"&6    don’t conflict."
	]
	quest.4CC1CF537349C2D6.quest_desc: [
		"Need a little more room to work? Summoning another island is always an option. "
		""
		"Alternatively, Right-Click &7Tuff&r with an &7Earth Essence&r to convert a &n21x11x21&r area to this biome!"
	]
	quest.4CC1CF537349C2D6.title: "Biome Conversion"
	quest.4D8B278BDF762813.quest_desc: ["As cold as the void, this material seems to phase in and out of existence."]
	quest.4DFD963932B9FF81.quest_desc: [
		"With a &7Vortex Tube&r, you can easily create the very high, or very low, temperatures needed for many recipes."
		""
		"The &7Vortex Tube&r will consume air constantly to create a temperature differential. It is therefore advisable to use a &7Regulator Tube Module&r to limit or disable air flow."
		""
		"When operating, the red side will produce heat while the blue side will grow colder. "
		""
		"As this is operating on differentials, the warmer you make the blue side, the hotter the red side will get. "
		""
		"Very often, this just means adding a &7Heat Sink&r to the blue side to warm it up to ambient temperature. However, it can be useful at times to put hot blocks, such as &7Magma&r or &7Lava&r, on the blue side to really push temperatures higher on the red side.  "
		""
		"&a🛈 Tip: Use Thermal Lagging on "
		"&a    machines to prevent heat loss."
	]
	quest.4E175A06927C3A75.quest_desc: [
		"A &7Charging Station&r is a convenient way to refill the air in your pneumatic tools and equipment. "
		""
		"It will also give you access to modify the equipment such as installing &7Speed&r and &7Volume Upgrades&r."
		""
		"Lastly, and perhaps most importantly, the &7Charging Station&r acts as the workstation for Pressure Mechanics. "
		""
		"&a🛈 Tip: A Dispenser Upgrade allows the "
		"&a    Charging Station to charge entities "
		"&a    standing on top of it. This can be "
		"&a    used to recharge a Drone or to "
		"&a    recharge all your gear at once!"
	]
	quest.4E2D6D91B5DA19EE.quest_desc: ["Deep intelligence and prescient capabilities allow these devices to handle the unpredictable power surges and chaotic arcane energies necessary for advanced technology. "]
	quest.4EA58751A74DABAA.quest_desc: ["Capable of storing immense power, &7Vibrant Crystals&r will allow you to begin dealing with EV Tier power. "]
	quest.4F2E18DABA17E0AC.quest_desc: [
		"The &7Atomic Reconstructor&r is a powerful device used to transmute certain materials such as &7Mud&r to &7Moss&r."
		""
		"It can be incredibly power hungry!"
		""
		"This machine, when powered, will periodically emit a beam of energy. Any appropriate items or blocks in its path will be converted. "
		""
		"&a🛈 Tip: Right-Click the machine with a "
		"&a    Redstone Torch to change it to "
		"&a    Pulse Redstone mode."
		""
		"&6⚠ Note: Blocks may be converted both"
		"&6    in item form and as blocks placed"
		"&6    in-world."
	]
	quest.4FEA49AD05720ED7.quest_desc: [
		"Ah, the simple joys of playing with chalk outside. "
		""
		"Arts and Crafts allows you to craft paint brushes to rapidly re-color blocks such as Wool, Terracotta, or any of the many blocks added by the mod itself. "
		""
		"&a🛈 Tip: Search &3@arts&r &ain EMI to "
		"&a    discover more."
	]
	quest.4FEA49AD05720ED7.title: "Arts and Crafts"
	quest.5009BB4B0D1B459E.quest_desc: [
		"The &7Hopper Enhancement&r is placed on top of a &7Hopper&r, allowing it to pick up items from up to seven blocks away. "
		""
		"When coupled with an &7Adept Hopper&r, it can be filtered to specific items."
	]
	quest.503873180200D878.quest_desc: [
		"Made from &7Sculk&r, &7Reverberating Dorodangos&r may be processed down into new materials!"
		""
		"                   &n&6Materials&r"
		""
		"  • &7Zanite Gemstone&r"
		"  • &7Echo Dust&r"
		"  • &7Otherworld Ashes&r"
	]
	quest.51233852CD921F79.quest_desc: [
		"&7Drives&r act as compact storage capable of holding tens of thousands of items."
		""
		"A single drive may contain up to 10 &7Storage Cells&r, each with their own capacity and limitations. "
		""
		"Cells may also be filtered in a &7Cell Workbench&r, allowing you to dictate exactly what materials will be stored on that cell. "
	]
	quest.513BDF32A8F6EF45.quest_desc: [
		"Alakarkinos is eager and ready to assist! "
		""
		"New &7Dorodangos&r await you with the materials available on this island. "
	]
	quest.51636F3E5A461A7B.quest_desc: [
		"You'll be able to scrape away the ice from &7Icestone&r on a cutting board with any &7Axe&r."
		""
		"After it has been cleaned up, you’ll be left with &7Holystone&r which may be crushed down to obtain other materials. "
		""
		"Notably, you’ll need some &7Ambrosium&r which is an important catalyst for transmutation magic."
		""
		"&6⚠ Note: Icestone is cold and holding "
		"&6    too much will rapidly lower your "
		"&6    body temperature!"
	]
	quest.51A88370BE1CAC99.quest_desc: [
		"Not only do &7Worms&r speed up crop growth, but they’ll also keep the soil mostly hydrated. "
		""
		"A single &7Worm&r will help maintain a 3x3 plot of farmland."
	]
	quest.520241157010066D.quest_desc: [
		"Animate a &7Wilden Stalker&r and harvest it for parts."
		""
		"&7Wilden Wings&r may only be obtained through &7Soul Shattering&r. "
		""
		"&6⚠ Note: The Ritual Item is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.521DE7879A4B6F03.quest_desc: ["With access to &7EV Tier Cables&r and &7Transformers&r, upgrading your power infrastructure to handle high powered &7Particle Accelerator&r crafts would be a very good idea.  "]
	quest.5226F1BC0A1B23D0.quest_desc: ["[ \"\", { \"text\": \"Water Essence\", \"color\":\"gray\"}, \" grants access to the ever-flowing waterfalls of the \", { \"text\": \"Cascading Island\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"7893072479F01DC2\" } }, \".\" ]"]
	quest.5226F1BC0A1B23D0.title: "Cascading Island"
	quest.529329FE6CB3D29E.quest_desc: ["Cells may be broken down in a DNA Extractor to obtain the juicy DNA Helices. "]
	quest.52E79B2EB7400D13.quest_desc: [
		"&7Terminals&r grant you visibility into the network and allow you to manually interact with the contents."
		""
		"&7Crafting Terminals&r also have a built in crafting grid, making them the better choice most of the time."
		""
		"&a🛈 Tip: Cable Subparts cannot be "
		"&a    placed on Dense Cables."
	]
	quest.537EDDC45D94BDE4.quest_desc: ["Upgrading your Goo will give you access to newer recipes and faster in-world processing."]
	quest.53CE92319716971B.quest_desc: [
		"Minecraft has long allowed you to duplicate tall flowers such as &7Rose Bushes&r by applying &7Bone Meal&r. "
		""
		"Here, that ability is extended to &7small flowers&r as well. "
	]
	quest.53CE92319716971B.title: "Small Flower Duplication"
	quest.53D3092CA777D3B5.quest_desc: [
		"Nearly perfect, this Resonator seems to be able to react to changing conditions well in advance. "
		""
		"This will be of use when dealing with highly unstable arcane flows. "
	]
	quest.540133B792547B21.quest_desc: [
		"Make a &7Calcination Oven&r and place it atop a &7Pyromantic Brazier&r. "
		""
		"Items, such as &7Pebbles&r, may be Right-Clicked into the &7Oven&r while fuel may be Right-Clicked into the &7Brazier&r to begin processing."
	]
	quest.55065F1D9C6716C1.quest_desc: [
		"The &7Advanced Sensor&r gets an area upgrade over its Simple counterpart, allowing it to interact with things in a larger area. "
		""
		"&a🛈 Tip: Use the Render Area button to "
		"&a    easily configure the working area."
	]
	quest.5550423B6E6BDBAF.quest_desc: [
		"In need of some saplings? Maybe you’d like to get some bees producing honey? "
		""
		"Summon forth the Queen Bee in her throne and see what trades she has to offer!"
	]
	quest.5550423B6E6BDBAF.title: "Beehive Island"
	quest.55D51F58CA3130AA.quest_desc: [
		"Alakarkinos is eager and ready to assist! "
		""
		"New &7Dorodangos&r await you with the materials available on this island. "
	]
	quest.56AD6E7F12056140.quest_desc: [
		"The &7Enchanting Apparatus&r is a vital tool in and of itself and will become important soon enough. "
		""
		"The &7Arcane Core&r used in this device is also the &7Job Site&r for &7Shady Wizard Villagers&r, who will sell you various magical trinkets."
		""
		"Consider picking up some Wixies to help you with cooking up food to feed your villagers."
	]
	quest.56AD6E7F12056140.title: "Shady Wizard"
	quest.56DDD2327724F715.quest_desc: [
		"&7Cables&r come in a variety of sizes and colors to suit your needs. "
		""
		"Different colors of cable will not interconnect, meaning they can be easily run alongside each other without risk. "
		""
		"&7Fluix Cables&r, on the other hand, will connect to any other cable."
		""
		"&7Glass&r and &7Covered Cables&r can support up to eight channels, while &7Dense Cables&r can carry a full 32 channels. "
		""
		"Typically, these would be run from an &7ME Controller&r with smaller cables branching off where needed."
		""
		"&a🛈 Tip: Cable Anchors may be used to "
		"&a    prevent connections between"
		"&a    cables."
	]
	quest.56DDD2327724F715.title: "Cables"
	quest.56EDBF31457D8112.quest_desc: [
		"The Aura Detector may be read with a Comparator to determine how much Aura is in the area. "
		""
		"This is generally most useful when paired with a Generator, allowing you to turn it on or off as needed."
	]
	quest.574555F24035E48A.quest_desc: [
		"This collection of blocks do pretty much what their name implies; placing and picking up blocks or fluid."
		""
		"They cannot be filtered, but they can be controlled via Redstone, so they can be combined with a &7Sensor&r for more advanced logic. "
		""
		"They each have a single inventory slot which behaves slightly differently for each. "
		""
		"The &7Block Breaker&r will break using whatever item is in this slot as its tool. "
		""
		"The &7Block Placer&r only places the blocks in that inventory slot."
		""
		"Meanwhile the &7Fluid Collector&r and &7Placer&r blocks accept a tank in those slots to manually insert/extract fluids. Of course, fluids can also be piped in or out. "
	]
	quest.574555F24035E48A.title: "Simple Placers and Collectors"
	quest.577337FFD6AD9C83.quest_desc: ["[ \"Check out the \", { \"text\": \"Replication Chapter\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"13C15ACA23526F9E\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]} }, \" for information on using these machines to produce items. \" ]"]
	quest.577337FFD6AD9C83.title: "Replication"
	quest.579B2C5CB83022ED.quest_desc: [
		"The &7Manipulation Infused Turret&r combines the benefits of a &7Focus of Block Shaping&r with an &7Enchanted Turret&r, meaning it can not only cast all the examples from the previous quest, but it gets an enormous mana discount in doing so. "
		""
		"You will undoubtedly want to spend some time setting up such Turrets to conjure important materials such as &7Cold Aerclouds&r, &7Aerogel&r, and &7Clay&r, to name a few."
		""
		"&a🛈 Tip: Item Pickup, when used with a Turret, "
		"    &aplaces the items in any adjacent inventory."
		""
		"&6⚠ Note: Right-Click a Turret with your "
		"&6    Spell Book or Spell Parchment to set a spell."
	]
	quest.579C07CD07599438.quest_desc: [
		"In order to autocraft anything, AE needs a CPU to manage the craft. These are multi-block constructions composed of up to three components."
		""
		"The multi-block itself must contain at least one Storage Unit and must be a rectangular prism."
		""
		"One CPU is needed for each simultaneous craft request."
		""
		"• Crafting Storage: Used to store all "
		"  the items required for the craft. "
		"  More than one may be used."
		""
		"• Crafting Co-Processor: Optional. "
		"  Allows the CPU to send out batches "
		"  more often."
		""
		"• Crafting Units: Optional. Cheap filler "
		"  blocks to meet the shape "
		"  requirements."
		""
		"• Crafting Monitor: Optional. Displays "
		"  the request a CPU is currently "
		"  handling."
	]
	quest.579C07CD07599438.title: "Crafting CPUs"
	quest.5859B0217F1C837A.quest_desc: ["With an Aura Attraction Cart, Aura may be pulled from a centralized Generator and dispersed throughout an area to power machines that might be too far away to otherwise benefit from the Generator. "]
	quest.58A275DB77CDF7F8.quest_desc: [
		"Malum adds several special drops from mobs that are only obtainable with an appropriate weapon. "
		""
		"Normally, you will want to start by crafting a &7Crude Scythe&r, however if you’ve already progressed in some other mods, you may find that you’ve already got a weapon capable of harvesting these materials. "
		""
		"&a🛈 Tip: A Soulwoven Pouch will "
		"&a    auto-collect these drops, keeping "
		"&a    your inventory clean!"
	]
	quest.58A3F58B7F1C580B.quest_desc: [
		"The &7Large Settling Tank&r is a multiblock version of the &7Settling Tank&r capable of processing in larger batches. "
		""
		"Consider upgrading to this as your &7Water&r recycling needs grow."
		"&n                                                                          &r"
		""
		"Every Modern Industrialization multiblock requires input and output hatches commensurate with the recipes it handles. "
		""
		"In this case, the &7Large Settling Tank&r requires both fluid and item hatches."
		""
		"&a🛈 Tip: Place the controller block, then hold a Wrench "
		"&a    to see the structure. Similarly, hold a Hatch to see "
		"&a    valid locations for them."
	]
	quest.598473588831F46D.quest_desc: [
		"&7Fluid Laser Relays&r act as a wireless fluid pipe. Simply place them against the machines that need liquids and a tank, then link them all together with the Laser Wrench. "
		""
		"They have a relatively short range but can be chained to extend their reach!"
		""
		"&a🛈 Tip: Use a Compass to change modes"
		"&a    to pull from the source tank!"
	]
	quest.59DC95275C1091C6.quest_desc: [
		"&7Blaze Ember Fuel&r represents a significant upgrade over &7Refined Canola&r and will be well worth the effort of producing it. "
		""
		"Spend some time automating production early and it should keep your machines powered for a while to come."
	]
	quest.59F0519A7ED69E19.quest_desc: [
		"&7Oil&r is normally formed under intense pressure over millions of years."
		""
		"Ain't nobody got time for that."
		""
		"Let's speed things along a little with the magic of &7Time Fluid&r."
		"&n                                                              &r"
		""
		"[ \"Obtaining the materials to create these crystals will require a visit to the \", { \"text\": \"Flashing Island\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"19F8B29D38CA31B8\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]} }, \". \" ]"
		""
		"Once you’ve obtained the requisite ingredients, the only thing standing in your way is Time itself."
		""
		"And Aura. Lots of Aura."
	]
	quest.59F0519A7ED69E19.title: "Crude Oil"
	quest.5A5596ED63306534.quest_desc: ["It seems to flicker to a breeze that isn't there. "]
	quest.5A5706DE9011B222.quest_desc: [
		"With a &7Tesla Tower&r, you’ll be able to transmit power wirelessly in a large radius. "
		""
		"The exact radius and transmission rate is determined by the &7Coils&r used in the structure, while the &7Energy Hatch&r determines the power tier."
		""
		"&a🛈 Tip: A Tesla Receiver Hatch can "
		"&a    power a multiblock directly without"
		"&a    extra wires!"
	]
	quest.5A74D7EFD6AD1EAC.quest_desc: [
		"Slaughtering mobs with a &7Soul Shattering Weapon&r will cause Spirit Aspects to drop These are useful for many crafts in Malum, so pay attention to what mobs drop which Spirit Aspects."
		""
		"Check the Info tab in EMI on each Spirit Aspect to see where to obtain it."
		""
		"&a🛈 Tip: Spirit Jars can hold an "
		"&a    enormous number of Spirits!"
	]
	quest.5AC80FA3683D9E45.quest_desc: ["Upgrading your Goo will give you access to newer recipes and faster in-world processing."]
	quest.5AD1A273F3714FAF.quest_desc: [
		"It’s probably about time we started thinking about Source. "
		""
		"Many of Ars Nouveau’s devices either require Source to run, such as certain &7Enchanting Apparatus&r recipes, or are dramatically improved by having Source supplied, like the &7Imbuement Chamber&r."
		""
		"So, let’s pick a method and get some Source generated!"
		"&n                                                              &r"
		""
		"Each Sourcelink uses a different \"fuel\" to generate Source, which it deposits into a nearby Source Jar."
		""
		"• &7Agronomic&r – Generates Source from natural "
		"    crop growth. Place in the middle of a field "
		"    for best results."
		""
		"• &7Volcanic&r – Consumes furnace fuels like coal. "
		"    This can be dropped nearby or inserted into "
		"    an adjacent Arcane Pedestal."
		""
		"• &7Alchemical&r – Consumes potions from an "
		"    adjacent Potion Jar. Best paired with a Wixie "
		"    designated to craft potions into the jar."
		""
		"• &7Vitalic&r – Converts mob deaths to Source, an "
		"    excellent addition to any mob farm."
		""
		"• &7Mycelial&r – Consumes food. This can be dropped "
		"    nearby or inserted into an adjacent "
		"    Arcane Pedestal."
		""
		"&a🛈 Tip: Source Jars hold 10,000 Source."
	]
	quest.5AFB064A80189AA4.quest_desc: [
		"This &7Moss&r appears to be concentrating different minerals as it grows. "
		""
		"Crush some to obtain &7Copper&r and other useful minerals!"
		""
		"Using &7Bone Meal&r on &7Moss&r will cause it to spread to nearby blocks, such as &7Mud&r and &7Dirt&r. As long as you keep at least one &7Moss&r, you will have an infinite supply!"
	]
	quest.5AFB064A80189AA4.title: "Copper"
	quest.5D1960D1AE64E4A2.quest_desc: [
		"The Flourishing Island comes with a ready-made &7Natural Altar&r to get you started. "
		""
		"You’ll also notice several &7Swamp Homis&r dotted around under the &7Spore Blossoms&r. These handy little devices will convert nearby &7Moss&r back to &7Mud&r, releasing some Aura into the environment in the process. "
	]
	quest.5D50FB987FCA7BB5.quest_desc: [
		"The &7Vexing Archwoods&r on this island will already have a few &7Bastion Fruit&r grown on them. "
		""
		"Gather a few and consider setting up a farm when you can; they grow when placed on a &7Vexing Archwood Log&r and can be sped up by applying &7Bone Meal&r or other grow effects. "
		""
		"&a🛈 Tip: Harvest Rituals can be an easy "
		"&a    way to farm these fruit!"
	]
	quest.5D74493BC797D6F0.quest_desc: [
		"Only the most evil and malicious of creatures have &7Wicked Spirits&r within them to harvest. "
		""
		"Maybe go see what your Goats have in their bleating hearts."
		""
		"&6⚠ Note: The Spawn Egg is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.5D74493BC797D6F0.title: "Wicked Spirit"
	quest.5D97DDB66F470605.quest_desc: ["Neptunium tools and armor are Unbreakable, making the tools quite useful in farms. "]
	quest.5DF0502B194247F9.quest_desc: [
		"Ever wanted to transfer Source around your base through your AE system? Perhaps you’d like more Source storage than Source Jars can easily accommodate? "
		""
		"Source Storage Cells are the answer. "
		""
		"By combining these with an ME Source Jar you can import and export Source anywhere you need it while storing vast amounts of the stuff in your system for future use. "
		""
		"&a🛈 Tip: Place an ME Source Jar nearby "
		"&a    where Source is needed, then "
		"&a    transport it with a Relay to a "
		"&a    regular Source Jar for use. "
	]
	quest.5E4077F317135E34.quest_desc: [
		"As the woman awoke on the newly formed earth, alone and surrounded by unfamiliar sights. Her belly rumbled and she knew hunger. Her people were gone and she knew fear. She shed tears for what was lost."
		""
		"The animals, seeing that she hungered, brought her roots to feed her. Seeing that she was alone, they gathered near to comfort her. "
		""
		"The woman ate her fill and sang her praises to the animals. With her heart full of company, she brushed her tears away. They spread across the sky where they glistened and became stars. With her belly full of nourishment, she pressed the roots into the newly formed earth. They flourished in the soil and multiplied."
		""
		"As she wandered the new earth, she sang to the animals and they adored her. When her hunger returned, the animals fed her. Each place she visited, she pressed roots into the ground. Each place, they flourished and multiplied. The land grew lush and was filled with new life.  "
	]
	quest.5E4077F317135E34.title: "Taking Root"
	quest.5E581FAC8D96FC22.quest_desc: [
		"The &7Molecular Assembler&r is a simple auto crafter that will repeatedly craft whatever recipe has been set in an installed Pattern. Items may be piped in and the results will be auto exported into an adjacent inventory. "
		""
		"These can be an excellent early way to automate basic crafting tasks. "
		""
		"&a🛈 Tip: Molecular Assemblers need "
		"&a    power but do not consume a "
		"&a    channel, allowing many to be set up "
		"&a    on an Ad-Hoc Network for power "
		"&a    while external pipes passively feed "
		"&a    them crafting materials."
	]
	quest.5E727F7B600E0E91.quest_desc: [
		"The &7Dissolution Chamber&r combines multiple ingredients with some type of fluid. "
		""
		"The machine only holds enough items for a single craft at a time, so it can be useful to lock the slots to a specific recipe and pipe items in. "
		""
		"This way it can run larger batches as you work on other things."
		""
		"&6⚠ Note: The items may be input in any "
		"&6    order!"
	]
	quest.5F9A998072170415.quest_desc: [
		"Alakarkinos is eager and ready to assist! "
		""
		"New &7Dorodangos&r await you with the materials available on this island. "
	]
	quest.5FC9979B966955DE.quest_desc: [
		"Spin up an Oritech &7Centrifuge&r and start producing &7Carbon Fibre Strands&r. "
		""
		"You’ll need these to create parts for more advanced machinery. "
	]
	quest.5FD8F4BE050D55B2.quest_desc: [
		"&7Pretty Pipes&r are a simple item logistics and sorting system with some powerful features. "
		""
		"Perhaps the biggest draw is that they show what’s moving through them for a more immersive experience. "
		""
		"Beyond this, however, they offer both push and pull functionality, where an &7Extraction Module&r can be used to pull items from an adjacent inventory and disperse them throughout the network, or a &7Retrieval Module&r may be used to pull items from any inventory on the network and push into the adjacent inventory. "
		""
		"Various filters and priority modules exist to help ensure the items are going to the correct place. "
	]
	quest.5FE4FD410171ABFD.quest_desc: [
		"As power needs increase, it is generally better to upgrade your &7Boilers&r instead of building more of the same. "
		""
		"After all, a single &7Advanced Boiler&r is worth four standard &7Boilers&r."
		"&n                                                                          &r"
		""
		"Upgrade your power production by switching to &7Advanced Large Steam Boilers&r."
		""
		"&a🛈 Tip: Place the controller block, then hold a Wrench "
		"&a    to see the structure. Similarly, hold a Hatch to see "
		"&a    valid locations for them."
	]
	quest.60239B38B7288779.quest_desc: [
		"That little boiler back in the &7Gazebo&r is undoubtedly looking rather insufficient by now, so let’s work on a “little” upgrade."
		"&n                                                                          &r"
		""
		"Every Modern Industrialization multiblock requires input and output hatches commensurate with the recipes it handles. "
		""
		"In this case, the &7Large Steam Boiler&r only requires Fluid Hatches; it does not accept solid fuel."
		""
		"Other blocks required for any structure can also be found by looking at uses for the controller block (ie. &7Large Steam Boiler&r block) in EMI. Note that some of the blocks listed will be replaced by Hatches."
		""
		"&a🛈 Tip: Place the controller block, then hold a Wrench "
		"&a    to see the structure. Similarly, hold a Hatch to see "
		"&a    valid locations for them."
	]
	quest.6030BA17DB9228F2.quest_desc: [
		"One day the woman found herself in the North and few animals remained with her. "
		""
		"Here, the land was covered in deep snow and frozen in ice. Here, the woman’s wanderings slowed; she knew she had not the strength of body to traverse the land. She watched as the animals burrowed into the snow to stay warm and she did as they did. "
		""
		"There she sat, and there she reflected on her travels. "
		""
		"The North Wind began to blow, strong and cold, and the world stood still."
	]
	quest.6030BA17DB9228F2.title: "Snowed Under"
	quest.605A60825B68C2D7.quest_desc: [
		"Many animals are not well adapted to these heights, and as such have a diminished lifespan. "
		""
		"The following creatures will only survive about &710 in-game days&r as adults before they die, meaning you will have to keep breeding them if you wish to keep them around. They must also be kept in a warm environment to avoid freezing to death."
		""
		"Aging animals will show the following signs:"
		"    1. Their &7maximum health&r will be reduced."
		"    2. They'll move &7slower&r and become &7blind&r."
		"    3. Finally, they will &7wither&r and die. "
		""
		"Mobs that die in this way will &7drop no loot&r."
		""
		"Thankfully, you have some options to automate breeding, thus keeping your herds renewed. "
		""
		"                  &6&nSenescent Animals&r"
		""
		"      &7Chickens                     &7Mooshrooms"
		"      &7Cows                       &7Flying Cows      "
		"      &7Sheep                        &7Sheepuffs      "
		"      &7Pigs                          &7Phygs"
		"      &7Rabbits                      &7Aerbunnies"
		"      &7Goats"
	]
	quest.605A60825B68C2D7.title: "Animal Senescence"
	quest.60DC19DA26E8CCA4.quest_desc: ["With all of the impurities purged, &7Stainless Steel&r should prove useful in more advanced technology where a stray soul or two might otherwise disturb the process and prove disastrous. "]
	quest.616862D8ADBE3928.quest_desc: [
		"Water will freeze, of course, if left out in the cold. But you’ll need some particularly cold, dense ice soon. "
		""
		"Freeze a &7Water Bucket&r and then re-freeze it until you get &7Blue Ice&r. "
		""
		"Be careful, however, it's extremely cold to hold!"
		""
		"The &7Freezer&r uses &7Icestone&r as fuel."
	]
	quest.619FB543EE458A0E.quest_desc: [
		"Summon a &7Polar Bear&r at the Altar of Birthing and gather some &7Organic Matter&r from it."
		""
		"&6⚠ Note: The Spawn Egg is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.619FB543EE458A0E.title: "Polar Bear"
	quest.61F55FC24EA0CD1C.quest_desc: [
		"To begin, we’ll need some Organic Matter samples. You’ll obtain these by using your Scraper on different mobs. "
		""
		"Toss those in a Cell Analyzer to obtain Cells."
		""
		"&a🛈 Tip: A Scraper enchanted with "
		"&a    Delicate Touch will cause no harm."
	]
	quest.623B5F0C0464F907.quest_desc: [
		"While it is true that a scurry of &7Starbuncles&r all share a single over-worked brain cell, they can be immensely helpful, nonetheless. "
		""
		"Naturally, each one can only manage a single task at a time, but they can be instructed to do several different jobs depending on the hat you give them. "
		""
		"&6Default Jobs&r"
		"  • Collect items on the ground and deposit them into a "
		"    designated inventory"
		"  • Collect Sourceberries from bushes and deposit them "
		"    into a designated inventory"
		"  • Transport items from one inventory to another"
		""
		"&6Starbuncle Shades&r"
		"  • Disables their ability to pick up items and to collect "
		"    Sourceberries"
		""
		"&6Square Robin Mask&r"
		"  • Enables round-robin item transportation."
		""
		"&6Wixie Hat&r"
		"  • Transport potions from one Potion Jar to another"
		""
		"&6Starbucket&r"
		"  • Transport fluids from one fluid container to another"
		""
		"&6StarBin&r"
		"  • Voids items that are collected"
		""
		"&6Starminer&r"
		"  • Allows the Starbuncle to break blocks at a location"
		""
		"&6Starbuilder&r"
		"  • Allows the Starbuncle to place blocks at a location"
	]
	quest.625AE1AEF37DAE03.quest_desc: [
		"One of several options for automated farming. It has its quirks, but it’ll do for now. "
		""
		"Remember to set up an &7Agronomic Sourcelink&r nearby to capture some extra Source from your crop farms!"
		""
		"&a🛈 Tip: Right-Click this machine with a "
		"&a    Compass to adjust the working "
		"&a    area."
	]
	quest.628A6A79EFA30990.quest_desc: [
		"The Storage Lectern is your primary interface to your storage network. Here, you can access all the linked inventories and there’s a handy crafting grid included. "
		""
		"Each network will have exactly one &7Primary Storage Lectern&r and may have as many &7Secondary Lecterns&r as desired. "
		""
		"Only the primary one is allowed to be linked to inventories; the secondary ones simply act as remote access. "
		""
		"                &6&nPrimary Storage Lectern&r"
		""
		"To designate the &7Primary Lectern&r, Right-Click it with a &7Bookwyrm Charm&r. "
		""
		""
		"              &6&nSecondary Storage Lectern&r"
		""
		"To designate a &7Secondary Lectern&r, Right-Click it with the &7Dominion Wand&r, then Right-Click the &7Primary Lectern&r to form the connection. "
		""
		"&7Secondary Lecterns&r may be chained to reach greater distances."
		""
		"                     &6&nBinding Storage&r"
		""
		"Bind an inventory to your &7Primary Lectern&r using the Dominion Wand; Sneak Right-Click the inventory, then Right-Click the &7Primary Lectern&r."
	]
	quest.62C7492F54D80CBA.quest_desc: [
		"The few spell tomes you’ve been left with should prove useful, but they’re no substitute for a full &7Spell Book&r. Fully recovering that is going to take time but we can get a start on it now."
		""
		"Gather some wood and craft up some basic tools. "
		""
		"With an &7Axe&r and &7Cutting Board&r, you’ll be able to get some &7Bark&r for &7Paper&r. "
		""
		"With a &7Knife&r, you’ll be able to break &7Grass&r for &7Straw&r."
		""
		"Later, the &7Cutting Board&r may also be used with spells. The following combinations simulate the respective tools."
		""
		"                           &6&nExample Spells&r"
		""
		"&7Knife or Shears&r"
		"    &5Touch&r > &aCut&r"
		""
		"&7Axe or Knife&r"
		"    &5Touch&r > &aCut&r > &6Amplify&r"
		""
		"&7Shears&r"
		"    &5Touch&r > &aCut&r > &6Extract&r"
		""
		"&7Pickaxe&r"
		"    &5Touch&r > &aBreak&r"
		""
		"&7Shovel&r"
		"    &5Touch&r > &aCrush&r "
		""
		"&7Axe&r"
		"    &5Touch&r > &aFell&r "
	]
	quest.62C7492F54D80CBA.title: "On the Chopping Block"
	quest.62E2DEBF71698376.quest_desc: [
		"&7Import&r, &7Export&r, and &7Storage Buses&r are your primary interface with the network. "
		""
		"&7Import&r and &7Export Buses&r act as one might expect, pulling items into, or pushing them out of the network. "
		""
		"&7Storage Buses&r, on the other hand, effectively make the attached inventory a part of the network; anything in it can be accessed by the network and it can be used to store anything coming into the network."
		""
		"&a🛈 Tip: Cable Subparts cannot be "
		"&a    placed on Dense Cables."
	]
	quest.631AA5AAA6EF687C.quest_desc: [
		"&7Pattern Providers&r are the network's means of interfacing with crafting machines, both to insert crafting materials and to receive the crafting result. "
		""
		"For basic crafting patterns, such as you'd do at a &7Crafting Table&r, the &7Pattern Provider&r must be placed next to one or more &7Molecular Assemblers&r. "
		""
		"For machine crafting, or processing patterns, the &7Provider&r should be placed facing that machine on a side where the machine can accept inputs. "
		""
		"It can also feed into any type of inventory, allowing you to route items from there. For example, an array of &7Furnaces&r could be fed by a single &7Provider&r pushing into a &7Barrel&r. Pipes would then carry items and distribute them amongst the Furnaces, as well as return the results back to the &7Pattern Provider&r."
		""
		"&a🛈 Tip: Consider using a Subnet for "
		"&a    machines that need fluids and items "
		"&a    delivered to separate faces!"
	]
	quest.631AA5AAA6EF687C.title: "Autocrafting"
	quest.6384F08466CA9FB9.quest_desc: [
		"The &7Redstone Aura Vaporizer&r is, quite simply, a clock. "
		""
		"Insert &7Bottled Aura&r into it to set different intervals. Each bottle of &7Sunlight&r is a second, &7Ghosts&r for minutes, and &7Darkness&r for hours. "
	]
	quest.63944BDC078E728A.quest_desc: [
		"The &7Focus of Block Shaping&r is a powerful piece of kit for any spell-caster as it allows you to stack effects into a single spell that would normally take multiple casts. "
		""
		"For example, you’re probably quite used to using a spell such as the one below to conjure Aerclouds."
		""
		"&7Conjure Cold Aercloud&r"
		"    &5Touch&r > &aConjure Terrain&r > &aCrush&r"
		""
		"With a &7Focus of Block Shaping&r equipped, however, the following forms become viable, allowing you to instantly create and pick up the conjured material."
		""
		"&7Conjure and Collect Cold Aercloud&r"
		"    &5Touch&r > &aConjure Terrain&r > &aCrush&r > "
		"            &aBreak&r > &aItem Pickup&r"
		""
		"Without the Focus, this would conjure an Aercloud and break the block you had clicked on to cast. With the Focus, however, the Break affects the block that was summoned."
		""
		"Below are a few more spells of interest, but take some time to explore what else you can come up with."
		""
		"                           &6&nExample Spells&r"
		""
		"&7Conjure and Collect Glass (Requires Cascading Isle)&r"
		"    &5Touch&r > &aConjure Terrain&r > &aCrush&r > &aSmelt&r > "
		"            &aBreak&r > &6Extract&r > &aItem Pickup&r"
		""
		"&7Conjure and Collect Terracotta (Requires Cascading Isle)&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aSmelt&r > "
		"            &aBreak&r > &6Extract&r > &aItem Pickup&r"
		""
		"&7Conjure and Collect Bricks (Requires Cascading Isle)&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aBreak&r > "
		"            &aSmelt&r > &6Sensitive&r > &aItem Pickup&r"
	]
	quest.63A7E92BBCEDF461.quest_desc: [
		"All too soon, the woman felt she must move on. She headed into the South and the animals came with her."
		""
		"Here, forests gave way to wetlands, wetlands to sand-strewn shores. The woman, seeing how the animals swam along the winding waterways, made a canoe to follow them.  When she grew tired, she lay down amongst the sandy dunes of the coast to rest. When she grew unclean, she bathed in the warm waters of the seas. "
		""
		"Of the animals who accompanied the woman, some found homes in the rivers and seas and were content to stay. "
		""
		"The South Wind began to blow, hot and strong, bringing with it Summer and the promise of adventure."
	]
	quest.63A7E92BBCEDF461.title: "Soaking Up the Sun"
	quest.63AFE7CB35AE94BF.quest_desc: [
		"Want to change things up a bit? Looking for a more magical experience over Create’s normal machines?"
		""
		"Ars Technica, an addon for Ars Nouveau, includes glyphs to mimic many of Create’s processes. Below are a few example spells to get you started."
		""
		"These are great for quick manual processing or can be a powerful replacement to Create if the spells are inscribed in a Spell Turret."
		""
		"                     &6&nExample Spells&r"
		""
		"&7Encased Fan - Bulk Washing&r"
		"    &5Projectile&r > &aWhirl&r > &aConjure Water&r"
		""
		"&7Encased Fan - Bulk Blasting&r"
		"    &5Projectile&r > &aWhirl&r > &aSmelt&r"
		""
		"&7Deployer&r"
		"    &5Projectile&r > &aApply&r"
		""
		"&7Mechanical Mixer&r"
		"    &5Projectile&r > &aFuse&r"
		""
		"&7Sandpaper&r"
		"    &5Projectile&r > &aPolish&r"
		""
		"&7Mechanical Press&r"
		"    &5Projectile&r > &aPress&r"
		""
		"&a🛈 Tip: Try adding AOE or stacking spell casts!"
	]
	quest.6490781066FAE8CF.quest_desc: [
		"                &6&nBiome: Mangrove Swamp&r&r"
		""
		"The following Placement Conversions are in effect in this biome. Remember to use these to your advantage by using Conjure Terrain to summon these blocks."
		""
		"  • &7Dirt&r                 &2⟶&r      &7Mud&r"
		"  • &7Grass Block&r      &2⟶&r      &7Mud&r"
		"  • &7Cobblestone&r      &2⟶&r      &7Tuff&r"
		"  • &7Stone&r              &2⟶&r      &7Infused Rock&r"
		"  • &7Sand&r               &2⟶&r      &7Cold Aercloud&r"
		"  • &7Sandstone&r        &2⟶&r      &7Quicksoil&r"
		"  • &7C. Deepslate&r      &2⟶&r      &7Aerogel&r"
		"  • &7Deepslate&r         &2⟶&r      &7Aerogel&r"
		""
		"                     &6&nExample Spells&r"
		""
		"&7Conjure Mud&r"
		"    &5Touch&r > &aConjure Terrain&r"
		""
		"&7Conjure Tuff&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r"
		""
		"&7Conjure Infused Rock&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aSmelt&r"
		""
		"&7Conjure Cold Aercloud&r"
		"    &5Touch&r > &aConjure Terrain&r > &aCrush&r"
		""
		"&7Conjure Quicksoil&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aCrush&r"
		""
		"&7Conjure Aerogel&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify x2&r"
	]
	quest.6534548E8A6A318C.quest_desc: [
		"Alakarkinos is eager and ready to assist! "
		""
		"New &7Dorodangos&r await you with the materials available on this island. "
	]
	quest.65FDD18E441E2E6E.quest_desc: [
		"An animate Book, Bookwyrms are part of a complete storage system built into Ars Nouveau. "
		""
		"The guidebook offers a full guide on setting this system up, however as a brief overview use a Bookwyrm Charm on a Storage Lectern to enable that Lectern to be linked to inventories."
		""
		"&a🛈 Tip: Adding more Bookwyrms allows "
		"&a    more connections!"
	]
	quest.6660BE0C308A1744.quest_desc: [
		"Summon a &7Goat &rat the Altar of Birthing and gather some &7Organic Matter&r from it."
		""
		"&6⚠ Note: The Spawn Egg is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.6660BE0C308A1744.title: "Goat"
	quest.66C2FBA12D91F642.quest_desc: [
		"The Exo Suit is an unbreakable suit of powered armor which provides moderate protection, night vision, and speed increases. "
		""
		"Upgraded versions of the Chestplate are also available to add Elytra or Jetpack flight!"
	]
	quest.66DAC6EC4232C44A.quest_desc: [
		"Fun-loving denizens of the deeps, Sirens live in warm oceans and will happily join your menagerie if you give them a Sea Pickle. "
		""
		"In exchange, the Siren will help you automatically obtain fishing loot. "
		"&n                                                  &r"
		""
		"Right-Click a block of Prismarine with her charm to create her home. Placing more aquatic plants and animals in their home will make them happier and more productive."
	]
	quest.6703E3A9E3571660.quest_desc: [
		"Standing out in the open without protection or holding too many cold items will cause your body temperature to drop rapidly. "
		""
		"Wearing protective clothing will slow the rate at which heat is lost, so don't leave home without it. "
		"&n                                                             &r"
		""
		"Between your Health and your Hunger, you'll notice a new indicator showing your Temperature Rating. This indicator ranges from 0 to 100, where 0 is considered comfortable and 100 is deadly. It displays as &9Blue&r for freezing and &6Orange&r for overheating. "
		""
		"Starting at around &950&r, you'll notice your movements becoming sluggish and your view start to diminish. "
		""
		"If your Temperature Rating hits &9100&r, you will rapidly freeze to death."
		""
		"Overheating may not seem like a threat at the moment, but be aware that holding certain items, like Lava Buckets, will affect your body temperature."
	]
	quest.6705BECBD94CAAAD.quest_desc: [
		"With stronger gearing and motors, this &7SAG Mill&r can help you get more from your ores than before. "
		""
		"Be sure to supply it with &7Grinding Balls&r to get the best results. "
		""
		"&6⚠ Note: Enderio machines require  "
		"&6    a Capacitor to function."
	]
	quest.6728201CEC8220A3.quest_desc: [
		"If, for whatever reason, your Pentacle becomes damaged, worry not. All the materials to recreate it are easily accessible at this point. "
		""
		"Refer to EMI for recipes, as usual. For the &7Strange Crystals&r, they'll form randomly when using &7Bone Meal&r on &7Blighted Earth&r.  "
		""
		"Click the &6👁&r next to each ritual recipe in EMI to preview the pentacle in world. This will show where each block must be placed. They all use the same pentacle. "
		""
		"The &7Chalice&r may be replaced with a &7Golden&r or &7Iesnium Sacrificial Bowl&r if desired, though this will slow down the rituals. This may be advantageous, however, depending on your needs."
		""
		"Feel free to recreate the pentacle elsewhere as desired if you need more room for automation."
		""
		"                 &6&nA Note on Automation&r&r"
		""
		"Occultism’s pentacles have gotten easier to automate than ever, so if you’re only familiar with older versions, read on. "
		""
		"You may use any pipe or hopper to put items into each &7bowl&r, including the central &7chalice&r. "
		""
		"The central item may only be inserted once a valid recipe is present in the surrounding bowls and the ritual will start immediately without further interaction. "
		""
		"This means you can quite simply pipe the items into each bowl without any extra logic.  "
		""
		"&a🛈 Tip: The shape of individual chalk marks is "
		"&a    random and doesn’t affect the pentacle!"
	]
	quest.672B88E9A3FA1FCE.quest_desc: [
		"With the &7Winter’s Calling&r active, snow will rapidly accumulate in the area and water will freeze to ice. "
		""
		"Snow Golems may also appear to further spread the snowy goodness!"
		""
		"Needless to say, this can be a great way to get some &7Snow&r to make &7Ice&r!"
	]
	quest.679DACB985517C55.quest_desc: [
		"The &7Advanced Dropper&r allows for dropping items further away and in more configurable amounts. "
		""
		"&a🛈 Tip: Use the Render Area button to "
		"&a    easily configure the working area."
	]
	quest.6806970967942788.quest_desc: [
		"The &7Coffee Maker&r is the work site for the &7Engineer&r villager. In exchange for a hearty breakfast, these villagers will gladly provide you with all the parts you need to start &7making power&r."
		""
		"[ \"Check out the \", { \"text\": \"Energy Chapter\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"0FF1E0FF9CAD1914\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]} }, \" to learn about better \", {\"text\": \"Boilers\", \"color\":\"gray\"}, \" as well as generating power with \", {\"text\": \"Turbines\", \"color\":\"gray\"}, \".\" ]"
		""
		"The &7Coffee Maker&r may also be used to automatically brew &7Coffee&r. "
		""
		"Simply pipe in the ingredients, supply some energy, and provide it a &7Redstone Signal&r to make it start."
		""
		"&6⚠ Note: The Steam Alembic may be used "
		"&6    to brew a wicked cup of coffee to "
		"&6    get you started!"
	]
	quest.6849CF8933FC70F9.quest_desc: [
		"With &7Steel Machine Casings&r, a whole new world of technology becomes available. In particular, many Oritech machines will now be craftable. "
		""
		"Be sure to check the uses for this casing in EMI to find more devices that you may now have access to."
		""
		"[ \"Also take a look in the \", { \"text\": \"Energy Chapter\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"0FF1E0FF9CAD1914\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]} }, \" for information on upgrading your power infrastructure. \" ]"
	]
	quest.687E532AD956C57A.quest_desc: [
		"With excellent insulation and heating capabilities, this &7Alloy Smelter&r can reach temperatures capable of burning the Hell out of things."
		""
		"&6⚠ Note: Enderio machines require  "
		"&6    a Capacitor to function."
	]
	quest.68C212D2C7F8B308.quest_desc: [
		"Animate a &7Wilden Defender&r and harvest it for parts."
		""
		"&7Wilden Spikes&r may only be obtained through &7Soul Shattering&r. "
		""
		"&6⚠ Note: The Ritual Item is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.69295042E8C3A609.quest_desc: [
		"Source Relays are used for transporting Source from place to place. This way you can have a centralized Source generation area that feeds multiple devices or Spell Turrets around your home."
		""
		"These come in a variety of flavors, however perhaps the most relevant right now will be the Splitter. Not only will this transfer Source faster than the basic Relay, but it can also be used to pull from or deposit to multiple targets. "
		""
		"Use a Dominion Wand to link Relays to other Relays or Source Jars. First Right-Click the origin, then Right-Click the destination."
		""
		"&a🛈 Tip: You can recolor the beams shot "
		"&a    by a Relay using the Wololo Glyph!"
	]
	quest.692EDEAEC3F4A2AD.quest_desc: [
		"The &7Swapper&r is a powerful teleportation device that swaps the blocks or entities in front of it with its linked partner. "
		""
		"This can be a great way to get around your base, teleport long distances, move babies out of a farm, and more. "
		""
		"They must be set up in a linked pair and are bound to each other by using a &7Ferricore Wrench&r."
		""
		"Simply place them both, then Right-Click one with the &7Wrench&r. Finish by Right-Clicking the other with the &7Wrench&r. "
	]
	quest.692EDEAEC3F4A2AD.title: "Simple Swapper"
	quest.697E0106FF4F5691.quest_desc: [
		"&7Ender Resonators&r, despite their prescience, still lack the higher-order thinking capabilities of a conscious mind. "
		""
		"Combining the two will permit working with the most unstable and powerful aspects of magic."
	]
	quest.699B01CFAEE29827.quest_desc: ["An excellent way to cool &7Plastic&r or simply make &7Ice&r. "]
	quest.69EE67B1B612D74D.quest_desc: [
		"Climb to the top of the island and approach the &7Soulwood Tree&r located there. "
		""
		"You’ll find several &7Exposed Soulwood Logs&r which can be stripped with an &7Axe&r. "
		""
		"Right Click the &7Revealed Soulwood Log&r with a &7Glass Bottle&r to obtain some &7Cursed Sap&r."
		""
		"A few of these &7Exposed Logs&r will spawn in every new &7Soulwood Tree&r you grow, allowing you to obtain more as needed."
	]
	quest.6A4C2B4518E341D6.quest_desc: [
		"Animate a &7Blue Swet&r and defeat it to obtain &7Aqueous Spirits&r."
		""
		"&6⚠ Note: The Ritual Item is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.6A4C2B4518E341D6.title: "Aqueous Spirit"
	quest.6A4DD846F7E08FD6.quest_desc: [
		"The woman flew higher and higher, up and up. She soared for what seemed like ages. "
		""
		"When the air grew thin and her lungs began to burn, the gentle winds of Spring filled her with breath."
		""
		"When the air grew cold and her limbs began to ache, the warm winds of Summer warmed her flesh. "
		""
		"Higher and higher, up and up. She soared until at last she approached the Sun."
		""
		"When the light grew bright and her eyes could not see, the Autumn winds guided her."
		""
		"When the light grew hot and scorched her flesh, the Winter Winds braced her. "
		""
		"She soared until at last, she plunged her walking stick into the burning heights."
	]
	quest.6A4DD846F7E08FD6.title: "Borrowed Flame"
	quest.6A8ACE8E9B7A056D.quest_desc: [
		"As the woman plummeted into the sea, the animals rushed to her knowing she would surely perish without a place to rest."
		""
		"They took it in turns to dive down into the depths, each attempting to bring up the mud from the bottom. Each boasted of their strengths, claiming they would be the one to reach the bottom. Each failed and upon resurfacing claimed the task to be impossible. "
		""
		"When hope was nearly lost, the smallest among them came forward and asked to be permitted to try. It made no boast and all doubted its ability, but the other animals stood aside to allow it to try. Through quiet determination, it dove deeper and deeper. It dove until its lungs burned and its limbs ached. It dove until at last, one small paw brushed the mud in the lightless depths. "
		""
		"Grasping a handful of the mud, it turned and swam to the surface. There, it was greeted with praise when the other animals saw what it held. It spread the mud on Turtle’s back and, knowing that more would be needed, it dove again and again, slowly covering Turtle’s back to build a new land where the woman could rest. "
	]
	quest.6A8ACE8E9B7A056D.title: "The Earth Diver"
	quest.6A94923547B93B51.quest_desc: ["Fluid Cards for LaserIO allow Laser Nodes to transport Fluids."]
	quest.6AA9F3E0D4BC181A.quest_desc: [
		"You’ll find two important structures located on this island. "
		""
		"The first is the &7Weeping Well&r, which can exchange certain items. Simply toss an item in and the new item will be thrown back at you."
		""
		"The second is a &7Ritual&r for more elaborate requests. Look for the chalice surrounded by chalk marks."
	]
	quest.6AC4CADE97CB512F.quest_desc: ["[ \"\", { \"text\": \"Earth Essence\", \"color\":\"gray\"}, \" grants access to the swampy environs of the \", { \"text\": \"Flourishing Island\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"6490781066FAE8CF\" } }, \".\" ]"]
	quest.6AC4CADE97CB512F.title: "Flourishing Island"
	quest.6AF21EDF59FCE0D4.quest_desc: [
		"In the time before Time, the Sky People lived high above on islands of clouds. "
		""
		"They knew no strife for all was changeless. "
		""
		"They knew no grief for all were eternal. "
		""
		"Then, something changed. "
		""
		"One of the Sky People fell from on high. She fell, and fell, and all mourned her as she tumbled through the endless blue sky. The Sky People, seeing her falling, felt that loss cut them deeply. Loss for her and loss for what was and would be no more. "
		""
		"In their lamentation, their tears fell in great heaving sobs, racing the woman to the place below as if to cushion her fall. "
		""
		"There, they pooled. There, the oceans rose. And there, the woman landed."
	]
	quest.6AF21EDF59FCE0D4.title: "Innocence Lost"
	quest.6AFCA9F187AE6EB2.quest_desc: [
		"The Building section covers mods and tools to help you build up or tear down. "
		""
		"From mining and decoration, to destruction and more, the mods shown here will help you do it all."
	]
	quest.6AFCA9F187AE6EB2.title: "Building"
	quest.6BA05AC6ECC577DA.quest_desc: [
		"By now, you should have everything you need to summon your first Island, the Lush Garden. "
		""
		"There, you'll find a number of plants to expand your cooking repertoire as well as an &7Altar of Birthing&r where you can summon in some animals for meat and other resources. "
		""
		"Simply toss your recipe ingredients near the &7Altar&r and your animal will appear. Magic!"
		"&n                                                              &r"
		""
		"Be careful when setting up these Island rituals. They will not destroy blocks when spawning the island. "
		""
		"So, if anything is in the way, you may miss out on important blocks."
		""
		"Use the &7Potion of Flying&r from the previous quest to get a little ways from your main island and then cast your &7Holdfast&r spell to place a temporary block to build on."
		""
		"Your &7Ritual Brazier&r may then be set atop that block."
		""
		"Once the &7Brazier&r has been placed, Right-Click it with the &7Tablet&r and then once once more with an empty hand to start the ritual."
		""
		"&6⚠ Note"
		"&6  If important blocks are missing, simply clear "
		"&6  whatever was in the way and run the ritual "
		"&6  again in the same spot to refresh the island."
	]
	quest.6BA05AC6ECC577DA.title: "Lush Garden "
	quest.6C4A7BF577605E4A.quest_desc: [
		"The &7Time Wand&r uses Time Fluid and Energy to drastically accelerate machines for a brief period. "
		""
		"Simply Sneak + Right Click on a machine to apply stacking boosts up to 256x speed.   "
	]
	quest.6CA8BA78F5B8FB6A.quest_desc: [
		"Animate a &7Wilden Pack Hunter&r and harvest it for parts."
		""
		"&7Wilden Horns&r may only be obtained through &7Soul Shattering&r. "
		""
		"&6⚠ Note: The Ritual Item is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.6CE9EE018596DAD2.quest_desc: [
		"Craft a &7Novice Spell Book&r. It comes with a few key glyphs that you’ll be able to put together, but you’ll soon want to explore more glyphs to pull off ever more impressive feats."
		""
		"                          &6&nUseful Keybinds&r"
		""
		"[\"• Open Book (\",{\"color\":\"gold\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Open Book\"}]},\"keybind\":\"key.ars_nouveau.open_book\"},\")\"]"
		"[\"• Selection HUD (\",{\"color\":\"gold\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Selection HUD\"}]},\"keybind\":\"key.ars_nouveau.selection_hud\"},\")\"]"
		"[\"• Next Slot (\",{\"color\":\"gold\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Next Slot\"}]},\"keybind\":\"key.ars_nouveau.next_slot\"},\")\"]"
		"[\"• Previous Slot (\",{\"color\":\"gold\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Previous Slot\"}]},\"keybind\":\"key.ars_nouveau.previous_slot\"},\")\"]"
		""
		"If you're feeling a little daunted by spellcraft, that's normal. It's a huge and very powerful system. We'll try to point out useful spells to know throughout the quests, however. "
		""
		"The guidebook also has a section that explains the rules, such as placing &5Form&r before &aEffect&r or where &6Augments&r are allowed. "
		""
		"[\"Lastly, the community driven \",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://ars.guide/spells/introduction/compendium/\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Ars.Guide\",\"underlined\":true},\" has a repository of useful spells. Feel free to explore them and submit your own creations!\"]"
		""
		"                           &6&nExample Spells&r"
		""
		"&7Multi-Tool&r"
		"    &5Touch&r > &aBreak&r"
		""
		"&7Tree Harvesting&r"
		"    &5Projectile&r > &aFell&r"
		""
		"&7Conjure Icestone&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r"
		""
		"&a🛈 Tip: Refer to the guide for more examples."
		""
		"&6⚠ Note: Spells may contain up to thirty glyphs."
	]
	quest.6D09D016EDE0AAFB.quest_desc: [
		"This workstation allows the Wixie to craft standard &7Crafting Table&r and &7Brewing Stand&r recipes. "
		""
		"Brewing potions, however, will require a nearby Potion Jar to store the result."
		""
		"                   &6&nFormation&r"
		""
		"Right-Click a &7Cauldron&r with a &7Wixie Charm&r."
		""
		"&6⚠ Note: For multi-step crafts, each "
		"&6    step must be specified separately."
	]
	quest.6D09D016EDE0AAFB.title: "Wixie Crafting and Brewing"
	quest.6DA23C4B7F016B1D.quest_desc: [
		"&7Greenhouse Glass&r provides a significant growth boost to the crop directly below it. "
		""
		"Use it to build yourself a nice enclosure for your plants that is also functional. "
	]
	quest.6DBBD5B744B801B1.quest_desc: [
		"You'll notice that a number of blocks either cannot be placed in this frigid place or will transform when placed. "
		""
		"Notably, the following blocks will be transformed if placed by any means, including conjuration!"
		""
		"  • &7Dirt&r                     &2⟶&r          &7Aether Dirt&r"
		"  • &7Grass Block&r          &2⟶&r          &7Aether Grass&r"
		"  • &7Cobblestone&r          &2⟶&r          &7Icestone&r"
		"  • &7Stone&r                  &2⟶&r          &7Holystone&r"
		"  • &7Sand&r                   &2⟶&r          &7Cold Aercloud&r"
		"  • &7Sandstone&r            &2⟶&r          &7Quicksoil&r"
		"  • &7C. Deepslate&r          &2⟶&r          &7Aerogel&r"
		"  • &7Deepslate&r             &2⟶&r          &7Aerogel&r"
		""
		"                     &6&nExample Spells&r"
		""
		"&7Conjure Aether Dirt&r"
		"    &5Touch&r > &aConjure Terrain&r"
		""
		"&7Conjure Icestone&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r"
		""
		"&7Conjure Holystone&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aSmelt&r"
		""
		"&7Conjure Cold Aercloud&r"
		"    &5Touch&r > &aConjure Terrain&r > &aCrush&r"
		""
		"&7Conjure Quicksoil&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aCrush&r"
		""
		"&7Conjure Aerogel&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &6Amplify&r"
	]
	quest.6DD8DD44D4B70AD4.quest_desc: [
		"With an &7Addon Splicer&r, it’s possible to compact a set of Addons into a single block, allowing you to make more compact setups for your Oritech machines. "
		""
		"Once the structure is built, attach addons to it like you would any other machine. Then either click the &7Compact!&r button in the GUI or supply a Redstone signal to the front of the machine to produce a &7Heart of the Machine&r. "
		""
		"This new compact addon will have provide the same benefits as the addons used to craft it and must be attached directly to an Oritech machine; it cannot be extended in any way, nor combined with other addons. "
	]
	quest.6DE4258F18A7A321.quest_desc: [
		"Welcome to &6Enigmatic Skies&r! We hope you enjoy your time here! :D"
		""
		"It's dangerous to go alone. Take these to get you started!"
		""
		"If you lose your &7Morphing Tool&r or &7Eccentric Tome&r, worry not; a newly crafted one will come pre-filled. "
		"&n                                                  &r"
		""
		"Quests are divided into three sections:"
		""
		"[ {\"text\":\"                \"}, { \"text\": \"Enigmatic Skies\", \"color\":\"green\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"0A8B7FD4A52663D3\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]} }]"
		""
		"[ {\"text\":\"           \"}, { \"text\": \"Discovering Enigmatica\", \"color\":\"green\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"44BD4C393C59F1CB\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]} }]"
		""
		"[ {\"text\":\"                \"}, { \"text\": \"Learning Mods\", \"color\":\"green\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"16C7D5478BF3D449\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]} }]"
	]
	quest.6DE4258F18A7A321.title: "Welcome!"
	quest.6E4554D07901967C.quest_desc: [
		"Quite possibly the last suit of armor you’ll ever need. "
		""
		"Self-repairing, flight-enabling, high-jumping, and so much more. "
		""
		"The endermen will ignore you, the pigmen will adore you, and the pillagers will abhor you. "
		""
		"&a🛈 Tip: Load the armor into a Charging "
		"&a    Station to see all of the upgrades "
		"&a    each item can accept."
	]
	quest.6E4554D07901967C.title: "Pneumatic Armor"
	quest.6EA0560551B821B3.quest_desc: [
		"The &7Flourishing Archwoods&r on this island will already have a few &7Mendosteen&r and &7Glow Berries&r grown on them. "
		""
		"Gather a few and consider setting up a farm when you can."
		"                      &n&6A Note on Automation&r&r"
		""
		"&7Mendosteen&r grow when placed on the side of &7Flourishing Archwood Logs&r and &7Glow Berries&r grow when placed on the bottom of most blocks. "
		""
		"Both can be sped up by applying &7Bone Meal&r or other grow effects such as spells."
		""
		"                           &6&nExample Spells&r"
		""
		"&7Grow and Harvest Mendosteen&r"
		"    &5Touch&r > &aGrow&r > &aHarvest&r > &aItem Pickup&r"
		""
		"&7Grow and Harvest Glow Berries&r"
		"    &5Touch&r > &aGrow&r > &aInteract&r > &aItem Pickup&r"
		""
		"&a🛈 Tip: Harvest Rituals are an easy way farm these!"
	]
	quest.6EA0560551B821B3.title: "Island Fruits"
	quest.6EB5108D30F5A94A.quest_desc: [
		"With a &7Heat Exchanger&r and &7High Pressure Water&r secured, we can start feeding it into a &7High Pressure Boiler&r to recycle it back into steam. "
		""
		"Early on, this process may stutter a bit due to the low volume of fluids; leave your &7TPP&r configured to generate more &7High Pressure Steam&r to fill the system over time. Things will smooth out soon enough."
		""
		"                         &n&6A Note on Ratios&r"
		""
		"Each &7Boiler&r produces a max of 8k EU/t worth of &7High Pressure Steam&r, meaning it will take two &7Boilers&r to max out a single &7Heat Exchanger&r."
		""
		"&a🛈 Tip: Place the controller block, then hold a Wrench "
		"&a    to see the structure. Similarly, hold a Hatch to see "
		"&a    valid locations for them."
	]
	quest.6EB5108D30F5A94A.title: "High Pressure Advanced Large Steam Boiler"
	quest.6EB6E8DEEBB32911.quest_desc: [
		"In order to obtain a trait, it must be injected into a blood sample. So we’ll need to get one of those first."
		""
		"You can obtain your own blood with an Empty Syringe; simply hold Right-Click until your vision goes dark."
		""
		"To obtain the blood of another creature, you’ll need an Empty Metal Syringe."
		""
		"Once a sample is obtained, run it through the Blood Purifier to get it ready for modification."
		""
		"&a🛈 Tip: You need to stand very close to "
		"&a    a mob to extract their blood."
	]
	quest.6EBB293F3DDE5EC7.quest_desc: [
		"The woman wandered into the East and the animals came with her."
		""
		"Here, everywhere she walked, the lands bloomed with flowers and lush grasslands. Everywhere she lay down to rest, dense woodlands grew to offer her shade. "
		""
		"Of the animals who accompanied the woman, some found homes amongst the trees and grasses and were content to stay. "
		""
		"The East Wind began to blow, gentle and warm, bringing with it Spring and the promise of a new beginning. "
	]
	quest.6EBB293F3DDE5EC7.title: "A Spring in Her Step"
	quest.6F1A7E1B49FCC4C0.quest_desc: [
		"Replication begins by breaking down material into their base components. "
		""
		"There are eight of these Matter types in total and materials may consist of more than one. You'll be able to obtain them all by crafting Tokens."
		"&n                                                                          &r"
		""
		"Place the &7Disintegrator&r then connect the provided &7Matter Pipes&r and &7Matter Tank&r to it. "
		""
		"&7Matter Tanks&r only connect to &7Pipes&r from the top and bottom faces. &7Tanks&r can also be stacked on top of each other and will still connect through to the network. "
		""
		"Replication also uses a fair amount of power, which can be provided directly to machines or transmitted through Matter Pipes to any machines on the network."
		""
		"Once everything is connected, toss some items in the &7Disintegrator&r. The matter will automatically flow out from this machine and be stored in the &7Matter Tank&r. From here, it's available to other machines for use. "
	]
	quest.6F8C048404EAF9FF.quest_desc: [
		"Autocrafting is a central part of Applied Energistics, allowing it to perform all of the sub-crafting required for a requested item. "
		"Naturally, this becomes very helpful when dealing with more complicated crafts from other mods. "
		""
		"In order to craft anything automatically, the system must first be taught a pattern. These patterns are configured at the &7Pattern Encoding Terminal&r."
		""
		"Configured &7Patterns&r must then be put into a &7Pattern Provider&r. This can be done directly at the &7Provider&r, but a &7Pattern Access Terminal&r also gives you access to all of them in a single place for easy management."
		"&n                                                  &r"
		""
		"We won’t fully cover Autocrafting in the quests here; it’s already explained quite well in the AE Guidebook. We will touch on a few key pieces, however."
		""
		"&a🛈 Tip: Cable Subparts cannot be "
		"&a    placed on Dense Cables."
	]
	quest.6FC31B3806BF222A.quest_desc: [
		"The &7Thermal Compressor&r uses heat differentials to produce compressed air up to &710 bar&r. "
		""
		"Blocks such as &7Lava&r or &7Magma&r may be used to heat one side while a &7Heat Sink&r placed opposite will be enough to produce the required differential. "
		""
		"Heat sources will degrade over time and will need to be replaced."
		""
		"&a🛈 Tip: Look at Uses for Heat Pipes in"
		"&a    EMI for a list of heat sources."
	]
	quest.6FC31B3806BF222A.quest_subtitle: "Raising the Bar"
	quest.706758F1FE31E268.quest_desc: [
		"Pre-Programmed Drones are a class of drone that are largely set-and-forget. "
		""
		"They come with a basic program that allows them to perform one task automatically and with no further oversight. "
	]
	quest.710D7615763E9945.quest_desc: [
		"Oaths and vows have power, though they come at a cost. "
		""
		"The &7Soulbinding Brazier&r is used to enter in to such a pact, the details of which may be found within the Encyclopedia Arcana. "
		""
		"Choose carefully, as breaking your pact is not done easily. "
		"&n                                                  "
		""
		"To start the ritual, place the central item in the brazier, followed by all the items listed around it in the recipe. If done correctly, all the items will go from circling around the brazier to circling above it. "
		""
		"Once the items are ready, ignite the brazier by Right-Clicking with Ether. Finally, Right-Click the brazier one final time and wait for the animation to finish. "
	]
	quest.710D7615763E9945.title: "Geasa"
	quest.714379744B3CF395.quest_desc: [
		"The first few &7Gold Ingots&r you make should go towards making an &7Imbuement Chamber&r. "
		"&n                                                                          &r"
		""
		"The &7Digestion Vat&r is operated by Right-Clicking the inputs into the machine. Once everything is in, Sneak Right-Click it again to ‘close’ it. It will only operate while closed."
		""
		"The Vat will open again automatically once it can no longer do any work. Be that because it finished, ran out of room for outputs, or ran out of inputs. "
		""
		"                       &n&6A Note on Automation&r&r"
		""
		"Fluids and Items may be inserted by any form of logistics such as pipes or hoppers, but only while the device is open. Similarly, items may only be extracted while it is open."
		""
		"The device may be closed by applying a Redstone signal to any side other than the front, which can be identified by the red dot at the bottom. "
		""
		"Regardless of the signal, the device will still open automatically if it has no room for outputs."
		""
		"The front will output a signal when the device has finished a recipe, allowing finer control for small batches."
	]
	quest.7163E7EBDB861D72.quest_desc: [
		"There is no advanced version of the &7Item Collector&r, instead tools at this tier may be given the ability to teleport items to a bound block."
		""
		"Running a mob farm? Use a &7Celestigem Sword&r bound to a storage system; all the mob drops will be inserted automatically."
		""
		"Setting up a tree farm? Use a &7Celestigem Axe&r to teleport the logs to storage. "
		""
		"Farmland tilled with a &7Celestigem Hoe&r will self-harvest and teleport the drops to a bound storage as well."
	]
	quest.7163E7EBDB861D72.title: "Advanced Item Collector?"
	quest.7234B1B299DE122D.quest_desc: [
		"Finally, craft a &7Drygmy Charm&r. "
		""
		"These items may be Right-Clicked on &7Mossy Cobblestone&r to make a home for your new friend."
		""
		"The &7Drygmy&r will manage creatures in a large area, gently harvesting drops and depositing them in an inventory &7adjacent to its Henge&r."
		""
		"Source is required and will be taken from a nearby &7Source Jar&r."
	]
	quest.72B6C89DB165BB07.quest_desc: [
		"When placed in-world, &7Organic Compost&r will slowly transform into &7Rich Soil&r, a particularly good soil for growing crops."
		""
		"Any crops planted on &7Rich Soil Farmland&r will gain a significant boost in growth rates. "
	]
	quest.72C1A824063BAFA3.quest_desc: [
		"Caretakers of natural spaces, &7Drygmies&r once roamd the lands tending to animals to maintain balance. They’ll willingly join your menagerie if you give them a &7Wilden Horn&r, thus showing your commitment to maintaining order."
		""
		"In exchange, the &7Drygmy&r will help you harvest drops from animals and monsters alike. "
		"&n                                                  &r"
		""
		"Right-Click a &7Mossy Cobblestone&r with their charm to create their home. Placing many different creatures in their home will make them happier and more productive. "
		""
		"&a🛈 Tip: Drygmies will work with mobs "
		"&a    in Containment Jars!"
	]
	quest.7327D905FE8B38FC.quest_desc: [
		"The Item Terminal turns a Pretty Pipes network into a full-fledged item management system, allowing you to access the items throughout a network in one central location. "
		""
		"This may even be upgraded to a Crafting Terminal which has an integrated crafting grid. "
		""
		"Attaching and powering a Pipe Pressurizer will greatly increase the speed at which items are retrieved, however it is also recommended to keep your storage network pipe length short to ensure the items get to you quickly when requested."
		"&n                                                  &r"
		""
		"Lastly, through the use of Crafting Modules, these Terminals may be used to request crafts on demand. "
		""
		"Simply program the Crafting Module in a pipe segment adjacent to a machine and it will insert the ingredients upon request. "
		""
		"Another unconfigured pipe segment is needed for the Terminal to retrieve the craft."
	]
	quest.7327D905FE8B38FC.title: "Pretty Pipes"
	quest.739A201F595E3EFE.quest_desc: [
		"You always have the option of simply scaling out more Boilers as you need more power, but that gets cumbersome as power needs increase."
		""
		"Instead, consider an upgrade to a &7High Pressure Steam&r system. "
		""
		"To get started, you’ll need to produce some &7High Pressure Steam&r with a TPP. This is an energy intensive process and very slow, far too slow to run a Turbine. A Turbine would also consume the &7High Pressure Steam&r, leaving you with nothing in return."
		""
		"The &7Heat Exchanger&r solves this problem handily. When fed &7Water&r and &7High Pressure Steam&r, it will transfer the heat into the &7Water&r, generating regular &7Steam&r and &7High Pressure Water&r. "
		""
		"This &7High Pressure Water&r can then be heated back into &7High Pressure Steam&r in and &7Advanced High Pressure Boiler&r and recycled endlessly."
		""
		"                         &n&6A Note on Ratios&r"
		""
		"A single upgraded &7Heat Exchanger&r can handle &716k EU/t&r of &7High Pressure Steam&r."
		""
		"Max Efficiency: &n592&r"
		""
		"&a🛈 Tip: Place the controller block, then hold a Wrench "
		"&a    to see the structure. Similarly, hold a Hatch to see "
		"&a    valid locations for them."
	]
	quest.739A201F595E3EFE.title: "Heat Exchanger"
	quest.73D70F80C3AE999C.quest_desc: [
		"Who doesn’t love yeeting things through the air? "
		""
		"The &7Air Cannon&r is perfect for exactly that; launching items to either land in the world or be directly inserted into an inventory. "
		""
		"With the proper upgrades, they can also be used to launch nearby entities, or to act as a long-range Dispenser. "
		""
		"TNT cannon, anyone?"
	]
	quest.7413DDDB64FFAC2A.quest_desc: [
		"In what seemed like no time at all, the woman’s explorations led her into the West and the animals came with her."
		""
		"Here, wetlands gave way to dry brushland and stifling deserts. The woman found travel difficult and though she grew tired faster, places to take rest were fewer and farther between. Food grew scarce and the days grew hard. "
		""
		"The woman watched the animals cache food when it was available. Doing as they did, she could eat when none could be found. Seeing that shelter was scarce, she made her own that she could carry and move with her."
		""
		"Of the animals who accompanied the woman, some took to the air and made homes in the trees and were content to stay."
		""
		"The West Wind began to blow, dry and harsh, bringing with it Autumn and the promise of challenges ahead."
	]
	quest.7413DDDB64FFAC2A.title: "Laying in Supplies"
	quest.7431B398FFDF3DCA.quest_desc: [
		"With a &7Potion of Mutation&r set to the proper mob type, you’re ready for the next step. "
		""
		"This potion will again be combined in the &7Advanced Incubator&r, this time with a key item. Check the uses for your &7Potion of Mutation&r to see what it needs. "
		""
		"This process is slow and any attempt to speed it up will result in a lower chance of success. "
		""
		"Adding &7Chorus Fruit&r to the right-hand slot of the A&7dvanced Incubator&r will increase your chances of success."
		""
		"&a🛈 Tip: When looking for these recipes, "
		"&a    check the Uses on the Potion of "
		"&a    Mutation."
		""
		"&c⚠ Warning: Overclockers drastically "
		"&c    increase failure rates. "
		"&c    Patience, grasshopper!"
	]
	quest.7431B398FFDF3DCA.title: "Mutation"
	quest.74463B3FC2D297AC.quest_desc: [
		"Welcome to PneumaticCraft, a powerful logistics and automation mod revolving around the use of compressed air and heat to perform many different tasks."
		""
		"The mod comes with an extensive guidebook, which covers every aspect of the mod in detail. Therefore, the quests will be covering the highlights; getting you started and through basic progression. "
		""
		"&a🛈 Tip: Be sure to check tooltips often "
		"&a    for quick reminders on how an item"
		"&a    or block works."
	]
	quest.74463B3FC2D297AC.title: "PneumaticCraft"
	quest.752888EAF2861EB4.quest_desc: ["The following are various forms of item transfer options available in Enigmatica 10."]
	quest.752888EAF2861EB4.title: "Items"
	quest.75507A3DE753BC75.quest_desc: [
		"Tired of losing drops in the clouds? "
		""
		"Make yourself a &7Magnet&r and you won't need to worry about it any longer."
		""
		"A &7Demagnetization Coil&r may prove similarly indispensable, rendering your &7Magnet&r inert near things you'd like to avoid picking up."
	]
	quest.75BD1F2EB47FB7CF.quest_desc: [
		"The &7Advanced Liquid Compressor&r operates using the same fuels you've been using thus far and can reach up to &720 bar&r. "
		""
		"It does produce heat, however, and must be kept cool to run efficiently. At low speeds, a few &7Heat Sinks&r will suffice, especially at this altitude."
		""
		"[\"For a step-by-step guide to cooling, refer to our \",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://wiki.enigmatica.net/enigmatica6/gameplay/how-to.../pneumaticcraft-heating-and-cooling#advanced-compressors-1\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Wiki\",\"underlined\":true},\".\"]"
	]
	quest.76695BF2B0E70087.quest_desc: [
		"[ \"After a quick jaunt to the \", { \"text\": \"Blazing Island\", \"color\":\"aqua\", \"underlined\": true, \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"0A799F91D9A1C8A1\" } }, \", you’ll be able to upgrade your \", {\"text\": \"Goo\", \"color\": \"gray\"}, \" to a \", {\"text\": \"Blazebloom Goo\", \"color\": \"gray\"}, \" \" ]"
		""
		"&a🛈 Tip: Higher tier Goos will do all of the "
		"&a    lower tier’s recipes faster."
		""
		"&6⚠ Note: Goo is hungry and needs to be "
		"&6    fed to work! "
		""
		"&6    Right-Click with items to activate it."
		"&6    To find what items work, search "
		"&3    #goo_revive_tier_2&r&6 in EMI!"
	]
	quest.768869D763EC54EB.quest_desc: [
		"                    &6&nBiome: Deep Dark&r&r"
		""
		"The following Placement Conversions are in effect in this biome. Remember to use these to your advantage by using Conjure Terrain to summon these blocks."
		""
		"  • &7Dirt&r                 &2⟶&r      &7Aether Dirt&r"
		"  • &7Grass Block&r      &2⟶&r      &7Aether Grass Block&r"
		"  • &7Cobblestone&r      &2⟶&r      &7Sculk&r"
		"  • &7Stone&r              &2⟶&r      &7Sculk&r"
		"  • &7Sand&r               &2⟶&r      &7Cold Aercloud&r"
		"  • &7Sandstone&r        &2⟶&r      &7Quicksoil&r"
		"  • &7C. Deepslate&r      &2⟶&r      &7C. Deepslate&r"
		"  • &7Deepslate&r         &2⟶&r      &7Deepslate&r"
		""
		"                     &6&nExample Spells&r"
		""
		"&7Conjure Aether Dirt&r"
		"    &5Touch&r > &aConjure Terrain&r"
		""
		"&7Conjure Sculk&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r"
		""
		"&7Conjure Cold Aercloud&r"
		"    &5Touch&r > &aConjure Terrain&r > &aCrush&r"
		""
		"&7Conjure Quicksoil&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aCrush&r"
		""
		"&7Conjure Cobbled Deepslate&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify x2&r"
		""
		"&7Conjure Deepslate&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify x2&r > &aSmelt&r"
	]
	quest.76EC73B59502E2A5.quest_desc: [
		"A bit of slicing and splicing will get us what we need. Prepare the required items for the ritual and create your very own &7Drygmy&r. "
		""
		"To earn a &7Token&r of its trust, toss a &7Wilden Horn&r to your &7Drygmy&r."
		""
		"&6⚠ Note: The Ritual Item is not required. "
		"&6    It's simply here as a courtesy for "
		"&6    viewing the recipe."
	]
	quest.7750C6E87B1EBF43.quest_desc: [
		"The humble Imbuement Chamber is perhaps the single most important apparatus in Ars Nouveau. "
		""
		"With it, you’ll be able to generate the Source Gems and Essences you’ll need for all future crafts. "
		""
		"&a🛈 Tip: Source is optional!"
	]
	quest.77A66ADAB0845804.quest_desc: [
		"Macaw’s Mods are an expansive suite of decorative mods to fit just about any build. Enigmatica 10 currently has the following:"
		""
		"• Macaw’s Bridges"
		"• Macaw’s Doors"
		"• Macaw’s Fences and Walls"
		"• Macaw’s Lights and Lamps"
		"• Macaw’s Paths and Pavings"
		"• Macaw’s Trapdoors"
		""
		"&a🛈 Tip: Search &3@mcw&r &ain EMI to"
		"&a    discover more."
	]
	quest.77A66ADAB0845804.title: "Macaw's Mods"
	quest.77FA6854AC88C138.quest_desc: [
		"Made from &7Cold Aerclouds&r, &7Cloudy Dorodangos&r may be processed down into new materials!"
		""
		"                   &n&6Materials&r"
		""
		"  • &7Sky Stone Dust&r"
		"  • &7Sal Ammoniac Crystals&r"
	]
	quest.78626EE046E48EF3.quest_desc: [
		"                &6&nBiome: Archwood Forest&r&r"
		""
		"The following Placement Conversions are in effect in this biome. Remember to use these to your advantage by using Conjure Terrain to summon these blocks."
		""
		"  • &7Dirt&r                 &2⟶&r      &7Aether Dirt&r"
		"  • &7Grass Block&r      &2⟶&r      &7Aether Grass Block&r"
		"  • &7Cobblestone&r      &2⟶&r      &7Blackstone&r"
		"  • &7Stone&r              &2⟶&r      &7Polished Blackstone&r"
		"  • &7Sand&r               &2⟶&r      &7Gold Aercloud&r"
		"  • &7Sandstone&r        &2⟶&r      &7Quicksoil&r"
		"  • &7C. Deepslate&r      &2⟶&r      &7Basalt&r"
		"  • &7Deepslate&r         &2⟶&r      &7Smooth Basalt&r"
		""
		"               &c⚠ Warning: Contents HOT!"
		""
		"                     &6&nExample Spells&r"
		""
		"&7Conjure Aether Dirt&r"
		"    &5Touch&r > &aConjure Terrain&r"
		""
		"&7Conjure Blackstone&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r"
		""
		"&7Conjure Polished Blackstone&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aSmelt&r"
		""
		"&7Conjure Gold Aercloud&r"
		"    &5Touch&r > &aConjure Terrain&r > &aCrush&r"
		""
		"&7Conjure Quicksoil&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aCrush&r"
		""
		"&7Conjure Basalt&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify x2&r "
		""
		"&7Conjure Smooth Basalt&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify x2&r > &aSmelt&r"
	]
	quest.7893072479F01DC2.quest_desc: [
		"                   &6&nBiome: Warm Ocean&r&r"
		""
		"The following Placement Conversions are in effect in this biome. Remember to use these to your advantage by using Conjure Terrain to summon these blocks."
		""
		"  • &7Dirt&r                 &2⟶&r      &7Aether Dirt&r"
		"  • &7Grass Block&r      &2⟶&r      &7Aether Grass Block&r"
		"  • &7Cobblestone&r      &2⟶&r      &7Clay&r"
		"  • &7Stone&r              &2⟶&r      &7Terracottae&r"
		"  • &7Sand&r               &2⟶&r      &7Sand&r"
		"  • &7Sandstone&r        &2⟶&r      &7Sandstone&r"
		"  • &7C. Deepslate&r      &2⟶&r      &7Salt&r"
		"  • &7Deepslate&r         &2⟶&r      &7Salt&r"
		""
		"                     &6&nExample Spells&r"
		""
		"&7Conjure Aether Dirt&r"
		"    &5Touch&r > &aConjure Terrain&r"
		""
		"&7Conjure Clay&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r"
		""
		"&7Conjure Terracotta&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aSmelt&r"
		""
		"&7Conjure Sand&r"
		"    &5Touch&r > &aConjure Terrain&r > &aCrush&r"
		""
		"&7Conjure Sandstone&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify&r > &aCrush&r"
		""
		"&7Conjure Salt&r"
		"    &5Touch&r > &aConjure Terrain&r > &6Amplify x2&r "
	]
	quest.78B1BC9540590D17.quest_desc: [
		"Need a place to store that hard earned experience? "
		""
		"Try the &7Experience Holder&r. "
		""
		"This handy device can be used to keep you at a specific level of experience, as well as storing an incredible amount of experience. "
		""
		"It makes an indispensable addition to any enchanting area. "
	]
	quest.78E557B17D1EB84F.quest_desc: [
		"The Altar uses &7Ambrosium&r as fuel to transmute items. "
		""
		"As a first recipe, make some &7Rice&r by transmuting a &7Straw Bale&r, then plant the rice in water to get it growing. "
		""
		"From that, you'll be able to create a &7Magebloom Seed&r."
	]
	quest.7973D06875662CFE.quest_desc: [
		"You may have noticed that many Aura Generators stop working when Aura gets too high. The threshold is different from one to the next, but present just the same. "
		""
		"The Creational Catalyst removes this limit. "
		""
		"Simply place it beneath the Generator block to unlock its full potential."
	]
	quest.79951647661D4B52.quest_desc: [
		"[ \"Face off against a \", {\"text\": \"Warden\", \"color\": \"gray\"}, \" at the \", { \"text\": \"Flashing Island\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"300207E2557764E1\" } }, \" to obtain the necessary ingredients required for this tier of \", {\"text\": \"Goo\", \"color\": \"gray\"}, \".\" ]"
		""
		"&a🛈 Tip: Higher tier Goos will do all of the "
		"&a    lower tier’s recipes faster."
		""
		"&6⚠ Note: Goo is hungry and needs to be "
		"&6    fed to work! "
		""
		"&6    Right-Click with items to activate it."
		"&6    To find what items work, search "
		"&3    #goo_revive_tier_4&r&6 in EMI!"
	]
	quest.799839991CC1DDF9.quest_desc: [
		"It is no small wonder that ancient stories still resonate with us. "
		""
		"They speak to something universal; an unbroken thread reaching back through time. A thread that binds us all together through shared experience and common plights. Memories linger, stories repeat, and we find their echoes in our day-to-day, in the stories we tell of our lives. "
		""
		"Here, we find ourselves at the end. And with every end, a new story takes root.  "
		""
		"What threads will we weave for those who will come after us?"
	]
	quest.799839991CC1DDF9.title: "The Formless Void"
	quest.79DFBA1E35132332.quest_desc: [
		"This workstation allows the &7Wixie&r to craft &7Farmer's Delight Cooking&r recipes. "
		""
		"The &7Wixie&r is generally quicker than the &7Cooking Pot&r, and far easier to automate!"
		""
		"                   &6&nFormation&r"
		""
		"Right-Click a &7Cooking Pot&r with a &7Wixie Charm&r."
		""
		"&6⚠ Note: For multi-step crafts, each "
		"&6    step must be specified separately."
	]
	quest.79DFBA1E35132332.title: "Wixie Cooking"
	quest.79FA7B5854C9606F.quest_desc: [
		"The Anti-Field Orb and Block both function to suppress certain genes; specifically the Item Attraction and XP Attraction traits."
		""
		"Place the block in an area where you don’t want to be sucking up items randomly. Or carry the orb with you to enable and disable the trait at will. Just Right-Click it to toggle the feature."
	]
	quest.7ADBC282C9692EDE.quest_desc: ["Cable Façades are a universal façade that you can use to cover just about any pipe! "]
	quest.7ADBC282C9692EDE.title: "Cable Facades"
	quest.7B4E085679031F8B.quest_desc: [
		"When full on Steam, the &7Steam Boiler's&r burn rate will reduce, keeping the structure warm but not wasting Water. "
		""
		"To conserve Fuel, therefore, it may be advisable to use Redstone to control the Boiler. "
		""
		"Combining a &7Redstone Control Module&r with a &7Threshold Switch&r is a simple way to do just that. "
		""
		"Simply point the &7Threshold Switch&r at a buffer tank and use the signal from that to enable and disable the boiler. "
		""
		"Keep in mind that the higher your power consumption, the larger the buffer you'll need to make this tactic viable. Otherwise the time spent warming back up could very well cost you more fuel compared to simply leaving the Boiler running. "
	]
	quest.7B6267C141FE9B83.quest_desc: [
		"These dapper ocean critters have a knack for digging up lost treasures from sand. "
		""
		"Build them a little home and be sure to provide them with plenty of fresh Sand or Gravel and they’ll while away their days sifting through it for obscure artifacts. "
	]
	quest.7B6DF86E979614F4.quest_desc: [
		"Having sat for some time in thought and preparation, the woman stepped out from her snow-bound home."
		""
		"She looked to the East and implored the gentle winds of Spring to raise her. "
		""
		"She looked to the South and beseeched the warm winds of Summer to protect her."
		""
		"She looked to the West and urged the dry winds of Autumn to guide her."
		""
		"She looked to the North and pleaded that the cold winds of Winter brace her."
		""
		"The Four Winds came at her call and uplifted her into the heavens. Soaring higher than even the birds dare, joy and elation swelled in her heart."
	]
	quest.7B9D8AD7BFC1E87D.quest_desc: [
		"Direct Steam power will only get you so far. To begin working with electricity, you'll need a very special device; a &7Flux Gate&r."
		""
		"[ \"Head on over to the \", { \"text\": \"Vexing Island\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"13F15094F3AF4A73\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]} }, \" to begin. \" ]"
	]
	quest.7BEC7AF0176EA162.quest_desc: [
		"Fluid Storage Cells are often best used by locking their type in a Cell Workbench and dedicating a cell to each fluid you wish to store. "
		""
		"For fluids that may be generating endlessly, such as Lava or Water, an Overflow Destruction Card can be a handy way to keep your Interfaces from clogging as any excess will simply be voided."
	]
	quest.7C1E4DDAAA75E58F.quest_desc: [
		"Oritech’s &7Item Pipes&r offer limited logistics and filtering, perfect for point-to-point transfers. "
		""
		"These come in four varieties, though the differences are mainly cosmetic. "
		"&7Framed Pipes&r have a nice supporting structure around them, while &7Duct Pipes&r are a full block for passing through a wall without gaps. &7Duct Pipes&r only connect to other pipes, however."
		""
		"Right-Click the pipe connecting to a machine or tank to set it to Extract mode."
	]
	quest.7C27093E25633B9F.quest_desc: [
		"The Mercurial Fluid transport system is a simple logistics network for moving, well, fluids."
		""
		"The &7Inserters&r and &7Extractors&r can be placed against machines or other inventories and then linked up with &7Mercurial Copper Wire&r. "
		""
		"&7Mercurial Connection Nodes&r allow multiple wires to come together to form a broader network, as well as to extend the reach of individual wires."
	]
	quest.7C27093E25633B9F.title: "Mercurial Fluid Nodes"
	quest.7C3C0E6AC71F621B.quest_desc: ["The &7Item Distributor&r takes items from an inventory above it and evenly distributes them to inventories on each side. "]
	quest.7D63AB919406E5AD.quest_desc: [
		"&7Dorodangos&r produced by &7Alakarkinos&r are suffused with magic, full of latent potential. The &7Steam Alembic&r is capable of transmuting them into invaluable resources. "
		""
		"Of course, only &7Alakarkinos&r knows how to operate the device in this way. Consider setting its home to the &7Input Hatch&r to ensure one is always nearby."
		"&n                                                                          &r"
		""
		"Every Modern Industrialization multiblock requires input and output hatches commensurate with the recipes it handles. "
		""
		"In this case, the &7Steam Alembic&r requires both fluid and item hatches."
		""
		"&a🛈 Tip: Place the controller block, then hold a Wrench "
		"&a    to see the structure. Similarly, hold a Hatch to see "
		"&a    valid locations for them."
	]
	quest.7D82585D50D7207A.quest_desc: [
		"Welcome to Applied Energistics, a powerful logistics and storage mod with fully integrated autocrafting capable of interfacing with most any other mod."
		""
		"The following chapter will take you through getting started with this mod as well as some basic concepts. "
		""
		"We recommend that you also check out the guides and tutorials built into the mod’s own &7Guide&r."
	]
	quest.7D82585D50D7207A.title: "Applied Energistics"
	quest.7D8AEEB13B201CFB.quest_desc: [
		"These highly advanced processors will enable creating a powerful AE2 system to assist in crafting and stock management."
		""
		"Very handy indeed as crafts become more and more complex."
		""
		"[ \"Check out the \", { \"text\": \"Applied Energistics Chapter\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"777EE0C4949DFE12\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]} }, \" for information on setting up an ME Network. \" ]"
	]
	quest.7EBB38BA04910A92.quest_desc: [
		"A cooking pot worthy of any industrial kitchen, this beast can handle larger batches of ingredients at a time. "
		""
		"&6⚠ Note: This structure must be built in "
		"&6    a warm biome, such as the Archwood "
		"&6    Forest on the Blazing Island. "
	]
	quest.7EE93B81F83AD199.quest_desc: [
		"Enchanting &7Clay&r appears to impart it with its own form of transmutation magic, though it seems to need to eat to work?"
		""
		"No matter, this should prove quite useful."
		"&n                                                  &r"
		""
		"To work with Goo, place it and then place the required block next to it so the two are touching. "
		""
		"In this case, we’ll need some &7Slime Blocks&r, which you can make from dough. We'll also need to feed the thing something suitably magical. "
		""
		"A &7Source Berry Roll&r ought to suffice for now."
	]
	quest.7F43653C4B9A96CE.quest_desc: [
		"Made from sturdier materials capable of greater rotational speeds, the &7MV Steam Turbine&r is a logical replacement for any &7LV Steam Turbines&r you’ve been using."
		""
		"It only outputs MV power, so you’ll either need to replace wiring or bridge the two networks with a &7Transformer&r."
	]
	quest.7F445C22C528AC1F.quest_desc: [
		"Runewood Obelisks are used to accelerate the Spirit Altar, so crafting a few should be a high priority. "
		""
		"As many as four Obelisks may be used to speed up crafting, with each one reducing the total crafting time. "
	]
	quest.7F829A1BFED304D0.quest_desc: [
		"What’s magic without some functional devices powered by it? "
		""
		"The following section will highlight some of the more interesting devices Nature’s Aura has to offer. It’s up to you to figure out when and where they make sense in your base!"
		""
		"For a full rundown of how to use these devices, remember to consult the &7Book of Natural Aura&r!"
	]
	quest.7F829A1BFED304D0.title: "Natural Devices"
	quest.7FAC3A637F82BFED.quest_desc: [
		"These floaty little witch friends can be tasked with automating standard 3x3 Crafting Table crafts, Potion Brewing, and even the Enchanting Apparatus. "
		""
		"Obtaining the Wixie Token to craft the Charm is going to require a little bit of Spellcraft; essentially you must Dispel a Witch that’s at less than half health. "
		""
		"&6&nExample Spells&r"
		""
		"&7Villager to Wixie&r"
		"    &5Projectile&r > &aLinger&r > &aLightning&r > &aDispel&r "
