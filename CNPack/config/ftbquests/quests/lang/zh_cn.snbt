	file.0000000000000001.title: "&n&6谜之天空&r"
	quest.00066BB06F509677.quest_desc: ["Item Cards for LaserIO allow Laser Nodes to transport Items."]
	quest.008F3C0FB9F4B451.quest_desc: ["[ \"\", { \"text\": \"火之精华\", \"color\":\"gray\"}, \"能够让你进入\", { \"text\": \"烈焰空岛\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"78626EE046E48EF3\" } }, \"上的炽热火山。\" ]"]
	quest.008F3C0FB9F4B451.title: "烈焰空岛"
	quest.00946DF0B2C88A9F.quest_desc: [
		"金属和塑料可以作为骨骼结构的完美替代，但马达和伺服器在灵活性能上仍有欠缺。"
		""
		"你问为什么要重新创造这些已近乎完善的天然造物？那是因为，这些重新赋予生命的肉体可以继续强化，从而变得前所未有的强壮耐用。"
	]
	quest.00DE313EE5B9954D.quest_desc: ["一个简单的卷尺，可以辅助测量距离。对专业的建筑师们来说非常实用，值得常备一个。"]
	quest.01266355AAB13C39.quest_desc: [
		"凿子（Chisel ）模组提供了大量方块的变种，让你的建筑大放异彩，拿上凿子和方块开建吧！"
		""
		"&a🛈 提示：在EMI中搜索&3@chisel&r查阅"
		"&a    更多相关内容。"
	]
	quest.015857940250CE8D.quest_desc: [
		"&7Fluid Modules&r for &7Modular Routers&r allows them to transfer fluid bi-directionally. They can also be used to place fluid in the world. "
		""
		"The &7Router&r needs some kind of storage tank in its buffer to work. A bucket is sufficient but a larger fluid tank from any other mod is ideal."
	]
	quest.016B7CA4A7FC58A1.quest_desc: ["有了&7黄铜&r之后，你现在可以使用来自机械动力模组的更多功能了，这意味着你现在拥有更多可选的自动化方案。"]
	quest.0227D9EC391788D6.quest_desc: [
		"厌倦了随处可见的线缆？"
		""
		"&7伪装板&r可以由大部分实心方块合成，能够很好的遮盖线缆和线缆组件，让你的AE系统看起来像是基地的一部分。"
	]
	quest.0227D9EC391788D6.title: "线缆伪装板"
	quest.0230942DF53BB9E5.quest_desc: ["下面是可以用来充能物品和装备的方块。"]
	quest.0230942DF53BB9E5.title: "充能器"
	quest.03405336161EF1B5.quest_desc: [
		"在大多数OriTech模组的机器上，都有一个带有两条垂直插口、类似电源插座的蓝色方形。这是用于连接各种&7机器插件&r的接口。"
		""
		"在这些位置添加&7机器扩展坞&r将允许你使用更多插件，但这同时也需要更高品质的&7机器核心&r。使用更好的&7核心&r将增加插件与机器间允许连接的&7扩展坞&r数量。"
		""
		"例如，当机器质量为4时，插件与机器之间最多可放置4个&7扩展坞&r。"
	]
	quest.03405336161EF1B5.title: "机器插件"
	quest.03D475AF2266ECB6.quest_desc: [
		"村民是获取材料的重要来源，一定要多和他们交流，充分利用他们的技术！"
		""
		"首先制作一个&7锻造台&r以获得一个&7工具匠村民&r。他们会向你出售其他村民使用的各种工作站，让你轻松扩展交易业务！"
		""
		"村民需要稳定的优质食物供应才能发挥最佳工作状态，所以请确保食物供应的多样性！"
		""
		"他们还需要保持温暖！如果壁炉的火熄灭了，你们都会一起冻死。"
		""
		"              &6&n实用按键绑定&r"
		""
		"鼠标悬停在&7村民刷怪蛋&r上按&6U&r即可查看所有的村民工作站。"
		""
		""
		""
		""
		"&a🛈 提示：紫色坐垫可以通过法师之花合成获得！"
		""
	]
	quest.03D475AF2266ECB6.title: "村民"
	quest.0458B6BC887C9725.quest_desc: [
		"使用降生祭坛召唤一只&7狼&r，然后从它身上采集一些&7有机物质&r。"
		""
		"&6⚠ 注意：刷怪蛋并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.0458B6BC887C9725.title: "狼"
	quest.04AE4EA4C7CFB080.quest_desc: [
		"&7涡轮增压喷气背包&r的机制与鞘翅类似，你可以使用空格键进行操作。"
		""
		"它所使用的燃料类型与&7锅炉&r相同。"
		""
		"[\"• 切换飞行（\",{\"color\":\"gold\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"切换飞行\"}]},\"keybind\":\"key.modern_industrialization.toggle_flight\"},\"）。\"]"
		""
		"• 在地面上按住空格键垂直抬升。"
		""
		""
		"• 按下空格键开始滑翔。"
		""
		"• 处于滑翔状态下时，按住空格键可以朝视线方向加速。"
		""
		""
		""
		"&c⚠ 警告：请勿在室内使用。"
	]
	quest.04CE3E8B1DF8B441.quest_desc: ["以下是Enigmatica 10中可用的各种流体传输方式。"]
	quest.04CE3E8B1DF8B441.title: "流体"
	quest.04D144DC0EAE8BE3.quest_desc: [
		"购买一个&7酿造台&r，解锁&7牧师村民&r的交易。"
		""
		"尤其是马上就会用到的&7仪式火盆&r，一定要记得换一个。"
		""
		"&a🛈 提示：将药水放入壁炉可以将药水效果扩散到整片区域！"
		""
		""
	]
	quest.04D144DC0EAE8BE3.title: "牧师"
	quest.0537E3C9A2164A7D.quest_desc: [
		"Oritech的&7流体管道&r除了恪尽职守完成自己的本职工作外没有太多花哨的功能。"
		""
		"这些管道分为三种类型，差异主要在外观上。&7带框架的管道&r在管道周围有漂亮的支撑结构；&7集装管道&r则是一个完整的方块，可以严丝合缝地嵌入墙体，不过&7集装管道&r只能与其他管道连接。"
		""
		"右击管道与机器或储罐相连的部分，将其设置为提取模式。"
	]
	quest.053C43E68E7ADB2B.quest_desc: [
		"只要有了&7头颅装配机&r，我们就可以将这些来自不同生物基因材料重新组合、拼接到一起，创作出我们想要的怪物。"
		""
		"&6⚠ 注意：EnderIO模组的机器需要安装电容才能工作。"
		""
	]
	quest.054093E1130E24C1.quest_desc: [
		"&7自动饲育机&r就是一个自动饲育附近动物的站点。"
		""
		"只需要在里面装满动物繁殖所需的物品，剩下的交给它自己搞定。"
		""
		"            &6&n关于自动化的说明&r"
		""
		"&7自动饲育机&r可以用来统计该区域内的动物数量。"
		""
		"将&7红石比较器&r对着它放置以进行粗略估计，每级红石信号表示两只动物。"
		""
		"在信号为15时，机器会停止饲育动物，这意味着是时候开刀了。"
	]
	quest.0545305EBB98A0BA.quest_desc: [
		"&7高级替换器&r必须与另一个&7高级替换器&r绑定，就像&7初级替换器&r那样。"
		""
		"这种替换器运行需要能量，但它有更大的操作范围，对农场更实用。"
		""
		"&a🛈 提示：点击显示区域按钮，这可以让配置工作"
		"&a   区域更方便。"
	]
	quest.0554264AE11578D2.quest_desc: [
		"&7压力室&r是一个来自气动工艺的多方块机器，使用压缩空气进行操作。物品通过机器的&7界面&r输入或提取，气体则通过&7阀门&r进入。"
		""
		"起初接口的运作速度会比较慢，你可以安装一些&7速度升级&r来改善这一情况。"
		"&n                                                &r"
		""
		"一开始可以先搭建一座3x3x3的结构，这个体积更容易达成需要的压力。"
		""
		"&7压力室玻璃&r是可选方块，但建议使用这一方块，以便观察内部情况。"
		""
		"&a🛈 提示：PNC手册中列举了多方块结构的详细需求。"
		""
	]
	quest.0554264AE11578D2.title: "压力室"
	quest.05F232C12FA99F92.quest_desc: [
		"&7电动窑&r能够承受更高的温度，让你得以制造&7钢&r及其他有用的材料。"
		""
		"&n                                       &r"
		""
		"每个现代工业化的多方块结构都需要根据其处理的配方配备相应的输入和输出仓。"
		""
		"该任务中，&7电动窑&r同时需要流体仓和物品仓。"
		""
		"&a🛈 提示：放置控制器方块后，手持扳手即可预览完整结构。类似地，手持仓室可以查看能够放置的位置。"
		""
		""
	]
	quest.062BB5F675CF9F45.quest_desc: [
		"欢迎游玩Just Dire Things！"
		""
		"这个模组包含了许多小型实用方块，让生活更轻松，可以执行与实体交互、种植等多种任务。"
		""
		"此章节将带你熟悉下其使用机制，并介绍些著名方块。"
		""
		"[\"此外，作者还在YouTube上提供了些实用的\",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.youtube.com/playlist?list=PLvGYM7MCieIomj0tKtO9T5DUhvaYFjSxA\"},\"color\":\"blue\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处前往\"}]},\"text\":\"视频教程\",\"underlined\":true},\"。如果你需要帮助，不妨去看看。\"]"
	]
	quest.062BB5F675CF9F45.title: "Just Dire Things"
	quest.064BF1AA27A01A3A.quest_desc: [
		"BetterBlockZ是一款装饰mod，提供了海量受科幻启发的的元素，可以在你建筑中使用。"
		""
		"每个方块有多种变种，可以被快捷键轻松选取。与此同时，你也可以使用多种手杖，来快速修改已经放置的方块。"
		""
		"&a🛈 提示：在EMI中搜索&3@blockz&r&a查询"
		"&a    更多相关内容。"
	]
	quest.064BF1AA27A01A3A.title: "BetterBlockZ"
	quest.064F6355185A51D4.quest_desc: [
		"这些热爱黄金的可爱小家伙们能极大地帮你保持家园整洁。"
		""
		"与箱子绑定后，星宝石兽会迅速收集地面上的物品，把它们放到绑定的箱子里。"
		""
		"它们也可以将物品从一个箱子转移到另一个箱子里。还可以在不被刺扎到的情况下采集魔源浆果！"
		""
		"&a🛈 提示：可以使用允许卷轴和拒绝卷轴对星宝石兽拾取的物品进行配置！"
		""
	]
	quest.07189DA532A429AE.quest_desc: [
		"&7旋风&r魔符能够组合成一些相当实用的法术，但自己获取旋风魔符可能要花些时间。"
		""
		"目前，你可以制作一些特殊的&7施法者卷册&r来使用这些预设法术！"
		""
		"&a🛈 提示：施法者卷册可以用来给法术炮塔设置法术！"
		""
	]
	quest.07189DA532A429AE.title: "旋风"
	quest.0745FDF3F22807CA.quest_desc: ["[ \"\", { \"text\": \"气之精华\", \"color\":\"gray\"}, \"通往令人目眩的\", { \"text\": \"闪耀空岛\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"768869D763EC54EB\" } }, \"。\" ]"]
	quest.0745FDF3F22807CA.title: "闪耀空岛"
	quest.074827E52A09685F.quest_desc: [
		"&7水&r，珍贵又稀少，在这个地方非常难以获得。"
		""
		"目前，你可以通过将云放入&7蓄积器&r中来凝结出极少量的水。"
		""
		"&7蓄积器&r下方的地板中布有管道，可以将&7水&r直接抽到你的&7锅炉&r里。"
		""
		"多余的&7水&r会流入地下室的&7流体抽屉&r，以便取用。只需用空&7桶&r左击抽屉正面即可。"
		""
		"记得留意你的&7壁炉&r！一桶水只能供应大约12分钟。"
		""
		"&6⚠ 注意：水源方块&n无法&r&6提供无限水！"
	]
	quest.074827E52A09685F.title: "水"
	quest.07684F58521A4D34.quest_desc: [
		"在和朋友一起游玩吗？"
		""
		"你可以使用&7注解手抄本&r，将你已掌握的魔符知识分享给你的朋友。"
		""
		"右击保存自己的学习进度，你的朋友再次右击便能获得所有这些保存的进度。"
	]
	quest.07EC0853BE4C6391.quest_desc: [
		"活化一个&7史莱姆&r，然后击杀它以获得&7大地精魂&r。"
		""
		"&6⚠ 注意：这里的仪式图标物品只是方便查阅配方，本身并不是任务目标物品。"
		""
		""
	]
	quest.07EC0853BE4C6391.title: "大地精魂"
	quest.08D496EFE575AD1E.quest_desc: [
		"运气好的话，你会得到一个有你想要的性状的转基因细胞。运气不好的话，那就祝你下次运气好点。"
		""
		"成功之后，再把那个转基因细胞放回DNA提取器，然后像处理正常细胞一样继续操作。最后，你就会得到一个带有你全新升级性状的血液样本。"
	]
	quest.0916404C0979D753.quest_desc: [
		"&7钢材升级&r可以在任意&7安山合金级机器&r上右击使用，直接将其升级为&7钢级&r。"
		""
		"这种升级方式相当无害，被升级的机器将保留所有过滤器和内容物。"
	]
	quest.0963C14E9AF5A836.quest_desc: ["&7有线充能器&r可以给放在其中的设备充能。"]
	quest.09B6773CDA5A7565.quest_desc: [
		"附魔装置应该是你第二个需要搭建的设备，它可以完成更多高级合成操作、装备升级，以及附魔操作！"
		""
		"这一多方块结构可以自由搭建。只有附魔装置必须放在奥术核心上方，其余的奥术基座可以放在核心周围三格以内的任意位置。"
		""
		"基座上的物品会被配方消耗掉。"
	]
	quest.09C3C5173499DF7C.quest_desc: [
		"要开始合成精华，你需要在&7灌注室&r附近摆放一些奥术基座，然后在每个基座上放置一个指示物品。"
		""
		"这些指示物品只是用来设置配方，过程中&n不会被消耗&r。"
		""
		"合适摆放位置是以&7灌注室&r为中心的3x3x3区域。"
		""
		"&a🛈 提示：魔源不是必需的！"
	]
	quest.09C3C5173499DF7C.title: "精华"
	quest.0A8B7FD4A52663D3.quest_desc: [
		"&6谜之天空&r是一款专注于自动化的专家包，整合包的设计旨在以新颖、引人入胜的方式挑战你的能力。"
		""
		"&7谜之天空&r任务线对达成主要进度目标起到主要的指导作用。"
		""
		"                  &n&6关于信息来源的说明&r"
		""
		"本专家包对模组的默认进度和配方做了大量修改。也就是说，本包中所包含的各个模组的指南手册可能会提供错误的信息。这些手册在解释方块和物品的作用方面仍然是宝贵的资源，但请不要认为手册中的配方或进度条件总是准确无误。"
		""
		"对合成配方而言，最好的信息来源是EMI，在查看物品的合成配方时，记得查看所有标签，一个物品可能有多种获取方式。"
		""
		"许多物品还添加了额外的提示框和信息面板，以帮助解释其使用方法，或用来强调该整合包特有的、未作说明的重要信息。"
		""
		"同样地，任务也会为你提供额外的提示和技巧，帮助你更好了解整合包的内容，尤其是在涉及自定义机制的部分。"
	]
	quest.0AEC5C2683575F1C.quest_desc: [
		"&7符文树苗&r可以通过哭泣之井换取。"
		""
		"接下来主要用到的是它的木材，但它的树液也很有使用价值。"
	]
	quest.0B04BC5F88746182.quest_desc: ["以下是一些功能完善的存储系统，它们能容纳多种类型的物品，并通过可交互的界面实现便捷的浏览与搜索功能。"]
	quest.0B04BC5F88746182.title: "存储"
	quest.0B05FA716D7335D2.quest_desc: ["&7初级投物器&r是一款很出色的工具，它可以自动化一些世界交互的配方。"]
	quest.0B17FF64DFA4BA90.quest_desc: ["想更快地到处探索？做个鞘翅就能帅气地在岛屿间滑翔！"]
	quest.0BB08CCD3FEDEB54.quest_desc: [
		"长距离运输材料非常麻烦，但有了&7纠缠方块&r，你就可以把“那边”绑定成“这边”。"
		""
		"手持&7绑定器&r潜行右击容器以选中它，然后再右击&7纠缠方块&r来将二者绑定。"
		""
		"绑定后，你就能够像操作绑定的容器那样，通过&7纠缠方块&r输入输出。非常适合远距离存取流体或物品！"
	]
	quest.0BB6D2595F99ADB4.quest_desc: [
		"既然我们可以活化方块并收集更多种类的精魂，那么是时候深入研究基因改造技术了。"
		""
		"制作一柄&7刮刀&r，并用它右击生物，以此收集生物们的&7有机物质&r。"
		""
		"&a🛈 提示：精细触控魔咒可以让刮刀不再对生物造成伤害！"
		""
	]
	quest.0BF882C463675433.quest_desc: [
		"现在我们有了DNA，是时候该看看它能干什么了。"
		""
		"每个生物都会提供基础基因，但其他生物有概率提供更为特殊的基因，这些才是我们想要的东西。"
		""
		"举个例子，如果从羊开始这套流程，就有概率获得吃草基因，它可以让你通过右击草来吃草。"
		""
		"&a🛈 提示：在EMI中查看DNA螺旋的配方，了解能从哪些生物身上获取"
		""
		""
	]
	quest.0C0A7017CEF34F6C.quest_desc: [
		"你可能会想，把这些玩意丢地上冷却不就好了。"
		""
		"不幸的是，我们需要一个稍微更可控的环境，以保证&7塑料&r成品的质量稳定。"
	]
	quest.0C32904CD01E4743.quest_desc: [
		"活化一个西风啸云，然后收集它的身体部件。"
		""
		"&6⚠ 注意：仪式图标物品并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.0C8FAB4B801907B1.quest_desc: [
		"&7特斯拉手持接收器&r可以无线接收能量，在和你的特斯拉线圈连接后。"
		""
		"它可以给你物品栏中用FE和EU的设备充电，是保持电量充足的实用工具。"
	]
	quest.0CCE0467AF123EAB.quest_desc: [
		"Just Dire Things introduces a number of tools with special capabilities, from aoe breaking to teleportation of items to a linked inventory. "
		""
		"Higher tiers also run on FE instead of using durability!"
		""
		"&a🛈 提示：手持工具潜行右击可以打开它们的选项菜单。"
		""
	]
	quest.0D32F25CCBC9B192.quest_desc: [
		"用于传输现代工业化EU电力的简易电缆。"
		""
		"也可以为使用FE的机器供电，但只能接从现代工业化的发电机中提取能量。"
	]
	quest.0D65061DFD04B301.quest_desc: [
		"&7Item Modules&r for &7Modular Routers&r allow them to send to or pull from an inventory. "
		""
		"The first tier, MK1, can only send in a straight line, while MK2 can interact with any linked inventory in range. MK3 Senders are special in that they have no range limits and work across dimensions."
		""
		"&7Distributor Modules&r can pull from or send to a maximum of up to eight inventories per module, making them perfect for distributed crafts or collecting from many machines."
	]
	quest.0D65061DFD04B301.title: "物品模块"
	quest.0D7B7B9CF7362FD8.quest_desc: [
		"有不想要的性状？你可以制作抗质粒来移除它。"
		""
		"将它与同类型的质粒一起合成。然后将其注入血液样本，就像使用普通质粒一样。"
	]
	quest.0DA6F0172E06CCB1.quest_desc: [
		"在工具升级系统的基础上，Just Dire Things也为各个等级的盔甲引入了多种能力。"
		""
		"和工具类似，这些升级通过锻造台加装在盔甲上。其中许多升级是主动能力，而非始终生效的被动能力。"
		"其中一些能力，如疾跑速度，会根据盔甲等级提升其效果。"
		"&n                                       &r"
		""
		"要配置盔甲能力并为其绑定按键，你需要在穿戴盔甲的同时手持Just Dire Things模组的任意工具。"
		""
		"手持工具潜行右击打开菜单，然后再点击盔甲栏中显示的各个装备。"
		""
		"下文将介绍每种能力的效果。"
		""
		"&a🛈 提示：在EMI中，将鼠标指针悬停在盔甲上按下Shift，即可查看能够加装的所有升级。"
		""
		""
		"{@pagebreak}"
		"&7&n头盔能力"
		""
		" • &a夜视&r：持续提供夜视效果。"
		""
		" • &a水下呼吸&r：持续提供水下呼吸效果。"
		""
		" • &a减益移除&r：激活时移除减益效果。"
		""
		"{@pagebreak}"
		"&7&n胸甲能力"
		""
		" • &a无敌&r：激活时提供短暂的无敌效果。"
		""
		""
		" • &a灭火&r：着火时自动扑灭火焰。"
		""
		""
		" • &a鞘翅&r：提供鞘翅飞行能力。"
		" • &a死亡保护&r：每过一段时间获得一次免遭死亡的机会。"
		""
		" • &a飞行&r：提供创造模式飞行。"
		" • &a熔岩免疫&r：完全免疫火焰伤害。"
		"{@pagebreak}"
		"&7&n护腿能力"
		""
		" • &a疾跑速度&r：提供可调节的疾跑速度加成。"
		""
		" • &a行走速度&r：提供可调节的行走速度加成。"
		""
		" • &a游泳速度&r：提供可调节的游泳速度加成。"
		""
		" • &a诱饵&r：生成一个吸引怪物的诱饵。"
		""
		" • &a穿墙&r：允许你穿过墙壁。但在方块中无法透视，且坠落时会穿过地面。"
		""
		""
		""
		"{@pagebreak}"
		"&7&n靴子能力"
		""
		" • &a步伐辅助&r：直接走上完整的一格方块。"
		" • &a跳跃提升&r：提供可调节的跳跃高度加成。"
		""
		" • &a抵消衰落&r：软着陆。"
		" • &a震地&r：激活时击退附近的生物。"
		""
		" • &a地震&r：激活时对附近的生物施加缓慢效果。"
		""
	]
	quest.0DA6F0172E06CCB1.title: "Just Dire Things模组的盔甲"
	quest.0DD1FC129B316381.quest_desc: [
		"这些红石装置对于本章中的一些自动化流程极为有用。"
		""
		"发挥创意，看看其他可能有用的装置，比如&7红石笔&r模组中的设备，乃至&7侦测器&r这样的原版方块。"
	]
	quest.0DE5D9ADB947B171.quest_desc: [
		"活化一个&7荒野奇美拉&r，然后击杀它以获得&7荒野供物&r。"
		""
		"&7奇美拉肉&r可以使用&7碎魂武器&r攻击获得，也可以用多余的&7荒野供物&r与&7屠夫&r交易得到。"
		""
		"&6⚠ 注意：这里的仪式图标物品只是方便查阅配方，本身并不是任务目标物品。"
		""
		""
	]
	quest.0E1258E2B2C7FFD5.quest_desc: [
		"&7Modular Routers&r can be upgraded with an &7Energy Distributor Module&r, allowing them to deliver power wirelessly to eight different blocks per module."
		""
		"To use them, the &7Router&r must also have an &7Energy Upgrade&r installed, which determines the type of energy the &7Router&r will send. This is fully compatible with both FE and EU."
	]
	quest.0E1F3FCCA1A9E405.quest_desc: [
		"这些简单的平台仅由草地和云朵构成。"
		""
		"如果想要扩建基地，就用它们来帮你！"
	]
	quest.0F63D034A018A4FC.quest_desc: ["在你的动物下方放置&7排污器&r可以收集&7污水&r，污水可以用来获取更多&7水&r并最终转化为&7石油&r！"]
	quest.105CABB7D9705359.quest_desc: [
		"&7农民&r有一些非常实用的工具，可以帮助你加快作物农场的速度。务必要去看看他们的商品哦！"
		""
		"他们还会提供&7菌丝魔源通道&r，将食物直接转化为魔源，帮助你开始魔源生产。"
	]
	quest.105CABB7D9705359.title: "农民"
	quest.11B62E499806390F.quest_desc: [
		"&7收获之板&r是在游戏早期开始自动化作物种植的好方法。"
		""
		"它不仅会收获你在农田里种植的普通作物，还能轻松收获树上生长的豆荚，比如&7可可豆&r、&7门多山竹&r，以及新生魔艺中的其他豆荚。"
		""
		"它每收获一株作物，就要从附近的&7魔源罐&r中消耗少量魔源。收获的所有物品都会被存入相邻的容器中。"
		""
		"&a🛈 提示：粒子效果表示该仪式的生效区域。"
		""
	]
	quest.11EDFB60C787114D.quest_desc: [
		"&7凝胶&r可以用来转化其周围的材料，让它们变成更有价值的物质。"
		""
		"将物品放置在&7凝胶&r的任意一面便可开始转化，不妨放置些&7铁块&r来做些&7核源铁&r。"
		""
		"当方块完全被&7凝胶&r吞噬后，它们将会被晶簇取代，挖掉晶簇便可获得转化后的材料。"
		""
		"&6⚠ 注意：凝胶饿了，需要喂食才能工作！"
		""
		""
		"&6手持物品右键激活。"
		"&6    在EMI中搜索&3#goo_revive_tier_1&6来查看"
		"&6    哪些物品有效！"
	]
	quest.123BB918DF6E3936.quest_desc: [
		"想要更传统的管道？这些来自Oritech的管道应该能满足你的要求。"
		""
		"只需将管道放置下来，右击与容器的连接处，即可从提取模式和输入模式间切换。"
		""
		"然而，&7物流管道&r有个小特点：默认情况下，它只从相连容器的第一个槽位提取物品。"
		""
		"要让它们能够从全部槽位提取，只需对连接处使用&7迅捷符文&r即可。"
	]
	quest.1275C61F2390D761.quest_desc: [
		"&7ME复制连接器&r能把你的复制网络与AE2网络链接起来。有了它，AE2就能从你的复制网络请求任何物品进行自动合成。"
		""
		"一定要学会如何在AE2创建物质类型：将样板供应器对着分解器放置，然后给每种物质类型设置样板。"
		""
		"最好为每种物质类型创建一个样板。"
	]
	quest.128449F277949E31.quest_desc: [
		"将&7促符&r放在&7修复基柱&r上后，放在激活的&7精魂坩埚&r附近，就可以修复它，并使其在最佳工作状态。"
		""
		"当然，&7修复基柱&r需要合适的材料才能进行修复，具体配方可在EMI中查询。它同样可以用来修复许多在铁砧上修复的物品。"
		""
		"对于这种物品，你需要把它们放置在附近的物品台或物品基座中。"
	]
	quest.12E0E45FC08A5912.quest_desc: ["&7无线玩家充能器&r可以在小范围内给你身上的设备充电。"]
	quest.12E7105B33AC043E.quest_desc: ["[ \"\", { \"text\": \"防护之精华\", \"color\":\"gray\"}, \"能够让你进入\", { \"text\": \"恼人空岛\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"13F15094F3AF4A73\" } }, \"的枯萎之地。\" ]"]
	quest.12E7105B33AC043E.title: "恼人空岛"
	quest.130A2701B96A941D.quest_desc: [
		"这个地方基本不会有怪物，然而，有比周围徘徊的僵尸和骷髅更严重的事情等待处理。"
		""
		"亭子下面的&7壁炉&r启动后就能让整个建筑内保持温暖。"
		""
		"将任务奖励的&7小块木炭&r放进左边的&7箱子里&r，&7晶化水&r右击放入右边的&7蓄积器&r里。"
		""
		"如果你想查看壁炉的工作情况，打开壁炉前的&7活板门&r即可前往地下室。"
		""
		"&7壁炉&r需要一些时间加热，而且它不会给地下室供暖。你可以从地下室的&7破朽锅炉&r里查看壁炉的工作情况。"
		"{@pagebreak}"
		"&7壁炉&r可以在&7室内区域&r为&7半径20格的球形范围&r提供热量，壁炉产生的热量无法穿过固体方块。"
		""
		"在壁炉顶部搭建&7烟囱&r能够改变保护区域的中心点。"
		""
		"每个&7壁炉&r只能创造一片保护区域，分叉&7烟囱&r无法使其影响多个区域。"
		""
		"&7壁炉&r有两个面用来&c制热&r（左面和后面），两个面用来&9制冷&r（右面和下面）。"
		"&n                                                &r"
		""
		"                       &6&n燃料"
		"      &c制热&r                             &9制冷&r"
		"      &7蒸汽                               &7冰"
		"&n                                                &r"
		""
		"这些面需要合适的&7燃料&r并通入&7红石&r信号才能启动壁炉。"
		""
		"举例来说，将&7蒸汽&r输送至左侧，红石线路通向后侧，用&7红石&r启动壁炉，为这片区域供暖。"
	]
	quest.130A2701B96A941D.title: "欢迎来到天空！"
	quest.136AD444BD07EFCF.quest_desc: [
		"&7收割机&r和&7播种机&r是两台相辅相成的机器。"
		""
		"默认情况下，当收割机&7收割&r作物时，会破坏作物留下空地。因此，&7播种机&r需要配合使用来重新种植这些空地，以保持整个系统运行。"
		""
		"最好把&7收割机&r放在田地边缘，而&7播种机&r则放在田地正中央的地下。"
		""
		"务必在其GUI中勾选“显示工作区域”按钮，以了解它们的作业范围。"
		""
		"安装了&7插件：范围升级插件层级4&r后，这些机器的工作范围将能够覆盖标准的9x9农田。"
		""
		"&a🛈 提示：向收割机提供以太气体能够使其在不破坏作物的情况下收割。"
		""
		""
	]
	quest.136AD444BD07EFCF.title: "作物种植"
	quest.136EC4060E233E16.quest_desc: [
		"建筑手杖适合于大量放置方块的场景，例如搭建墙壁和地板等。"
		""
		"They offer a variety of options out of the box, but can be upgraded with new features by applying a Template in a Smithing Table.  "
	]
	quest.136FD7D7C0EECAE3.quest_desc: [
		"The first step to making our own &7Oil&r is, of course, lots of organic material. "
		""
		"You should have plenty of raw materials for this from your various animal farms and dorodangos. "
	]
	quest.13F15094F3AF4A73.quest_desc: [
		"                      &6&n生物群系：蘑菇岛&r&r"
		""
		"以下放置转换规则在本生物群系中生效。务必记得这一规律，这样在使用“构筑地层”法术时能更加灵活的生成方块。"
		""
		"  • &7泥土&r                      &2⟶&r           &7腐枯土&r"
		"  • &7草方块&r                    &2⟶&r           &7腐枯土&r"
		"  • &7圆石&r                      &2⟶&r           &7污秽石&r"
		"  • &7石头&r                      &2⟶&r           &7平滑污秽石&r"
		"  • &7沙子&r                      &2⟶&r           &7寒风境云&r"
		"  • &7沙岩&r                      &2⟶&r           &7速沙&r"
		"  • &7深板岩圆石&r                &2⟶&r           &7扭曲石&r"
		"  • &7深板岩&r                      &2⟶&r           &7平滑污秽石&r"
		""
		"{@pagebreak}"
		"&6&n示例法术&r"
		""
		"&7构筑腐枯土&r"
		"    &5触摸&r > &a构筑地层&r"
		""
		"&7构筑污秽石&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r"
		""
		"&7构筑平滑污秽石&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &a烧炼&r"
		""
		"&7构筑寒风境云&r"
		"    &5触摸&r > &a构筑地层&r > &a粉碎&r"
		""
		"&7构筑速沙&r"
		"   &5触摸&r > &a构筑地层&r > &6强化&r > &a粉碎&r"
		""
		"&7构筑污秽石&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &6强化&r"
		""
		"&7构筑平滑污秽石&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &6强化&r > &a烧炼&r"
	]
	quest.140BFF0572840B6E.quest_desc: ["这款二合一的充能器不仅能充能，同时还能补充流体，因此与&7喷气背包&r一起使用更佳。"]
	quest.144E3D7884732298.quest_desc: [
		"&7无人机&r是强大的可编程设备，几乎无所不能。"
		""
		"无论是持械讨伐生物、挥镐破坏方块，还是放置方块、收集物品、处理流体乃至合成物品，它们全能完成。"
		""
		"不过，要想使用它们，需要了解编程。借助&7编程器&r，你只需如拼拼图般拼接模块，便能使用简单的&7可视化编程语言&r构建程序。"
		""
		"无人机还能读取各类信息来触发条件逻辑，例如所有者的位置与朝向、特定方块的红石信号强度、流体与物品余量，乃至生物的生长阶段等。"
		""
		"尽情发挥创意，探索无限可能吧。无论是管理牲畜、击杀生物、运作树场等繁杂的农业任务，还是操纵仪式等精密的合成机制，它们都能游刃有余。"
		""
		"&a🛈 提示：务必查阅指南，了解更多关于无人机编程的详细信息。"
		""
	]
	quest.144E3D7884732298.title: "可编程无人机"
	quest.1476B02AA2977ACB.quest_desc: [
		"在高空的有趣之处就在于，只要设置得当，就能吸引到大量闪电。"
		""
		"&7静电压缩机&r会随机吸引雷击，将能量转化为压缩空气，最高可达&720bar&r。"
		""
		"在晴朗的天气下它的表现也不错，但暴风雨来临时它才能真正运转起来。"
		""
		"到目前为止，它都&o非常高效&r。"
		"&n                                       &r"
		""
		"[\"你可以在\",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://blockprints.io/schematic/f0d838f5-6460-4f3d-aaf0-ab6590df20e5\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]},\"text\":\"BlockPrints.io\",\"underlined\":true},\"找到该压缩机所需结构的搭建示例，按(\",{\"color\":\"gold\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"translate\":\"key.blockprints.open_menu\"}]},\"keybind\":\"key.blockprints.open_menu\"},\")键打开菜单！\"]"
		""
		"&a🛈 提示：在EMI中搜索&3#electrostatic&r&a查阅所有能够作为静电网格的方块。"
		""
	]
	quest.1476B02AA2977ACB.quest_subtitle: "效率惊人"
	quest.149BC66585EA0C34.quest_desc: [
		"每个连接至&7主讲台&r的书龙都可以连接八个容器。但如果你直接连接到箱子之类的容器，连接数量很快就会用光。"
		""
		"要解决这一问题，将其改为连接至&7仓库目录&r，并将&7仓库&r紧邻仓库目录放置。"
		"&n                                       &r"
		""
		"&7仓库目录&r充当存储控制器的角色，能够最大化连接到存储系统的容器数量。"
		""
		"所有相邻且相互连接的&7仓库&r都会自动加入&7目录&r，存入其中的物品将被智能分类到相连的所有&7仓库&r中。"
		""
		"&7仓库目录&r和&7仓库&r仅作为一个推荐，使用其他容器也无妨。"
	]
	quest.154F980273016EAF.quest_desc: [
		"仅需要一点火花，&7蒸汽&r便点燃了&7光以太&r。"
		""
		"&a🛈 提示：放置控制方块，然后拿着扳手来预览结构。"
		"&a   同样，拿着仓室可以显示它们的位置。"
		""
	]
	quest.157A20804F9E8F83.quest_desc: [
		"在世界合成中，一个&7物品拾取器&r肯定会派上用场。"
		""
		"&7物品拾取器&r会将其中的物品放到附近的库存中，并支持多种方式过滤。"
		""
		"&a🛈 提示：点击显示区域按钮，这可以让配置工作"
		"&a   区域更方便。"
	]
	quest.159F7020B1DE875D.quest_desc: [
		"想要带上你的新朋友一起冒险吗？"
		""
		"把它们带到&7绑定仪式&r的附近，你就会得到一个&7绑定手稿&r，对空中右击即可习得这一使魔。"
		""
		"习得使魔后，你的&7法术书&r中&7使魔&r一栏就会出现新的条目。你现在可以随时召唤一个使魔（一次只能召唤一个），以此获得增益效果。"
		""
		"增益效果可以是增加法术伤害或提高抢夺概率，也可以是提升速度或范围收集物品等。"
		""
		"可在每种&7绑定手稿&r的提示框里查看它们能解锁的内容！"
	]
	quest.15FAB1720AD470A0.quest_desc: [
		"每种现代工业化的多方块结构中，输入仓与输出仓需要完全匹配待处理的配方。"
		""
		"该任务中，&7蒸汽窑&r同时需要物品和流体仓。你可以放置多个仓以输入多种原料。"
		""
		"你需要至少一个流体输入仓来提供&7蒸汽&r，驱动设备。你可以从&7破朽锅炉&r里导出蒸汽。"
		""
		"在&7EMI&r中，查看控制器方块（即&7蒸汽窑&r方块）的用途便可知道这个结构所需的其他方块。注意，所列的方块可被仓室替代。"
		""
		"&a🛈 提示：放置控制器方块后，手持扳手即可预览完整结构。类似地，手持仓室可以查看能够放置的位置。"
		""
		""
	]
	quest.161CA05D18639AD4.quest_desc: [
		"该工作站允许&7薇克精&r使用&7农夫乐事切削&r配方。"
		""
		"不过，它只会生产配方的主产物。例如，以此方式生产&7稻米&r时&n不会&r产出&7草杆&r。"
		""
		"                   &6&n转化&r"
		""
		"手持&7薇克精护符&r右击&7砧板&r。"
		""
		"&6⚠ 注意：对于多步合成，每一步都需要分别标示出来。"
		""
	]
	quest.161CA05D18639AD4.title: "薇克精切削"
	quest.16BFB19411FE195F.quest_desc: [
		"LaserIO is a catch all logistics mod capable of many things. "
		""
		"Check out the guidebook for more information on how to use it to your advantage!"
	]
	quest.16BFB19411FE195F.title: "LaserIO"
	quest.16C7D5478BF3D449.quest_desc: [
		"&7学习&r章节旨在帮你发现各大主要模组的实用部分。"
		""
		"这些章节还包含指引你利用各种模组特性的提示。"
		""
		"这些章节涵盖的内容虽然广阔，但也并非全部。因此，务必去查阅那些模组附带的指南手册。"
	]
	quest.16C7D5478BF3D449.title: "学习模组"
	quest.17198F7EC5DC1A4F.quest_desc: ["这些生化&7机械臂&r可能气味上令人不适，但它们极其精准，且能在任务中根据情况变化灵活调整。"]
	quest.17553CF42EDC67A6.quest_desc: [
		"引导更强大的魔法需要更专业的媒介。"
		""
		"使用在岛上发现的材料升级你的&7法术书&r，开启一个充满可能性的全新世界。"
		""
		"&a🛈 提示：法术书中的法术会在升级后保留！"
		""
	]
	quest.17553CF42EDC67A6.title: "二级法术"
	quest.18A17E8080792318.quest_desc: [
		"需要更多空间吗？你随时都可以再召唤另一座空岛。"
		""
		"或者使用&7防护之精华&r右击&7污秽石&r，将&n21x11x21&r的区域变成该空岛的生物群系！"
	]
	quest.18A17E8080792318.title: "生物群系转化"
	quest.18D575594C6F74A7.quest_desc: [
		"由&7沙子&r制成的&7粉质泥球&r可以加工成新材料！"
		""
		"                    &n&6材料&r"
		""
		"  • &7海晶碎片&r"
		"  • &7海晶砂粒&r"
		"  • &7鹦鹉螺壳&r"
	]
	quest.19F8B29D38CA31B8.quest_desc: [
		"这座空岛上生长的&7闪耀至高树&r上已经结出了一些&7闪电菠萝&r。"
		""
		"可以先收集一些，然后随时可以建造一个农场。闪电菠萝可以在&7闪耀至高原木&r上生长，可以通过&7骨粉&r或其他催熟手段加速生长。"
		""
		"&a🛈 提示：收获仪式可以更方便地采集这些水果！"
		""
	]
	quest.1A2B5BCA37161B1A.quest_desc: [
		"该工作站允许&7薇克精&r使用&7附魔装置&r配方。"
		""
		"对于重复制作来说尤其有用，因为&7薇克精&r处理材料的速度比普通&7附魔装置&r更快。"
		""
		"                   &6&n转化&r"
		""
		"手持&7薇克精护符&r右击&7附魔装置&r。"
		""
		"&6⚠ 注意：对于多步合成，每一步都需要分别标示出来。"
		""
	]
	quest.1A2B5BCA37161B1A.title: "薇克精附魔"
	quest.1A9CC0DF3D43189C.quest_desc: [
		"生成的空岛会将所处的区域转化为其对应的生物群系类型，从而开启新的方块转化并解锁新资源。"
		""
		"要将一片区域重置为虚空生物群系，只需使用&7召唤之精华&r右击&7圣石&r，即可将&n21x11x21&r区域转换为该生物群系！"
	]
	quest.1A9CC0DF3D43189C.title: "生物群系转化"
	quest.1AB4455F15DF1F84.quest_desc: [
		"&7自然祭坛&r是最常用的灵气设备。"
		""
		"你可以把灵气想象成氧气和二氧化碳，在你呼吸时，吸入氧气、呼出二氧化碳，若只消耗氧气却不补充，最终将会死亡。"
		""
		"灵气，就是你的氧气。"
		""
		"&7灵气制造设备&r可以制造灵气，但灵气是一种需要维护的有限资源，一旦过度消耗，可怕的事情便会接踵而至。"
		""
		"万幸的是，一旦灵气过低，&7自然祭坛&r会直接停止工作，但其他设备却能将灵气彻底耗尽。"
		""
		"&7自然灵气之书&r会为你详细讲解这种神秘能量。"
		"&n                                                &r"
		""
		"该设备需搭建多方块结构才能正常工作。"
		""
		"你可以参考&7自然灵气之书&r，提前查看方块的摆放方式。"
	]
	quest.1ABB07894781F511.quest_desc: [
		"在你的牲畜附近放置一些&7繁殖之粉&r，便可以用灵气代替食物来让它们保持快乐并促进繁殖。"
		"&n                                                &r"
		""
		"粉末可以成组使用，其作用范围直接取决于放置时手持的粉末数量。"
		""
		"例如，手持六个粉末放置在地面上，这六个粉末将作为一个整体放置，其效果覆盖半径六格范围。"
		""
		"手持你的&7奥秘放大镜&r右击漂浮的粉末来可视化效果区域。"
		""
		"&a🛈 提示：击打粉末就可以移除他们。"
		""
	]
	quest.1ABB07894781F511.title: "说到底不过是哺乳动物而已"
	quest.1ACB8880980AF206.quest_desc: [
		"没做的事情堆积成山，一个人实在难承其重。看你周围也没什么人，该搞几个朋友了。"
		""
		"长久以来，人偶的制造方式总是如此：将黏土塑成人形，再把承载指令的纸条嵌入其脑中。"
		""
		"然后，用一抹魔法来赋予它生命的表像。"
		"&n                                       &r"
		""
		"合成一些&7魔源墨水&r和&7空白羊皮纸&r，用它们制作一个&7雕像&r。"
		""
		"&7速沙&r烧制成的玻璃非常适合做成&7瓶子&r。"
	]
	quest.1ACB8880980AF206.title: "以章显才"
	quest.1AE63FE6C7EF59AB.quest_desc: ["让&7初级点击器&r或&7执行模块&r使用&7碎魂武器&r攻击生物，可以更高效地自动化生产并收集&7精魂&r。"]
	quest.1AE63FE6C7EF59AB.title: "咔哒咔哒"
	quest.1B0718B6BDA972F0.quest_desc: ["锅炉燃料的最高等级——&7蚀空燃液&r，给你机器供能的最高效方式。"]
	quest.1B276AC6C7D95526.quest_desc: [
		"&7等离子涡轮机&r可以从&7光以太&r中获得原始创世能量。"
		""
		"这只是你至今为止用过的众多&7涡轮机&r中的一台，但你还需要不少这样的涡轮机来满足你&7聚变反应堆&r的产能。"
		""
		"&a🛈 提示：放置控制方块，然后拿着扳手来预览结构。"
		"&a   同样，拿着仓室可以显示它们的位置。"
		""
	]
	quest.1BAEB780F38B1C56.quest_desc: [
		"将一个ME无线访问点接入你的网络，然后将无线终端放在其中进行连接，这样你就可以无线访问你的网络。"
		""
		"范围越远，耗能越多！"
	]
	quest.1BDCA4CF5ED739BA.quest_desc: ["更高级的凝胶可以解锁更多配方，并且加快在游戏世界中的方块处理速度。"]
	quest.1C21EC957B97C70A.quest_desc: [
		"&7高级点击器&r相当适合对生物进行操作，放入武器或工具时，它既能攻击生物，也能右击与生物交互。"
		""
		"且与&7初级点击器&r不同，&7高级点击器&r可以在更大的区域内工作。"
	]
	quest.1C4DB05778703E9B.quest_desc: [
		"&7监守者&r为了保护而被创造出来，至少原本如此。"
		""
		"不知何时起，它们认定守护的最佳方式便是吞噬所守护之人的灵魂。毕竟，如果连躯体都不复存在，便再无人能受到伤害。"
		""
		"通过收割这些生物的灵魂，我们可以让许多机器运行得更快。"
		"&n                                                &r"
		""
		"许多机器都内置了加速方法，比如插件、升级等。然而有时仅凭这些并不足够。另一些情况下，机器本身根本没有内置的提速方式。"
		""
		"这个系统可以极大地加速诸如&7厨锅&r和&7自然祭坛&r等设备的运作。"
	]
	quest.1C83B47F599B117A.quest_desc: [
		"目前为止，我们已涉足了灵魂的魔法。要想再进一步深入，我们就必须凝视虚空本身。"
		"&n                                       "
		""
		"找到一座哭泣之井，并将你的奥术全典丢进去，来获得必要的知识。"
		""
		"在全典转化之后，你会发现多出了一个新章节：&d虚空通史&r"
	]
	quest.1C9565D5C51B74CC.quest_desc: [
		"在准备好&7细胞分析器&r与&7DNA提取器&r后，你可以使用它们分解&7有机物质&r，从而提取出&7DNA&r。"
		""
		"然后可以将这些DNA样本拼接起来，注入到某个宿主体内，创造出全新的生物。"
		""
		"[ \"这些机器也能让实体获得永久的增益效果。详见\", { \"text\": \"Genetics: Resequenced\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"7F17CDF8564DCC49\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处前往\"}]} }, \"章节。\" ]"
	]
	quest.1C9565D5C51B74CC.title: "基因"
	quest.1CBC50FA40BFB54A.quest_desc: [
		"&7大型蒸汽涡轮机&r用&7蒸汽&r运行，就像你之前的电力设施一样。&7热交换机&r便可胜任。"
		""
		"它也可以接受&7高压蒸汽&r，但正如之前提到的，这&n并不提倡&r。"
		""
		"                         &n&6关于比率的说明&r"
		""
		"每台&7涡轮机&r可以处理等价于16kEU/t的蒸汽，最终比例为&7两台锅炉&r比&7一台热交换机&r比&7一台大型蒸汽涡轮机&r. "
		""
		"不过，要使&7涡轮机&r达到这一产能，需要&7超高压等级能量仓&r和线缆。它当然可以使用低级的仓室，但这会导致输出被限制。"
		""
		"&a🛈 提示：放置控制方块，然后拿着扳手来预览结构。"
		"&a   同样，拿着仓室可以显示它们的位置。"
		""
	]
	quest.1CEDA28FD4CB759E.quest_desc: [
		"&7Transfer Labels&r slip between blocks to enable block-to-block transfer without a pipe. "
		""
		"Sneak + Right-Click to install one on the side of a block. Once installed, the label may be configured by Right-Clicking either with another label or with a &7Label Accessor&r. "
		""
		"While in the Configuration screen, you may add more labels to control the quantity and speed of transfer, as well as set filters."
		""
		"The label may be removed by Left-Clicking it with another label or with a &7Label Accessor&r."
	]
	quest.1CF0D1E63C34AE6E.quest_desc: [
		"&7精魂催化器&r能加速&7精魂坩埚&r。只需将它们放置在附近，并填入指定熔炉燃料即可。"
		""
		"以此方式加速&7坩埚&r的同时，也会导致&7促符&r耐久消耗加快，但这种方式算是利大于弊。"
	]
	quest.1CF4103BFBCE0E29.quest_desc: [
		"有了&7灌注室&r，就有了进入新空岛的渠道，每个空岛都有自己独特的资源和方块转化类型。"
		""
		"使用你的&7魔源宝石&r来制作各个空岛所需的&7精华&r。"
		""
		"然而，这些空岛并非相互独立；在探索每个空岛的任务时，深入程度越高，就越需要其他空岛的资源。"
		""
		"因此你应该尽快将所有空岛召唤出来。"
		""
		"[ \"一个比较好的起点是\", { \"text\": \"繁茂空岛\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"6490781066FAE8CF\" } }, \"，所以先收集制作\", { \"text\": \"土之精华\" , \"color\":\"gray\"}, \"的材料吧。\" ]"
		""
		"使用&7灌注室&r时，需要在其相邻位置放置一些&7奥术基座&r或&7奥术台座&r。配方中间显示的物品放入&7灌注室&r中，其余材料则必须放置在&7基座&r上。"
		""
		"&6⚠ 注意：基座上的物品&n不会&r&6被消耗。"
		""
		"&a🛈 提示：魔源不是必需的，但能加快制作速度！"
	]
	quest.1D2F5CE5D285BAEA.quest_desc: [
		"曾经，&7风转草&r们在大地上游荡，并守护着大自然。虽然它们如今销声匿迹，但也许仍有办法逆转这一现状？"
		""
		"古老的文字提到了它们与另一种生物&7悦灵&r的联系，而后者我们稍作努力便能召唤……"
		"&n                                       &r"
		""
		"合成一盏&7神灯&r，然后通过&7降生祭坛&r释放里面囚禁的生物。最后从它身上收集一些&7有机物质&r。"
		""
		"&6⚠ 注意：刷怪蛋并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.1D2F5CE5D285BAEA.quest_subtitle: "要好好爱护我哦"
	quest.1D2F5CE5D285BAEA.title: "瓶中精灵"
	quest.1D5616DFA428D46F.quest_desc: [
		"建筑小帮手模组提供了一系列使用FE能量驱动的工具，用以完成例如方块放置、方块替换、复制粘贴甚至是删除大片方块的工作。"
		""
		"If you’re looking to build a massive base, Building Gadgets likely has a tool to help. "
		""
		"&a🛈 Tip: Search &3@buildinggadgets&r &ain EMI"
		"&a    to discover more."
	]
	quest.1D5616DFA428D46F.title: "建筑小帮手"
	quest.1D5E773A3A547A2C.quest_desc: [
		"If you’re into Cottagecore or just want some knicknacks to fill your shelves with, Handcrafted is the place to start. It’s loaded with comfy chairs and interior decorations."
		""
		"&a🛈 提示：在EMI中搜索“&3@handcrafted&r”&a查阅更多相关内容"
		""
	]
	quest.1D5E773A3A547A2C.title: "精巧手艺"
	quest.1D783196F551142F.quest_desc: [
		"吃得好，干得好。"
		""
		"给你的村民供应上你能提供的最营养的烹饪美食，它们便能创造出奇迹。"
		""
		"                 &6&n关于自动化的说明&r&r"
		""
		"&7厨锅&r和&7熔炉&r类似，都是固定侧面传输的方块，也就是说，在传输时，物品只能从特定的面输入输出。"
		""
		" • 食材必须从顶部输入。"
		""
		""
		" • 盛装容器，比如&7瓶子&r和&7碗&r，必须从侧面输入。"
		""
		""
		" • 烹饪出的食物只能从底部输出。"
		""
		""
		" • 其余物品，比如食材槽位中的瓶子，会被直接扔在地上。"
		""
		""
		"物品的输入顺序无关紧要，重复物品可堆叠在同一槽位中。"
		""
		"由于这些限制，早期自动化&7厨锅&r会比较困难，因为当&7热源&r位于&7厨锅&r下方时，几乎没法从底部提取物品。"
		""
		"然而&7星宝石兽&r能够做到这一点。"
	]
	quest.1D7DF143EDEAE1EC.quest_desc: [
		"无需任何麻烦就能种植更多蘑菇的巧妙装置。"
		""
		"只需提供电力、水和一些蘑菇就能启动，剩下的它会自己完成。"
	]
	quest.1D9182A079919158.quest_desc: [
		"需要更多空间吗？你随时都可以再召唤另一座空岛。"
		""
		"或者使用&7气之精华&r右击&7幽匿块&r，将&n21x11x21&r的区域变成该空岛的生物群系！"
	]
	quest.1D9182A079919158.title: "生物群系转化"
	quest.1DA29F3B45DEFB4B.quest_desc: [
		"魔法师这个职业可能会很孤独。周围人都在关心你做的如何，却没有人关心你过的如何。"
		""
		"虽然你也可以使用法术炮塔替你放法术，但炮塔给人的感觉要更加冰冷……且死气沉沉。"
		""
		"如果说你可以创造出自己的伙伴呢？这些可爱的、招人喜欢的、让人想抱抱的伙伴们，哪怕只是看它们在周围玩耍，都可以幸福很久。"
	]
	quest.1DA29F3B45DEFB4B.title: "魔法伙伴"
	quest.1DB63D0AAD1F0E11.quest_desc: [
		"由&7平滑玄武岩&r制成的&7火山泥球&r可以加工成新材料！"
		""
		"                   &n&6材料&r"
		""
		"  • &7烈焰石英&r"
		"  • &7晶化熔岩&r"
		"  • &7余烬面粉&r"
	]
	quest.1E0B03155C2CAEE7.quest_desc: [
		"精魂聚焦算得上是一种炼金术，通过向催化剂物品（即&7促符&r）中灌注&7精魂&r来生成新材料。"
		"&n                                       "
		""
		"首先，制作一个&7炼金促符&r并将其放入&7坩埚&r，再加入精魂，根据放入&7精魂&r的不同，将会开始生成不同的新材料。"
		""
		"此过程中&7促符&r会消耗耐久，最后会碎掉，但也有办法修复它们，让这个过程得以无限持续。"
	]
	quest.1E0B03155C2CAEE7.title: "精魂聚焦"
	quest.1E514F5A18364625.quest_desc: [
		"最后，合成一枚&7风转草护符&r，用它右击任意花朵，为你的新朋友打造一个小屋。"
		""
		"&7风转草&r可以管理大范围的植物，温和地从它的家园区域里采集少量的任意植物，然后存放在&7与它的小花房相邻的&r容器中。"
		""
		"这一过程需要魔源，由附近的&7魔源罐&r提供。"
	]
	quest.1FDA97FE562A2C4D.quest_desc: [
		"大多数工业先锋模组的机器都可以安装插件，以提高运行速度和效率。"
		""
		"不要错过哦！"
	]
	quest.1FDA97FE562A2C4D.title: "插件"
	quest.20454EB2C6E93573.quest_desc: [
		"&7玩家访问器&r允许任意物流与你的物品栏交互，就像和箱子一样。"
		""
		"这就可以用来为大型建筑项目提供材料，以及一些其他用途。"
	]
	quest.2150EE8D0B1474CE.quest_desc: [
		"物流部分包括各种有助于实现自动化物品运输的模组物品。"
		""
		"无论是物品、流体还是能量，这里展示的模组都能够协助运输。"
	]
	quest.2150EE8D0B1474CE.title: "物流"
	quest.21B7BDFCF5144431.quest_desc: [
		"创世的迷雾，这种物质诞生于万物之前。"
		""
		"甚至在“事物”的概念之前。"
		""
		"原始创造触手可及。"
	]
	quest.21C1CAA38D040AC8.quest_desc: [
		"Functional Storage is an expandable storage solution capable of holding all of your items and liquids. "
		""
		"Each drawer can hold from one to four item types, but will hold a truly astronomical amount of them. "
		""
		"Drawers may also be linked up to a Drawer Controller, allowing you to link all of the drawers into a single network. So, item pipes and other logistics can pipe into or out of the Controller and have access to every attached drawer."
		""
		"It’s not possible to manually access the Storage Controller, so you’ll likely want to pair this with something else that allows you access the items. An Ad Hoc AE2 network, Pretty Pipes, or an Ars nouveau Storage Lectern are all excellent options."
	]
	quest.21C1CAA38D040AC8.title: "Functional Drawers"
	quest.21FA8A625A79BE61.quest_desc: [
		"Simple fluid pipes for getting fluid from one place to another. "
		""
		"Each one will only transfer a single fluid type at a time."
	]
	quest.22344008D43D4710.quest_desc: [
		"村民是许多关键原料的来源，而且他们胃口大得吓人。你需要一些帮手来喂养它们！"
		""
		"&7薇克精&r提供了一种非常简单的自动化方式，用于操作各种厨房用具等等。"
		""
		"                            &6&n注意事项与使用方法&r&r"
		""
		"为了让你的&7薇克精&r正常工作，你需要设置好它们的工作区域。"
		""
		"首先，放置他们的工作站。通常用于合成的工作站是&7炼药锅&r。手持&7薇克精护符&r右击工作站即可召唤他们。"
		""
		"接下来，你需要告诉他们要合成什么。这可以通过将&7奥术基座&r直接放置在工作站旁，然后在基座上放入所需成品来实现。"
		""
		"单个薇克精可以通过使用多个&7基座&r来支持多个合成。用红石激活&7基座&r会禁用该基座对应的合成，从而让你在达到所需数量时停止合成。"
		""
		"当然，他们还需要合成材料。在附近放置一个或多个容器，使用&7支配之杖&r将其绑定到工作站；手持&7支配之杖&r时，先潜行右击容器，再右击工作站。"
		""
		"最后也是最重要的，薇克精需要魔源。在附近放置一个&7魔源罐&r，填满它，然后尽情享受吧。"
	]
	quest.22344008D43D4710.title: "厨师帮手"
	quest.223BE2F1F8A5C87C.quest_desc: [
		"&7复制终端&r可以从&7存储芯片&r上的样板请求合成。"
		""
		"它还会显示网络上存储的每种&7物质&r的总量，也允许你管理任何进行中的请求。"
	]
	quest.22ABFC3024E54FEA.quest_desc: [
		"汞驱物品运输系统是一个用于运输物品的简单物流网络。"
		""
		"将&7输入器&r和&7输出器&r放置在机器或其他容器上，然后通过&7汞驱铜线缆&r连接起来即可使用。"
		""
		"&7汞驱连接节点&r允许多条线缆汇集到一处，形成更广泛的网络，同时也能用来延伸单条线缆的连接距离。"
	]
	quest.22ABFC3024E54FEA.title: "汞驱物品节点"
	quest.235D7EF41916E480.quest_desc: ["以下是Enigmatica 10中可用的各种能量传输方式。"]
	quest.235D7EF41916E480.title: "能量"
	quest.23DDFBC0DB19F6A4.quest_desc: [
		"灵气失衡区使用方法：放置在消耗灵气的设备下方，它可以防止设备过度消耗灵气，防止灵气值过低。"
		""
		"建议你尽快在所有消耗灵气的设备下方都放上一个，因为有些设备消耗灵气的速度真的很快！"
	]
	quest.23ED7167CB856D26.quest_desc: [
		"魔力当然不会凭空产生，那太疯狂了！"
		""
		"从你的好邻居&7图书管理员&r那里购买一个&7符典条目节选&r，将其溶解在&7硇砂&r中以获取&7液态魔源&r。"
		""
		"然后，将其注入&7神能晶片&r来制造&7魔源宝石&r。"
	]
	quest.24095EE1A419152D.quest_desc: [
		"A small multiblock consisting of the &7Controller&r and up to four &7Outputs&r stacked atop it, the &7Refinery&r is central to processing &7Crude Oil&r. "
		""
		"The Refinery uses Heat instead of Air. You can use passive heat sources such as &7Magma Blocks&r or &7Lava&r, however you may wish to use a &7Vortex Tube&r to heat it instead. "
		""
		"&a🛈 提示：可以在EMI中点击查看热管的用途，以此获取详细的热源列表。"
		""
	]
	quest.25570E19FFABD951.quest_desc: [
		"&7奥术触媒&r和&7稳定附魔器&r能够超附魔你的工具、武器和盔甲，达到简直荒谬的强力水平。"
		""
		"随着&7精魂&r需求的增加，提高你的精魂劫掠附魔等级或许是个不错的主意。"
	]
	quest.25B419FE32D9752B.quest_desc: [
		"制作一个&7汞蒸馏器&r并将其放置在&7御炎火盆&r上方。"
		""
		"手持物品右击&7汞蒸馏器&r即可放入（如&7陨石粉&r），此外还需要往&7御炎火盆&r中右击放入燃料，才能开始蒸馏。"
	]
	quest.25B779319401405B.quest_desc: [
		"欢迎来到灵灾，这是一个以操控精魂来施行强力仪式为核心的魔法模组。"
		""
		"此任务章节涵盖了模组使用的基础知识。如需更深入了解，请参阅奥术全典。"
	]
	quest.25B779319401405B.title: "灵灾"
	quest.26188F1C7EBA08B6.quest_desc: [
		"活化一个&7恼人林地行者&r，然后击杀它以获得&7邪术精魂&r。"
		""
		"&6⚠ 注意：这里的仪式图标物品只是方便查阅配方，本身并不是任务目标物品。"
		""
		""
	]
	quest.26188F1C7EBA08B6.title: "邪术精魂"
	quest.264783EF292A494B.quest_desc: [
		"&7初级点击器&r可以自动执行多种交互操作，例如剪羊毛或者击杀前方经过的生物。"
		""
		"它确实需要一个工具，确保为羊毛农场提供了剪刀，为击杀生物提供一把趁手的抢夺剑。"
	]
	quest.267FEB0BB5D9B4D9.quest_desc: [
		"&7装配台&r是一种多方块机器，适用于更高级的合成配方。"
		""
		"Each piece has requirements for valid placement; refer to the PNC:R manual for the exact rules."
		""
		"A simple layout can be setup in a 2x3 space, however:"
		"&a    IO Unit   Controller     IO Unit"
		"&a    Drill      Platform        Laser"
		""
		"&6⚠ 注意：在安装了装配程序：钻头\\&激光后，装配机既可以完成需要钻头或激光其中之一的配方，也可以完成同时需要二者的配方。"
		""
		""
		""
	]
	quest.267FEB0BB5D9B4D9.title: "装配台"
	quest.26B8DEFFA75B3944.quest_desc: [
		"鉴定室用于扫描物品，并将样板存储到存储芯片中。此过程具有破坏性，会损失你的输入物品。但这也算合情合理吧？毕竟你很快就会拥有无限量的这种物品了。"
		""
		"每个存储芯片最多可存储16种不同的样板，放入芯片存储器后，就可以从终端请求这些物品。"
		""
		"&a🛈 提示：物品可以从底部用管道送入鉴定室。"
		""
		""
	]
	quest.26D35A0B06B5EA35.quest_desc: [
		"女子的手杖渐渐燃作灰烬，四风将她送回大地的怀抱。"
		""
		"她小心翼翼地将火苗送入特制的陶瓮中。火焰得到了滋养，渐渐地变得旺盛。"
		""
		"女子再度降临地面时，陶瓮的热量愈发强盛，流溢而出，遍布四野。"
		""
		"自那以后，凛冽之冬后也有温柔之春接替，四季轮回，生生不息。"
	]
	quest.2722D0A13CF02C73.quest_desc: ["&7魔源凝聚器&r可以很方便地把&7魔源&r转化为&7液态魔源&r。"]
	quest.274C351C4A8F794F.quest_desc: ["活跃地涌动着，充满奥术能量。"]
	quest.2850FCAFEEF5004C.quest_desc: [
		"部分基因（比如&7效率&r），可以通过突变升级。"
		""
		"突变的结果带有不确定性，但有一些方法可以提高成功率。"
		""
		"首先，制作一些&7突变药水&r，然后从一个能提供基础基因的生物（比方说蠹虫）上获取&7细胞&r。"
		""
		"将细胞样本与突变药水一起酿造，就能得到一瓶以该生物为实体的突变药水。"
	]
	quest.288F7A968693F3E5.quest_desc: [
		"只要输入合适的流体并用&7烟花火箭&r将其送至高空，这座&7方尖碑&r就能掌控天气，让气候如你所愿般温和或狂暴。"
		""
		"  • &6液态阳光&r能够驱散阴云，带回万里晴空。"
		""
		""
		"  • &6云之精华&r能够召来云层，引发降雨或降雪。"
		""
		""
		"  • &6浓缩云之精华&r能够召来强力的风暴，雷雨交加。"
		""
	]
	quest.289A1CE4C4092687.quest_desc: [
		"&7ME接口&r本质上是个集成的输入/输出总线。"
		""
		"举个例子，一个可能用于为发电机储存煤炭，而附近的小麦农场可以通过同一个ME接口将小麦返回。"
		""
		"它们的组合意味着可以用一个频道完成更多工作。"
		""
		"&a🛈 提示：线缆组件不能连接致密线缆。"
		""
	]
	quest.289DEC367A80D718.quest_desc: [
		"这些&7高级&r的设备的运作方式与那些&7初级&r的基本相同，但它们提供了更多功能且需要能量。"
		""
		"首先，它们的工作范围更大，你可以自行配置。"
		""
		"它们还内置了更强大的过滤系统，因此可以独立完成任务而无需&7传感器&r控制。"
		""
		"&a🛈 提示：点击显示区域按钮，这可以让配置工作"
		"&a   区域更方便。"
	]
	quest.289DEC367A80D718.title: "高级放置和收集器"
	quest.28ACDB98DC2B9D41.quest_desc: [
		"虽然我们的燃料可以产生很高的热量，但由于这里极度寒冷，这些热量仍然不足以将某些机器加热到合适的温度。"
		""
		"我们需要一些隔热手段，尽可能保住来之不易的温暖。"
		""
		"                           &6&n示例法术&r"
		""
		"&7构筑气凝胶&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &6强化&r"
		""
		"&6⚠ 注意：在破坏魔符后插入强化魔符即可用来收获气凝胶。"
	]
	quest.28E44D5D6A6C1D6E.quest_desc: [
		"一种炼金装置，用于生产具有重要魔法意义的世界塑造材料。"
		""
		"利用&7酿液桶&r，你可以生产能够随心所欲改变天气的流体。"
		""
		"当然，这些流体还有其他的用途，比如生产一种特别耐用的钢材——&7玄钢&r。"
		""
		"&6⚠ 注意：EnderIO模组的机器需要安装电容才能工作。"
		""
	]
	quest.28F4519591D71F80.quest_desc: [
		"将多个&7物品激光中继器&r连入一个&7物品传输接口&r，即可将多个小型容器整合成大型存储网络。"
		""
		"将&7激光中继器&r放在你的箱子上，再将另一个放到&7物品传输接口&r上。使用&7中继器扳手&r将所有中继器连接起来，这样任何被输送至&7接口&r的物品都会被存储到箱子中。"
		""
		"类似地，你也可以通过&7接口&r从系统中取出物品，这意味着它可以与AE2或新生魔艺的存储讲台很好地配合使用。"
	]
	quest.294B023DD4F19FE3.quest_desc: [
		"你的&7毛皮套装&r足以在出门时保暖，但它无法提供更多防护。"
		""
		"如果要穿戴其他盔甲的话，可以用&7缝纫台&r为其缝入隔温层。 "
		""
		"将&7剪刀&r放入底部槽位即可移除隔温层，该操作不会损坏隔温层和盔甲。"
		"                           &6&n隔温层类型&r"
		""
		"    • &9隔冷&r - 有效抵御&9寒冷&r  "
		"    • &6隔热&r - 有效抵御&c高温&r"
		"    • &d中性&r - 有效抵御&c高温&r&o和&r&9寒冷&r"
		"        效果是专用隔温层的50%"
		"    • &a自适应&r - 对&c高温&r&o和&r&9寒冷&r都很有效 "
		"        效果是专用隔温层的75%"
		"        且可以随时间自适应隔温"
		""
		"&a🛈 提示：在EMI中搜索\"Insulate\"查阅合适的隔温材料。"
	]
	quest.2961B707783AC925.quest_desc: [
		"一旦你开始从事能量生产，你会很乐意将&7凝胶&r升级到这个等级。"
		""
		"&a🛈 提示：高级凝胶兼容所有低级配方。"
		""
		"&6⚠ 注意：凝胶饿了，需要喂食才能工作！"
		""
		""
		"&6手持物品右键激活。"
		"&6    在EMI中搜索&3#goo_revive_tier_3&6来查看"
		"&6    哪些物品有效！"
	]
	quest.2A7455D9EE649BA4.quest_desc: [
		"图腾魔法能让勇敢的术士创造出一些独特的范围效果。"
		""
		"例如，抽液仪式能让滴水石锥滴水速度加快，而潮汐仪式则能增强区域内玩家的钓鱼能力。"
		"&n                                       "
		""
		"建造图腾的方式并不复杂。只需放置一个符文木图腾基座，然后在其上放置若干符文原木。所需原木的数量取决于具体的仪式。"
		""
		"用相应的精魂右击原木就可以刻写符文。"
		""
		"例如，在抽液仪式中需要四根原木，从上到下依次用&9碧水&r、&9碧水&r、&d奥术&r和&5邪术&r右击。"
		""
		"最后，右击基座就可以激活仪式。"
		""
		"仪式激活后无需维护或持续供应。"
		""
		"查阅奥术全典以了解每种仪式的详细描述，以及它所需要刻写的符文列表。"
		""
		"建造邪恶仪式是获取更多精魂的绝佳方式。"
		""
		"&a🛈 提示：手持图腾法杖时，会显示图腾的工作区域。"
		""
	]
	quest.2A7455D9EE649BA4.title: "图腾魔法"
	quest.2AA352D00D86DCC3.quest_desc: [
		"借助&7空气接口&r，可远程访问自身物品栏。"
		""
		"此接口可用于为气动设备充能、自动存取物品，甚至能自动喂食或管理经验。玩法无穷无尽！"
	]
	quest.2B0DDF8003305DB6.quest_desc: [
		"&7Transfer Labels&r slip between blocks to enable block-to-block transfer without a pipe. "
		""
		"Sneak + Right-Click to install one on the side of a block. Once installed, the label may be configured by Right-Clicking either with another label or with a &7Label Accessor&r. "
		""
		"While in the Configuration screen, you may add more labels to control the quantity and speed of transfer, as well as set filters."
		""
		"The label may be removed by Left-Clicking it with another label or with a &7Label Accessor&r."
	]
	quest.2B759D4770C13739.quest_desc: [
		"虽然手工制作的物品确实有其独特的魅力，但有些事情最好还是交给机器来完成，它们能更高效地胜任这项工作。"
		""
		"比如那些被你糟践的&7马达&r，机器的制作水平更好。"
	]
	quest.2BB91161DB6B6AF5.quest_desc: [
		"什么？你还以为只能通过炸掉&7铁锭&r的方式制作&7压缩铁锭&r？"
		""
		"现在只要用力捶打就行了！"
	]
	quest.2C07E148B9B60809.quest_desc: [
		"&7热气动加工机&r（&7TPP&r）需要同时使用热量和压力来创造新的材料。"
		""
		"相邻放置的热气动加工机会均摊压力。如果你需要在不同配方中应用不同压力的话，务必牢记前面的这条规律。"
		""
		"类似的，所有方向上相邻的机器也会共享热量，因此将它们排成一条线，可以更方便地为多个配方提供所需热量。"
	]
	quest.2C1538BE243F0CB4.quest_desc: [
		"终于找到了一个自己想要的基因？接下来只需要把它注入质粒中。"
		""
		"用DNA螺旋来设置质粒的类型，然后可以使用更多同类型的DNA螺旋来填满它，基础基因也可以，不过使用基础基因需要消耗更多数量。"
		""
		"&a🛈 提示：使用基础基因来制作空质粒，"
		"&a    而不要把有用的基因浪费在它上面。"
		""
	]
	quest.2C3B39CD6A7E044C.quest_desc: [
		"安山合金级的机器全部使用&7蒸汽&r运行，通过管道直接输入蒸汽以提供动力。"
		""
		"你的&7破朽锅炉&r目前应该能够生产足够的蒸汽，但马上你就能建造更好的锅炉来产生&7蒸汽&r，为更多机器提供动力。"
	]
	quest.2C3B39CD6A7E044C.quest_subtitle: "糕科技！"
	quest.2CA1A8A7B84FAD71.quest_desc: [
		"Modular Routers is a catch all logistics mod capable of many things. "
		""
		"Check out the guidebook for more information on how to use it to your advantage!"
	]
	quest.2D55E211F5B4F0BF.quest_desc: ["一个简单的充能站，可以给放在其中的设备充能。"]
	quest.2D755021F6490B86.quest_desc: [
		"使用神能炉附神&7云莓&r，获取你的第一颗&7魔源浆果&r。"
		""
		"务必多多种植收获&7魔源浆果&r。你掌握的法术能够帮助你迅速地完成这项任务。"
		""
		"&6⚠ 注意：在砧板上磨出制作面团所需的面粉！"
		""
	]
	quest.2F1EA0B091C700E1.quest_desc: [
		"&7渔夫村民&r提供一些不寻常的鱼类，比如谜一样的&7褐蕈（xù‌n）鱼&r。"
		""
		"它们可以被转化为&7棕色蘑菇&r，非常适合用来制作&7饺子&r！"
	]
	quest.2F1EA0B091C700E1.title: "渔夫"
	quest.2F9C801DFAC1C0D9.quest_desc: [
		"&7存储讲台&r能够用来整理你的所有家当，设置&7存储讲台&r需要的所有物品都可以在图书管理员处购买。"
		""
		"还有，他们出售的符典是获取新魔符的&n&7唯一&r&r途径。"
		""
		"每个符典都会教给你一个你尚未掌握的&n&7随机魔符&r&r。"
		""
		"&a🛈 提示：学习魔符可以提升你的魔力，让你施放更多法术！"
		""
	]
	quest.2F9C801DFAC1C0D9.title: "存储讲台"
	quest.304838EDEC32DE97.quest_desc: [
		"感谢游玩&n&6Enigmatic Skies&r！再次祝愿你在这里玩得愉快！"
		""
		"                    &6&n延伸阅读&r"
		""
		"本整合包的灵感来源有很多，一部分来自欧洲传统文化。当然，如果没有北美原住民的传说和神话故事启发的话，这个整合包也就不会存在了。"
		""
		"如果你想探索更多知识，可以点击以下链接："
		""
		"&6&n民族&r"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://anishinabek.ca/\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处访问\"}]},\"text\":\"阿尼什纳贝族\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.cherokee.org/\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处访问\"}]},\"text\":\"切罗基族\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.lenape-nation.org/\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处访问\"}]},\"text\":\"莱纳佩族\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://ojibwe.net/stories/\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处访问\"}]},\"text\":\"欧及布威族\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.wendake.ca/\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处访问\"}]},\"text\":\"温达特族\",\"underlined\":true}]"
		""
		"&6&n故事&r"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://thecanadianencyclopedia.ca/en/article/turtle-island\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处访问\"}]},\"text\":\"《神龟驮世》\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.indigenouspeople.net/spider.htm\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处访问\"}]},\"text\":\"《盗火的蜘蛛奶奶》\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.americanfolklore.net/rainbow-crow/\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处访问\"}]},\"text\":\"《彩虹乌鸦》\",\"underlined\":true}]"
		""
		"[\" • \", {\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.ganondagan.org/legend-of-the-three-sisters\"}, \"color\":\"green\", \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处访问\"}]},\"text\":\"《三姐妹的故事》\",\"underlined\":true}]"
	]
	quest.305A56BDCBE2D2AE.quest_desc: [
		"&7沉淀池&r可让&7废水&r通过&7沙子&r和&7沙砾&r进行过滤，使它得到净化，恢复正常使用的标准。"
		""
		"As such, it can be a great way to supplement your &7Water&r production from the waste produced by your animals."
	]
	quest.307FEC610F0B542F.quest_desc: [
		"复制器主要有两种运作模式。"
		""
		"无论哪种模式，它都会自动从连接到网络的储罐中抽取所需材料。"
		""
		""
		"&7&n无限模式&r"
		""
		"要使用此模式，只需将物品放入无限模式栏。复制器就会持续用网络中的物质复制该物品。"
		""
		"一般用于你需要稳定供应的物品。"
		""
		""
		"&7&n按需模式&r"
		""
		"网络上未处于无限模式的复制器是按需请求。在终端发起请求后，会在可用的复制器之间自动均衡复制。"
		""
		"需要将样板存储在存储芯片上才能发出此类请求。"
		""
		"&6⚠ 注意：带有额外数据的物品，"
		"&6    例如电池或具有物品栏的物品，复制后会清空数据。"
		""
	]
	quest.30FE41CF0C7F1270.quest_desc: [
		"需要燃料支持？"
		""
		"&7原初煤炭&r的燃烧时间是原木的16倍，且可通过&7煅烧炉&r轻松生产。"
	]
	quest.3104ECE58D5CC796.quest_desc: [
		"用&7御炎火盆&r来驱动炼金设备相当浪费，因为只要有燃料它就会一直燃烧。"
		""
		"考虑改用&7汞催化剂&r。该装置可接收&7汞晶碎片&r并将其转化为能量流，并像电池一样储存它们。"
		""
		"然后将&7流态热质发射器&r连接到一个设备，再将其放置在附近的&7汞催化剂&r上，使其能够向连接的设备远程发送能量。"
		""
		"只有在连接的装置运行时，才会消耗能量，运行效率大大提高。"
	]
	quest.31903F40C2037EBD.quest_desc: [
		"有了&7交易置物台&r，你就可以与&7村民&r自动交易了。"
		""
		"将&7置物台&r背面的红点正对&7村民工作站&r放置，然后在&7置物台&r上放入交易物品。"
		""
		"右击即可放入或取出物品，但我们要的是自动化对吧？所以，用漏斗或管道来向&7置物台&r输送或提取物品吧。"
		""
		"村民只有在工作时才能从&7置物台&r进行交易。因此请确保在夜间囤积好他们所需的物品，以便在白天最大限度地完成交易。"
		""
		"&a🛈 提示：可以在置物台正面设置过滤器，指定用于交易的物品。"
		""
	]
	quest.319FD618D4608068.quest_desc: [
		"这座空岛上生长的&7烈焰至高树&r上已经结出了一些&7炸弹石榴&r。"
		""
		"可以先收集一些，然后随时可以建造一个农场。炸弹石榴可以在&7烈焰至高原木&r上生长，可以通过&7骨粉&r或其他催熟手段加速生长。"
		""
		"&a🛈 提示：收获仪式可以更方便地采集这些水果！"
		""
	]
	quest.31CAA3BC20CCDF25.quest_desc: [
		"需要更多空间吗？你随时都可以再召唤另一座空岛。"
		""
		"或者使用&7火之精华&r右击&7黑石&r，将&n21x11x21&r的区域变成该空岛的生物群系！"
	]
	quest.31CAA3BC20CCDF25.title: "生物群系转化"
	quest.31FAEA42AC32BD3E.quest_desc: ["这个充能站有超大的能量缓存，可以快速给物品充能。"]
	quest.32305BE195F77F2F.quest_desc: [
		"出发前，你还需要生产一些魔源。以下所有仪式都需要一个满的&7魔源罐&r才能启动。"
		""
		"从&7农民村民&r处购买一个&7菌丝魔源通道&r，用它把多余的食物直接转化成美味的魔源。"
		""
		"&a🛈 提示：将食物放在紧邻菌丝魔源通道的奥术基座上！"
		""
	]
	quest.323D480E3C37579E.quest_desc: [
		"这座空岛上生长的&7奔流至高树&r上已经结出了一些&7霜木瓜&r。"
		""
		"可以先收集一些，然后随时可以建造一个农场。霜木瓜可以在&7奔流至高原木&r上生长，可以通过&7骨粉&r或其他催熟手段加速生长。"
		""
		"&a🛈 提示：收获仪式可以更方便地采集这些水果！"
		""
	]
	quest.3263757C9A240C70.quest_desc: [
		"Chipped offers a multitude of block variants to fit your every decorative need. The Workbenches themselves are equally lovely and can spruce up your interiors quite easily."
		""
		"If you’d like to work on the go, the mod also offers a variety of handheld tools that work exactly like a placed Workstation."
		""
		"Workstation variants are aesthetic only. They can all make any Chipped block, so pick your favorite!"
		""
		"&a🛈 Tip: Search &3@chipped&r &ain EMI to "
		"&a    更多相关内容。"
	]
	quest.3263757C9A240C70.title: "Chipped"
	quest.3282293AB6B43287.quest_desc: [
		"这台&7压缩机&r运行迟缓但却稳定，有了它就能开始制造&7压缩铁&r和&7钻石&r了。"
		""
		"以后还可以用它来更简单地制作板材。"
		""
		"&a🛈 提示：记得通过锁定栏位来控制它要处理的配方！"
		""
	]
	quest.33679351A7B6D8E6.quest_desc: [
		"能够自动放置和拾取方块有助于实现一些早期任务的自动化。"
		""
		"在繁茂空岛上，你可以用之前获取&7冰石&r的法术来获取&7凝灰岩&r。它可以合成对自动化很有帮助的基础设备。（译者注：标题英文Picking Up What You're Putting Down可作俚语，意为“懂你意思”）"
		""
		"                           &6&n示例法术&r"
		""
		"&7构筑凝灰岩&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r"
	]
	quest.3456EED039818662.quest_desc: [
		"&7量子桥&r是用于跨纬度拓展网络的一种多方快结构，它由八个&7量子环&r围绕一个&7量子连接仓&r构成。"
		""
		"在大部分情况下，两端都需要一个相互连接的&7量子缠绕态奇点&r。不过，还有个非常方便的&7量子桥卡&r，它可以安装在你的&7无线终端&r中，让其与&7量子桥&r连接。"
		""
		"这意味着，你只需要动动手指，便可跨纬度与家中的网络进行连接！"
		""
		"&a🛈 提示：给你的量子缠绕态奇点命名，这可以让"
		"&a   你更好分辨其用途。"
		""
	]
	quest.3456EED039818662.title: "量子桥"
	quest.34F48A8F71A7C937.quest_desc: [
		"&7末影板条箱&r是末影箱的升级版。它不仅支持自动化与物流系统接入，还能根据命名划分多个独立存储频道。"
		""
		"设定频道的方法：将&7末影板条箱&r和一颗&7末影之眼&r一起放入&7铁砧&r并命名。这个名字就会成为专属频道，所有与之同名的&7末影板条箱&r都会共享同一个存储空间。"
		""
		"使用&7末影目镜&r可远程访问&7末影板条箱&r，只要和&7板条箱&r命名一致，就能绑定对应频道。"
	]
	quest.34FB10F0A2504973.quest_desc: [
		"购买一个&7织布机&r即可解锁&7牧羊人村民&r。"
		""
		"现在你可能还买不了太多东西，但一定要给自己买一个&7繁茂花园空岛构筑之板&r。"
	]
	quest.34FB10F0A2504973.title: "牧羊人"
	quest.359562022532BAE1.quest_desc: [
		"精魂灌注用于强化物品和材料，加强它们的效果。"
		"&n                                                  &r"
		""
		"When viewing Spirit Altar recipes in EMI, the central item and the Spirits shown to the left should be insterted onto the Altar itself. "
		""
		"Any items shown on the right must be instered into a nearby Item Pedestal or Item Stand. "
		""
		"Items may be piped into the these blocks, or otherwise Right-Clicked into place when crafting by hand."
		""
		"&6⚠ Note: Item Stands and Pedestals "
		"&6    must be within four blocks of "
		"&6    the Altar."
	]
	quest.359A7C9127500D6C.quest_desc: ["一个简单的&7熔炉&r，尽管天气寒冷，它也能很好地保护那宝贵的热量供你使用。"]
	quest.35A8CEA408114638.quest_desc: [
		"正如之前所说，灵气是一种有限资源，必须用心维护。"
		""
		"好在，你可以使用多种灵气制造设备来补充灵气。"
		""
		"每种灵气制造设备都各有优缺点，工作时所需材料也各不相同，一般来说，材料越容易获取，设备产出的灵气就越少。"
		""
		"想要更高灵气产量，可以看看&2射击标靶&r、&2烟火凝望&r或是&2滞留型吸收器&r。"
		""
		"如果你的设备只需要消耗少量灵气，那么有&2草食性吸收器&r或&2沼泽之霍米&r就够用了。"
		""
		"这些内容在&7自然灵气之书&r中均有详细说明，如需了解具体搭建方法，请查阅对应条目。"
	]
	quest.35FD905A4A4EB1F5.quest_desc: [
		"Pretty Pipes: Fluids is an addon to Pretty Pipes which allows the network to carry fluids in addition to items. The same network will effectively carry both, allowing everything to flow through a single block space. "
		""
		"&7Fluid Pipes&r are therefore only required at the end points where the pipes connect to a fluid tank. "
		""
		"Like Pretty Pipes, this addon includes &7Extraction&r and &7Retrieval Modules&r for getting fluids into and out of tanks. It also features a suite of filters and works with the Pretty Pipes priority system. "
	]
	quest.363AB8EC195285BE.quest_desc: ["&7Sludge Refiners&r sort all the gunk fed into them to create more useful materials, such as &7Soul Sand&r, &7Clay&r, and &7Rich Soil&r. "]
	quest.369D0F2CC8D028D2.quest_desc: [
		"在&7精魂坩埚&r上放置最多四个&7增强件&r和一个&7核心增强件&r，可以进一步加强它。类似地，附近的每个&7精魂催化器&r也可以用&7增强件&r进行增强。"
		""
		"相同的增强件可以使用多次，但最好混合搭配以达到理想的效果。"
		""
		"手持&7调谐音叉&r会显示所有已安装增强件的总效果。"
		""
		"用&7调谐音叉&r右击&7坩埚&r，还可以选择一个修饰项，进行额外加强。"
	]
	quest.36A18D327A03810B.quest_desc: [
		"那口&7哭泣之井&r对你十分慷慨，你唯一能给它的，只有自己。"
		""
		"相信它，跳进去。"
		"&n                                                &r"
		""
		"跳入井中，你便可获得一个&7幽影精魂&r。"
		""
		"如果你弄丢了或者需要更多，你可以努力在&7粒子加速器&r中重新制作。"
	]
	quest.36A482587B5E89F7.quest_desc: [
		"这些注入了闪耀之光的方块深受&7探宝蟹&r们的欢迎。它们可以使用这些方块搓出更多&7泥球&r！"
		""
		"哎呀，稍微多花点能量也值啦。"
	]
	quest.36A482587B5E89F7.quest_subtitle: "从此实现泥球自由"
	quest.36BCEB3B27822AD1.quest_desc: [
		"这些奇异的宝石看上去几乎不能稳定地保持自身的形状。"
		""
		"与特定的其他物品组合时，这种宝石能立刻呈现出新的形态，并且稳定下来。"
		""
		"大多数机器升级可以使用这种方式复制。"
	]
	quest.3753A3EB1909F923.quest_desc: [
		"由&7盐块&r制成的&7多盐泥球&r可以加工成新材料！"
		""
		"                   &n&6材料&r"
		""
		"  • &7青金石&r"
		"  • &7赛特斯石英水晶&r"
		"  • &7海王粒&r"
	]
	quest.37AA9E6270DB015A.quest_desc: [
		"这是一个多方块结构，由放置在中心位置的&7充能台&r和周围四个&7物品展示台&r组成。"
		""
		"每个&7物品展示台&r都需要放在&7充能台&r四个方向上距离三格方块远的地方。"
		""
		"要开始合成，配方中间的物品需要放在&7充能台&r上，其他物品可按任何顺序放在周围的&7物品展示台&r上。"
		""
		"需要向所有四个&7物品展示台&r提供能量。"
	]
	quest.37C965C1FA40221E.quest_desc: [
		"&7法术炮塔&r是用来施放预备法术的极其强大的自动化工具。"
		""
		"当然，有一些限制，因为&7法术炮塔&r不能使用所有法术形态，主要只能使用触摸和弹射物。不过，能够用&7红石&r信号触发法术的特点仍然是极其珍贵的。"
		""
		"&7炮塔&r可以通过使用&7法术书&r、&7施法者卷册&r或&7法术羊皮纸&r右击来写入法术。"
		""
		"他们也可以使用诸如&7拾取&r和&7放置方块&r等魔符，前提是它们紧邻着一个可以接收或抽取物品的容器。"
		""
		"它们还需要在附近放置一个&7魔源罐&r来提供魔源。"
		""
		"试试在你的&7炮塔&r上设置&5布兰朵&r法术，然后射击&7云莓灌木&r。"
	]
	quest.37DF459B5B6E6221.quest_desc: [
		"&7物流框架&r可通过管道网络传输物品与流体。"
		""
		"得益于其极高的自定义程度，它们能完美串联机器实现自动化运行，并维持关键物品的储备。"
		""
		"例如，可使用&7存储框架&r将多个不同的流体储罐和装有物品的箱子接入网络。随后在每台机器处，利用&7请求框架&r精准提取当前合成所需的确切物品与流体。"
		""
		"合成产物同样能通过&7主动供应框架&r存回网络，或是直接留在机器内供下一环节调用。"
	]
	quest.37ED5A328F30DD34.quest_desc: [
		"创造怪物并非易事，要成功完成这一任务，我们还需要一些非常特殊的材料。"
		""
		"我们先从简单的开始，试着去召唤一个史莱姆。我们可以借助特定食物中蕴藏的魔力开始这一进程，但过程中还需要一些额外的力量推动。"
		""
		"在高灵气环境手动繁殖一些动物，用这种方式收集一些&7降生之魂&r。"
		""
		"当你成功活化了一只史莱姆后，确保使用&7镰刀&r或其他&7碎魂武器&r杀死史莱姆，这样才能得到它的&7精魂&r。"
		""
		"&6⚠ 注意：你可以只使用&6&o碎魂武器&r&6或&o碎魂魔符&r对生物造成伤害，然后用其他武器补刀，这样更省资源。"
		""
		""
		""
		""
		"&a🛈 提示：附魔了精魂劫掠的武器可以获取更多精魂！"
		""
	]
	quest.3895E1D9DE518B3F.quest_desc: [
		"释放法术会大量消耗你的魔力，尤其是你想要用&7法术书&r作为你的主要挖掘工具的话。"
		""
		"希望更快速地回复魔力的话，你可以考虑制作一个&7湮灭之瓶&r。这种手持设备可以吃掉你拾取的物品，把它们直接转化为魔力。"
		""
		"要设置允许吃掉的物品，请副手持对应物品，主手持&7湮灭之瓶&r，然后按下右键。"
		""
		"可以考虑设置成&7圆石&r或是其他的一些&7石头&r。"
		""
		"&a🛈提示：随时可以潜行并右击魔源罐以进行配置。"
		""
	]
	quest.38E929DADF66C1F3.quest_desc: [
		"由&7泥巴&r制成的&7泥沼泥球&r可以加工成新材料！"
		""
		"                   &n&6材料&r"
		""
		"  • &7焦黑石英&r"
		"  • &7鱼骨&r"
		"  • &7腐肉&r"
	]
	quest.3954AC8D791145CE.quest_desc: ["流浪商人总在你家门口骚扰你？让这家伙替你去打个招呼吧！"]
	quest.39716C901B98BAF2.quest_desc: [
		"该工作站允许&7薇克精&r使用&7切石机&r配方。"
		""
		"                   &6&n转化&r"
		""
		"手持&7薇克精护符&r右击&7切石机&r。"
		""
		"&6⚠ 注意：对于多步合成，每一步都需要分别标示出来。"
		""
	]
	quest.39716C901B98BAF2.title: "薇克精切石"
	quest.398AE848C969FCEF.quest_desc: [
		"一种看似坚实，实则轻如空气的神秘材料。"
		""
		"获取它需要将大量空气在高压下液压成&7液态空气&r。"
		""
		"仅靠&7温差压缩机&r产生足够体积的压缩空气可能相当困难。你可以考虑使用功率更大的设备，例如&7静电压缩机&r。"
	]
	quest.39BCDF29A792B723.quest_desc: [
		"灵气缓存相当于个人电池，可以给灵气工具与装备“充电”。"
		""
		"这其中包括所有附有自然修补附魔的物品，以及自然灵气模组的全部装备与工具。想要修复这类物品，只需手持工具或身穿装备时潜行即可。"
		""
		"灵气缓存可在自然祭坛中充能，若所在区域灵气极为充沛，穿戴在身上时也能被动地充能。"
	]
	quest.39E9D5470F347400.quest_desc: [
		"粗金、粗铜和粗铁中可能含有一些非常有用的次生矿物，只需加入一点额外工序即可把它们提取出来。"
		""
		"合成一台&7滚筒筛&r，处理你的粉碎矿石并获取&7废水&r。"
		""
		"然后将其回收为淡&7水&r和其他各种方块。"
		""
		"&a🛈 提示：记得通过锁定栏位来控制它要处理的配方！"
		""
	]
	quest.3A078285904792A2.quest_desc: [
		"Simple item pipes for moving things around. "
		""
		"They can be filtered and accept Motors as upgrades to speed them up."
	]
	quest.3A0F43654CE474DA.quest_desc: [
		"作为亲近树木的林地精灵，&7风转草&r很愿意加入你的家园，只要你能展现对她的爱，在她的附近种下一棵树。"
		""
		"作为交换，&7风转草&r可以帮你种植和收获农场作物。"
		"&n                                       &r"
		""
		"用对应的护符右击任意花朵可以创造出她的家园。在她的家园里放置更多数量与种类的植物，可以让她更加开心，更有生产力。"
	]
	quest.3A7AD25302240A1B.quest_desc: [
		"临时网络是最简单的AE网络形式；它由一段&7福鲁伊克斯色线缆&r和一些连接设备组成，例如&7存储总线&r和&7终端&r。"
		""
		"该系统也需要一点能量，这些能量可以由&7水晶谐振发电机&r被动提供，也可通过&7能源接收器&r主动提供。"
		"&n                                                            "
		""
		"利用你收集到的物品和本次任务奖励，搭建一个临时网络吧。"
		""
		"1. 在每个&7桶&r旁放置&7存储总线&r并都用&7福鲁伊克斯色线缆&r连接。"
		""
		""
		"2. 将&7合成终端&r放置在&7福鲁伊克斯色线缆&r上的任意位置。"
		""
		""
		"3. 最后，按你的想法提供能量。"
		""
		""
		"如果操作正确，那么你应该可以看到六个&7桶&r中的内容，并可以用其在&7终端&r里制作物品。"
		""
		"&6⚠ 注意：一个临时网络最多可以建立八个连接。"
		""
	]
	quest.3A7AD25302240A1B.title: "临时网络"
	quest.3B609B8A4DE93B53.quest_desc: [
		"建造一个&7西瓜&r农场，让你的探宝蟹制造&7西瓜球&r！"
		""
		"西瓜里的水比你用的那些云多得多。"
	]
	quest.3B77FB0A8CFAAB97.quest_desc: [
		"&7末影激光器&r会摧毁其路径上的大多数方块。这也许相当危险，然而有些方块反而会因此获得强化。"
		""
		"使用&7目标标识器&r，令末影激光器瞄准&7原子锻造器&r以提供其运行所需的能量。"
		"&n                                       &r"
		""
		"要将目标设置为某个方块，先手持&7目标标识器&r潜行右击该方块，再潜行右击&7激光器&r。"
	]
	quest.3BBFA042D4C4EA4E.quest_desc: [
		"&7处理阵列&r能够将任意单方块现代工业化机器转变为能够进行批量处理的多方块厂房。"
		""
		"只需搭建结构，然后在GUI中插入一个或多个单方块机器。可插入的机器数量取决于&7处理阵列&r的尺寸，范围从8到64。"
		""
		"最后，请确保&7阵列&r中安装了处理相应配方需要的对应仓室，并提供材料。"
	]
	quest.3BCD9E36D48B205A.quest_desc: [
		"组装一台&7低压蒸汽涡轮机&r来生产能量。"
		""
		"别忘了搞些&7低压电缆&r！依旧从你的村民那。"
		""
		"&a🛈 提示：EU可直接转化为FE！"
	]
	quest.3BF1CB7CDDA99856.quest_desc: [
		"与精魂打交道是件麻烦事，无论是从身体上还是精神上。"
		""
		"只有选择了合适的材料才有希望掌握这种魔法，而一切都从灵魂石开始。"
		"&n                                       "
		""
		"我们稍后会学到进一步精炼它的方法。"
		""
		"就现在而言，去挖掘一些灵魂石矿石，然后烧炼它以获得精制灵魂石。"
	]
	quest.3BF458796782EB49.quest_desc: [
		"你可以通过&7赛博改造中心&r进行研究，并在自己身体里植入多种生物机械增强，以此获得永久增益效果和额外能力。"
		""
		"能力种类各不相同，从普通的“登高辅助”，到神奇的“硬化护板”、“隐形斗篷”甚至是“御风之术”。"
		""
		"与来自Oritech模组的其他机器不同，这台机器只有安装了合适的升级组件才能工作。"
		""
		"共有三种升级可以安装在&7改造中心&r的侧面与背面。"
		""
		"起始阶段，你可以合成并安装&7赛博研究站&r。后期的升级需要用到更高阶级的&7研究站&r。"
		" "
	]
	quest.3C4305830D6978C5.quest_desc: [
		"想要升级你的挖矿装备吗？"
		""
		"气动凿岩锤是一种多功能挖掘工具，能够轻松开采大片区域。"
		""
		"你甚至可以在凿岩锤中放入时运或精准采集附魔书，随时切换附魔。"
		""
		"&a🛈 提示：空气罐阵列能够作为便携式空气电池，随时为你的工具充气以供长时间使用！"
		""
		""
	]
	quest.3C50D5FE5FA787A9.quest_desc: ["当你只需要一把超大的枪来告诉怪物谁才是老大时。"]
	quest.3C905ECF6E0A543E.quest_desc: [
		"烈焰烬质燃烧着来自地狱的热量，可以被加工成一种强效燃料，以提高你的能源生产力。"
		""
		"这种燃料对于钢的生产也至关重要，而钢将为你打开通往各类科技机械的门扉。"
	]
	quest.3CA4472228D0F866.quest_desc: [
		"将&7ME控制器&r接入网络，我们可以获得更多的频道——每个面提供32频道。"
		""
		"还不止如此，多个&7ME控制器&r可以相互连接形成更大的多方快结构，每个外露面都可以提供32频道。"
		""
		"建造多方快结构需要遵循以下规则："
		""
		"1.同一网络中的所有控制器方块必须连接在一起"
		""
		""
		"2.总大小不能超过7x7x7"
		""
		""
		"3.控制器只能在最多1个轴向方向上有2个相邻方块"
		""
		""
		"&7AE指南&r为感兴趣的人提供更多技术细节，并附有有用的图片！"
		""
		"&a🛈 提示：可以使用ME网络分析仪调试网络频道！"
		""
	]
	quest.3CA4472228D0F866.title: "ME网络"
	quest.3CBA1384BD3D28ED.quest_desc: [
		"该工作站允许&7薇克精&r使用&7熔炉&r配方。"
		""
		"                   &6&n转化&r"
		""
		"手持&7薇克精护符&r右击&7熔炉&r。"
		""
		"&6⚠ 注意：对于多步合成，每一步都需要分别标示出来。"
		""
	]
	quest.3CBA1384BD3D28ED.title: "薇克精烧炼"
	quest.3CC1C6949E17A1B9.quest_desc: [
		"Simple and reliable, the &7Liquid Compressor&r is suitable for running basic PneumaticCraft machines up to &75 bar&r. "
		"&n                                                &r"
		""
		"Machines and Tubes will burst if over pressurized! Avoid this by disabling the Compressor when it’s nearly full. "
		""
		"[\"Refer to the \",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://wiki.enigmatica.net/enigmatica6/gameplay/how-to.../pneumaticcraft-safe-compressor-usage#compressing-air-and-basic-control\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\":\"Safe Compressor Usage\",\"underlined\":true},\" article on our wiki for more information.\"]"
	]
	quest.3CC1C6949E17A1B9.quest_subtitle: "基础压力"
	quest.3D1D6D17B2900DF0.quest_desc: [
		"活化一个&7岩浆怪&r，然后击杀它以获得&7狱火精魂&r。"
		""
		"&6⚠ 注意：仪式图标物品并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.3D1D6D17B2900DF0.title: "狱火精魂"
	quest.3D59639F51E89CF9.quest_desc: [
		"&7高级点击器&r和初级相比有了范围升级，可以与更大范围内的物品交互。"
		""
		"&a🛈 提示：点击显示区域按钮，这可以让配置工作"
		"&a   区域更方便。"
	]
	quest.3D6441ECF951BAD4.quest_desc: [
		"This incredibly cold fluid holds some mystical capabilities that may be used to augment certain Industrial Foregoing machines."
		""
		"  • Auto-harvesting in &7Hydroponic Beds&r"
		"  • Gentle-harvesting in the &7Plant Gatherer&r"
		""
		"It's also a vital component for more advanced machinery!"
	]
	quest.3D76C219EB7EEC03.quest_desc: [
		"一种可以在一定范围内放置方块的机器。它会从上方的容器中提取物品，并将其放置在指定的方块上方。"
		""
		"将方块放入贴在&7无感知建造器&r上的&7物品展示框&r内，建造器便只会在此方块上方放置方块。"
	]
	quest.3D7B773741D78864.quest_desc: [
		"想从&7荒野族裔&r身上割下可以食用的肉，这一过程需要高超的技巧与专注力。稍有不剩，割下的肉就会被生物身上流淌的诅咒魔力沾染。"
		""
		"这样精细的操作只能使用&7小刀&r完成。"
		""
		"将&7小刀&r放在&7德格米石阵&r旁的&7奥术基座&r上，德格米就能为你收集&7肉类&r。"
	]
	quest.3D7B773741D78864.title: "野味"
	quest.3DD21FD2F10FE43D.quest_desc: [
		"&7胶乳&r主要用于制作&7橡胶片&r，但其本身也用于多种配方。"
		""
		"你得花些时间来设计一套自动化生产线。"
	]
	quest.3DE69E7B1359D76D.quest_desc: [
		"这种金属里回荡着虚空中无限的可能性。"
		""
		"它很轻盈，但在动量突然变化时却表现出极大的阻力，就像是某种及其致密的金属或是把什么东西从粘稠的流体中拽出来似的……"
	]
	quest.3E7A4470BD04F2A1.quest_desc: [
		"&7初级传感器&r是一种多功能的方块与实体检测器，可以根据其设置发出信号。"
		""
		"将物品或方块从EMI中拖入中间的过滤槽，右键过滤槽中的方块以改变其配置，例如是否含水。"
		""
		"要过滤实体，请使用刷怪蛋；要过滤流体，请使用桶装流体。"
	]
	quest.3EA53BBEBC32F813.quest_desc: [
		"欢迎来到基因重组！"
		""
		"本模组能让你自己和其它生物获得特殊能力。"
		""
		"有没有想过从猪身上剪下肉；或者给鸡挤奶；或者像羊一样吃草；再或者通过光合作用直接给自己补充能量？"
		""
		"现在你可以做到了。"
		""
		"这些任务将引导你完成使用模组的基础步骤。之后，无论怎样，就靠你自己去运用这些知识了。"
		""
		"[\"请务必查阅他们的\",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://github.com/aaronhowser1/Genetics-Resequenced/wiki\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]},\"text\":\"Wiki\",\"underlined\":true},\"，可以为你补充很多信息。\"]"
	]
	quest.3EA53BBEBC32F813.title: "基因重组"
	quest.3EA705A9C893F04A.quest_desc: [
		"现代工业化的&7锅炉&r和&7涡轮机&r都是生产能量的基础，无论是FE还是EU。"
		""
		"现代工业化的&7电缆&r可以帮你自动完成EU和FE的一比一转化，这意味着你可以直接将电缆连接到FE设备上为其供能。"
		""
		"                       &n&6能量等级的说明&r&r"
		""
		"现代工业化的能量等级存在两个局限，这值得你去牢记。"
		""
		"首先，它限制了电网传输的能量上限。因此，使用&7变压器&r将低等级的电网合并成更高级的干线是可行的。比如，八台&7低压涡轮机&r集群会使低压电网传输速率达到极限，但可将其升至中压，从而便可让四个这样的集群给中压电网供电。"
		""
		"其次，电缆等级会影响它们可连接的EU机器等级；一条&7充能电缆（高压）&r根本无法连接非高压的机器，如果机器等级改变，连接也会被断开。因此，如果你使用的是更高级的干线，你就需要用&7变压器&r进行降压来使机器正常运行。不过，这并不影响FE机器，它们可以连接任意等级的EU电缆。"
		""
		"                           &n&6关于FE的说明&r&r"
		""
		"那么，你怎么知道哪些机器使用FE呢？事实上很多模组都是，它们只是喜欢将FE改个名字，让其更与众不同罢了。在这个整合包中，只有现代工业化和其附属模组使用EU。使用其他能量的模组实际上在背后使用的依然是FE。"
	]
	quest.3ED6754FC6B0A36D.quest_desc: [
		"Just Dire Things模组新增的工具能够加装多种有趣的能力，只需在&7锻造台&r中将工具和升级一起合成即可。"
		""
		"加装后，手持工具潜行右击即可启用、禁用升级或对其进行配置。"
		""
		"大多数升级在启用后会自动运行，但有些功能（如割草）则需要通过右击来激活。"
		""
		"下文将介绍每种能力的效果。"
		""
		"&a🛈 提示：在EMI中，将鼠标指针悬停在工具上按下Shift，即可查看能够加装的所有升级。"
		""
		""
		"{@pagebreak}"
		"&7&n武器能力"
		""
		"能够加装在剑和镐尖斧上。"
		""
		" • &a烟熏&r：自动烧炼生物掉落物。"
		" • &a烧灼清创&r：消耗耐久或能量以治疗自身。"
		""
		" • &a生物透视&r：高亮附近的生物。"
		""
		"&7&n杂项能力"
		""
		"能够加装在各种工具上。"
		""
		" • &a掉落物传送&r：将掉落物传送到绑定的容器中。"
		""
		" • &a熔岩修补&r：扔进熔岩以进行修复，同时将熔岩转化为黑曜石。"
		""
		""
		" • &a重锤&r：3x3范围挖掘，范围根据工具品质增加。"
		""
		" • &a烧炼&r：自动烧炼挖掘的方块。"
		" • &a瞬间破坏&r：就是这样。"
		"{@pagebreak}"
		"&7&n镐子能力"
		""
		"能够加装在镐和镐尖斧上。"
		""
		" • &a矿石采掘&r：自动挖掘相连的矿石。"
		""
		"&7&n铲子能力"
		""
		"能够加装在锹和镐尖斧上。"
		""
		" • &a割草&r：瞬间破坏附近的所有花草。"
		""
		""
		"&7&n斧头能力"
		""
		"能够加装在斧和镐尖斧上。"
		""
		" • &a伐木&r：一次砍伐整棵树。"
		" • &a除叶&r：瞬间破坏周围的树叶。"
		""
		"{@pagebreak}"
		"&7&n锄头能力"
		""
		"锄与其他工具稍有不同，其特殊能力是创造新类型的耕地。"
		""
		"所有耕地都拥有以下能力："
		""
		" • 免疫踩踏。"
		" • 加速作物生长。"
		" • 自动收获并重新种植。"
		""
		"对于拥有掉落物传送能力的锄头，其耕地自动收获的作物将直接传送至该锄头绑定的容器中。"
	]
	quest.3ED6754FC6B0A36D.title: "Just Dire Things模组的工具"
	quest.3F021EBB71F4BC70.quest_desc: [
		"&7智能线缆&r与其包层版本相同，但有个小小的附加功能：它们会在表面直接显示频道数量。"
		""
		"这是帮助你跟踪使用中的频道数量的绝佳方式，因为你可以追溯到这些频道的来源。"
	]
	quest.3F20E7D7E1C07311.quest_desc: [
		"给这个小家伙一个桶、一把铲子和一点零食，就能让它乐乐呵呵给你干活。"
		"&n                                       &r"
		""
		"手持&7探宝蟹护符&r右击即可放置到世界中，用&7支配之杖&r即可将其连接到附近的容器。"
		""
		"探宝蟹会消耗附近&7魔源罐&r中的魔源，将各种方块转化为&7泥球&r。"
		""
		"产出的&7泥球&r可以进一步加工成其他关键物品，比如&7水&r、&7熔岩&r、&7焦黑石英&r等！"
	]
	quest.3F20E7D7E1C07311.title: "滚金翻银"
	quest.3FF6566453299DC1.quest_desc: [
		"Applied Energistics is the ultimate storage and logistics solution. Not only does it store items and fluids, but it acts as a controller for external machines by way of its auto crafting system. "
		""
		"[\"Read more about this system in the dedicated \",{\"clickEvent\":{ \"action\": \"change_page\", \"value\": \"7D82585D50D7207A\" },\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"Click Here\"}]},\"text\": \"Applied Energistics\",\"underlined\":true},\" chapter. \"]"
	]
	quest.3FF8D40CD4CB33BB.quest_desc: [
		"想找个不会损坏的工具？这些就能满足你的需求。"
		""
		"它们需要能量，还可以接受附魔，因此能够成为普通工具的绝佳替代品。"
	]
	quest.3FF8D40CD4CB33BB.title: "电动工具"
	quest.410225ED927857D4.quest_desc: [
		"这三台机器可以组合在一起，实现友好生物的自动化养殖。"
		""
		"首先，&7动物饲育机&r会持续喂养你的动物，让它们保持快乐并繁衍后代。当工作区域内动物数量过多时，饲育机将会自动停止。"
		""
		"&7动物资源收获机&r可以在同一区域收集绵羊的羊毛和牛的奶。"
		""
		"&7幼崽分管机&r可以将幼崽送到指定区域等待长大。该方块还具有反向模式，可以将成年动物从幼崽区分离出来，送至最终目的地。"
		""
		"&a🛈 提示：在机器中安装相应的范围插件来确保覆盖整个养殖区域。"
		""
		""
	]
	quest.410225ED927857D4.title: "动物养殖"
	quest.414458433C4734C6.quest_desc: [
		"女子再临地面时，她环视周围，只见那全新的生态中，生命正蓬勃发展。曾经亦师亦友的动物们，而今也已繁衍生息，遍布整片大地。"
		""
		"天地间百花竞放，但女子心中再度生出孤寂。她所学甚多，却无人可以分享。"
		""
		"于是，她掬起湿润的土壤，将黏土塑成自己的形貌。她点燃温暖的火焰，将泥团烧结成坚固的土偶。她呼出蕴生的气息，使土偶得以苏醒。"
		""
		"她催动心中真言，教导新生之人以万物之灵和天地之道——教他们如何狩猎与扎营、耕种与收获，教他们如何养护火种，创造工具。"
	]
	quest.41614A924E5556EE.quest_desc: [
		"欢迎游玩新生魔艺！"
		""
		"这个精彩的模组能够满足你所有关于魔法的幻想。从简单的释放法术，酿造药水，"
		""
		"到召唤魔法生物和制作魔法装置，并且让它们自动完成你家里的几乎任何工作！"
		""
		"新生魔艺还有很多附属模组，它们为游戏带来更多新的机制与新的特性。"
		""
		"仅靠这些任务无法囊括所有信息，通过指南手册应该可以解决这里没有提到的问题。"
		""
		"&a🛈 提示：魔源浆果可以种在草方块上。"
		""
	]
	quest.41614A924E5556EE.title: "新生魔艺"
	quest.427846D4FFE678C5.quest_desc: [
		"古老传说中的勇士们会在战前吞服这些&7碎片&r以增强生命力，保护他们平安归来。"
		""
		"也许它以后会成为合适的祭品。"
		""
		"&a🛈 提示：食用生命碎片能够增加你的最大生命，每个碎片加一颗心！"
		""
	]
	quest.42A899B5E25F6124.quest_desc: [
		"引导最强大的魔法需要及其专精的媒介。"
		""
		"使用在这些空岛上发现的材料升级你的&7法术书&r，展现你的真正法力。"
		""
		"&a🛈 提示：法术书中的法术会在升级后保留！"
		""
	]
	quest.42A899B5E25F6124.title: "三级法术"
	quest.42F2191B5C08849B.quest_desc: [
		"制作一柄&7刮刀&r，并用它右击生物，从生物的身上采集&7有机物质&r。"
		""
		"&6⚠ 注意：刷怪蛋并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
		""
		"&a🛈 提示：记得把这些蝙蝠圈起来！"
		""
	]
	quest.42F2191B5C08849B.title: "蝙蝠"
	quest.43580B4D15FCEF00.quest_desc: [
		"只需一点小小的切割和拼合，就能得到我们想要的东西。准备好仪式需要的物品，然后造出属于你的&7风转草&r。"
		""
		"想得你的风转草信任你并交出它的&7护符&r的话，就在它的周围让一棵树苗生长。"
		""
		"&6⚠ 注意：仪式图标物品并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.4421EB35235888DF.quest_desc: ["欢迎来到自然灵气！"]
	quest.4421EB35235888DF.title: "自然灵气"
	quest.4457D6BB7AE28073.quest_desc: [
		"这个模组不提供任何形式的能量管道，但它提供了次优选择：无线能量传输。"
		""
		"&7能量传输器&r可以用来给一小片区域内的方块供能。"
		""
		"点击显示区域按钮，配置工作区域来覆盖机器。"
	]
	quest.44BD4C393C59F1CB.quest_desc: [
		"&7发现&r任务线用来展示整合包中可用的东西。"
		""
		"如果你刚开始玩模组整合，或是恰好需要一些灵感，这些章节对你来说是一个很好的起点。"
	]
	quest.44BD4C393C59F1CB.title: "发现谜团"
	quest.453240979BB90EBD.quest_desc: [
		"汞驱物流系统是一种用于转移物品和流体的简单网络。"
		""
		"将&7输入器&r和&7输出器&r放置在机器或其他容器上，然后通过&7汞驱线缆&r连接起来即可使用。"
		""
		"&7汞驱连接节点&r允许多条线缆汇集到一处，形成更广泛的网络，同时也能用来延伸单条线缆的连接距离。"
		""
		"从这里开始，事情只会变得越来越复杂，所以务必在自动化上多投入些时间。"
		""
		"&a🛈 提示：尽量将你的线缆布设在已加载的区块内。"
	]
	quest.453240979BB90EBD.title: "汞驱网络"
	quest.4537806144939A6B.quest_desc: [
		"作为紫水晶块的活化版本，这种傀儡可以自动化创造，促生并收集母岩上的方块。"
		""
		"通过绑定它们与容器，来设置它们要进行工作的区域。附近的方块会被转化成母岩方块。当母岩上长出晶芽后，紫晶傀儡可以破坏这些晶芽并收集掉落物，然后存进它们绑定的那个容器中。"
		""
		"&a🛈 提示：紫晶傀儡也能用于生产赛特斯石英！"
		""
	]
	quest.454EB146FC67E3D5.quest_desc: [
		"谁知道将物体加速到近相对论性速度并让它们相撞能有如此好处呢？"
		""
		"&7粒子加速器&r是一个可自由搭建的大型多方块结构。&7加速器&r本身用于将物品注入光束中，而&7导向环&r则用于让光束沿预定路径行进。"
		""
		"通常，这条路径应该是一个循环，以便积攒进行各种制作所需的动量。"
		""
		"加速粒子需要一个或多个&7直线型马达&r。当输入的物品穿过通电的&7马达&r时，会消耗&640×当前速度的FE&r来加速&61J&r。这意味着&6100J&r的低速碰撞只需要约&6200kFE&r，而高速可能会消耗数百万甚至数十亿FE。"
		""
		"你一开始应该只有几个&7直线型马达&r，因此最好搭建一个较小的环，以减少粒子每次转到&7马达&r所需的时间。"
		""
		"&7导向环&r可以通过&c红石&r控制，将粒子发射到更大的循环中，更大的循环可以让粒子获得更多动量，达到更高的速度。"
		"&n                                       &r"
		""
		"[\"该结构有大量非固定部件，请务必查看Oritech Wiki上的\",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://moddedmc.org/en/project/oritech/docs/interaction/particle_accelerator\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]},\"text\":\"粒子加速器\",\"underlined\":true},\" 部分，该部分非常详细地描述了整个系统的工作原理。\"]"
		""
		"为了直观理解规模，设想一个需要&61000J&r能量碰撞的配方。要在保持粒子不逸散的同时达到此速度，转弯之间的最小距离需达到11格。"
		""
		"请翻到下一页查看&7传感器&r根据对应速度输出的&c红石信号强度&r。"
		""
		"{@pagebreak}"
		"            &6&n信号强度&r            &6&n粒子速度&r "
		"                      1                             0"
		"                      2                            10"
		"                      3                            50"
		"                      4                            75"
		"                      5                           100"
		"                      6                           150"
		"                      7                           250"
		"                      8                           500"
		"                      9                           750"
		"                     10                          1000"
		"                     11                          2500"
		"                     12                          5000"
		"                     13                          7500"
		"                     14                         10000"
		"                     15                         15000"
	]
	quest.45B1C10885F542A7.quest_desc: [
		"物品存储元件可以存储任意类型的物品，你可能需要不少才能妥善保管所有物品。"
		""
		"从小开始，以后你可以随时升级更大的元件！"
	]
	quest.45E411460C53A082.quest_desc: [
		"通过往材料里注入一种或更多的&7精魂&r，你可以极大地提升材料的性能。你需要准备一个&7祭坛&r来完成这一操作。"
		""
		"&7精魂祭坛&r的使用方式比较简单。最简单的一种情况是，你只需要&7祭坛&r本身，以及数个用于放置配方中额外物品的&7物品基座&r。"
		""
		"在&7祭坛&r，你需要放置配方中间所显示的主要材料，然后是配方左列显示的&7精魂&r。配方右列显示的物品需要放置在&7物品基座&r上。一旦放置的物品满足一个有效的配方，合成仪式就会启动。"
		""
		"合成所需的时间相当漫长，但可以通过周围放置的最多四个&7符文木方尖碑&r提速。你养殖的被动动物们应该足以提供过程中需要的&7精魂&r。"
		""
		"                       &n&6关于自动化的说明&r"
		""
		"物品可以手动放入，也可以由任意一种物品物流输入。推荐使用带有过滤功能的管道，但不强制要求如此。"
		""
		"一开始的时候，配置&7祭坛&r使它批量被动产出单一物品更为方便。但在后期，你可以将这一装置与AE样板集成，使它能够按需生产物品。"
		""
		"[\"因为需要使用多个物品输入槽位，毫无疑问的，你会需要使用\",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://guide.appliedenergistics.org/1.21.1/ae2-mechanics/subnetworks#root\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处访问\"}]},\"text\":\"子网\",\"underlined\":true},\"来正确调配物品。\"]"
	]
	quest.45F3C4F0EDA160C5.quest_desc: [
		"除了你的小脑瓜和手上的小玩意儿以外，这还有几本书可以帮你快速开局。"
		""
		"• &6层云爆&r能够生成一片蓬松的云。"
		""
		"• &6布兰朵&r能够让植物快速生长。"
		""
		"• &6固身锚&r能够在半空中放置一个方块，"
		"一段时间后消失。"
		"&n                                                &r"
		""
		"把书弄丢了？树苗用光了？"
		""
		"没关系！此任务可以被重复完成，助你重新上路！"
	]
	quest.4613FE560EAC7695.quest_desc: [
		"在&7质粒注射器&r中将&7净化血液&r与已填充的&7质粒&r组合，就可以在血液样本中设置基因。"
		""
		"如果愿意，你可以在同一份血液样本中插入多个性状。"
		""
		"一旦你对增强后的血液样本感到满意了，你就可以准备把它注射进生物体内了。"
		""
		"[\"许多基因都可以注入到生物上，但不是所有基因都可以。如有疑问，请参考\",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://github.com/aaronhowser1/Genetics-Resequenced/wiki/3.-Gene-List\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]},\"text\":\"Wiki\",\"underlined\":true},\"。\"]"
		""
		"&6⚠ 注意：一些性状需要有前置条件才能表达，如果未满足会使得注射失败。具体可参考EMI。"
		""
		""
		""
		"&a🛈 提示：可繁殖动物的性状可以遗传给后代！"
		""
		""
	]
	quest.465D195EA5630857.quest_desc: [
		"With a Storage Lectern from Ars Nouveau, you can easily link together multiple inventories to have a central storage and crafting interface. "
		""
		"Be sure to check out the Worn Notebook for more information on this system!"
	]
	quest.46DDBE0A9170F54A.quest_desc: [
		"使用&7烈焰烬质&r铸造的&7钢材&r与使用传统方式铸造出的相比，应该……有些优势。"
		""
		"这种钢材不仅坚固耐用，而且在与&7精魂&r接触时有特别的渗透性；仿佛它对灵魂有着深不见底的渴求一般。"
	]
	quest.46F17885C957FD5C.quest_desc: [
		"Potions of &7Fire Resistance&r and &7Ice Resistance&r won’t affect your body temperature, but they will prevent any negative effects associated with being too &9cold&r or &chot&r, making them ideal for prolonged jaunts outside of the area of your &7Hearth&r."
		""
		"By feeding them into a &7Potion Diffuser&r, you can even share the effects with your friends and &oother creatures&r in the area."
		""
		"&a🛈 Tip: Diffusers can be bound to "
		"&a    Jars that are &overy far away&r&a."
	]
	quest.472936F50BC28EBF.quest_desc: [
		"Sophisticated Storage offers a wide range of inventories to suit your needs, all of which may be connected through a Storage Controller for centralized access to everything in the network. "
		""
		"The Storage Tool is used to select the Controller and then bind different inventories to it. This allows wireless connections within a limited range. "
		""
		"It’s not possible to manually access the Storage Controller, so you’ll likely want to pair this with something else that allows you access the items. An Ad Hoc AE2 network, Pretty Pipes, or an Ars nouveau Storage Lectern are all excellent options."
	]
	quest.472936F50BC28EBF.title: "Sophisticated Storage"
	quest.47A2DB9344C8CE26.quest_desc: [
		"拥有&7西风促符&r后，你就能够批量生产一些重要材料：&7天气水晶&r和&7风弹&r。"
		""
		"[ \"查阅\", { \"text\": \"灵灾\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"0C0D9C8007301C03\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]} }, \"章节的精魂聚焦任务以了解更多有关使用促符的信息。\" ]"
		""
		"&a🛈 提示：使用修补弥散器是防止促符破碎的一种简单方式。"
		""
		""
	]
	quest.47AFEF3DCB2990FB.quest_desc: [
		"操作&7大型蒸汽锅炉&r需要点液体燃料。"
		""
		"所有可用燃料都在EMI中列举了，只需要搜索&7锅炉&r的用途即可。"
		""
		"不过，在行动之前，你需要开始生产&7精制菜籽油&r。"
		""
		"&6⚠ 注意：多方快锅炉&n只&r&6接受液体燃料。"
		""
	]
	quest.47AFEF3DCB2990FB.title: "精制菜籽油"
	quest.47CB92C2ECBB7FF4.quest_desc: [
		"骨头是最容易复活的东西之一。它们承载着生命的记忆和行动的渴望，只是缺乏一些动力。"
		""
		"目前，我们可以将让它们负责控制一些基础机械。"
	]
	quest.47FF0CFF9CC92DBE.quest_desc: [
		"一台蓄势待发的&7精炼厂&r，通过自动调节热量和压力，为你处理更复杂的加工环节！"
		""
		"对于具有多种流体输出的配方，请务必在精炼厂上方堆叠&7精炼厂罐室模块&r，以获取额外输出。"
	]
	quest.48B6E6CDBFFD77A7.quest_desc: [
		"符文可以注入强大的效果，佩戴时就会激活。然而，只有合适的容器才能装备它们。"
		"&n                                       "
		""
		"从制作符文胸针开始。装备后可以让你佩戴两个自选的符文。"
		""
		"符文本身是在符文工作台上合成的，只需把配方中间的物品放到工作台上，然后提供所需的精魂即可。"
	]
	quest.48B6E6CDBFFD77A7.title: "符文工艺"
	quest.48C487AF892A80B2.quest_desc: [
		"一旦你将凝胶升级为&7虚空辉凝胶&r，你就可以开始将你的燃料改进成&7虚炎燃料&r。"
		""
		"这将充分利用你输入的材料，提升效率，使缓慢的机器满足需求。"
	]
	quest.4914692B607F8BE0.quest_desc: [
		"末影魔源罐是跨维度传输魔源的理想方案。"
		""
		"也就是说，如果你在末地建造了一个疯狂的生物农场，你可以使用末影魔源罐配合生死魔源通道，将这些可口的魔源运回基地。"
	]
	quest.49968116FCB311B0.quest_desc: [
		"&7红宝石&r是一种以硬度闻名的珍贵宝石，常被用作精密机械中的轴承。"
		""
		"它也是某些魔法追求的绝佳媒介。"
	]
	quest.49E18B07D6E4A5EB.quest_desc: [
		"利用神能晶片中蕴含的能量，我们可以制造一个发酵釜，用炼金手段转化某些材料。"
		""
		"我们需要一种合适的材料在缸内作为衬物，以控制反应。"
		""
		"                           &6&n示例法术&r"
		""
		"&7构筑速沙&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &a粉碎&r"
		""
		"&7构筑天壤&r"
		"    &5触摸&r > &a构筑地层&r"
		""
		"&n                                                &r"
		""
		"&7发酵釜&r的操作方式如下：手持物品右击放入发酵釜，物品放入完毕后，再次潜行右击发酵釜将其“关闭”。发酵釜只有在关闭时才会进行发酵。"
		""
		"一旦发酵无法再进行，发酵釜就会自动打开，导致无法进行的因素有：发酵已完成、输出槽位已满、输入材料耗尽。"
		""
		"                       &n&6关于自动化的说明&r&r"
		""
		"只有在发酵釜打开时，流体和物品才能通过管道和漏斗等方式输入。同样地，产物也只能在发酵釜打开时提取。"
		""
		"对除正面外的任意面输入红石信号，可以关闭发酵釜。发酵釜正面可以通过底部的红点辨识。"
		""
		"无论是否输入信号，如果发酵釜内缺少输出空间，它仍然会自动打开。"
		""
		"发酵釜完成一个配方时，会从正面输出一个红石信号，利用该机制可以实现更加精细的分批操控。"
	]
	quest.49F48B91801BE4FE.quest_desc: [
		"&7传输标贴&r是在相邻容器之间转移物品的好方法，这意味着与&7熔炉&r相邻的&7箱子&r现在无需漏斗或其他管道即可推送物品。"
		""
		"流动方向取决于&7标贴&r所处的面。"
		""
		"举个例子，放置在&7熔炉&r侧面的&7存入标贴&r会从相邻的&7箱子&r中将物品存入&7熔炉&r。反过来，放置在&7箱子&r上的&7提取标贴&r会将物品从&7箱子&r里提取进&7熔炉&r。"
		""
		"使用&7标贴访问器&r右击你的标贴（包括被遮挡的标贴）进行配置。潜行左击可移除&7标贴&r。"
		""
		"标贴能够处理相当复杂的过滤，甚至还能通过在GUI中放入更多&7标贴&r来加快速度。"
	]
	quest.49F48B91801BE4FE.title: "传输标贴"
	quest.4A3B9586D14D5037.quest_desc: [
		"Need a little more room to work? Summoning another island is always an option. "
		""
		"Alternatively, Right-Click &7Clay&r with a &7Water Essence&r to convert a &n21x11x21&r area to this biome!"
	]
	quest.4A3B9586D14D5037.title: "生物群系转化"
	quest.4ACD723FC7EB7CD6.quest_desc: ["这个地方很难点着火，大部分明火会立即熄灭，或者根本打不着。"]
	quest.4ACD723FC7EB7CD6.title: "火"
	quest.4B2DF8F028C3CFA0.quest_desc: [
		"活化一个&7守卫者&r，然后从它身上采集一些&7有机物质&r。"
		""
		"&6⚠ 注意：仪式图标物品并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.4C46DBD26BE50BCD.quest_desc: [
		"&7灵气场生成器&r使用方法：将其成对放置，可破坏两者之间的所有方块。"
		""
		"强化方法：在任意一台灵气场生成器上的&7物品展示框&r中放入工具，就可获得该工具的&7精准采集&r、&7时运&r及其它特殊挖掘效果。"
	]
	quest.4C91792ACCC53A2B.quest_desc: ["By applying high heat in a low-oxygen environment, we can convert &7Pelagite&r into &7Kerogen&r. "]
	quest.4CB21D6351486281.quest_desc: [
		"在&7自然祭坛&r上安装催化剂，就可处理新的配方。"
		""
		"将其放置在结构的&7矮石柱&r上即可。"
		""
		"&6⚠ 注意：在不冲突的前提下，装有催化剂的祭坛仍然可以处理基础配方。"
		""
		""
	]
	quest.4CC1CF537349C2D6.quest_desc: [
		"需要更多空间吗？你随时都可以再召唤另一座空岛。"
		""
		"或者使用&7土之精华&r右击&7凝灰岩&r，将&n21x11x21&r的区域变成该空岛的生物群系！"
	]
	quest.4CC1CF537349C2D6.title: "生物群系转化"
	quest.4D8B278BDF762813.quest_desc: ["这种物质如同虚空般冰冷，它的存在似乎时有时无。"]
	quest.4DFD963932B9FF81.quest_desc: [
		"With a &7Vortex Tube&r, you can easily create the very high, or very low, temperatures needed for many recipes."
		""
		"The &7Vortex Tube&r will consume air constantly to create a temperature differential. It is therefore advisable to use a &7Regulator Tube Module&r to limit or disable air flow."
		""
		"机器工作时，红色端会产生热量，而蓝色端则会变冷。"
		""
		"As this is operating on differentials, the warmer you make the blue side, the hotter the red side will get. "
		""
		"Very often, this just means adding a &7Heat Sink&r to the blue side to warm it up to ambient temperature. However, it can be useful at times to put hot blocks, such as &7Magma&r or &7Lava&r, on the blue side to really push temperatures higher on the red side.  "
		""
		"&a🛈 提示：在机器上使用隔热板，可以避免热量损耗。"
		""
	]
	quest.4E175A06927C3A75.quest_desc: [
		"&7充气站&r可便捷地为气动工具与设备充气。"
		""
		"同时还提供设备改装功能，可安装&7速度升级&r与&7容积升级&r。"
		""
		"最后且最重要的一点，&7充气站&r可用作压力技工的职业工作台。"
		""
		"&a🛈 提示：安装发射器升级后，充气站可为站立于其上的实体充能。"
		""
		"&a    此功能可用于为无人机充气，或是一次性补满全身装备的气压！"
		""
		""
	]
	quest.4E2D6D91B5DA19EE.quest_desc: ["凭借深度智能与预知能力，这些装置得以满足高阶科技的需求，驾驭不可预测的电涌与混沌奥术能量。"]
	quest.4EA58751A74DABAA.quest_desc: ["&7振动水晶&r能够储存庞大的能量，让你开始发展EV级的电力。"]
	quest.4F2E18DABA17E0AC.quest_desc: [
		"&7原子再构机&r是一台能够转化特定物品的强大装置，比如将&7泥巴&r转化为&7苔藓块&r。"
		""
		"它可是个了不起的吃电大户！"
		""
		"在通电后，这台机器会周期性地释放能量光束。光束路径上的任何适用物品或方块都将被转化。"
		""
		"&a🛈 提示：手持红石火把右击机器可以将红石模式更改为脉冲。"
		""
		""
		""
		"&6⚠ 注意：掉落物形式的方块和放置在世界中的方块都可以被转化。"
		""
		""
	]
	quest.4FEA49AD05720ED7.quest_desc: [
		"Ah, the simple joys of playing with chalk outside. "
		""
		"Arts and Crafts allows you to craft paint brushes to rapidly re-color blocks such as Wool, Terracotta, or any of the many blocks added by the mod itself. "
		""
		"&a🛈 Tip: Search &3@arts&r &ain EMI to "
		"&a    更多相关内容。"
	]
	quest.4FEA49AD05720ED7.title: "Arts and Crafts"
	quest.5009BB4B0D1B459E.quest_desc: [
		"&7漏斗增强器&r使用方法：放置在&7漏斗&r上方，其拾取范围可提升至7格。"
		""
		"与&7专家型漏斗&r配合使用时，还可针对特定物品进行过滤。"
	]
	quest.503873180200D878.quest_desc: [
		"由&7幽匿块&r制成的&7回响泥球&r可以加工成新材料！"
		""
		"                   &n&6材料&r"
		""
		"  • &7紫晶石&r"
		"  • &7回响粉&r"
		"  • &7异界灰烬&r"
	]
	quest.51233852CD921F79.quest_desc: [
		"&7驱动器&r作为紧凑存储设备，可以存储成千上万的物品。"
		""
		"单个驱动器可以存储最多10个&7存储元件&r，每个元件有独自的容量和限制。"
		""
		"元件也可以在&7元件工作台&r中进行过滤，让你精确控制哪些物品可以存储在这个元件上。"
	]
	quest.513BDF32A8F6EF45.quest_desc: [
		"探宝蟹已经迫不及待要帮忙啦！"
		""
		"内含该空岛独特材料的新&7泥球&r正在等候着你。"
	]
	quest.51636F3E5A461A7B.quest_desc: [
		"你可以在砧板上用&7斧头&r刮掉&7冰石&r上的冰。"
		""
		"清理后，你将得到&7圣石&r，圣石可以粉碎以获得其他材料。"
		""
		"值得注意的是，你还需要一些&7神能晶片&r，它是附神转化的重要催化剂。"
		""
		"&6⚠ 注意：冰石很冷，持有过多冰石会迅速降低你的体温！"
		""
		""
	]
	quest.51A88370BE1CAC99.quest_desc: [
		"&7蚯蚓&r不仅能加速作物生长，还能保持土壤湿润。"
		""
		"一只&7蚯蚓&r可以维持一片3x3的耕地。"
	]
	quest.520241157010066D.quest_desc: [
		"活化一个&7荒野伏击者&r，然后收集它的身体部件。"
		""
		"&7荒野膜翼&r只能通过&7碎魂&r能力获得。"
		""
		"&6⚠ 注意：仪式图标物品并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.521DE7879A4B6F03.quest_desc: ["有了&7EV级电缆&r和&7变压器&r，升级基础电力设施以满足高功率&7粒子加速器&r的需求会是一个明智之举。"]
	quest.5226F1BC0A1B23D0.quest_desc: ["[ \"\", { \"text\": \"水之精华\", \"color\":\"gray\"}, \"能够让你进入\", { \"text\": \"奔流空岛\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"7893072479F01DC2\" } }, \"的不绝飞瀑。\" ]"]
	quest.5226F1BC0A1B23D0.title: "奔流空岛"
	quest.529329FE6CB3D29E.quest_desc: ["在DNA提取器中分解细胞来获得美味多汁的DNA螺旋。"]
	quest.52E79B2EB7400D13.quest_desc: [
		"&7终端&r让你可以访问网络，让你和其中的物品交互。"
		""
		"&7合成终端&r内置了工作台，因此大多情况下它们都是更好的选择。"
		""
		"&a🛈 提示：线缆组件不能连接致密线缆。"
		""
	]
	quest.537EDDC45D94BDE4.quest_desc: ["更高级的凝胶可以解锁更多配方，并且加快在游戏世界中的方块处理速度。"]
	quest.53CE92319716971B.quest_desc: [
		"我的世界里一直可以使用&7骨粉&r来复制&7玫瑰丛&r等大型花。"
		""
		"在这里，这种能力也扩展到了&7小型花&r上。"
	]
	quest.53CE92319716971B.title: "复制小花"
	quest.53D3092CA777D3B5.quest_desc: [
		"这个共振器已近乎完美，能够很好地预判不断变化的情况。"
		""
		"这在处理高度不稳定的奥术流时将会很有用。"
	]
	quest.540133B792547B21.quest_desc: [
		"制作一个&7煅烧炉&r，并将其放置在&7御炎火盆&r上。"
		""
		"&7石子&r等物品可以通过右击直接放入&7煅烧炉&r中，而燃料则需要右击放入&7火盆&r以开始煅烧。"
	]
	quest.55065F1D9C6716C1.quest_desc: [
		"&7高级传感器&r和初级相比有了范围升级，可以与更大范围内的物品交互。"
		""
		"&a🛈 提示：点击显示区域按钮，这可以让配置工作"
		"&a   区域更方便。"
	]
	quest.5550423B6E6BDBAF.quest_desc: [
		"需要树苗吗？或者想养些蜜蜂产蜜？"
		""
		"在蜂后的王座上召唤她，看看她能提供哪些交易！"
	]
	quest.5550423B6E6BDBAF.title: "蜂巢空岛"
	quest.55D51F58CA3130AA.quest_desc: [
		"探宝蟹已经迫不及待要帮忙啦！"
		""
		"内含该空岛独特材料的新&7泥球&r正在等候着你。"
	]
	quest.56AD6E7F12056140.quest_desc: [
		"&7附魔装置&r本身就是一个关键工具，而且很快将会成为必须。"
		""
		"此装置所用的&7奥术核心&r也是&7可疑的巫师村民&r的&7工作站点&r，他会向你出售各式各样的魔法小物件。"
		""
		"考虑搞几个薇克精来帮你烹饪食物，好喂饱你的村民。"
	]
	quest.56AD6E7F12056140.title: "可疑的巫师"
	quest.56DDD2327724F715.quest_desc: [
		"&7线缆&r有不同的颜色与尺寸供你选择。"
		""
		"不同颜色的线缆不会相互连接，这意味着它们可以轻松的并排铺设而无需担心风险。"
		""
		"另一方面，&7福鲁伊克斯色线缆&r可以连接任何其他线缆。"
		""
		"&7玻璃&r和&7包层线缆&r最多可以传输8个频道，而&7致密线缆&r可以传输全部32个频道。"
		""
		"通常来说，这些线缆会通过&7ME控制器&r，在需要时使用较小的线缆分支。"
		""
		"&a🛈提示：线缆锚用来阻止两条线缆之间进行连接。"
		""
		""
	]
	quest.56DDD2327724F715.title: "线缆"
	quest.56EDBF31457D8112.quest_desc: [
		"使用比较器读取灵气探测器的数据，就可检测当前区域内的灵气值。"
		""
		"与灵气制造设备搭配使用时效果更好，这可以让你根据灵气值打开或关闭制造设备。"
	]
	quest.574555F24035E48A.quest_desc: [
		"这一系列方块的功能正如它们的名字所写；放置与收集方块或流体。"
		""
		"它们无法过滤，但可以被红石信号控制，所以配合&7传感器&r使用以实现更高级的逻辑功能。"
		""
		"它们都拥有一个功能各不相同的槽位。"
		""
		"&7方块破坏器&r会使用栏位内的工具进行破坏。"
		""
		"&7方块放置器&r仅会将其栏位内的方块进行放置。"
		""
		"与此同时，&7流体收集器&r和&7放置器&r都需要在栏位中放置容器，这样便可手动输入/输出流体。当然，它们也可以使用管道进行流体输入输出。"
	]
	quest.574555F24035E48A.title: "初级放置和收集器"
	quest.577337FFD6AD9C83.quest_desc: ["[ \"在\", { \"text\": \"Replication章节\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"13C15ACA23526F9E\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]} }, \"了解更多有关使用这些机器生产物品的信息\" ]"]
	quest.577337FFD6AD9C83.title: "Replication"
	quest.579B2C5CB83022ED.quest_desc: [
		"&7操纵之灌注炮塔&r结合了&7方块塑形之核心&r与&7附魔炮塔&r的优点，也就是说它不仅可以施展前一任务中的所有示例法术，还能在施法时获得巨大的魔力消耗减免。"
		""
		"毫无疑问你会想花些时间设置这样的炮塔，用来构筑如&7寒风境云&r、&7气凝胶&r和&7黏土&r等重要材料——仅举几例。"
		""
		"&a🛈 提示：当与炮塔一起使用时，拾取魔符会将物品放入相邻的容器中。"
		""
		""
		"&6⚠ 注意：使用你的使用法术书或法术羊皮纸右击炮塔来设置法术。"
		""
	]
	quest.579C07CD07599438.quest_desc: [
		"为了自动合成物品，AE需要一个CPU来管理合成。这些是由三个部分组成的多方块结构。"
		""
		"这种多方块本身必须包含至少一个合成存储器，而且必须是长方体。"
		""
		"每个同时进行的制造请求都需要一个CPU。"
		""
		"• 合成存储器：存储合成所需的所有材料。"
		"  可以使用多个。"
		""
		""
		"• 并行处理单元：可选。"
		"  让CPU更频繁的发送材料批次。"
		""
		""
		"• 合成单元：可选。"
		"  廉价的填充块，以满足形状需求。"
		""
		""
		"• 合成监控器：可选。"
		"显示CPU当前处理的任务。"
		""
	]
	quest.579C07CD07599438.title: "合成CPU"
	quest.5859B0217F1C837A.quest_desc: ["灵气吸引矿车可从中心灵气制造设备抽取灵气，并将其分散至整个区域，为距离远的设备提供灵气。"]
	quest.58A275DB77CDF7F8.quest_desc: [
		"灵灾为生物添加了几种特殊掉落物，只能用特定的武器获得。"
		""
		"一般来说，都是从合成一把&7粗制镰刀&r开始的，但是如果你已经在其他模组中有所进展，你可能会发现你已经拥有了一把能获取这些材料的武器。"
		""
		"&a🛈 提示：魂织布袋会自动收集这些掉落物"
		"&a    注意整理好你的物品栏！"
		""
	]
	quest.58A3F58B7F1C580B.quest_desc: [
		"&7大型沉淀池&r是&7沉淀池&r的多方块结构的版本，能够更大批量的处理配方。"
		""
		"随着&7水资源&r的循环需求不断增加，你可以考虑进行这一项升级。"
		"&n                                                &r"
		""
		"每种现代工业化的多方块结构中，输入仓与输出仓需要完全匹配待处理的配方。"
		""
		"该任务中，&7大型沉淀池&r同时需要流体仓和物品仓。"
		""
		"&a🛈 Tip: Place the controller block, then hold a Wrench "
		"&a    to see the structure. Similarly, hold a Hatch to see "
		"&a    valid locations for them."
	]
	quest.598473588831F46D.quest_desc: [
		"&7流体激光中继器&r相当于一个无线流体管道。只需将其放置在储罐和需要流体的机器上，然后用中继器扳手将它们全部连接起来即可。"
		""
		"它们的连接范围相对较短，但可以连锁延伸来扩大范围！"
		""
		"&a🛈 提示：使用指南针即可将模式切换为从流体储罐中传出！"
		""
	]
	quest.59DC95275C1091C6.quest_desc: [
		"&7烈焰燃料&r相较于&7精制菜籽油&r有了显著提升，其价值绝对值得付出努力。"
		""
		"尽早完成自动化可以让机器在未来的一段时间内维持运转。"
	]
	quest.59F0519A7ED69E19.quest_desc: [
		"通常情况下，&7石油&r是在数百万年的漫长岁月里，在巨大的压力作用下形成的。"
		""
		"没人能等得了那么久。"
		""
		"让我们使用&7时间流体&r为这个过程稍微提一点速。"
		"&n                                                &r"
		""
		"[ \"要获得制作这种结晶体所需的材料，你需要先到访过\", { \"text\": \"闪耀空岛\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"19F8B29D38CA31B8\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]} }, \"。\" ]"
		""
		"Once you’ve obtained the requisite ingredients, the only thing standing in your way is Time itself."
		""
		"And Aura. Lots of Aura."
	]
	quest.59F0519A7ED69E19.title: "石油"
	quest.5A5596ED63306534.quest_desc: ["在不存在的微风下，它闪烁不定。"]
	quest.5A5706DE9011B222.quest_desc: [
		"有了&7特斯拉电塔&r后，你就可以大范围无线传输电力。"
		""
		"区域半径和传输速率由结构中使用的&7线圈&r决定，而&7能量仓&r则决定了电压等级。"
		""
		"&a🛈 提示：特斯拉接收仓可以直接为多方块结构无线供能！"
		""
		""
	]
	quest.5A74D7EFD6AD1EAC.quest_desc: [
		"用&7碎魂武器&r击杀生物会掉落精魂碎晶。这在灵灾中的许多合成都有用到，所以要注意哪种生物掉落哪种精魂碎晶。"
		""
		"在EMI中查看每种精魂碎晶的信息选项卡，了解从何处获得它们。"
		""
		"&a🛈 提示：精魂罐可以容纳"
		"&a    巨量的精魂！"
	]
	quest.5AC80FA3683D9E45.quest_desc: ["更高级的凝胶可以解锁更多配方，并且加快在游戏世界中的方块处理速度。"]
	quest.5AD1A273F3714FAF.quest_desc: [
		"是时候开始考虑生产魔源了。"
		""
		"来自新生魔艺模组的多种设备需要魔源才能运作，例如&7附魔装置&r。另一些设备在提供魔源时会有极大增幅，例如&7灌注室&r。"
		""
		"因此，从下面挑一个方案，现在开始魔源大生产！"
		"&n                                       &r"
		""
		"每种魔源通道会使用不同的“燃料”产生魔源，然后将产生的魔源输送到附近的魔源罐中。"
		""
		"• &7农艺魔源通道&r：作物自然生长时产生魔源。将它放在农田正中可以让效果最大化。"
		""
		""
		""
		"• &7火山魔源通道&r：消耗煤炭等熔炉燃料产生魔源。燃料可以直接丢在附近，或者放进相邻的奥术基座上。"
		""
		""
		""
		"• &7炼金魔源通道&r：从相邻的药水罐消耗药水以产生魔源。最好安排一个薇克精专门为这个药水罐生产药水。"
		""
		""
		""
		"• &7生死魔源通道&r：将生物的死亡转化为魔源。与任意生物农场是绝配。"
		""
		""
		"• &7菌丝魔源通道&r：消耗食物以产生魔源。食物可以直接丢在附近，或者放进相邻的奥术基座上。"
		""
		""
		""
		"&a🛈 提示：魔源罐罐可以容纳10,000点魔源。"
	]
	quest.5AFB064A80189AA4.quest_desc: [
		"这种&7苔藓&r似乎在生长过程中汇聚了各种矿物质。"
		""
		"粉碎他们可以获得&7铜&r和其他有用的矿物质！"
		""
		"对&7苔藓&r使用&7骨粉&r会使其蔓延到附近的方块，比如&7泥巴&r和&7泥土&r。所以只要你保留至少一块&7苔藓&r，就能无限地获取！"
	]
	quest.5AFB064A80189AA4.title: "铜"
	quest.5D1960D1AE64E4A2.quest_desc: [
		"繁茂空岛自带一个现成的&7自然祭坛&r助你启程。"
		""
		"你应该已经注意到了，有几个&7沼泽之霍米&r散步在&7孢子花&r下。这些实用的小装置能将附近的&7苔藓&r还原为&7泥巴&r，同时向周遭释放一些灵气。"
	]
	quest.5D50FB987FCA7BB5.quest_desc: [
		"这座空岛上生长的&7恼人至高树&r上已经结出了一些&7堡垒果&r。"
		""
		"可以先收集一些，然后随时可以建造一个农场。堡垒果可以在&7恼人至高原木&r上生长，可以通过&7骨粉&r或其他催熟手段加速生长。"
		""
		"&a🛈 提示：收获仪式可以更方便地采集这些水果！"
		""
	]
	quest.5D74493BC797D6F0.quest_desc: [
		"只有从那些最邪恶、最残忍的生物的体内才能收集到&7邪恶精魂&r。"
		""
		"你也许应该把那些咩咩叫的山羊的心脏挖出来看看。"
		""
		"&6⚠ 注意：刷怪蛋并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.5D74493BC797D6F0.title: "邪恶精魂"
	quest.5D97DDB66F470605.quest_desc: ["海王工具和盔甲不可破坏，非常适合在农场中使用。"]
	quest.5DF0502B194247F9.quest_desc: [
		"你是否想过用AE系统转移魔源？或者是与魔源罐相比，可以轻松存储更多魔源的存储空间？"
		""
		"魔源存储元件便是答案。"
		""
		"将这些元件与ME魔源罐结合使用，你可以随时随地按需输入输出魔源，同时将大量魔源存储在系统中以备不时之需。"
		""
		"&a🛈提示：将ME魔源罐放在需要魔源的地方，然"
		"&a   后用中转器传输到常规魔源罐以供使用。"
		""
		""
	]
	quest.5E4077F317135E34.quest_desc: [
		"女子在新生的大地上苏醒时，发现自己孤身一人，举目皆是陌生的景象。女子听到自己的肚肠饥鸣，由此始知饥饿的滋味。女子清楚难以再见同伴，由此有了害怕的感受。泪连成线，女子为失去的往昔而伤感。"
		""
		"动物们见女子饥饿，便送来根茎让她果腹。又见女子孤身一人，于是纷纷围拢来安慰女子。"
		""
		"女子饱餐了一顿，她用歌声表达对动物们的感谢。有了动物们的陪伴，女子止住了哭泣。泪水洒向天空，化作点点繁星。她将根茎埋入新生的大地，根茎开始生长，渐渐变得繁盛。"
		""
		"女子在新生的大地上行走，歌声伴随左右，诸兽倾心相随。她再次感到饥饿时，诸兽为她献上口粮。每到新的地点，女子将根茎植入土壤。由此，根茎滋长繁盛。由此，大地葱茏，万象竞发。"
	]
	quest.5E4077F317135E34.title: "培育根茎"
	quest.5E581FAC8D96FC22.quest_desc: [
		"&7分子装配室&r是一款简单的自动化合成器，它可以根据样板终端设置好的配方重复合成。物品可以通过管道输入，结果会自动输出到相邻的库存。"
		""
		"这是早期基础合成自动化的最好方式。"
		""
		"&a🛈 提示：分子装配室需要能量但不占用频道，所"
		"&a   以可以在临时网络中放置多个来获取能量，同"
		"&a   时用外部管道被动提供材料。"
		""
		""
		""
	]
	quest.5E727F7B600E0E91.quest_desc: [
		"&7溶解成型机&r能够将多种原料与某些流体混合。"
		""
		"这台机器只能接收一次合成所需的物品，因此锁定槽位以制作特定配方并通过管道输入物品是非常实用的技巧。"
		""
		"这样，它就能在你处理其他事情时进行批量制作。"
		""
		"&6⚠ 注意：物品可以以任意顺序进入机器！"
		""
	]
	quest.5F9A998072170415.quest_desc: [
		"探宝蟹已经迫不及待要帮忙啦！"
		""
		"内含该空岛独特材料的新&7泥球&r正在等候着你。"
	]
	quest.5FC9979B966955DE.quest_desc: [
		"让Oritech的&7离心机&r旋转起来，开始生产&7碳纤维&r。"
		""
		"你需要这些碳纤维来制作更高级机器所需的零件。"
	]
	quest.5FD8F4BE050D55B2.quest_desc: [
		"&7Pretty Pipes&r are a simple item logistics and sorting system with some powerful features. "
		""
		"Perhaps the biggest draw is that they show what’s moving through them for a more immersive experience. "
		""
		"Beyond this, however, they offer both push and pull functionality, where an &7Extraction Module&r can be used to pull items from an adjacent inventory and disperse them throughout the network, or a &7Retrieval Module&r may be used to pull items from any inventory on the network and push into the adjacent inventory. "
		""
		"Various filters and priority modules exist to help ensure the items are going to the correct place. "
	]
	quest.5FE4FD410171ABFD.quest_desc: [
		"随着能量需求激增，更好的方案通常是升级你的&7锅炉&r，并非制造更多相同的。"
		""
		"毕竟，一个&7进阶锅炉&r比的上四个标准&7锅炉&r。"
		"&n                                                &r"
		""
		"使用&7进阶大型蒸汽锅炉&r来提升你的能量产出。"
		""
		"&a🛈 提示：放置控制方块，然后拿着扳手来预览结构。"
		"&a   同样，拿着仓室可以显示它们的位置。"
		""
	]
	quest.60239B38B7288779.quest_desc: [
		"&7亭子&r上的那个小锅炉显然已经不够用了，所以我们现在给它做个“小”升级吧。"
		"&n                                                &r"
		""
		"每种现代工业化的多方块结构中，输入仓与输出仓需要完全匹配待处理的配方。"
		""
		"该任务中，&7大型蒸汽锅炉&r只需要流体仓，而且流体仓无法接受固体燃料。"
		""
		"在EMI中，查看控制器方块（即&7大型蒸汽锅炉&r方块）的用途便可知道这个结构所需的其他方块。注意，所列的方块可被仓室替代。"
		""
		"&a🛈 提示：放置控制方块，然后拿着扳手来预览结构。"
		"&a   同样，拿着仓室可以显示它们的位置。"
		""
	]
	quest.6030BA17DB9228F2.quest_desc: [
		"又一天，女子猛觉自己已身处北方，仍在跟随的动物寥寥无几。"
		""
		"天地间银装素裹，女子前行的脚步越来越慢。她意识到自己的体力正在流失，已不足以穿越这片地界。她见看到动物们钻入雪地取暖，便效仿它们，也将自己埋进了雪堆。"
		""
		"她在雪中静坐，回想自己旅程中的点点滴滴。"
		""
		"北风开始呼啸，强劲而寒冷。一切仿佛静止了。"
	]
	quest.6030BA17DB9228F2.title: "雪中求生"
	quest.605A60825B68C2D7.quest_desc: [
		"许多动物无法适应这种高度，这会缩短它们的寿命。"
		""
		"下列生物成年后只能存活大约&710个游戏日&r，这意味着若想饲养它们，就必须持续繁殖。此外，它们必须生活在温暖环境中，以免冻死。"
		""
		"衰老的动物将表现出以下迹象："
		"    1. 它们的&7最大生命值&r降低。"
		"    2. 它们移动&7缓慢&r且会&7失明&r。"
		"    3. 最后，它们会&7凋零&r并死亡。"
		""
		"以此方式死亡的生物&7不会掉落物品&r。"
		""
		"所幸，你有一些方法可以实现自动繁殖，从而持续更新畜群。"
		""
		"                  &6&n会衰老的动物&r"
		""
		"      &7鸡                       &7哞菇"
		"      &7牛                       &7天翼牛"
		"      &7羊                       &7云跳羊"
		"      &7猪                       &7飞天猪"
		"      &7兔子                     &7天跃兔"
		"      &7山羊"
	]
	quest.605A60825B68C2D7.title: "动物衰老"
	quest.60DC19DA26E8CCA4.quest_desc: ["清除所有不洁灵魂后，&7不锈钢&r在更先进的科技中应该会大有用处，因为在这些科技中，一两个游荡的灵魂可能会干扰处理过程并带来灾难性的后果。"]
	quest.616862D8ADBE3928.quest_desc: [
		"水在寒冷中会结冰，毫无疑问。不过你很快就会需要一些特别寒冷、致密的冰。"
		""
		"将&7水桶&r冻成冰，然后再冻，再冻，直到冻成&7蓝冰&r。"
		""
		"不过要小心，持有它时会感到极其寒冷！"
		""
		"&7冷冻器&r使用&7冰石&r作为燃料。"
	]
	quest.619FB543EE458A0E.quest_desc: [
		"使用降生祭坛召唤一只&7北极熊&r，然后从它身上采集一些&7有机物质&r。"
		""
		"&6⚠ 注意：刷怪蛋并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.619FB543EE458A0E.title: "北极熊"
	quest.61F55FC24EA0CD1C.quest_desc: [
		"首先，我们需要一些有机物质样本，可以对不同生物使用刮刀来获得。"
		""
		"然后扔进细胞分析器来获得细胞。"
		""
		"&a🛈 提示：带有精细触控附魔的刮刀不会造成伤害。"
		""
	]
	quest.623B5F0C0464F907.quest_desc: [
		"虽然“一群&7星宝石兽&r共享一个过度工作的脑细胞”的传言确实是真的，但它们依然能带来巨大的帮助。"
		""
		"一般来说，每只星宝石兽一次只能专注于一项任务，但你可以通过给予它们不同的帽子来给它们指派各种工作。"
		""
		"&6默认工作&r"
		"  • 拾取地面上的物品并存入指定容器"
		""
		"  • 从魔源浆果丛中采集魔源浆果并将其存入指定容器"
		""
		"  • 将物品从一个容器运输到另一个容器中"
		""
		"&6星宝石兽墨镜&r"
		"  • 禁用拾取物品和采集魔源浆果的能力"
		""
		""
		"&6方形轮询罗宾假面&r"
		"  • 启用轮询物品运输。"
		""
		"&6薇克精帽子&r"
		"  • 将药水从一个药水罐转移到另一个药水罐中"
		""
		"&6星宝石储罐&r"
		"  • 将流体从一个流体容器运输到另一个流体容器中"
		""
		"&6星宝石垃圾桶&r"
		"  • 销毁捡起的物品"
		""
		"&6星宝石挖掘工帽&r"
		"  • 允许星宝石兽挖掘指定位置的方块"
		""
		"&6星宝石建筑工帽&r"
		"  • 允许星宝石兽在指定位置放置方块"
	]
	quest.625AE1AEF37DAE03.quest_desc: [
		"自动耕作的一种选择。虽然有些小毛病，但暂时够用了。"
		""
		"别忘了在旁边设置一个&7农艺魔源通道&r，从你的农田里捕获额外的魔源！"
		""
		"&a🛈 提示：手持指南针右击机器可以调整工作区域。"
		""
		""
	]
	quest.628A6A79EFA30990.quest_desc: [
		"存储讲台是你与存储网络交互的主要界面。在这里，你可以访问所有已连接的容器，还能方便地使用工作台。"
		""
		"每个网络中只有一个&7主存储讲台&r，且可以根据需要连接任意数量的&7副讲台&r。"
		""
		"只有主讲台能够与容器连接，副讲台仅作延申远程访问距离使用。"
		""
		"                &6&n主存储讲台&r"
		""
		"手持&7书龙护符&r右击存储讲台即可将其指定为&7主讲台&r。"
		""
		""
		"              &6&n副存储讲台&r"
		""
		"要指定&7副讲台&r，先手持&7支配之杖&r右击该存储讲台，再右击&7主讲台&r将它们连接起来。"
		""
		"你可以串连&7副讲台&r以达到更远的距离。"
		""
		"                     &6&n绑定存储容器&r"
		""
		"使用支配之杖将容器绑定到&7主讲台&r：先潜行右击容器，再右击&7主讲台&r。"
	]
	quest.62C7492F54D80CBA.quest_desc: [
		"先前留给你的几本法术卷册效果应该不错，但它们毕竟无法替代真正的&7法术书&r。完全修复它需要费点功夫，我们现在开始着手。"
		""
		"首先收集一些木材，制作几个基础工具。"
		""
		"有了&7斧头&r和&7砧板&r，你就能够切削&7树皮&r，制作&7纸&r。"
		""
		"再用&7刀&r破坏&7草&r以获得&7草杆&r。"
		""
		"之后也可以对&7砧板&r施展法术。以下组合模拟了相应的工具效果。"
		""
		"                           &6&n示例法术&r"
		""
		"&7刀或剪刀&r"
		"    &5触摸&r > &a剪切&r"
		""
		"&7斧或刀&r"
		"    &5触摸&r > &a剪切&r > &6强化&r"
		""
		"&7剪刀&r"
		"    &5触摸&r > &a剪切&r > &6提取&r"
		""
		"&7镐&r"
		"    &5触摸&r > &a破坏&r"
		""
		"&7锹&r"
		"    &5触摸&r > &a粉碎&r "
		""
		"&7斧&r"
		"    &5触摸&r > &a砍伐&r "
	]
	quest.62C7492F54D80CBA.title: "我为刀俎"
	quest.62E2DEBF71698376.quest_desc: [
		"&7输入&r，&7输出&r，和&7存储总线&r是你网络中的主要接口。"
		""
		"&7输入&r和&7输出总线&r的作用正如其名，可以将物品输入网络或从网络中输出。"
		""
		"另一方面，&7存储总线&r可以让连接的库存变为网络的一部分；网络可以访问其中的内容，它也可以用来存储网络中的内容。"
		""
		"&a🛈 提示：线缆组件不能连接致密线缆。"
		""
	]
	quest.631AA5AAA6EF687C.quest_desc: [
		"&7样板供应器&r是网络与制作机器交互的方式，既可以输入制作材料，也可接受制作的结果。"
		""
		"对于基础的合成样板，例如你在&7工作台&r的合成，&7样板供应器&r需要被放在一个或多个&7分子装配室&r旁。"
		""
		"对于机器制作或处理样板，&7供应器&r需要放置在机器可以输入输出的一侧，面朝机器。"
		""
		"它还可以接入任何形式的库存，让你可以向其发送物品。例如，一组&7熔炉&r可以通过一个&7供应器&r提供原料，将原料输入&7桶&r中，管道可以运送物品并将其分配到熔炉中，同时将产物返回到&7样板供应器&r中。"
		""
		"&a🛈 提示：对于需要将流体或物品分配到不同面的"
		"&a   机器，可以考虑使用子网！"
		""
	]
	quest.631AA5AAA6EF687C.title: "自动合成"
	quest.6384F08466CA9FB9.quest_desc: [
		"&7红石灵气蒸发器&r本质上就是一个时钟。"
		""
		"输入&7瓶装灵气&r可设定不同间隔。每瓶&7阳光&r对应一秒，&7鬼魂&r对应一分钟，&7黑暗&r对应一小时。"
	]
	quest.63944BDC078E728A.quest_desc: [
		"&7方块塑形之核心&r是施法者的强力法器，它允许你将多次施法才能产生的效果叠加到单个法术上。"
		""
		"例如，你可能已经相当习惯使用下面这样的法术来构筑寒风境云。"
		""
		"&7构筑寒风境云&r"
		"    &5触摸&r > &a构筑地层&r > &a粉碎&r"
		""
		"然而，装备了&7方块塑形之核心&r后，下面的法术构建变得可行，你能够立刻创造并拾取构筑出的材料。"
		""
		"&7构筑并收集寒风境云&r"
		"    &5触摸&r > &a构筑地层&r > &a粉碎&r > "
		"            &a破坏&r > &a拾取&r"
		""
		"没有核心时，这将会构筑一个寒风境云并破坏你点击施法的方块。而有了核心以后，破坏效果会作用于被构筑的方块。"
		""
		"以下还有更多有趣的法术，你也可以花点时间思索一些新点子。"
		""
		"                           &6&n示例法术&r"
		""
		"&7构筑并收集玻璃（需要奔流空岛）&r"
		"    &5触摸&r > &a构筑地层&r > &a粉碎&r > &a烧炼&r > "
		"            &a破坏&r > &6提取&r > &a拾取&r"
		""
		"&7构筑并收集陶瓦（需要奔流空岛）&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &a烧炼&r > "
		"            &a破坏&r > &6提取&r > &a拾取&r"
		""
		"&7构筑并收集砖块（需要奔流空岛）&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &a破坏&r > "
		"            &a烧炼&r > &6敏感&r > &a拾取&r"
	]
	quest.63A7E92BBCEDF461.quest_desc: [
		"有一天，女子觉得该继续上路了。这次她来到了南方，动物们依然随她同行。"
		""
		"在这里，森林让位于湿地，湿地又被沙岸环绕。女子见动物们在蜿蜒的河道中徜徉嬉戏，便欣然造了一艘独木舟加入其中。女子玩得累了，就靠在河岸的沙丘上歇息。女子觉得身上不洁净了，就在温热的海水中沐浴净身。"
		""
		"与女子一同旅行的动物们中，有一部分在这河川之中找到了居所，就此定居了下来。"
		""
		"南风开始吹动，炎热而猛烈。带来了夏天的讯息，也带来了冒险的希望。"
	]
	quest.63A7E92BBCEDF461.title: "沐浴阳光"
	quest.63AFE7CB35AE94BF.quest_desc: [
		"想来点新花样？想要在机械动力模组的普通机器上来点更魔幻的体验？"
		""
		"Ars Technica，新生魔艺的附属模组，包含众多可以模拟机械动力加工处理的魔符。下面有几个入门示例法术。"
		""
		"这些法术非常适合快速手动加工物品，或者，如果你将法术写进法术炮塔，也许能成为机械动力的强力替代品。"
		""
		"                           &6&n示例法术&r"
		""
		"&7鼓风机 - 批量洗涤&r"
		"    &5弹射物&r > &a旋风&r > &6延长时效&r > &a构筑水&r"
		""
		"&7鼓风机 - 批量熔炼&r"
		"    &5弹射物&r > &a旋风&r > &6延长时效&r > &a烧炼&r"
		""
		"&7机械手&r"
		"    &5弹射物&r > &a使用&r > &6扩散&r"
		""
		"&7动力搅拌器&r"
		"    &5弹射物&r > &a融合&r > &6扩散&r"
		""
		"&7砂纸&r"
		"    &5弹射物&r > &a打磨&r > &6扩散&r"
		""
		"&7动力冲压机&r"
		"    &5弹射物&r > &a冲压&r > &6扩散&r"
		""
		"&a🛈 提示：尝试增加更多扩散魔符或叠加施放法术！"
	]
	quest.6490781066FAE8CF.quest_desc: [
		"                      &6&n生物群系：红树林沼泽&r&r"
		""
		"以下放置转换规则在本生物群系中生效。务必记得这一规律，这样在使用“构筑地层”法术时能更加灵活的生成方块。"
		""
		"  • &7泥土&r                      &2⟶&r           &7泥巴&r"
		"  • &7草方块&r                    &2⟶&r           &7泥巴&r"
		"  • &7圆石&r                      &2⟶&r           &7凝灰岩&r"
		"  • &7石头&r                      &2⟶&r           &7灌注之石&r"
		"  • &7沙子&r                      &2⟶&r           &7寒风境云&r"
		"  • &7沙岩&r                      &2⟶&r           &7速沙&r"
		"  • &7深板岩圆石&r                &2⟶&r           &7气凝胶&r"
		"  • &7深板岩&r                    &2⟶&r           &7气凝胶&r"
		""
		"{@pagebreak}"
		"&6&n示例法术&r"
		""
		"&7构筑泥巴&r"
		"    &5触摸&r > &a构筑地层&r"
		""
		"&7构筑凝灰岩&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r"
		""
		"&7构筑灌注之石&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &a烧炼&r"
		""
		"&7构筑寒风境云&r"
		"    &5触摸&r > &a构筑地层&r > &a粉碎&r"
		""
		"&7构筑速沙&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &a粉碎&r"
		""
		"&7构筑气凝胶&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &6强化&r"
	]
	quest.6534548E8A6A318C.quest_desc: [
		"探宝蟹已经迫不及待要帮忙啦！"
		""
		"New &7Dorodangos&r await you with the materials available on this island. "
	]
	quest.65FDD18E441E2E6E.quest_desc: [
		"作为一本活化了的书，书龙是新生魔艺模组内置的完备仓储系统的一部分。"
		""
		"手册中可以查到有关如何建立这一系统的更详细的指南。不过如果按还需要简单概述的话，那就是对存储讲台使用一个书龙护符，这样就可以建立讲台与容器的连接。"
		""
		"&a🛈 提示：使用更多书龙可以增加可连接容器的数量！"
		""
	]
	quest.6660BE0C308A1744.quest_desc: [
		"使用降生祭坛召唤一只&7山羊&r，然后从它身上采集一些&7有机物质&r。"
		""
		"&6⚠ 注意：刷怪蛋并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.6660BE0C308A1744.title: "山羊"
	quest.66C2FBA12D91F642.quest_desc: [
		"外骨骼装甲是一套不可破坏的动力装甲，提供中等护甲、夜视和速度加成。"
		""
		"外骨骼胸甲还可以继续升级，添加鞘翅或喷气背包飞行功能！"
	]
	quest.66DAC6EC4232C44A.quest_desc: [
		"作为追求乐趣的海洋居民，塞壬生活在暖水海洋，也很愿意加入你的家园，只要你能给她一个海泡菜。"
		""
		"作为交换，塞壬可以帮你收集钓鱼战利品。"
		"&n                                       &r"
		""
		"用对应的护符右击海晶石块可以创造出她的家园。在她的家园里放置更多水生植物和水生动物可以让她更加开心，更有生产力。"
	]
	quest.6703E3A9E3571660.quest_desc: [
		"在没有防护的情况下进行户外活动，持有太多冰冷物品都会导致体温快速下降。"
		""
		"穿戴保暖衣物能够降低热量流失的速度，所以记得穿好衣服再出门。"
		"&n                                                &r"
		""
		"在生命条和饥饿条之间，现在有一个新标识用于表示你的的失温率。失温率的范围是0到100，0表示温度舒适，100则表示温度致命。过冷会显示为&9蓝色&r，过热则显示为&6橙色&r。"
		""
		"失温率超过&950&r后，你的移动速度逐渐变得迟缓，且视野开始慢慢收缩。"
		""
		"如果失温率达到&9100&r，你会立即冻成冰雕。"
		""
		"尽管过热目前并不会带来威胁，这一机制也仍然需要留意，熔岩桶等物品在持有状态下也会影响体温。"
	]
	quest.6705BECBD94CAAAD.quest_desc: [
		"有了更强的齿轮和马达，这台&7半自磨机&r能够帮你从矿石中获得比以往更多的产出。"
		""
		"务必给它提供&7磨珠&r以获得最佳效果。"
		""
		"&6⚠ 注意：EnderIO模组的机器需要安装电容才能工作。"
		""
	]
	quest.6728201CEC8220A3.quest_desc: [
		"无论何种原因导致五角星阵损坏，都不必担心。当前阶段下，重新完成阵法所需的所有材料都很容易再次获取。"
		""
		"通常可以在EMI上查到物品的配方。以&7怪异晶体&r为例，在&7腐枯土&r上使用&7骨粉&r后，可以随机生成一些怪异晶体。"
		""
		"可以在EMI中点击各个仪式配方旁的&6👁&r按钮，在世界中预览五芒星阵图案。这会展示每个方块应该放置的位置。它们都使用了相同的五芒星阵。"
		""
		"如果有需要，&7圣杯&r可以替换为&7金质&r或&7艾瑟金属献祭之碗&r，但这么做会让仪式变慢。视情况而定的话，有时也能开发出用途。"
		""
		"你完全可以在其他地方重建五芒星阵，如果你需要更大空间才能自动化的话。"
		""
		"            &6&n关于自动化的说明&r&r"
		""
		"当前版本中，神秘学的五芒星阵自动化更容易实现了，如果你只玩过旧版模组的话，请看下面的介绍。"
		""
		"可以通过任意管道或漏斗将物品送入所有&7碗&r中，这一机制也适用于中心的&7圣杯&r。"
		""
		"只有周围的碗中物品形成了一个有效的配方，中心的物品才能被送入，随后仪式立即开始，不需要进行额外操作。"
		""
		"这意味着你可以简单地将物品传送到每个碗中，而不必再设置额外的逻辑。"
		""
		"&a🛈 提示：粉笔画的形状是随机出现的，但它不会影响五芒星阵的效果！"
		""
	]
	quest.672B88E9A3FA1FCE.quest_desc: [
		"当&7凛冬的呼唤&r激活时，该区域内会快速积雪，水会冻结成冰。"
		""
		"雪傀儡也可能会生成，进一步扩大积雪区域！"
		""
		"毋庸置疑，这是获取&7雪&r来制作&7冰&r的绝佳途径！"
	]
	quest.679DACB985517C55.quest_desc: [
		"&7高级投物器&r可以将物品扔得更远，且可进行数量配置。"
		""
		"&a🛈 提示：点击显示区域按钮，这可以让配置工作"
		"&a   区域更方便。"
	]
	quest.6806970967942788.quest_desc: [
		"&7咖啡制造机&r是&7工程师&r村民的工作站。以一顿丰盛的早餐作为交换，这些村民们会很乐意提供开始&7发电&r所需的所有零件。"
		""
		"[ \"在\", { \"text\": \"能量章节\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"0FF1E0FF9CAD1914\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]} }, \"了解更多有关更好的\", {\"text\": \"锅炉\", \"color\":\"gray\"}, \"以及使用\", {\"text\": \"涡轮机\", \"color\":\"gray\"}, \"发电的信息。\" ]"
		""
		"&7咖啡制造机&r还可用于自动冲泡&7咖啡&r。"
		""
		"只需放入原料，提供能量，并给它一个&7红石信号&r即可启动。"
		""
		"&6⚠ 注意：你可以用蒸汽蒸馏器泡一杯超棒的咖啡，让你打起精神迎接新一天！"
		""
		""
	]
	quest.6849CF8933FC70F9.quest_desc: [
		"有了&7钢机器外壳&r，一个全新的科技世界便向你敞开了大门。特别是许多Oritech模组的机器，现在已经能够制造了。"
		""
		"请务必在EMI中查看此外壳的用途，发掘你现在可以使用的新设备。"
		""
		"[ \"也请查看\", { \"text\": \"能量章节\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"0FF1E0FF9CAD1914\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]} }, \"以获取关于升级基础发电设施的信息。\" ]"
	]
	quest.687E532AD956C57A.quest_desc: [
		"凭借出色的保温和加热能力，这台&7合金炉&r能够达到足以将地狱燃烧殆尽的温度。"
		""
		"&6⚠ 注意：EnderIO模组的机器需要安装电容才能工作。"
		""
	]
	quest.68C212D2C7F8B308.quest_desc: [
		"活化一个&7荒野守卫者&r，然后收集它的身体部件。"
		""
		"&7荒野尖刺&r只能通过&7碎魂&r能力获得。"
		""
		"&6⚠ 注意：仪式图标物品并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.69295042E8C3A609.quest_desc: [
		"魔源中转器可以把魔源从一个地方传输到另一个地方。这样你就可以在一处设立集中式的魔源生产区域，让它为周围多个设备或法术炮塔提供魔源。"
		""
		"中转器有多种不同的类型，目前来说，或许最具实用价值的还是分流中转器。相比普通的中转器，分流中转器不仅能输送更多魔源，还能同时向多个目标抽取或输送魔源。"
		""
		"使用支配之杖可以将中转器连接到另一个中转器或魔源罐上。先右击抽取源，再右击目标方块。"
		""
		"&a🛈 提示：可以使用Wololo魔符改变中转器发射的光束的颜色。"
		""
	]
	quest.692EDEAEC3F4A2AD.quest_desc: [
		"&7替换器&r是一个强大的传送装置，可以将前方的方块或实体与绑定的对象互换。"
		""
		"这将是个绝妙的方式在你的基地四处移动，远距离传送，将幼崽从农场转移，等等。"
		""
		"它们必须成对连接，通过&7核源铁扳手&r进行绑定。"
		""
		"只需要同时放置它们，用&7扳手&r右键一个，然后用&7扳手&r右键另一个，这样就能完成绑定。"
	]
	quest.692EDEAEC3F4A2AD.title: "初级替换器"
	quest.697E0106FF4F5691.quest_desc: [
		"尽管&7末影谐振器&r具有预见能力，但它仍然缺乏意识体所需的高级认知功能。"
		""
		"将这两者结合，便能涉足魔法中最不稳定也最强大的领域。"
	]
	quest.699B01CFAEE29827.quest_desc: ["一个冷却&7塑料&r或直接&7制冰&r的好方法。"]
	quest.69EE67B1B612D74D.quest_desc: [
		"爬到空岛的顶端，那里长着一棵&7灵魂树&r。"
		""
		"你可以在树上找到一些&7富脂灵魂原木&r，这些原木可以用&7斧&r去皮。"
		""
		"在你完成去皮后，手持&7玻璃瓶&r对&7去皮富脂灵魂原木&r右击以获得一些&7诅咒树脂&r。"
		""
		"之后栽种的每棵&7灵魂树&r上也会生成一些像这样的&7去皮原木&r，使你能收集更多诅咒树脂。"
	]
	quest.6A4C2B4518E341D6.quest_desc: [
		"活化一个&7蓝色史威特&r，然后击杀它以获得&7碧水精魂&r。"
		""
		"&6⚠ 注意：仪式图标物品并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.6A4C2B4518E341D6.title: "碧水精魂"
	quest.6A4DD846F7E08FD6.quest_desc: [
		"女子越飞越高，穿过云层。她就这样飞行了很久。"
		""
		"空气变得稀薄，女子肺部开始灼痛。徐徐的春风为她带来新鲜空气。"
		""
		"气温骤然下降，女子四肢传来痛感，温热的夏风抚慰她的肌肤。"
		""
		"女子没有片刻停留，越飞越高。女子感觉自己可以触碰到太阳的辉光。"
		""
		"光线愈发刺眼，女子双目难以睁开。秋风为她指引前进的方向。"
		""
		"光线愈发炽烈，女子身躯变得滚烫。冬风为她提供喘息的空间。"
		""
		"女子终于到达了她的目的地，她将手杖伸入那燃烧中的光球。"
	]
	quest.6A4DD846F7E08FD6.title: "盗取火种"
	quest.6A8ACE8E9B7A056D.quest_desc: [
		"女子骤然坠入海里，动物们争先恐后来到她的身边，因为它们知道，若无歇脚之处，女子必会溺死。"
		""
		"它们轮流潜入深处，想把海底的泥巴托举上来。它们卖弄着自己的力量，都认为自己能够潜到海底。但最后只能无奈地浮出水面，声称这项任务是不可能完成的。"
		""
		"希望即将破灭之际，一只最小的海龟挺身而出，请求让它也试一试。小龟先前并未展示过自己的能力，其他动物们将信将疑，但还是纷纷让开，给予小龟尝试的机会。怀揣坚定的决心，小龟不断向深处潜去。哪怕肺部灼痛，四肢酸胀，它也绝不放弃。功夫不负有心人，小龟那小小的爪子在漆黑的深水中探到了泥巴。"
		""
		"小龟抓起一小撮泥，转身游向水面。其他动物看到它手中拿着的东西时，纷纷赞叹不已。它们帮忙将泥巴涂抹到龟背上，发现还需更多泥巴，于是小龟又一次潜入水中，如此反复，小龟的背甲上的泥巴慢慢扩大，最终形成了一片新的陆地，让女子得以在上面休息。"
	]
	quest.6A8ACE8E9B7A056D.title: "潜水取泥"
	quest.6A94923547B93B51.quest_desc: ["Fluid Cards for LaserIO allow Laser Nodes to transport Fluids."]
	quest.6AA9F3E0D4BC181A.quest_desc: [
		"在这座空岛上有两个重要的结构。"
		""
		"第一个结构是&7哭泣之井&r，你可以通过它交易特定物品。直接将物品掷入井里，新的物品就会丢回到你手中。"
		""
		"第二个结构是为精细要求设计的&7仪式&r。你应该可以找到一个周围环绕着粉笔记号的圣杯。"
	]
	quest.6AC4CADE97CB512F.quest_desc: ["[ \"\", { \"text\": \"土之精华\", \"color\":\"gray\"}, \"能够让你进入\", { \"text\": \"繁茂空岛\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"6490781066FAE8CF\" } }, \"的深泽泥沼。\" ]"]
	quest.6AC4CADE97CB512F.title: "繁茂空岛"
	quest.6AF21EDF59FCE0D4.quest_desc: [
		"在时间诞生以前，天空之民定居在云中的岛屿。"
		""
		"他们不知纷争为何物，因为万物亘古不移。"
		""
		"他们不知苦难为何物，因为世人长生不老。"
		""
		"一切始于一场突生的变故。"
		""
		"有一名女子不慎坠落了下来。她不断坠落，不断坠落。当她从无垠的蓝天中翻滚下落时，凡目睹之人无一不为此感到忧伤。天空之民目睹了这一劫难，既痛失于失去的同伴，也痛失于不复存在的往昔。"
		""
		"伴随声声嗟叹，人们的泪水倾泻而下，那泪水争先赶往地面，似要为女子提供缓冲。"
		""
		"泪流成海，海面上涨，女子终于停止了坠落。"
	]
	quest.6AF21EDF59FCE0D4.title: "消逝的童真"
	quest.6AFCA9F187AE6EB2.quest_desc: [
		"The Building section covers mods and tools to help you build up or tear down. "
		""
		"From mining and decoration, to destruction and more, the mods shown here will help you do it all."
	]
	quest.6AFCA9F187AE6EB2.title: "建筑"
	quest.6BA05AC6ECC577DA.quest_desc: [
		"现在，你应该已经准备好了召唤第一座空岛——繁茂花园所需的全部材料。"
		""
		"在那里，你会发现一些植物，可以扩展你的烹饪菜谱。还有一个&7降生祭坛&r，你可以在那里召唤一些动物，以获取肉类和其他资源。"
		""
		"只需将你的配方材料扔到&7祭坛&r附近，动物就会出现。非常魔法！"
		"&n                                       &r"
		""
		"施展这些空岛仪式时要小心。它们在生成空岛时不会破坏方块。"
		""
		"所以，如果有什么东西阻挡空岛生成，一些重要的方块可能会消失。"
		""
		"使用上一个任务中的&7飞行药水&r离开主岛一小段距离，然后施放&7固身锚&r法术放置一个临时方块作为基点。"
		""
		"你的&7仪式火盆&r可以放置在这个临时方块上。"
		""
		"&7火盆&r放置后，手持&7仪式板&r右键点击，再空手右击火盆以启动仪式。"
		""
		"&6⚠ 注意"
		"&6如果重要方块缺失，先清除所有阻挡方块，再在同一位置重新举行仪式刷新空岛即可。"
		""
		""
	]
	quest.6BA05AC6ECC577DA.title: "繁茂花园"
	quest.6C4A7BF577605E4A.quest_desc: [
		"The &7Time Wand&r uses Time Fluid and Energy to drastically accelerate machines for a brief period. "
		""
		"Simply Sneak + Right Click on a machine to apply stacking boosts up to 256x speed.   "
	]
	quest.6CA8BA78F5B8FB6A.quest_desc: [
		"活化一个&7荒野猎首&r，然后收集它的身体部件。"
		""
		"&7荒野号角&r只能通过&7碎魂&r能力获得。"
		""
		"&6⚠ 注意：仪式图标物品并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.6CE9EE018596DAD2.quest_desc: [
		"合成一本&7初学者法术书&r。它自带一些可以组合使用的核心魔符，相信你很快就会想尝试更多魔符，实现更加惊人的壮举。"
		""
		"                          &6&n实用按键绑定&r"
		""
		"[\"• 打开法术书 (\",{\"color\":\"gold\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"打开法术书\"}]},\"keybind\":\"key.ars_nouveau.open_book\"},\")\"]"
		"[\"• 法术选取HUD (\",{\"color\":\"gold\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"法术选取HUD\"}]},\"keybind\":\"key.ars_nouveau.selection_hud\"},\")\"]"
		"[\"• 下一栏法术 (\",{\"color\":\"gold\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"下一栏法术\"}]},\"keybind\":\"key.ars_nouveau.next_slot\"},\")\"]"
		"[\"• 上一栏法术 (\",{\"color\":\"gold\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"上一栏法术\"}]},\"keybind\":\"key.ars_nouveau.previous_slot\"},\")\"]"
		""
		"如果你对法术制作有些犯怵，这很正常——这是一套庞大而强力的系统。因此，我们会尝试在任务中指明一些实用的法术。"
		""
		"指南书中也有一个解释规则的部分，解释了诸如&5形态&r应该放在&a效果&r之前，&6增强&r允许放置的位置等。"
		""
		"[\"最后，社区驱动的\",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://ars.guide/spells/introduction/compendium/\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处访问\"}]},\"text\":\"Ars.Guide\",\"underlined\":true},\"提供了一个实用的法术库。请随意探索，分享你自己的法术！\"]"
		""
		"                           &6&n示例法术&r"
		""
		"&7多合一工具&r"
		"    &5触摸&r > &a破坏&r"
		""
		"&7一键砍树&r"
		"    &5弹射物&r > &a砍伐&r"
		""
		"&7构筑冰石&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r"
		""
		"&a🛈 提示：参阅指南了解更多示例。"
		""
		"&6⚠ 注意：单个法术最多只可包含30个魔符。"
	]
	quest.6D09D016EDE0AAFB.quest_desc: [
		"该工作站允许薇克精使用标准的&7工作台&r和&7酿造台&r配方。"
		""
		"酿造药水时，需要在附近放置药水罐来存储药水。"
		""
		"                   &6&n转化&r"
		""
		"手持&7薇克精护符&r右击&7炼药锅&r。"
		""
		"&6⚠ 注意：对于多步合成，每一步都需要分别标示出来。"
		""
	]
	quest.6D09D016EDE0AAFB.title: "薇克精合成与酿造"
	quest.6DA23C4B7F016B1D.quest_desc: [
		"&7温室玻璃&r能够显著促进其正下方作物的生长。"
		""
		"用它来为你的植物搭建一个既美观又实用的温室吧。"
	]
	quest.6DBBD5B744B801B1.quest_desc: [
		"有些方块无法放置在这个冰冷的地方，有些则会在放置后转化为另一种方块。"
		""
		"值得注意的是，下列方块无论以何种方式放置（包括构筑法术！）都会被转化为对应的方块。"
		""
		""
		"  • &7泥土&r                      &2⟶&r           &7天壤&r"
		"  • &7草方块&r                    &2⟶&r           &7空叶草方块&r"
		"  • &7圆石&r                      &2⟶&r           &7冰石&r"
		"  • &7石头&r                      &2⟶&r           &7圣石&r"
		"  • &7沙子&r                      &2⟶&r           &7寒风境云&r"
		"  • &7沙岩&r                      &2⟶&r           &7速沙&r"
		"  • &7深板岩圆石&r                &2⟶&r           &7气凝胶&r"
		"  • &7深板岩&r                    &2⟶&r           &7气凝胶&r"
		""
		"{@pagebreak}"
		"&6&n示例法术&r"
		""
		"&7构筑天壤&r"
		"    &5触摸&r > &a构筑地层&r"
		""
		"&7构筑冰石&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r"
		""
		"&7构筑圣石&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &a烧炼&r"
		""
		"&7构筑寒风境云&r"
		"    &5触摸&r > &a构筑地层&r > &a粉碎&r"
		""
		"&7构筑速沙&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &a粉碎&r"
		""
		"&7构筑气凝胶&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &6强化&r"
	]
	quest.6DD8DD44D4B70AD4.quest_desc: [
		"&7插件铰接器&r可以将一套插件压缩成一个方块，从而使你的Oritech机器布局更加紧凑。"
		""
		"结构建成后，像其他机器一样为其安装插件。然后点击GUI中的&7压缩！&r按钮，或向机器前方输入红石信号，即可开始生产&7机器之心&r。"
		""
		"这个新的压缩插件将提供所有组成插件的效果，并且必须直接安装在Oritech机器上。它无法以任何方式扩展，也不能与其他插件组合使用。"
	]
	quest.6DE4258F18A7A321.quest_desc: [
		"欢迎来到&6谜之天空&r！希望你在这里玩得愉快！:D"
		""
		"独自行动太危险了，带上这些东西再开始吧！"
		""
		"如果你弄丢了&7变形工具&r或&7怪奇宝典&r，别担心，新做出来的也会内置所有工具和书籍。"
		"&n                                       &r"
		""
		"任务被分为三个板块："
		""
		"[ {\"text\":\"                      \"}, { \"text\": \"谜之天空\", \"color\":\"green\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"0A8B7FD4A52663D3\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处跳转\"}]} }]"
		""
		"[ {\"text\":\"                      \"}, { \"text\": \"发现谜团\", \"color\":\"green\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"44BD4C393C59F1CB\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处跳转\"}]} }]"
		""
		"[ {\"text\":\"                      \"}, { \"text\": \"学习模组\", \"color\":\"green\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"16C7D5478BF3D449\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处跳转\"}]} }]"
	]
	quest.6DE4258F18A7A321.title: "欢迎！"
	quest.6E4554D07901967C.quest_desc: [
		"这很可能就是你最后想要的一套盔甲了。"
		""
		"能够自我修复、飞行、跳高高，还有众多其他功能。"
		""
		"末影人会无视你，猪灵会亲近你，掠夺者会回避你。"
		""
		"&a🛈 提示：将盔甲放入充气站以查看能够安装的升级。"
		""
		""
	]
	quest.6E4554D07901967C.title: "气动盔甲"
	quest.6EA0560551B821B3.quest_desc: [
		"这座空岛上生长的&7繁茂至高树&r上已经结出了一些&7门多山竹&r和&7发光浆果&r。"
		""
		"先收集一些，有条件的话可以考虑建立一个农场。"
		"                      &n&6关于自动化的说明&r&r"
		""
		"&7门多山竹&r生长在&7繁茂至高木原木&r的侧面，而&7发光浆果&r生长在大部分方块的下方。"
		""
		"两者都可以通过施加&7骨粉&r或其他催熟手段（如法术）来加速。"
		""
		"                           &6&n示例法术&r"
		""
		"&7生长并收获门多山竹&r"
		"    &5触摸&r > &a生长&r > &a收获&r > &a拾取&r"
		""
		"&7生长并收获发光浆果&r"
		"    &5触摸&r > &a生长&r > &a交互&r > &a拾取&r"
		""
		"&a🛈 提示：收获仪式可以更方便地采集这些水果！"
	]
	quest.6EA0560551B821B3.title: "空岛水果"
	quest.6EB5108D30F5A94A.quest_desc: [
		"有了&7热交换机&r和&7高压水&r，我们可以将其送入&7高压锅炉&r，这样它们便可重新转化为蒸汽。"
		""
		"起初，由于流体流量低，这一过程可能有些卡顿；用你的&7热气动加工机&r生产更多的&7高压蒸汽&r，随着时间流逝慢慢填满系统，一切很快就会变得流畅。"
		""
		"                         &n&6关于比率的说明&r"
		""
		"每台&7锅炉&r最高生产等价于8kEU/t的&7高压蒸汽&r，这意味着需要两台&7锅炉&r才能使一台&7热交换机&r达到最高产量。"
		""
		"&a🛈 提示：放置控制方块，然后拿着扳手来预览结构。"
		"&a   同样，拿着仓室可以显示它们的位置。"
		""
	]
	quest.6EB5108D30F5A94A.title: "高压进阶大型蒸汽锅炉"
	quest.6EB6E8DEEBB32911.quest_desc: [
		"要想获得一个生物性状，你需要将它插入到血液样本中。为此，我们首先要采集一份血液样本。"
		""
		"你可以用空注射器采集自己的血液，只需按住鼠标右键，直到你的视野变暗。"
		""
		"想要采集其他生物的血液的话，就需要准备一支空的金属注射器。"
		""
		"采集到血液样本后，把它送入血液净化器里进行处理，这样就可以进行基因修饰了。"
		""
		"&a🛈 提示：你需要站得离生物非常近，才能提取它们的血液。"
		""
	]
	quest.6EBB293F3DDE5EC7.quest_desc: [
		"女子游荡到了东方，动物们随她一同前行。"
		""
		"在这里，她所走过的地方，鲜花盛开，芳草繁茂。当她躺下休息时，树木主动生长为她遮阳。"
		""
		"与女子一同旅行的动物们中，有一部分在这林地之中找到了居所，就此定居了下来。"
		""
		"东风开始吹动，轻柔而温暖。带来了春天的讯息，也标志了新的旅程的开始。"
	]
	quest.6EBB293F3DDE5EC7.title: "春日出游"
	quest.6F1A7E1B49FCC4C0.quest_desc: [
		"复制始于将材料分解为其基本组成成分。"
		""
		"世界总共有八种物质类型，而物质可以由多种类型构成。你可以制作印记来获得全部的物质类型。"
		"&n                                                &r"
		""
		"放置&7分解器&r，再将&7物质管道&r和&7物质储罐&r连接到上面。"
		""
		"&7物质储罐&r只能从顶面和底面连接&7管道&r。&7储罐&r也可以彼此堆叠放置，并且也能同时连接到网络。"
		""
		"复制还需要消耗相当多的能量，这些能量既可以直接提供给机器，也可以从网络上通过物质管道的其他机器传输给机器。"
		""
		"一切连接准备好后，就可以将物品丢入&7分解器&r，物质会自动输出并储存在&7物质储罐&r中。之后它就可以供其他机器使用了。"
	]
	quest.6F8C048404EAF9FF.quest_desc: [
		"自动合成是AE的核心组成部分，它可以处理所需物品的所以子合成过程。"
		"当然，这对处理其他模组的复杂工艺会十分有用。"
		""
		"要自动合成任何物品，你必须让系统学会其样板。这些样板可以在&7样板编码终端&r中配置。"
		""
		"配置好的&7样板&r必须被放进&7样板供应器&r。你可以直接在&7供应器&r处完成，但&7样板管理终端&r可以让你在一个地方轻松管理所有样板。"
		"&n                                       &r"
		""
		"我们并不会在这个任务里全面介绍自动化，这在AE指南中已被详细说明。不过，我们会提及几个要点。"
		""
		"&a🛈 提示：线缆组件不能连接致密线缆。"
		""
	]
	quest.6FC31B3806BF222A.quest_desc: [
		"The &7Thermal Compressor&r uses heat differentials to produce compressed air up to &710 bar&r. "
		""
		"Blocks such as &7Lava&r or &7Magma&r may be used to heat one side while a &7Heat Sink&r placed opposite will be enough to produce the required differential. "
		""
		"Heat sources will degrade over time and will need to be replaced."
		""
		"&a🛈 提示：可以在EMI中点击查看热管的用途，以此获取详细的热源列表。"
		""
	]
	quest.6FC31B3806BF222A.quest_subtitle: "Raising the Bar"
	quest.706758F1FE31E268.quest_desc: [
		"预编程无人机主打开箱即用。"
		""
		"内置基础程序，可全自动执行单一任务，全程无需值守。"
	]
	quest.710D7615763E9945.quest_desc: [
		"誓言和誓约具有力量，但它们需要付出代价。"
		""
		"用&7魂缚火盆&r宣告誓令，具体细节可在奥术全典中找到。"
		""
		"谨慎选择，因为收回誓令并不容易。"
		"&n                                       "
		""
		"开始仪式的方法是，将展示在配方中的中间物品放入火盆，然后放入旁边的其他物品。如果操作正确，所有物品会从围绕旋转变为在火盆上方旋转。"
		""
		"物品准备好后，用灵火右击以点燃火盆。最后再右击火盆，等待动画完成。"
	]
	quest.710D7615763E9945.title: "誓令"
	quest.714379744B3CF395.quest_desc: [
		"你得到的&7金锭&r应该最先用来制作一个&7灌注室&r。"
		"&n                                       &r"
		""
		"&7消化釜&r的操作方式如下：手持物品右击放入消化釜，物品放入完毕后，再次潜行右击消化釜将其“关闭”。消化釜只有在关闭时才会进行炼金消化。"
		""
		"一旦消化无法再进行，消化釜就会自动打开，导致无法进行的因素有：消化已完成、输出槽位已满、输入材料耗尽。"
		""
		"                       &n&6关于自动化的说明&r&r"
		""
		"只有在消化釜打开时，流体和物品才能通过管道和漏斗等方式输入。同样地，产物也只能在消化釜打开时提取。"
		""
		"对除正面外的任意面输入红石信号，可以关闭消化釜。消化釜正面可以通过底部的红点辨识。"
		""
		"无论是否输入信号，如果消化釜内缺少输出空间，它仍然会自动打开。"
		""
		"消化釜完成一个配方时，会从正面输出一个红石信号，利用该机制可以实现更加精细的分批操控。"
	]
	quest.7163E7EBDB861D72.quest_desc: [
		"这并没有&7物品拾取器&r的高级版本，但这一等级的工具可以被赋予将物品传送至绑定方块的能力。"
		""
		"运行一个生物农场？用&7苍穹晶剑&r绑定存储系统，这样所有生物掉落物都会自动存入。"
		""
		"成立一个树场？用&7苍穹晶斧&r将原木传送至存储中。"
		""
		"用&7苍穹晶锄&r开垦的耕地会自动收获，并将掉落物传送至绑定的存储中。"
	]
	quest.7163E7EBDB861D72.title: "进阶物品拾取器？"
	quest.7234B1B299DE122D.quest_desc: [
		"最后，合成一枚&7德格米护符&r。"
		""
		"然后用这枚护符右击&7苔石&r，为你的新朋友打造一个小屋。"
		""
		"&7德格米&r可以管理大范围的生物，温和地采集它们的掉落物，然后存放在&7与它的石阵相邻的&r容器中。"
		""
		"这一过程需要魔源，由附近的&7魔源罐&r提供。"
	]
	quest.72B6C89DB165BB07.quest_desc: [
		"放置后，&7有机堆肥&r会缓慢转化为特别适合农作物生长的&7沃土&r。"
		""
		"&7沃土耕地&r上作物的生长速度将获得显著提升。"
	]
	quest.72C1A824063BAFA3.quest_desc: [
		"作为自然的守护者，&7德格米&r曾经在这片大地上四处游历，维持着动物之间的平衡。他们也很愿意加入你的家园，只要你能给他一个&7荒野号角&r，以此表明你对维持秩序的坚定决心。"
		""
		"作为交换，&7风转草&r可以帮你收获动物和怪物的掉落物。"
		"&n                                       &r"
		""
		"用对应的护符右击&7苔石&r可以创造出他的家园。在他的家园里放置更多种类的动物，可以让他更加开心，更有生产力。"
		""
		"&a🛈 提示：德格米可以操作被收容罐捕捉的生物！"
		""
	]
	quest.7327D905FE8B38FC.quest_desc: [
		"The Item Terminal turns a Pretty Pipes network into a full-fledged item management system, allowing you to access the items throughout a network in one central location. "
		""
		"This may even be upgraded to a Crafting Terminal which has an integrated crafting grid. "
		""
		"Attaching and powering a Pipe Pressurizer will greatly increase the speed at which items are retrieved, however it is also recommended to keep your storage network pipe length short to ensure the items get to you quickly when requested."
		"&n                                       &r"
		""
		"Lastly, through the use of Crafting Modules, these Terminals may be used to request crafts on demand. "
		""
		"Simply program the Crafting Module in a pipe segment adjacent to a machine and it will insert the ingredients upon request. "
		""
		"Another unconfigured pipe segment is needed for the Terminal to retrieve the craft."
	]
	quest.7327D905FE8B38FC.title: "Pretty Pipes"
	quest.739A201F595E3EFE.quest_desc: [
		"当你需要更多能量的时候，你可以始终简单的选择增加更多锅炉，但随着能量需求激增，这会变得越来越麻烦。"
		""
		"相反，不妨考虑升级&7高压蒸汽&r系统。"
		""
		"要开始行动，你需要用热气动加工机生产一些&7高压蒸汽&r。这是一个能耗高且速度极慢的过程，慢到无法驱动涡轮机。然而，涡轮机会消耗掉这些&7高压蒸汽&r，让你一无所获。"
		""
		"&7热交换机&r可以轻松解决这个问题。当输入&7水&r和&7高压蒸汽&r时，它将热能传导到&7水&r中，从而生产出常规&7蒸汽&r和&7高压水&r。"
		""
		"&7高压水&r可以在&7进阶高压锅炉&r中被重新加热为&7高压蒸汽&r，从而无限重复利用。"
		""
		"                         &n&6关于比率的说明&r"
		""
		"一台升级后的&7热交换机&r可以处理等价于&716kEU/t&r的&7高压蒸汽&r。"
		""
		"最高效率：&n592&r"
		""
		"&a🛈 提示：放置控制方块，然后拿着扳手来预览结构。"
		"&a   同样，拿着仓室可以显示它们的位置。"
		""
	]
	quest.739A201F595E3EFE.title: "热交换机"
	quest.73D70F80C3AE999C.quest_desc: [
		"谁能拒绝把东西送上天的快感呢？"
		""
		"&7空气炮&r正是为此而生：它能将物品弹射而出，使其散落于地，或直接射入物品栏。"
		""
		"安装特定升级后，还可弹射周边实体，甚至化身为超远程发射器。"
		""
		"TNT大炮，不来一发吗？"
	]
	quest.7413DDDB64FFAC2A.quest_desc: [
		"光阴似箭，弹指之间，女子已经来到了西方，动物们依然随她同行。"
		""
		"这里不再有湿地，取而代之的是干枯的灌木丛和荒芜的沙漠。女子的步伐变得沉重，她越来越需要停下来休息，但可以歇脚的地方反而越来越少。干粮开始告急，生活变得困难。"
		""
		"女子观察到动物，看到它们在食物充足时，会匀出部分贮藏备用。她也照着它们的做法去做，这样即使食物短缺，她也不会立刻饿肚子。女子还发现合适的扎营点正在减少，她便自己动手搭造了一间可以携带、随身移动的小屋。"
		""
		"与女子一同旅行的动物们中，有一部分飞到了树上，在树枝间找到了居所，就此定居了下来。"
		""
		"西风开始吹动，干燥而强劲。带来了秋天的讯息，也带来了继续挑战的希望。"
	]
	quest.7413DDDB64FFAC2A.title: "整备物资"
	quest.7431B398FFDF3DCA.quest_desc: [
		"在设置好生物类型的&7突变药水&r后，就可以进行下一步了。"
		""
		"这个药水会在&7高级孵化器&r中，与一个关键物品一起合成。查阅你&7突变药水&r的用途，看看它需要什么物品来合成。"
		""
		"这个过程很慢，任何加速的方法都会导致成功率降低。"
		""
		"在&7高级孵化器&r右侧的槽位中添加&7紫颂果&r会增加成功率。"
		""
		"&a🛈 提示：在寻找这些配方时，不要忘记查看突变药水的用途。"
		""
		""
		""
		"&c⚠ 警告：超频器会大幅增加失败率"
		""
		"&c    耐心点，新手！"
	]
	quest.7431B398FFDF3DCA.title: "突变"
	quest.74463B3FC2D297AC.quest_desc: [
		"欢迎探索气动工艺。作为一款强大的物流与自动化模组，它以压缩空气与热力为核心，可包揽各类繁杂任务。"
		""
		"本模组内置了巨细无遗的指导手册，深度解析各项机制。因此，本任务线将仅提炼核心精要，助你快速入门，顺利度过前期发展阶段。"
		""
		"&a🛈 提示：务必多留意提示框，以便快速回顾各项物品与方块的运作机制。"
		""
		""
	]
	quest.74463B3FC2D297AC.title: "气动工艺"
	quest.752888EAF2861EB4.quest_desc: ["以下是Enigmatica 10中可用的各种物品传输方式。"]
	quest.752888EAF2861EB4.title: "物品"
	quest.75507A3DE753BC75.quest_desc: [
		"还在为物品总是掉入空岛下的云层烦恼？"
		""
		"制作一个&7磁铁&r，你就再也不用担心这个问题了。"
		""
		"&7消磁线圈&r同样必不可少，它能阻止&7磁铁&r吸附附近的掉落物。"
	]
	quest.75BD1F2EB47FB7CF.quest_desc: [
		"&7高级液体压缩机&r使用之前所用的相同燃料，且压力最高可达&720bar&r。"
		""
		"不过，它会产生热量，想要高效运转就必须持续冷却机器。低速运行时，几个&7散热片&r就足够了，尤其是在这个海拔高度。"
		""
		"[\"手把手教你如何冷却，敬请查阅我们的\",{\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://wiki.enigmatica.net/enigmatica6/gameplay/how-to.../pneumaticcraft-heating-and-cooling#advanced-compressors-1\"},\"color\":\"green\",\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]},\"text\":\"Wiki\",\"underlined\":true},\"。\"]"
	]
	quest.76695BF2B0E70087.quest_desc: [
		"[ \"在前往\", { \"text\": \"烈焰空岛\", \"color\":\"aqua\", \"underlined\": true, \"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"0A799F91D9A1C8A1\" } }, \"后，你可以将你的\", {\"text\": \"凝胶\", \"color\": \"gray\"}, \"升级成\", {\"text\": \"烈焰蕾凝胶\", \"color\": \"gray\"}, \"。\" ]"
		""
		"&a🛈 提示：高级凝胶能快速处理所有低级配方。"
		""
		""
		"&6⚠ 注意：凝胶饿了，需要喂食才能工作！"
		""
		""
		"&6手持物品右键激活。"
		"&6    在EMI中搜索&3#goo_revive_tier_2&6来查看"
		"&6    哪些物品有效！"
	]
	quest.768869D763EC54EB.quest_desc: [
		"                       &6&n生物群系：深暗之域&r&r"
		""
		"以下放置转换规则在本生物群系中生效。务必记得这一规律，这样在使用“构筑地层”法术时能更加灵活的生成方块。"
		""
		"• &7泥土&r                      &2⟶&r           &7天壤&r"
		"• &7草方块&r                    &2⟶&r           &7空叶草方块&r"
		"• &7圆石&r                      &2⟶&r           &7幽匿块&r"
		"• &7石头&r                      &2⟶&r           &7幽匿块&r"
		"• &7沙子&r                      &2⟶&r           &7寒风境云&r"
		"• &7沙岩&r                      &2⟶&r           &7速沙&r"
		"• &7深板岩圆石&r                &2⟶&r           &7深板岩圆石&r"
		"• &7深板岩&r                    &2⟶&r           &7深板岩&r"
		""
		"{@pagebreak}"
		"&6&n示例法术&r"
		""
		"&7构筑天壤&r"
		"    &5触摸&r > &a构筑地层&r"
		""
		"&7构筑幽匿块&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r"
		""
		"&7构筑金黄境云&r"
		"    &5触摸&r > &a构筑地层&r > &a粉碎&r"
		""
		"&7构筑速沙&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &a粉碎&r"
		""
		"&7构筑深板岩圆石&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &6强化&r"
		""
		"&7构筑深板岩&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &6强化&r > &a烧炼&r"
	]
	quest.76EC73B59502E2A5.quest_desc: [
		"只需一点小小的切割和拼合，就能得到我们想要的东西。准备好仪式需要的物品，然后造出属于你的&7德格米&r。"
		""
		"想得你的&7德格米&r信任你并交出它的&7护符&r的话，就向它投掷一个&7荒野号角&r。"
		""
		"&6⚠ 注意：仪式图标物品并不是任务需要提交的物品。这里只是方便查阅仪式配方。"
		""
		""
	]
	quest.7750C6E87B1EBF43.quest_desc: [
		"灌注室或许是新生魔艺模组中相对简单，但是相当重要的一个魔法装置。"
		""
		"通过这一设备，你现在可以生产魔源宝石与精华，为你接下来的合成做准备。"
		""
		"&a🛈 提示：魔源不是必需的！"
	]
	quest.77A66ADAB0845804.quest_desc: [
		"Macaw’s Mods are an expansive suite of decorative mods to fit just about any build. Enigmatica 10 currently has the following:"
		""
		"• Macaw’s Bridges"
		"• Macaw’s Doors"
		"• Macaw’s Fences and Walls"
		"• Macaw’s Lights and Lamps"
		"• Macaw’s Paths and Pavings"
		"• Macaw’s Trapdoors"
		""
		"&a🛈 Tip: Search &3@mcw&r &ain EMI to"
		"&a    discover more."
	]
	quest.77A66ADAB0845804.title: "Macaw 系列模组"
	quest.77FA6854AC88C138.quest_desc: [
		"由&7寒风境云&r制成的&7浑浊泥球&r可以加工成新材料！"
		""
		"                   &n&6材料&r"
		""
		"  • &7陨石粉&r"
		"  • &7硇砂晶体&r"
	]
	quest.78626EE046E48EF3.quest_desc: [
		"                       &6&n生物群系：至高木森林&r&r"
		""
		"以下放置转换规则在本生物群系中生效。务必记得这一规律，这样在使用“构筑地层”法术时能更加灵活的生成方块。"
		""
		"  • &7泥土&r                      &2⟶&r           &7天壤&r"
		"  • &7草方块&r                    &2⟶&r           &7空叶草方块&r"
		"  • &7圆石&r                      &2⟶&r           &7黑石&r"
		"  • &7石头&r                      &2⟶&r           &7磨制黑石&r"
		"  • &7沙子&r                      &2⟶&r           &7金黄境云&r"
		"  • &7沙岩&r                      &2⟶&r           &7速沙&r"
		"  • &7深板岩圆石&r                &2⟶&r           &7玄武岩&r"
		"  • &7深板岩&r                    &2⟶&r           &7平滑玄武岩&r"
		""
		"                    &c⚠ 警告：内部高温！"
		"{@pagebreak}"
		"&6&n示例法术&r"
		""
		"&7构筑天壤&r"
		"    &5触摸&r > &a构筑地层&r"
		""
		"&7构筑黑石&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r"
		""
		"&7构筑磨制黑石&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &a烧炼&r"
		""
		"&7构筑金黄境云&r"
		"    &5触摸&r > &a构筑地层&r > &a粉碎&r"
		""
		"&7构筑速沙&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &a粉碎&r"
		""
		"&7构筑玄武岩&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &6强化&r"
		""
		"&7构筑平滑玄武岩&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &6强化&r > &a烧炼&r"
	]
	quest.7893072479F01DC2.quest_desc: [
		"                          &6&n生物群系：暖水海洋&r&r"
		""
		"The following Placement Conversions are in effect in this biome. Remember to use these to your advantage by using Conjure Terrain to summon these blocks."
		""
		"  • &7泥土&r                      &2⟶&r           &7天壤&r"
		"  • &7草方块&r                    &2⟶&r           &7空叶草方块&r"
		"  • &7圆石&r                      &2⟶&r           &7黏土&r"
		"  • &7石头&r                      &2⟶&r           &7陶瓦&r"
		"  • &7沙子&r                      &2⟶&r           &7沙子&r"
		"  • &7沙岩&r                      &2⟶&r           &7沙岩&r"
		"  • &7深板岩圆石&r                &2⟶&r           &7盐块&r"
		"  • &7深板岩&r                    &2⟶&r           &7盐块&r"
		""
		"{@pagebreak}"
		"&6&n示例法术&r"
		""
		"&7构筑天壤&r"
		"    &5触摸&r > &a构筑地层&r"
		""
		"&7构筑黏土&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r"
		""
		"&7构筑陶瓦&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &a烧炼&r"
		""
		"&7构筑沙子&r"
		"    &5触摸&r > &a构筑地层&r > &a粉碎&r"
		""
		"&7构筑沙岩&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &a粉碎&r"
		""
		"&7构筑盐块&r"
		"    &5触摸&r > &a构筑地层&r > &6强化&r > &6强化&r"
	]
	quest.78B1BC9540590D17.quest_desc: [
		"需要一个用来存来之不易经验的地方吗？"
		""
		"试试&7经验存储器&r。"
		""
		"这个便携装置可以让你保持一定的经验等级，也能存储大量经验。"
		""
		"它是任何迷人区域中不可或缺的元素。"
	]
	quest.78E557B17D1EB84F.quest_desc: [
		"神能炉使用&7神能&r作为燃料来转化物品。"
		""
		"先来试试这个：将&7草捆&r转化为&7稻米&r，然后将稻米种在水中让其生长。"
		""
		"这样，你就能够收集足够多的稻米，制作一颗&7法师之花种子&r。"
	]
	quest.7973D06875662CFE.quest_desc: [
		"不知你是否注意，许多灵气制造设备在灵气值过高时会停止工作。不同制造设备的临界值各不相同，但都存在这一机制。"
		""
		"制造催化剂可解除该限制。"
		""
		"将其放置在灵气制造设备下方，即可释放其全部能力。"
	]
	quest.79951647661D4B52.quest_desc: [
		"[ \"你需要在\",{ \"text\": \"闪耀空岛\", \"color\":\"aqua\", \"underlined\": true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]}, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"300207E2557764E1\" } },\"与\",{\"text\": \"坚守者\", \"color\": \"gray\"}, \"对峙，才可以获得升级这一等级\", {\"text\": \"凝胶\", \"color\": \"gray\"}, \"的重要材料。\" ]"
		""
		"&a🛈 提示：高级凝胶能快速处理所有低级配方。"
		""
		""
		"&6⚠ 注意：凝胶饿了，需要喂食才能工作！"
		""
		""
		"&6手持物品右键激活。"
		"&6    在EMI中搜索&3#goo_revive_tier_4&6来查看"
		"&6    哪些物品有效！"
	]
	quest.799839991CC1DDF9.quest_desc: [
		"难怪说古老的传说总能引起人们的共鸣。"
		""
		"它们传授自然之理，它们传递人伦纲常。它们超越了历史，让不同时间上有着共同经历和遭遇的我们紧密联系在了一起。故事不断重演，记忆历久弥新，我们用生活演绎故事，我们用故事讲述生活。"
		""
		"现在我们的时代已经结束了。在这万物的尽头，新的故事正在生根发芽。"
		""
		"我们又会为后人留下什么样的传说呢？"
	]
	quest.799839991CC1DDF9.title: "混沌初开"
	quest.79DFBA1E35132332.quest_desc: [
		"该工作站允许&7薇克精&r使用&7农夫乐事烹饪&r配方。"
		""
		"&7薇克精&r通常比&7厨锅&r更快，而且更易于自动化！"
		""
		"                   &6&n转化&r"
		""
		"手持&7薇克精护符&r右击&7厨锅&r。"
		""
		"&6⚠ 注意：对于多步合成，每一步都需要分别标示出来。"
		""
	]
	quest.79DFBA1E35132332.title: "薇克精烹饪"
	quest.79FA7B5854C9606F.quest_desc: [
		"反场球和反场方块的功能都是抑制特定基因，尤其是物品吸引和经验吸引基因。"
		""
		"将方块放置在你不想随便吸取物品的区域。或者随身携带反场球，随时启用或禁用该基因。右击即可切换功能。"
	]
	quest.7ADBC282C9692EDE.quest_desc: ["Cable Façades are a universal façade that you can use to cover just about any pipe! "]
	quest.7ADBC282C9692EDE.title: "Cable Facades"
	quest.7B4E085679031F8B.quest_desc: [
		"当蒸汽充足时，&7蒸汽锅炉&r燃烧速率会降低，既能保持结构温暖，又不会浪费水。"
		""
		"因此，为了节约燃料，建议用红石来控制锅炉。"
		""
		"将&7红石控制模块&r和&7存量转信器&r结合使用，便是实现这一目标的简单方法。"
		""
		"只需要将&7存量转信器&r对着缓存储罐，并用红石信号来启用和禁用锅炉即可。"
		""
		"记住，你的耗电量越高，你这个策略所需的缓存容量就要越大。否则，重新预热所花费的时间很可能会消耗你更多的燃料。"
	]
	quest.7B6267C141FE9B83.quest_desc: [
		"这些优雅的海洋生物热衷于从沙子中找出失落的宝物。"
		""
		"为它们打造一个家园，然后提供大量新鲜的沙子或沙砾，它们就可以整天在沙子里淘取那些不为人知的宝藏。"
	]
	quest.7B6DF86E979614F4.quest_desc: [
		"沉思良久，筹谋已定。女子走出她那被冰雪覆盖的居所。"
		""
		"她望向东方，祈请春天的柔风托举其身；"
		""
		"她转望南方，恳求夏天的暖风护卫其行；"
		""
		"她凝视西方，呼唤秋天的燥风引导其路；"
		""
		"她复朝北方，乞愿冬天的寒风庇佑其身。"
		""
		"四风回应了她的呼唤，将她托举上那天际。她飞得比任何一只鸟儿还高，喜悦与激动的感情在心中回荡。"
	]
	quest.7B9D8AD7BFC1E87D.quest_desc: [
		"直接使用蒸汽动力只能让你走到这了。要开始使用电力，你需要一种非常特殊的设备——&7磁通门&r。"
		""
		"[ \"开始前往\", { \"text\": \"恼人空岛\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"13F15094F3AF4A73\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]} }, \"吧。\" ]"
	]
	quest.7BEC7AF0176EA162.quest_desc: [
		"流体存储元件最好在元件工作台中锁定其类型，并将你想存储的流体专门分配一个元件。"
		""
		"对于可以持续生产的流体，例如熔岩和水，使用溢出销毁卡可以销毁多余的流体，防止堵塞。"
	]
	quest.7C1E4DDAAA75E58F.quest_desc: [
		"Oritech的&7物流管道&r提供有限的物流和过滤功能，非常适合点对点传输。"
		""
		"这些管道分为四种类型，差异主要在外观上。"
		"&7带框架的管道&r在管道周围有漂亮的支撑结构；&7集装管道&r则是一个完整的方块，可以严丝合缝地嵌入墙体，不过&7集装管道&r只能与其他管道连接。"
		""
		"右击管道与机器或储罐相连的部分，将其设置为提取模式。"
	]
	quest.7C27093E25633B9F.quest_desc: [
		"汞驱流体运输系统是一个用于运输流体的简单物流网络。"
		""
		"将&7输入器&r和&7输出器&r放置在机器或其他容器上，然后通过&7汞驱铜线缆&r连接起来即可使用。"
		""
		"&7汞驱连接节点&r允许多条线缆汇集到一处，形成更广泛的网络，同时也能用来延伸单条线缆的连接距离。"
	]
	quest.7C27093E25633B9F.title: "汞驱流体节点"
	quest.7C3C0E6AC71F621B.quest_desc: ["&7物品分配器&r使用方法：从其上方容器中提取物品，并均匀分配到周围的容器中。"]
	quest.7D63AB919406E5AD.quest_desc: [
		"&7探宝蟹&r生产的&7泥球&r充满魔力和潜在价值。&7蒸汽蒸馏器&r能够将它们转化为珍贵的资源。"
		""
		"当然，只有&7探宝蟹&r知道如何正确操作设备。你可以尝试将它的家设置在&7输入仓&r，以确保始终有一只探宝蟹在附近。"
		"&n                                                &r"
		""
		"每个现代工业化的多方块结构都需要根据其处理的配方配备相应的输入和输出仓。"
		""
		"该任务中，&7蒸汽蒸馏器&r同时需要流体仓和物品仓。"
		""
		"&a🛈 提示：放置控制器方块后，手持扳手即可预览完整结构。类似地，手持仓室可以查看能够放置的位置。"
		""
		""
	]
	quest.7D82585D50D7207A.quest_desc: [
		"欢迎游玩应用能源，这是一款强大的物流和存储模组，它完全集成了自动化内容，能够与绝大多数其他模组兼容。"
		""
		"这一章节将带你了解如何使用此模组，以及一些基础概念。"
		""
		"我们建议你也可以查看模组自带的&7指南&r来查看指引与教程。"
	]
	quest.7D82585D50D7207A.title: "应用能源"
	quest.7D8AEEB13B201CFB.quest_desc: [
		"这些高度先进的处理器将能够构建一个强大的 AE2 系统，以协助进行物品制作和库存管理。"
		""
		"随着配方变得越来越复杂，这一设备必不可少。"
		""
		"[ \"在\", { \"text\": \"应用能源章节\", \"color\":\"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"777EE0C4949DFE12\" },\"hoverEvent\":{\"action\":\"show_text\",\"value\":[{\"text\":\"点击此处\"}]} }, \"了解更多有关组建ME网络的信息。\" ]"
	]
	quest.7EBB38BA04910A92.quest_desc: [
		"任何工业级厨房都值得拥有的大锅，这个大家伙一次能处理更大批量的食材。"
		""
		"&6⚠ 注意：该结构必须在温暖的生物群系搭建，比如烈焰空岛上的至高木森林。"
		""
		""
	]
	quest.7EE93B81F83AD199.quest_desc: [
		"附神&7黏土&r似乎让它获得了属于自己的转化魔法，不过它似乎需要“进食”才能工作？"
		""
		"不管怎么说，它应该会派上大用场。"
		"&n                                                &r"
		""
		"要使用凝胶，先将其放置在世界中，然后在旁边放置所需的方块，让两者相互接触。"
		""
		"该任务中，我们需要用到&7黏液块&r，其可以用面团来制作。此外我们还需要给这个凝胶喂一些足够魔法的东西。"
		""
		"一个&7魔源浆果卷&r暂时应该够用了。"
	]
	quest.7F43653C4B9A96CE.quest_desc: [
		"采用更坚固的材料可以使转速更高，&7中压蒸汽涡轮机&r是你此前使用的&7低压蒸汽涡轮机&r的合理替代品。"
		""
		"它只输出中压能量，所以你要么更换接线，要么用&7变压器&r将两个网络连起来。"
	]
	quest.7F445C22C528AC1F.quest_desc: [
		"符文木方尖碑用于加速精魂祭坛，最好尽早制作。"
		""
		"最多可使用四个方尖碑来加速合成，每一个都能减少总合成时间。"
	]
	quest.7F829A1BFED304D0.quest_desc: [
		"若是没有由其驱动的实用设备，魔法又有什么意义？"
		""
		"接下来将介绍自然灵气模组中一些更具特色的实用设备。你可以自行探索，判断它们在基地建设中的适用时机与场景。"
		""
		"想要了解这些设备的完整使用方法，请查阅&7自然灵气之书&r！"
	]
	quest.7F829A1BFED304D0.title: "自然设备"
	quest.7FAC3A637F82BFED.quest_desc: [
		"作为悬浮着的女巫小伙伴，她们可以自动完成标准的3x3工作台配方、药水酿造配方，甚至是附魔装置上的配方。"
		""
		"在制作薇克精护符前，获取薇克精词元需要一点魔法技巧。你需要对一个生命值少于一半的女巫使用“解除魔法”魔符。"
		""
		"&6&n示例法术&r"
		""
		"&7把村民变成薇克精&r"
		"    &5弹射物&r > &a滞留&r > &a闪电&r > &a解除魔法&r"
		""
		"&7把女巫变成薇克精&r"
		"    &5弹射物&r > &a伤害&r > &6强化&r > &a解除魔法&r"
	]
